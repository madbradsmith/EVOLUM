    <Paragraph Type="Dialogue" id="739ef0e5-3a74-4d90-8fd9-4af1140deade">
      <Text AdornmentStyle="-1">Šta</Text>
      <Text>, cili?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="81cf35fb-016f-4835-b3e0-1d40dc8f3d11">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e0f7e22b-235a-4b2a-bfd8-53fb3e2c4d42">
      <Text AdornmentStyle="-1">Očito</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">onaj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dio</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">di</Text>
      <Text> san </Text>
      <Text AdornmentStyle="-1">pisala</Text>
      <Text> da mi</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="300f53a3-334b-4706-9bcd-04415890239b">
      <Text>se </Text>
      <Text AdornmentStyle="-1">sviđa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jedna</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ženska</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Rekla</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zbog</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">droge</Text>
      <Text>. Al ja se </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drogiran</Text>
      <Text>. I biće </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">vidila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> one </Text>
      <Text AdornmentStyle="-1">manične</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eseje</Text>
      <Text>.</Text>
    </Paragraph>
