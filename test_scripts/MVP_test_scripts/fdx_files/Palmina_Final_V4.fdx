    <Paragraph Type="Dialogue" id="accfdcb1-e7a0-4bee-8bf4-73cf71752ab7">
      <Text AdornmentStyle="-1">Postajem</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Glasovi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ludila</Text>
      <Text>.</Text>
    </Paragraph>
