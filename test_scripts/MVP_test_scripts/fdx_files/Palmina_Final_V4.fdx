          </CharacterArcBeat>
          <CharacterArcBeat Name="ZLATKO">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. </Text>
      <Text>Dnevni</Text>
      <Text> </Text>
      <Text>boravak</Text>
      <Text> - noĆ</Text>
    </Paragraph>
    <Paragraph Type="Action" id="40ab28bf-9819-4f99-9fb1-3b657ea67e34">
      <Text>ZLATKO</Text>
      <Text> </Text>
      <Text>sjedi</Text>
      <Text> na </Text>
      <Text>kauču</Text>
      <Text> s </Text>
      <Text>bocom</Text>
      <Text> </Text>
      <Text>piva</Text>
      <Text> u </Text>
      <Text>ruci,</Text>
      <Text> i na </Text>
      <Text>televiziji</Text>
      <Text> </Text>
      <Text>gleda</Text>
      <Text> </Text>
      <Text>nogometnu</Text>
      <Text> </Text>
      <Text>utakmicu</Text>
      <Text>, igra</Text>
      <Text> </Text>
      <Text>Nizozemska</Text>
      <Text> protiv </Text>
      <Text>Španjolske</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="afceb930-c51d-4068-ae6b-48c39d9d344a">
      <Text>Komentator nogometne utakmice se čuje u pozadini.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="0629d360-9009-439b-b996-17ac83e4c807">
      <Text>ZlatkO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a2c78f9f-daa8-40fa-9ee1-94429b9bdd6f">
      <Text>Ovi</Text>
      <Text> </Text>
      <Text>deformirani</Text>
      <Text> </Text>
      <Text>Nizozemci</Text>
      <Text>. </Text>
      <Text>Jeben</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> mater </Text>
      <Text>Nizozemsku</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="66d48e80-65f8-4323-b346-33fd8c6186c0">
      <Text>FIFI, ZLATKOVA ŽENA, </Text>
      <Text>stavi</Text>
      <Text> </Text>
      <Text>tanjur</Text>
      <Text> </Text>
      <Text>bolonjez</Text>
      <Text> </Text>
      <Text>špageta</Text>
      <Text> </Text>
      <Text>ispred</Text>
      <Text> </Text>
      <Text>ZLATKA</Text>
      <Text> na </Text>
      <Text>stol</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="46c4e5ba-8328-443d-9965-8ee4e2ad0ca2">
      <Text>ZlaTKO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d9feca94-f701-4cd6-b060-1ca4e46f5805">
      <Text>Vidi kako mu </Text>
      <Text AdornmentStyle="-1">Enrique</Text>
      <Text> diše za </Text>
      <Text AdornmentStyle="-1">vraton</Text>
      <Text>. Hans ne vidi da je on tu, </Text>
      <Text AdornmentStyle="-1">al</Text>
      <Text> smrdi.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="808f6593-eead-4826-8259-277546feda31">
      <Text>ZLATKO</Text>
      <Text> se nasmije gledajući u televiziju, pa pogleda u tanjur i </Text>
      <Text>počinje</Text>
      <Text> </Text>
      <Text>jesti</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5a8ed447-0bb3-4365-aa28-a69a280580de">
      <Text>FIFI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eec565f3-9ee8-4303-a2d0-7e4257f4fce4">
      <Text>Zlatko, </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">need</Text>
      <Text> to talk. Do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">remember</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">told</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">before</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">moved</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">here</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a231cc50-6fe9-44b1-83dc-a48bcab244e2">
      <Text>ZlATKO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d278d573-07af-4c50-8f7d-ec675f43acdf">
      <Text>Ah?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aa22d966-6da4-40d8-8350-58a0b345eacd">
      <Text>Fifi</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="44ccb276-450d-482e-ab52-640e1738ea21">
      <Text>You </Text>
      <Text AdornmentStyle="-1">told</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> Croatia </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">just</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">like</Text>
      <Text> Australia. </Text>
      <Text AdornmentStyle="-1">Well</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">I’ve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">been</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">here</Text>
      <Text> for 5 </Text>
      <Text AdornmentStyle="-1">years</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> I </Text>
      <Text AdornmentStyle="-1">still</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">don’t</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">see</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">I’m</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">not</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">happy</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> I </Text>
      <Text AdornmentStyle="-1">feel</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">like</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">don’t</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">even</Text>
      <Text> care. </Text>
      <Text AdornmentStyle="-1">I’m</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">your</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">second</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">wife</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">then</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">why</Text>
      <Text> do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">treat</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">like</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">I’m</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">first</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="12717e8c-1f68-4d26-bcea-5025bb747877">
      <Text>ZLATKO</Text>
      <Text> </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>ignorira</Text>
      <Text> i </Text>
      <Text>nastavlja</Text>
      <Text> </Text>
      <Text>buljiti</Text>
      <Text> u </Text>
      <Text>televiziju</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="5eb686da-75ac-4c5c-a8a2-c11f68d93ff3">
      <Text>FIFI gleda u ZLATKA sa suzama u očima, brzo se okrene </Text>
      <Text>i</Text>
      <Text> otiđe u kuhinju.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="837bb74f-4321-4676-bf9d-f77faf04da30">
      <Text>ZLATKO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="516a6aa8-44a2-4f7e-9537-232b259ae3d5">
      <Text AdornmentStyle="-1">Enrique</Text>
      <Text> Miguel </Text>
      <Text>pička</Text>
      <Text> mu </Text>
      <Text>materina</Text>
      <Text> </Text>
      <Text>dlakava</Text>
      <Text>! Jesi </Text>
      <Text>znala</Text>
      <Text> da </Text>
      <Text>Španjolke</Text>
      <Text> </Text>
      <Text>ne</Text>
      <Text> </Text>
      <Text>briju</Text>
      <Text> pičku, </Text>
      <Text>sve</Text>
      <Text> su </Text>
      <Text>dlakave</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9f9ebd33-02b7-41d9-a4f5-5466a36347dc">
      <Text>FIFI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4b3cea91-2945-4713-bc47-c2b32592dff2">
