    </Paragraph>
    <Paragraph Type="Dialogue" id="c2fe2931-d321-4d95-afdc-a701e24560b2">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">kako</Text>
      <Text> ja </Text>
      <Text AdornmentStyle="-1">mogu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">vidit</Text>
