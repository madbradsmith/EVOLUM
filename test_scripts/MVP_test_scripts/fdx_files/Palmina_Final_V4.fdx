    <Paragraph Type="Dialogue" id="c3fac156-9ff2-49a7-a83c-57252150cde0">
      <Text AdornmentStyle="-1">Karolini</Text>
      <Text>; </Text>
      <Text AdornmentStyle="-1">Išla</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dvoje</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">djece</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">izlet</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">Makarsku</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Automobil</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kojeg</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> Karolina </Text>
      <Text AdornmentStyle="-1">vozila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sletio</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">litice</Text>
      <Text> u more. </Text>
      <Text AdornmentStyle="-1">Uspjela</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">površinu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">izvući</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Bornu</Text>
      <Text>, a Tomislav se </Text>
      <Text AdornmentStyle="-1">utopio</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Onda</Text>
      <Text> su </Text>
      <Text AdornmentStyle="-1">svi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mislili</Text>
      <Text> da se i </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">utopila</Text>
      <Text>, pa </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> tad </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">otišla</Text>
      <Text> u Beč."</Text>
    </Paragraph>
