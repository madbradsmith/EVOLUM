      <Text AdornmentStyle="-1">glas</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ludila</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="46dadd08-3935-427f-8f33-6eaed77ffa14">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4791faa2-8cf4-46db-b214-2af6645de86d">
      <Text AdornmentStyle="-1">Ljudi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">samo</Text>
      <Text> vide </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> se </Text>
      <Text AdornmentStyle="-1">događa</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="837b90ac-b49c-40bd-96aa-0372539889e6">
      <Text AdornmentStyle="-1">njima</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ono</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> se </Text>
      <Text AdornmentStyle="-1">događa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">oko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">njih</Text>
