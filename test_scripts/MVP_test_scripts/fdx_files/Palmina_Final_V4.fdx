      <Text AdornmentStyle="-1">Baš</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Budi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">malo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dama</Text>
