      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c95f3cc5-1546-40ec-a467-0a801895042e">
      <Text>Pa </Text>
      <Text>možeš</Text>
      <Text> </Text>
      <Text>ovo</Text>
      <Text> </Text>
      <Text>radit</Text>
      <Text> i u Beču.</Text>
