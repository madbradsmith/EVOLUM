    <Paragraph Type="Dialogue" id="130b78a6-3ca6-4b00-93e1-57525e8343d1">
      <Text AdornmentStyle="-1">Znači</Text>
      <Text> da san ja s </Text>
      <Text AdornmentStyle="-1">ove</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">strane</Text>
      <Text> s</Text>
