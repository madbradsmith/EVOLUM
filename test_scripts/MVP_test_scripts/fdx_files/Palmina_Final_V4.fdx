    </Paragraph>
    <Paragraph Type="Character" id="a2374c2e-29c2-491f-a9a6-4c6d76eaa0d8">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="427722a8-fb6c-40fd-8496-10522bf6a8f2">
      <Text>Da.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="604d0d6a-f65d-409d-b7ca-4ef19493b1c4">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a5f0c14f-059a-4b34-b5c4-01b469b86686">
      <Text>I? </Text>
      <Text>Kakva</Text>
      <Text> </Text>
      <Text>je</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8b3db3fc-f6a7-4b26-994a-79dcaf9fbe06">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="622e25fb-2841-430d-a5b2-b2b2a31730e8">
      <Text>Radi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text>kurva</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a2a6b4f9-51f6-432b-97e4-a265374db5d3">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54e88d33-8ec7-44e1-962e-38f2c6474d93">
      <Text>Pa </Text>
      <Text>šta</Text>
      <Text>? Bar </Text>
      <Text>radi</Text>
      <Text>, ti </Text>
      <Text>si</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="157982c9-2c6a-4771-9c6c-550557a706b0">
      <Text AdornmentStyle="-1">nezaposlena</Text>
      <Text AdornmentStyle="-1">.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="303948b1-c2e3-46cf-85aa-7457afc50b2e">
      <Text>PalMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7bbecbe2-87ba-47be-bb8c-7d7f89949816">
      <Text>Ha.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="abd30207-5e4a-4d32-aff1-81f949ba1cac">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eff89c62-4e0b-457a-a42d-1f74754be40c">
      <Text>Dobro ma </Text>
      <Text>šta</Text>
      <Text> </Text>
      <Text>te</Text>
      <Text> </Text>
      <Text>briga</Text>
      <Text>. Al </Text>
      <Text>isto</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cfd031fa-b25b-490f-b121-11e4558ef03a">
      <Text AdornmentStyle="-1">bolje</Text>
      <Text> </Text>
      <Text>nemoj</Text>
      <Text> </Text>
      <Text>pisat</Text>
      <Text> </Text>
      <Text>dnevnik</Text>
      <Text>. To se </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>može</Text>
      <Text> </Text>
      <Text>koristit</Text>
      <Text> </Text>
      <Text>protiv</Text>
      <Text> </Text>
      <Text>tebe</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="996d5009-b3ea-4dff-92d4-0a193bd0ca9b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="00d731ab-ada6-482f-aa80-e680695f0570">
      <Text>A i </Text>
      <Text>ta</Text>
      <Text> ti </Text>
      <Text>je</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="a3c2e2ab-10d5-4e93-872f-5266e499d650">
      <Text>Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bd2e5812-ae2b-44bf-9a60-0606e763de86">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="97ac7ce5-f551-425c-9687-35d89d2f97f4">
      <Text>Nema</Text>
      <Text> </Text>
      <Text>šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text>čitat</Text>
      <Text> </Text>
      <Text>tvoje</Text>
      <Text> </Text>
      <Text>misli</Text>
      <Text>, a</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fa75d00e-0f28-43de-99c4-f16a219282fd">
      <Text AdornmentStyle="-1">psihički</Text>
      <Text> </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>iscrpljujuće</Text>
      <Text> </Text>
      <Text>nekome</Text>
      <Text> </Text>
      <Text>objašnjavat</Text>
      <Text> </Text>
      <Text>svoju</Text>
      <Text> </Text>
      <Text>bol</Text>
      <Text>. </Text>
      <Text>Osim</Text>
      <Text> </Text>
      <Text>ako</Text>
      <Text> </Text>
      <Text>nema</Text>
      <Text> </Text>
      <Text>istu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ccc39687-e877-4a15-b866-eccc7939481f">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4c90c5e1-2ee9-4595-8c5d-e5ecf9899214">
      <Text>Nikad</Text>
