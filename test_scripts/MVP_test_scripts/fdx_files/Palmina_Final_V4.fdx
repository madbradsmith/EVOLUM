    <Paragraph Type="Character" id="cdd2e345-9165-472e-b123-8f48a0f864e7">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0c1f3b3e-78f4-4a1f-bb5d-c2cab28f2967">
      <Text>Ne </Text>
      <Text AdornmentStyle="-1">znan</Text>
      <Text>.</Text>
    </Paragraph>
