    <Paragraph Type="Dialogue" id="260b2fe0-c380-406c-a65f-cb366ff460d3">
      <Text AdornmentStyle="-1">Kakva</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">klijentela</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c76b5d7e-86fa-46bc-bc8d-25f66b515842">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cdbde9db-2854-4641-8644-143c11a96d73">
      <Text>Ah. Za </Text>
      <Text AdornmentStyle="-1">po</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ure</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bukira</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">termin</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ac1978c6-5b09-4e3d-8556-4c6639052f18">
      <Text AdornmentStyle="-1">od</Text>
      <Text> Renate ćaća.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5a2576ea-e123-4ec9-a45a-ac3d61c45dbc">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b11072de-6f38-4b7f-8e1a-2a5718994a34">
      <Text AdornmentStyle="-1">Molin</Text>
      <Text>?! </Text>
      <Text AdornmentStyle="-1">Sef</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">policije</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="58e456e3-0968-456d-803b-c9107f05b9ab">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0866fd52-ed6f-4f27-b2aa-e3e52d8530c7">
