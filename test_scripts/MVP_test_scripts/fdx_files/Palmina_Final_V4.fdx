      <Text> </Text>
      <Text AdornmentStyle="-1">luđe</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Manira</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Kako</Text>
      <Text> to?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b78bbaa4-5826-4353-baad-62e6735480be">
