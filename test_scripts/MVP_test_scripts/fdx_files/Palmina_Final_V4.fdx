    </Paragraph>
    <Paragraph Type="Dialogue" id="1cb99d97-c070-438c-ab96-353fff8b921f">
      <Text>Ma ima </Text>
      <Text AdornmentStyle="-1">ih</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kolko</Text>
      <Text> oćeš. Ja san </Text>
      <Text AdornmentStyle="-1">puna</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0148c118-d6d6-43ac-a7e9-ae8333601307">
