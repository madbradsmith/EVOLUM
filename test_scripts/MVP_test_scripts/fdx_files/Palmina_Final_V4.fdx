      <Text AdornmentStyle="-1">Aaa</Text>
      <Text>, </Text>
      <Text>znan</Text>
      <Text> </Text>
      <Text>ga</Text>
      <Text>, </Text>
      <Text>aj</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="4e9c68ed-21ca-43eb-b87e-108675801a32">
      <Text>ANDREJ </Text>
      <Text>rukom</Text>
      <Text> </Text>
      <Text>pokaže</Text>
      <Text> 4 </Text>
      <Text>crte</Text>
      <Text> </Text>
      <Text>kokaina</Text>
      <Text> na </Text>
      <Text>stolu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7f940fab-6255-4185-b387-ef116b55eced">
      <Text>ANDREJ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f6ea5693-ccab-4a6d-90be-e4d5573f2c05">
      <Text>Poslužite</Text>
      <Text> se.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="551cd5dd-c456-4120-8ae3-ae253dc74e5d">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2dbd4f9b-bc26-44ed-a3f8-7bf5a4a023c6">
      <Text>Je li </Text>
      <Text>koka</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="bf6c3baf-ddf0-406e-8c60-50c3a8ceb485">
      <Text>ANDREJ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f5a61f62-7c98-4f97-8812-82d40feab5b3">
      <Text>Je, i </Text>
      <Text>pri</Text>
      <Text> tome, </Text>
      <Text>neloša</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ebe87031-937c-4058-81e3-afcb9176986b">
      <Text AdornmentStyle="-1">VUJO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="483a0bd3-ba95-4093-8744-8e996d5c203f">
      <Text>On Vam </Text>
      <Text>ne</Text>
      <Text> </Text>
      <Text>voli</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">spid</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c155a7f2-a254-423d-b5fd-e461a606795e">
      <Text>ANDREJ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="12d4e68d-7019-4a0d-95c0-51b87c3c0eef">
      <Text>Mali ima </Text>
      <Text>standarde</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6e98803b-201e-47db-8e2b-8feed2ec111f">
      <Text AdornmentStyle="-1">VUJO</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pošmrće</Text>
      <Text> </Text>
      <Text>jednu</Text>
      <Text> </Text>
      <Text>crtu</Text>
      <Text>, pa </Text>
      <Text>PERE</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="312cdba6-8d7b-4352-b850-d5fded25d528">
      <Text>DUJE</Text>
      <Text> i ANDREJ </Text>
      <Text AdornmentStyle="-1">pošmrću</Text>
      <Text> </Text>
