    </Paragraph>
    <Paragraph Type="Action" id="885d4c8e-d322-4a76-93ea-d9bc0f277b6d">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="43f60eed-4691-4807-8226-19ea6ca1c66c">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="14135fe9-37ce-4ff9-81e0-95315a981409">
      <Text>Od </Text>
      <Text AdornmentStyle="-1">nula</Text>
      <Text> do </Text>
      <Text AdornmentStyle="-1">deset</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">koliko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">misliš</Text>
      <Text> da</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ce4601ad-769f-4ab9-af07-4b39f18623dc">
      <Text>san lipa?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="62e07bfe-a999-4bbb-8799-534da4cfa2f4">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
