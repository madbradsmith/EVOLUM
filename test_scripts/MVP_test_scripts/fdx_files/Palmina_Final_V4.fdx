    <Paragraph Type="Action" id="9f661314-ec6b-410e-a531-a99aa71fb7c1">
      <Text>Nastave</Text>
      <Text> se </Text>
      <Text>svađati</Text>
      <Text>. PETRA se </Text>
      <Text>dere</Text>
      <Text> na ROBERTA, </Text>
      <Text>koji</Text>
      <Text> </Text>
      <Text>stoji</Text>
      <Text> </Text>
      <Text>ispred</Text>
      <Text> </Text>
      <Text>nje</Text>
      <Text>, </Text>
      <Text>ignorira</Text>
      <Text> </Text>
      <Text>njene</Text>
      <Text> </Text>
      <Text>verbalne</Text>
      <Text> </Text>
      <Text>udarce</Text>
      <Text>, i </Text>
      <Text>rijetko</Text>
      <Text> </Text>
      <Text>uzvraća</Text>
      <Text>. PETRA se </Text>
      <Text>osjeća</Text>
      <Text> </Text>
      <Text>sasvim</Text>
      <Text> </Text>
      <Text>sama</Text>
      <Text>, </Text>
      <Text>bez</Text>
      <Text> </Text>
      <Text>potpore</Text>
      <Text> </Text>
      <Text>od</Text>
      <Text> ROBERTA </Text>
      <Text>kojemu</Text>
      <Text> </Text>
      <Text>očito</Text>
      <Text> </Text>
      <Text>nije</Text>
      <Text> </Text>
      <Text>stalo</Text>
      <Text> do </Text>
      <Text>nje</Text>
      <Text>, </Text>
      <Text>ni</Text>
      <Text> do </Text>
      <Text>DUJE</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="15cf0da1-1bc0-4a8a-aee4-790605bd1e7f">
      <Text>DUJE</Text>
      <Text> </Text>
      <Text>stoji</Text>
      <Text> </Text>
      <Text>ispred</Text>
      <Text> </Text>
