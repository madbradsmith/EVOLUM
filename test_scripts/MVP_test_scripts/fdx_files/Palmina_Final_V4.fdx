    </Paragraph>
    <Paragraph Type="Dialogue" id="109f1682-f2bb-4026-905f-080943038161">
      <Text>Diana mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">čitala</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dnevnik</Text>
      <Text>.</Text>
