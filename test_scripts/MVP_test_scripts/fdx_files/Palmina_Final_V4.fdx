    </Paragraph>
    <Paragraph Type="Character" id="07affb7d-91de-4a7c-bece-a0b0a50914f7">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bc00ec66-d4f4-4744-98a1-1a3c2a73fdd5">
      <Text>Pa se </Text>
      <Text AdornmentStyle="-1">vrtija</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">krug</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">po</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ure</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nas</Text>
