    </Paragraph>
    <Paragraph Type="Character" id="e2b2e484-f1f4-43c4-ba7b-7e70af54d875">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e0801cec-1c18-4cdb-bb99-3b16b524b2cb">
      <Text>On mi se </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">vraća</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="32dd08c3-7ad0-4198-b509-7e058129de59">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ea108def-ae60-4233-9235-11c76d7284d8">
      <Text>A </Text>
      <Text AdornmentStyle="-1">svašta</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="58e5f93e-34b6-4fb6-891f-223edbb39d51">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
