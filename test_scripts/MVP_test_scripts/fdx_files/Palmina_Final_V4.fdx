      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="11e47d0b-8d18-4a25-b059-89dfd3425f12">
      <Text AdornmentStyle="-1">Ajde</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">ajde</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="909920a1-995c-4b3f-bea6-078abfb600de">
      <Text AdornmentStyle="-1">MANIRA</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ostavi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mobitel</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">strane</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="751215a6-995f-45f1-866d-f0540970e455">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3442a486-decf-44f9-a43a-af04665b1434">
      <Text AdornmentStyle="-1">Jel</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">glasaš</Text>
      <Text> ti?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ceccf7c1-a37c-4af5-a82a-02bfe05e5d83">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1e028107-b926-4e9c-bf78-dfda10d8cd3d">
      <Text>Da </Text>
      <Text AdornmentStyle="-1">glasanje</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">išta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">minja</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">nebi</Text>
      <Text> nan</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46f50529-3970-4319-854c-6ba291fa1658">
      <Text>opće </Text>
      <Text AdornmentStyle="-1">dali</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">glasamo</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="002d5503-6171-40f9-a73f-d505b9d9cca6">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fceb7770-ab31-4a88-9210-36a49d3fbe88">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">minja</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jer</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nismo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jedni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">od</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="995cb60e-7019-4759-bcb3-b853a57c17e2">
      <Text AdornmentStyle="-1">odabranih</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ff00fff9-f445-4ddd-8a85-aefea50b053d">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="94aed959-042d-43f3-838c-c7f55b4082be">
      <Text AdornmentStyle="-1">Jebiga</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9198e7a9-58e3-423c-8f6e-99a657ff29d9">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="960d377d-445a-4e0b-b0ec-935c87227eba">
      <Text>Al to </Text>
      <Text AdornmentStyle="-1">oni</Text>
      <Text> oće </Text>
      <Text AdornmentStyle="-1">od</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nas</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">apatiju</Text>
      <Text>. Da</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3d24a678-f9ec-4661-b9fb-c055aabdbc87">
      <Text AdornmentStyle="-1">nas</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">briga</Text>
      <Text>, da se </Text>
      <Text AdornmentStyle="-1">predamo</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4d5988c4-360a-4704-9513-f7b102e5c241">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1259a67e-11ff-4b98-baf6-439c700271d0">
      <Text>Ja san </Text>
      <Text AdornmentStyle="-1">anarhist</Text>
      <Text>. I </Text>
      <Text AdornmentStyle="-1">mrzin</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0368ed9b-33e3-435a-af5b-419cfcf0819b">
      <Text AdornmentStyle="-1">birokraciju</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1e5d49d2-4a19-43a8-a16f-137648d41cc1">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c8d5889-04ba-451b-b338-aca61037f54c">
      <Text>Pa u </Text>
      <Text AdornmentStyle="-1">Austriji</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">isto</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">birokracija</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2b723b46-f004-4f8f-b354-0b12c7b0506f">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4bbe056a-d940-4844-a315-6255849241d1">
      <Text>Dobro, al </Text>
      <Text AdornmentStyle="-1">oni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nadoknadu</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">drugin</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a41ed458-b441-4e37-91e3-e7737ab03fe7">
      <Text AdornmentStyle="-1">stvarima</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="faaf166e-34eb-4f2a-b41a-712a4bcc2763">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ec7a40d2-7ba8-4864-804c-3cce2e9b8ee0">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">vidit</Text>
      <Text> ćeš </Text>
      <Text AdornmentStyle="-1">kad</Text>
      <Text> dođes.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="38e44b38-a0eb-405b-9488-417741da635f">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8066afbb-05e5-4ecd-aec4-5aade9cdbf66">
      <Text>Ti </Text>
      <Text AdornmentStyle="-1">si</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">rekla</Text>
      <Text> da ti </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> dobro </Text>
      <Text AdornmentStyle="-1">gori</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="93fb79b3-5677-4f27-8c15-5d86fe493307">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="92403027-b89f-4761-abba-d9b88a03593b">
      <Text>Je. </Text>
      <Text AdornmentStyle="-1">Upoznat</Text>
      <Text> ćeš </Text>
      <Text AdornmentStyle="-1">Zairu</Text>
      <Text>. Mater </Text>
      <Text AdornmentStyle="-1">joj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a951b411-c107-4f48-b685-2adbca6acce4">
      <Text AdornmentStyle="-1">Talijanka</Text>
      <Text>, ćaća </Text>
      <Text AdornmentStyle="-1">Bosanac</Text>
      <Text>, a </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Njemica</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a187614-9a34-4d21-ae9d-1c337e631865">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4f0619f9-d202-4a04-9a3c-ea23d7f77a2b">
      <Text>Aha.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="87be196f-cc2f-474d-bbfb-357446928bf3">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="64fd68d4-e99f-44a3-abe5-77207c2eb3ee">
      <Text>Biće nan dobro. Bićemo </Text>
      <Text AdornmentStyle="-1">zajedno</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ab338503-3f20-4ec8-bc76-ca804620a577">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="20667707-fc82-4021-bd34-69ffae1c14de">
      <Text>Biće i </Text>
      <Text AdornmentStyle="-1">ladno</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c85fa230-a3f8-4e3d-b7c3-8ae3b9a24c1d">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7cccd61a-bb98-4478-8c3a-a8a67802b262">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">obućeš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dobru</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jaketu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fb398abb-95b5-44a9-9f23-8e433e9ed128">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b3044e51-6988-441e-8b30-06cf7c10e580">
      <Text AdornmentStyle="-1">Nebi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">provest</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">svoje</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">najbolje</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c1eed7b6-1073-490c-9a8d-c431b72c93ea">
      <Text AdornmentStyle="-1">godine</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ispod</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jakete</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b317e33f-fd94-4323-97e1-e747a3ac7c10">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3076d207-c4e8-4ae4-96c6-a08bdf294e25">
      <Text>Ti </Text>
      <Text AdornmentStyle="-1">budi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">anarhist</Text>
      <Text>, pa </Text>
      <Text AdornmentStyle="-1">nemoj</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1b24ca42-f407-4ebf-bf58-f42481f849de">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9c984bd0-527e-460b-9c9f-2826a5f67709">
      <Text AdornmentStyle="-1">Anarhizam</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">moguć</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zbog</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ljudske</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f8d1df26-86f3-4e0b-b268-bd4a6eb84f04">
      <Text AdornmentStyle="-1">prirode</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Možeš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">čovika</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">naučit</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">od</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">malih</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nogu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ff458eba-2fd0-47ce-9b8f-81767d6fe864">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="233f98f1-21f6-47e1-aab3-5242e1bbd43c">
      <Text AdornmentStyle="-1">Pae</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">vidiš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kako</Text>
      <Text> su </Text>
      <Text AdornmentStyle="-1">nas</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">naučili</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">je</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6533cb8f-cc16-487b-a8ba-be6100635349">
      <Text AdornmentStyle="-1">ovo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">normalno</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="03349aa2-156f-46b5-8ad1-f32f38e3103f">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9f23317f-62e8-44bc-b424-3a67369fd51b">
      <Text>Ma </Text>
      <Text AdornmentStyle="-1">nije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nikome</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">normalno</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9bd9cb98-35f4-4c53-937c-6f1d867e64fa">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1fb4b11b-f0b0-4d51-afd5-119244bd9613">
      <Text AdornmentStyle="-1">Kad</Text>
      <Text> će </Text>
      <Text AdornmentStyle="-1">puknit</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fbe51f87-010a-48d2-a5ea-adc4190cab88">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1aed5623-6704-4949-ba24-aeddf8700baa">
      <Text>Ja bi </Text>
      <Text AdornmentStyle="-1">tila</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">pukne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dok</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">smo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">žive</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3e5be06b-7f99-4a39-a2ce-5606e84fac54">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e41b7e4c-dc36-4f8f-9430-7d70bcc23deb">
      <Text>Ja bi </Text>
      <Text AdornmentStyle="-1">tila</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">budemo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dio</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pucanja</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b06eab7f-51e3-49ce-8ed0-e1f4163079bc">
