    <Paragraph Type="Dialogue" id="44e9f184-9bfe-4fa5-a909-555b0cc01d39">
      <Text AdornmentStyle="-1">Aaaahaammmm</Text>
      <Text>. Hamm. </Text>
      <Text AdornmentStyle="-1">Mmmmmmm</Text>
      <Text>. </Text>
