      <Text AdornmentStyle="-1">Baš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lipo</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">slobodan</Text>
      <Text> duh. </Text>
      <Text AdornmentStyle="-1">Takvi</Text>
      <Text> san i</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="67a1d2d9-6cd3-413c-89f0-5ce5a986794f">
      <Text>ja </Text>
      <Text AdornmentStyle="-1">nekad</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bia</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Oćete</Text>
      <Text> pit </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">Iman</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">alkohola</Text>
      <Text>.</Text>
    </Paragraph>
