    <Paragraph Type="Character" id="4af6ad8b-160b-49bf-beb4-b13c55d56347">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="09325854-1d19-495e-b151-f8027db92ec5">
      <Text>A </Text>
      <Text AdornmentStyle="-1">virujen</Text>
