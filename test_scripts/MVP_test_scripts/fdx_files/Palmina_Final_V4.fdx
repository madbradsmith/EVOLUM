      <Text>ANDREJ</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b40f1411-57fc-4a1e-aee0-954167c763d1">
      <Text>Ma da. A </Text>
      <Text>šta</Text>
      <Text> ćeš ti </Text>
      <Text>radit</Text>
