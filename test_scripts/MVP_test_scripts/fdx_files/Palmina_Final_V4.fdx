    </Paragraph>
    <Paragraph Type="Dialogue" id="906eb44e-ec16-465c-99b5-761e00fc5c92">
      <Text>A mi u </Text>
      <Text AdornmentStyle="-1">onoj</Text>
      <Text> kućici </Text>
      <Text AdornmentStyle="-1">maloj</Text>
      <Text> se</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a0a24caf-7b15-408d-8895-e6bc7566299e">
      <Text AdornmentStyle="-1">sakrile</Text>
