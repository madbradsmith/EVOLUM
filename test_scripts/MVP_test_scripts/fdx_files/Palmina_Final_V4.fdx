    <Paragraph Type="Dialogue" id="5bceaf54-f049-469d-af98-de9917a50e4b">
      <Text AdornmentStyle="-1">Zlatko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kakva</Text>
      <Text> ti </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bila</Text>
