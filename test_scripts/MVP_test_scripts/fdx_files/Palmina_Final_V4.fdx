    <Paragraph Type="Character" id="4b1f3d51-5eeb-4c81-928e-e610cfec24a3">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0aa3de86-92ae-42a9-8c44-07f2e4b26c98">
      <Text AdornmentStyle="-1">Onda</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">kad</Text>
      <Text> se </Text>
      <Text AdornmentStyle="-1">putuje</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7b456d16-aa44-4e21-ad27-9b37d0d93b3b">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fe0abcee-8bd4-49c1-9220-d17fcf547d56">
      <Text>Za 2 </Text>
      <Text AdornmentStyle="-1">tjedna</Text>
      <Text>.</Text>
    </Paragraph>
