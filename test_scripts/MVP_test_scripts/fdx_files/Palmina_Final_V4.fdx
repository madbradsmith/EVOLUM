    <Paragraph Type="Dialogue" id="9f124bd5-54e8-4578-929c-0e4d57c19512">
      <Text AdornmentStyle="-1">Nego</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
