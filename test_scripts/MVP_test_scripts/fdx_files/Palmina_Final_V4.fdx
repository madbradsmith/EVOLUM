      <Text>Ha, i </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">radila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tamo</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c84a3eb3-207d-4025-930c-3d89b49456e3">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="54d383ca-4b32-4cd6-8b67-c2b20dbad39e">
      <Text>Ko </Text>
      <Text AdornmentStyle="-1">odgajateljica</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">vrtiću</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6ebbf758-5a22-49e5-b16d-7b6f9e35e739">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c60e6a09-9702-4c02-97fe-6f92915c6b49">
      <Text>Ne seri?! </Text>
      <Text AdornmentStyle="-1">Meni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">parila</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="931d1709-8c91-4cef-bc99-b8350978b0a9">
      <Text AdornmentStyle="-1">psihopat</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e4dcf128-4b1e-4175-8527-3fab78c15680">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="575f28cb-f80c-413a-8632-32b2c5ac595a">
      <Text>I </Text>
      <Text AdornmentStyle="-1">meni</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="fa8eeda4-18b5-4586-8486-38510192b7cd">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="65877ae1-7681-4af9-8575-760b814b096e">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="29dc5ecd-2941-4f94-a900-02bc88734211">
      <Text>To bi se </Text>
      <Text AdornmentStyle="-1">tebi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dogodilo</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="30fe3d27-f0c1-4a20-8913-c3948d0cd284">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fc13fdaa-11a1-4427-8040-b0da14d9d4a4">
      <Text AdornmentStyle="-1">Meni</Text>
      <Text>? Ja san </Text>
      <Text AdornmentStyle="-1">položila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">iz</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">prve</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ade08a15-0ec5-4392-93cc-42656892d58a">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fddc85b7-6416-4d18-ad2d-6ddd8eed17bc">
      <Text>To </Text>
      <Text AdornmentStyle="-1">samo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">policijska</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ćerka</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">može</Text>
      <Text> da</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="658ffb5b-d322-4e9f-9146-7c66cab30570">
      <Text AdornmentStyle="-1">dobije</Text>
      <Text>, a mi </Text>
      <Text AdornmentStyle="-1">smrtnici</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">po</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">četri-pet</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">puta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dok</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nas</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">izmuzu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">krave</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="74396108-7292-4528-8a93-f98165035f7e">
      <Text AdornmentStyle="-1">PALMINA</Text>
      <Text> (</Text>
      <Text AdornmentStyle="-1">GLEDA</Text>
      <Text> U </Text>
      <Text AdornmentStyle="-1">MANIRU</Text>
      <Text>)</Text>
    </Paragraph>
