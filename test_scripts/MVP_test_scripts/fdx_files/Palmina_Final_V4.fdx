      <Text>DUJINU</Text>
      <Text> </Text>
      <Text>mamu</Text>
      <Text>, u </Text>
      <Text>zid</Text>
      <Text>. PETRA se s očima </Text>
      <Text>punim</Text>
      <Text> </Text>
      <Text>bijesa</Text>
      <Text> </Text>
      <Text>odmakne</Text>
      <Text> </Text>
      <Text>od</Text>
