    </Paragraph>
    <Paragraph Type="Dialogue" id="fa66810e-ca37-47ad-901d-0085c22392c7">
      <Text>Pa vide </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> se tiče </Text>
      <Text AdornmentStyle="-1">njih</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> in </Text>
      <Text AdornmentStyle="-1">je</Text>
