      <Text> </Text>
      <Text AdornmentStyle="-1">nema</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mačke</Text>
      <Text>. Jesi ti </Text>
      <Text AdornmentStyle="-1">jos</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">psihoticna</Text>
