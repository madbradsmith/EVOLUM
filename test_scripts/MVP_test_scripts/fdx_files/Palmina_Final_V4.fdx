    <Paragraph Type="Action" id="afdede8d-d44a-4fc0-824b-8936da59b492">
      <Text>Kamera</Text>
      <Text> se </Text>
      <Text>fokusira</Text>
      <Text> na </Text>
      <Text>stražnju</Text>
      <Text> </Text>
      <Text>stranu</Text>
      <Text> </Text>
      <Text>glave</Text>
      <Text> </Text>
      <Text>DJEČAKA</Text>
      <Text> </Text>
      <Text>DUJE</Text>
      <Text>. </Text>
      <Text>Drži</Text>
      <Text> </Text>
      <Text>ruke</Text>
      <Text> </Text>
      <Text>preko</Text>
      <Text> </Text>
      <Text>ušiju</Text>
      <Text> </Text>
      <Text>dok</Text>
      <Text> mu se </Text>
      <Text>roditelji</Text>
      <Text> </Text>
      <Text>glasno</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">svadjaju</Text>
      <Text> u </Text>
      <Text>sobi</Text>
      <Text> do. S očima </Text>
      <Text>prati</Text>
      <Text> </Text>
      <Text>guštera</Text>
      <Text> na </Text>
      <Text>zidu</Text>
      <Text>.</Text>
