      <Text>, </Text>
      <Text AdornmentStyle="-1">sa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zarolanih</Text>
      <Text> 20 </Text>
      <Text AdornmentStyle="-1">eura</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f99e8473-42f0-4658-834e-0d8d0c0f27da">
      <Text AdornmentStyle="-1">ZLATKO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="631e00f8-5ca1-4c32-8e27-3d34aa6177f6">
      <Text AdornmentStyle="-1">Odlična</Text>
      <Text>. Luce </Text>
      <Text AdornmentStyle="-1">nije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">samo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kurva</Text>
      <Text>. Luce</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="302e29ae-9473-4905-9ef8-533d8c754be0">
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">žena</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">koju</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">volim</Text>
      <Text>.</Text>
    </Paragraph>
