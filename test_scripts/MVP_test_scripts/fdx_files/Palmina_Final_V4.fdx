      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f1e23ee8-9658-4076-96aa-26c55e4b5916">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">nismo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ništa</Text>
      <Text> pile </Text>
      <Text AdornmentStyle="-1">ni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pušile</Text>
      <Text>,</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fad2bc3d-f59d-4288-ac1f-b9bee902809c">
      <Text AdornmentStyle="-1">kakva</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mačka</Text>
      <Text>?!</Text>
    </Paragraph>
