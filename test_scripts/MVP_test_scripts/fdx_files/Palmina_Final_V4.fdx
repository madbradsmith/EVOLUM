    <Paragraph Type="Dialogue" id="eec7ac53-91d4-4497-a90f-3ed4b06f6613">
      <Text AdornmentStyle="-1">Idemo</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">đir</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5e4121ee-7583-4922-bb5b-81eb4b56c3cc">
      <Text>MATE</Text>
