    <Paragraph Type="Action" id="2b56d4db-81d3-4708-bae5-81d1cefae4d6">
      <Text>ANDREJ i </Text>
      <Text AdornmentStyle="-1">ZLATKO</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">puše</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">cigarete</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="34c30d31-9dde-41d5-8c8f-0c27bb662e5d">
      <Text AdornmentStyle="-1">ZLATKO</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="83263ce6-3671-42c2-a5c7-45406a573aab">
      <Text AdornmentStyle="-1">Ništa</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Nizozemska</Text>
      <Text>, Rotterdam ima</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b1b36b51-c249-4d2f-b782-f9471d1a9e62">
      <Text AdornmentStyle="-1">zatvoreni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">porat</Text>
      <Text>. Sad se </Text>
      <Text AdornmentStyle="-1">ide</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">priko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Antwerpa</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Belgija</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Zato</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">otvoreni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">porat</Text>
      <Text>. A i </Text>
      <Text AdornmentStyle="-1">Nizozemci</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nisu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brzi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">za</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">uzet</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mito</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">oni</Text>
      <Text> su </Text>
      <Text AdornmentStyle="-1">čudni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ljudi</Text>
      <Text>, vole </Text>
      <Text AdornmentStyle="-1">pravila</Text>
      <Text>. A </Text>
      <Text AdornmentStyle="-1">ovi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Belgijanci</Text>
      <Text>, to </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drugo</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">oni</Text>
      <Text> su </Text>
      <Text AdornmentStyle="-1">bliže</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Francuzima</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">štakori</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">prije</Text>
      <Text> će </Text>
      <Text AdornmentStyle="-1">te</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zajebat</Text>
      <Text>. A </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">skuplja</Text>
      <Text> pare? </Text>
      <Text AdornmentStyle="-1">Marokanci</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">škure</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">beštije</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ide</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">priko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">njih</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="640345c6-4d05-409d-837d-0947578af4d0">
      <Text>ANTE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5dd61d0e-c9a4-460e-bee8-5b30de35925f">
      <Text AdornmentStyle="-1">Kad</Text>
      <Text> san radio u </Text>
      <Text AdornmentStyle="-1">Španiji</Text>
      <Text>, 2 </Text>
      <Text AdornmentStyle="-1">ujutro</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="bcfb8f24-5e4e-4247-88ce-71c22c4a13b8">
      <Text>ja </Text>
      <Text AdornmentStyle="-1">šetan</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">prema</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stanu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">kad</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jedan</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Marokanac</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tuče</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">beskućnika</Text>
      <Text>, i </Text>
      <Text AdornmentStyle="-1">krade</Text>
      <Text> mu </Text>
      <Text AdornmentStyle="-1">kufer</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">onaj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mali</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Znači</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">za</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">povirovat</Text>
      <Text>. To </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">čovik</Text>
      <Text> ima, i ti mu </Text>
      <Text AdornmentStyle="-1">uzmeš</Text>
      <Text>. Pa </Text>
      <Text AdornmentStyle="-1">jebemu</Text>
      <Text> mater!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="48d08e03-b558-40c2-a902-423875c62ccf">
