    <Paragraph Type="Dialogue" id="af753f9a-bd04-41b9-918e-a934c29c237d">
      <Text AdornmentStyle="-1">se</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">tobon</Text>
      <Text> </Text>
      <Text>jer</Text>
      <Text> san se </Text>
      <Text AdornmentStyle="-1">tribala</Text>
      <Text> </Text>
      <Text>pritvarat</Text>
      <Text> da san </Text>
      <Text>neko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nisan</Text>
      <Text>. Opće </Text>
      <Text>nisi</Text>
      <Text> </Text>
      <Text>bila</Text>
      <Text> dobra </Text>
      <Text>osoba</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">mislin</Text>
      <Text>, </Text>
      <Text>ne</Text>
      <Text> </Text>
      <Text>znan</Text>
      <Text> </Text>
      <Text>te</Text>
      <Text> </Text>
      <Text>više</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">al</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> </Text>
      <Text>smo</Text>
      <Text> se </Text>
      <Text>pravili</Text>
      <Text> da </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>normalno</Text>
      <Text>. Ja </Text>
      <Text>kad</Text>
      <Text> bi </Text>
      <Text>bila</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">tobon</Text>
      <Text>, </Text>
      <Text>samo</Text>
      <Text> san </Text>
      <Text>tila</Text>
      <Text> bit s </Text>
      <Text AdornmentStyle="-1">njon</Text>
      <Text>. I </Text>
      <Text>znaš</Text>
      <Text> </Text>
      <Text>onaj</Text>
      <Text> dan </Text>
      <Text>kad</Text>
      <Text> san </Text>
      <Text>bila</Text>
      <Text> u </Text>
      <Text>tebe</Text>
      <Text> i </Text>
      <Text>tvoj</Text>
      <Text> brat </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">iša</Text>
      <Text> </Text>
      <Text>vanka</Text>
      <Text> i mi </Text>
      <Text>smo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tribali</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ić</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">njin</Text>
      <Text>, </Text>
      <Text>ali</Text>
      <Text> </Text>
      <Text>si</Text>
      <Text> ti </Text>
      <Text>dobila</Text>
      <Text>, pa ti se </Text>
      <Text>nije</Text>
      <Text> </Text>
      <Text>dalo</Text>
      <Text>? Ja san ti </Text>
      <Text>rekla</Text>
      <Text> da san </Text>
      <Text>išla</Text>
      <Text> </Text>
      <Text>doma</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">al</Text>
      <Text> san </Text>
      <Text>išla</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">njin</Text>
      <Text>, i </Text>
      <Text>spavali</Text>
      <Text> </Text>
      <Text>smo</Text>
      <Text> </Text>
      <Text>zajedno</Text>
      <Text> i </Text>
      <Text>onda</Text>
      <Text> san mu </Text>
      <Text>rekla</Text>
      <Text> da san </Text>
      <Text>trudna</Text>
      <Text>, da mi da pare </Text>
      <Text>za</Text>
      <Text> </Text>
      <Text>pobacit</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">al</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nisan</Text>
      <Text> </Text>
      <Text>bila</Text>
      <Text> </Text>
      <Text>trudna</Text>
      <Text>, i s parama san </Text>
      <Text>išla</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">The</Text>
      <Text> Cure </Text>
      <Text>koncert</Text>
      <Text> u Berlin </Text>
      <Text>jer</Text>
      <Text> san </Text>
      <Text>znala</Text>
      <Text> da </Text>
      <Text>će</Text>
