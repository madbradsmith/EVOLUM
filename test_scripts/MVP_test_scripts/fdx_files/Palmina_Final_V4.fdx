      <Text AdornmentStyle="-1">neću</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">želin</Text>
