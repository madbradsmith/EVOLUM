    <Paragraph Type="Dialogue" id="9896590b-66a9-4645-87e1-2615d58e7d57">
      <Text AdornmentStyle="-1">Krivo</Text>
      <Text> su me </Text>
      <Text AdornmentStyle="-1">upisali</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Tribalo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> bit</Text>
    </Paragraph>
    <Paragraph Type="Action" id="88aae644-942c-48e7-8286-a4c923a3aaf5">
      <Text>Marina.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6d36c983-ea5f-4f8f-a0b9-3d9bd532adda">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="25f49d93-d992-467a-85ca-3ae90c430946">
      <Text>To se i </Text>
      <Text AdornmentStyle="-1">meni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dogodilo</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Triba</Text>
      <Text> san</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d32f6563-ee39-4567-9f61-694c7a24f934">
      <Text>bit </Text>
      <Text AdornmentStyle="-1">Bogdan</Text>
      <Text> al san </Text>
      <Text AdornmentStyle="-1">ispa</Text>
      <Text> Mate. I </Text>
      <Text AdornmentStyle="-1">di</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">idu</Text>
      <Text> dvi cure pod </Text>
      <Text AdornmentStyle="-1">nazivom</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Palmina</Text>
      <Text> i </Text>
      <Text AdornmentStyle="-1">Manira</Text>
      <Text>?</Text>
    </Paragraph>
