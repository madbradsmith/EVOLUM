    </Paragraph>
    <Paragraph Type="Dialogue" id="613b27b7-df76-4d37-afb7-d8b6b0498973">
      <Text>Booked and busy.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="50669e9d-33a8-466e-8827-f02c2f158583">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0d951241-a109-44fa-b346-4c6277324aa9">
      <Text>Al ja san ti </Text>
      <Text AdornmentStyle="-1">internacionalna</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">žena</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="48e93d2f-c608-4db9-9350-e36a42dc8a07">
      <Text AdornmentStyle="-1">Nebi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bilo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">loše</Text>
      <Text> bit dominatrix. To </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mogu</Text>
      <Text> ode, a </Text>
      <Text AdornmentStyle="-1">gori</Text>
      <Text> bi </Text>
      <Text AdornmentStyle="-1">mogla</Text>
      <Text>, i </Text>
      <Text AdornmentStyle="-1">dobre</Text>
      <Text> su pare.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3c7dde7a-004e-4503-bd89-880ab43996ba">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6c71645d-3241-4f95-9194-8d9eac35eeaa">
      <Text>Pa to </Text>
      <Text AdornmentStyle="-1">triba</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Zajedno</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nas</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tri</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Čizme</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2e2633eb-f173-48f3-a7f0-2b15a593677f">
      <Text>na </Text>
      <Text AdornmentStyle="-1">petu</Text>
      <Text> i </Text>
      <Text AdornmentStyle="-1">gazit</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jadnicima</Text>
      <Text> jaja </Text>
      <Text AdornmentStyle="-1">za</Text>
      <Text> pare. </Text>
    </Paragraph>
    <Paragraph Type="Character" id="ae00053c-1555-481c-8047-8805467a5347">
      <Text AdornmentStyle="-1">ManIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="980697ba-03df-4c75-b779-683913c5f408">
      <Text AdornmentStyle="-1">Ajde</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">nama</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">bebo</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e84f7368-8db3-44fd-8b3b-8d2a69b41e95">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="11e39758-9648-4707-a61c-5d7a1e3a46a0">
      <Text>E. </Text>
      <Text AdornmentStyle="-1">Pušit</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">cigare</Text>
      <Text> i </Text>
      <Text AdornmentStyle="-1">puvat</Text>
      <Text> in dim u</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a5146fea-4854-4727-9146-0643dd81201f">
      <Text AdornmentStyle="-1">facu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dok</Text>
      <Text> se </Text>
      <Text AdornmentStyle="-1">gušu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="85416c84-0124-4239-87cb-b4d7a5118db8">
      <Text AdornmentStyle="-1">Sve</Text>
