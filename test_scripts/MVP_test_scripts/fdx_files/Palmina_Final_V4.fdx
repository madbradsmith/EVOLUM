      <Text AdornmentStyle="-1">šta</Text>
      <Text> sad?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e85f149f-1514-4bf1-ac8e-d3a7f332f48b">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2f250e7f-30fe-42f6-8321-8d8a3ec70558">
      <Text>Ne </Text>
      <Text AdornmentStyle="-1">znan</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="076f2972-05e0-4925-abc7-3f298ea6d1a8">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8ff2bc0d-9886-4c6d-bc37-2cac2af211e2">
      <Text>Ti, čini mi se, </Text>
      <Text AdornmentStyle="-1">tražiš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dubinu</Text>
      <Text> u</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0f0fd35c-1053-4553-91bb-d479957897ba">
      <Text AdornmentStyle="-1">plićaku</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="6fcda0e2-5c06-48e5-9710-f8e4c12bfb3e">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a78cf0c1-a49e-4bc9-a0bb-46b8b6f5c7e2">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2872a903-3e00-4ded-b730-45ecff59fc78">
      <Text AdornmentStyle="-1">Možeš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">samo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">naše</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">koji</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">živu</Text>
      <Text> u</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="244163c2-42b5-4f58-9b7c-e8932b892b4b">
      <Text AdornmentStyle="-1">inozemstvu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7fb02646-9559-4bd6-b4a8-623840cc5f4e">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d66b615b-3290-4af6-aa58-4487dc11395f">
      <Text>Al mama ja </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">živin</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">inozemstvu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9d4a3158-45db-4649-b854-15f91958bbde">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="835d40ad-48ea-47aa-95aa-4ac26b07466b">
      <Text AdornmentStyle="-1">Nema</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">veze</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">živit</Text>
      <Text> ćeš.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="56f26b50-e928-4432-b17f-d2deb010d4c0">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="23168bf9-337d-4fbe-a1a3-244f573630e7">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46097193-3282-46ad-963d-d83144aad17c">
      <Text AdornmentStyle="-1">Francuz</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9a830ee4-4c8d-4b3b-adb7-d11b59e6ec93">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="eb1148cf-b166-4f58-8b43-cd89c274d715">
      <Text AdornmentStyle="-1">Nemoj</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">te</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pedere</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dovodit</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cef188fd-d89c-48c1-aea5-717697317ebd">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="66777170-a78a-48ac-907c-2804f091b1c5">
      <Text AdornmentStyle="-1">Argentinac</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c41d1652-3820-4b10-bdce-2bf914719f7f">
      <Text>DIANA se </Text>
      <Text AdornmentStyle="-1">prekrsti</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="639caa57-cf1f-48e4-b8f3-c029a85cdfdb">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b01f9c1d-2ae5-4c60-b9e5-f330f4e85e1c">
      <Text>Dobro </Text>
      <Text AdornmentStyle="-1">onda</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">udat</Text>
      <Text> ću se </Text>
      <Text AdornmentStyle="-1">za</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="727b64e2-b8a5-4e87-be9e-8a3aab871c7f">
      <Text AdornmentStyle="-1">kriminalca</Text>
      <Text>. Ko i ti.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="60fe1c70-5db7-4ce0-ac65-1b2b6f12fd7d">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ebcc1457-5e9c-4cd1-8a69-38de377119dc">
      <Text AdornmentStyle="-1">Ajde</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">začepi</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="7a066d8c-7269-4fd8-ab69-4cc497a5fabe">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="eec83350-2b07-44c2-ba75-093bfdf0355a">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="84e11e85-e64c-4f9e-ae5f-e362f1ce1670">
      <Text AdornmentStyle="-1">Mogla</Text>
      <Text> bi se </Text>
      <Text AdornmentStyle="-1">nekad</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">napravit</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">malo</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="ddefdde2-73a8-4aff-ac3b-89173916545c">
      <Text AdornmentStyle="-1">gluplja</Text>
      <Text>, niko </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kreće</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">neosvojivu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tvrđavu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="b2450d57-3fa6-4598-a661-a37c53e67dda">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="edcc6605-6c60-4d0d-a3d5-7df14e0441e0">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="26d04fc5-e5c1-414a-b91d-33cd2a305390">
      <Text AdornmentStyle="-1">Kakvi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bia</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sprovod</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="82738c98-99f9-4173-8e99-443fb30e8cc6">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a75b89fe-ac1b-4458-9432-f034b913564a">
      <Text AdornmentStyle="-1">Sprovod</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bia</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stvarno</Text>
      <Text> super. </Text>
      <Text AdornmentStyle="-1">Bilo</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e2fbc42d-8372-4cac-ba7b-a850e0a5a795">
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">puno</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ljudi</Text>
      <Text>, al </Text>
      <Text AdornmentStyle="-1">nisu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nešto</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">plakali</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">bila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dugo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bolesna</Text>
      <Text>, u </Text>
      <Text AdornmentStyle="-1">glavu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">prije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">svega</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Bila</Text>
      <Text> san </Text>
      <Text AdornmentStyle="-1">obukla</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">onu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">modru</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lipu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">veštu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> ima </Text>
      <Text AdornmentStyle="-1">čipku</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">gori</Text>
      <Text>. E i </Text>
      <Text AdornmentStyle="-1">vidila</Text>
      <Text> san </Text>
      <Text AdornmentStyle="-1">Anitu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">rekla</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> da će </Text>
      <Text AdornmentStyle="-1">Manira</Text>
      <Text> doć.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c2ac5aea-9eb7-4bfa-ad12-fb923b23d7cb">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="aabdae3a-56b8-4e03-84a0-c1c57b5ab017">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="1683b2a8-ed0a-4312-b606-534334b98837">
      <Text>Je, </Text>
      <Text AdornmentStyle="-1">čule</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">smo</Text>
      <Text> se.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="415a86c1-f023-42e0-bdd9-99d2cab92f16">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="53227647-21c1-47c5-99cc-73372d9d6bb8">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">lipo</Text>
      <Text>. Stare </Text>
      <Text AdornmentStyle="-1">prijatejice</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9003dbc5-88ef-407d-868b-5ce0c48b01bb">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d48f6e13-4c9f-4c80-a726-e19d43d5adfc">
      <Text AdornmentStyle="-1">Otić</Text>
      <Text> ćemo </Text>
      <Text AdornmentStyle="-1">negdi</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="7a6c0e71-b711-48b3-8517-0ba3240bbb46">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b9bd39a5-c8fe-46a6-8888-32d019122ef8">
      <Text>Ma </Text>
      <Text AdornmentStyle="-1">di</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ćete</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="518793fe-f4b1-4bc3-baa8-d192a2e98762">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="db3ca768-3058-4e1a-a26f-151c8f9e76e6">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">izlet</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">napravit</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f840598d-b6b7-43aa-aace-59701ded118c">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="625cefe2-23df-4a3f-a5e5-ac35177056b9">
      <Text AdornmentStyle="-1">Kakvi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">izlet</Text>
      <Text>? Di </Text>
      <Text AdornmentStyle="-1">ćete</Text>
      <Text> ić?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8c59e45a-b27e-4ebc-ac12-f6576ff35790">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8dd00922-5045-418d-a7f0-b4c37813b608">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">znan</Text>
      <Text>, par dana </Text>
      <Text AdornmentStyle="-1">negdi</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="99ecf47d-c319-4d66-991f-79f8784b6c4c">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="551636bf-6435-4028-94b2-69686cca8044">
      <Text>Di </Text>
      <Text AdornmentStyle="-1">ćete</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">spavat</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="1e131995-ac29-4d9d-a617-62e8f894bc47">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="22776b90-b590-47ab-8dee-217ba9a009b0">
      <Text>U </Text>
      <Text AdornmentStyle="-1">autu</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="87a4c275-5ce6-4c73-a008-6d6d325610a5">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7ed93786-463c-4811-a313-e9e274826f4d">
      <Text>Nećeš </Text>
      <Text AdornmentStyle="-1">uzet</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">moje</Text>
      <Text> auto. </Text>
      <Text AdornmentStyle="-1">Uzmi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">starog</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="609d9fde-e689-42da-968c-3d44c6fb06ba">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b279afdd-b66e-46cb-b321-6e49f950882d">
      <Text>Dobro.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cd6da428-7e06-4ce5-aa62-f38acf2d4c43">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="00f2858c-c6b3-4749-b122-0c428d99b396">
      <Text AdornmentStyle="-1">Ako</Text>
      <Text> se dobro </Text>
      <Text AdornmentStyle="-1">sićan</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nešto</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">curi</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">ne</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dafcd08f-5bd6-45f5-ab18-3874946ae55f">
      <Text AdornmentStyle="-1">znan</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jel</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ulje</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">il</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">voda</Text>
      <Text> pa </Text>
      <Text AdornmentStyle="-1">provjeri</Text>
      <Text> to. </Text>
      <Text AdornmentStyle="-1">Ako</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">fali</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dodaj</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a4c31ba1-a59b-4c1b-91ee-a329eaf2a452">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="db4ff588-b410-44c9-914d-40ea5c35a71d">
      <Text>Oću.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="09c60f1c-3f3f-4132-bccb-75a3bbb877cf">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8683bcf1-021d-481b-9aad-fbc09abb5f54">
      <Text>A </Text>
      <Text AdornmentStyle="-1">ka</Text>
      <Text> će doć?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="d0971d14-d37e-432d-8bd2-14ade7ce1fc7">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="44fd1991-7617-456d-b00a-f0595aa99bec">
      <Text>U </Text>
      <Text AdornmentStyle="-1">nedilju</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="e41ba975-a6c7-4e59-97bf-f10cc7b76fe0">
      <Text AdornmentStyle="-1">Kratka</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="54fd321a-78a5-4110-b9bd-0031f56ffbdf">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b45b25ce-29a8-4aa1-8d36-7a19a123be0c">
      <Text>A i </Text>
      <Text AdornmentStyle="-1">ta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">njena</Text>
      <Text> mater se </Text>
      <Text AdornmentStyle="-1">pravi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ka</Text>
      <Text> da</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="6e677f7b-e453-42c9-91fb-88b20b7d6a73">
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nešto</Text>
      <Text>. Ja </Text>
      <Text AdornmentStyle="-1">svaki</Text>
      <Text> put </Text>
      <Text AdornmentStyle="-1">kad</Text>
      <Text> in prođen </Text>
      <Text AdornmentStyle="-1">doli</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ispo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">verande</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">čita</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Bibliju</Text>
      <Text>, al </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">istoj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stranici</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="4474dc8c-b6bc-4a2c-ab00-f13ea4842f9c">
      <Text>CUT</Text>
    </Paragraph>
