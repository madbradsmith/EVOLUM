    <Paragraph Type="Dialogue" id="f9160751-2f45-40bb-8cff-702a35f34c84">
      <Text>Eto</Text>
      <Text> </Text>
      <Text>neki</Text>
      <Text> </Text>
      <Text>idu</Text>
      <Text> u Beč, a ja </Text>
      <Text>osuđen</Text>
      <Text> na</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d74f19f5-cdc4-487b-bfd8-b274b0b15936">
      <Text>Lijepu</Text>
      <Text> </Text>
      <Text>Našu</Text>
      <Text>. </Text>
