    <Paragraph Type="Dialogue" id="c17641e2-8672-4645-8f22-0cdba4984a1b">
      <Text AdornmentStyle="-1">Šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">devet</Text>
      <Text>?! </Text>
      <Text AdornmentStyle="-1">Šta</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">meni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">valja</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="d5050357-6893-4335-abb7-68c44ac7ad64">
      <Text AdornmentStyle="-1">Mrš</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="dfa3950a-e483-4d59-befa-981422b7027e">
      <Text AdornmentStyle="-1">MANIRA</Text>
      <Text> (</Text>
      <Text AdornmentStyle="-1">SARKASTIČNO</Text>
