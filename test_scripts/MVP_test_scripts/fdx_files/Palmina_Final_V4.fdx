      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7f979d10-a94c-4fea-bb29-29c275433acb">
      <Text>I on </Text>
      <Text AdornmentStyle="-1">doša</Text>
