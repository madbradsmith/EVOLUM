    </Paragraph>
    <Paragraph Type="Character" id="967a91a6-59ae-4e92-bf4f-0a773dbbd0d0">
      <Text>LUCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="797b51f7-7167-4278-8e3b-8fe3a98acd4d">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">konobarin</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">doli</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">Štete</Text>
