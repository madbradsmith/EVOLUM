      <Text AdornmentStyle="-1">rukon</Text>
      <Text>, </Text>
      <Text>kad</Text>
      <Text> me </Text>
      <Text>ugrizla</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Auuuu</Text>
      <Text>. </Text>
