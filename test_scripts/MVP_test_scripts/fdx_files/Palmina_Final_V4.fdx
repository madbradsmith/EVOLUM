    <Paragraph Type="Character" id="683104ff-d339-4b03-9492-df02f23e19e9">
      <Text>Diana</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="617e3447-d4da-4e89-a493-1b70694bb6cd">
      <Text AdornmentStyle="-1">Jel</Text>
      <Text> znaš onog susjeda šta je </Text>
      <Text AdornmentStyle="-1">bia</Text>
      <Text> muško, a sad je žensko? Luka, Luce se zove sad. Strašno šta ljudi sve rade sebi ovih dana. Pa di ide ovaj svit?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a82e1e2-773d-44e4-9ca9-95c421185615">
      <Text>PalMINA (nezainteresirano)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="7fd07027-d9c9-49ec-bdc8-0d98e15bf87c">
      <Text>Aha.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="798a8a8b-d29f-4acc-a3b7-120d59f8acb7">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e110e034-8174-47c2-a61c-76eddf20708b">
      <Text AdornmentStyle="-1">Jel</Text>
      <Text> ti </Text>
      <Text>znaš</Text>
      <Text> da </Text>
      <Text>pederi</Text>
      <Text> </Text>
      <Text>idu</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">pakal</Text>
      <Text>? I </Text>
      <Text AdornmentStyle="-1">lezbe</Text>
      <Text> </Text>
      <Text>isto</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="907c3915-52c6-46bc-819d-0c9897db35d1">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3ee104b0-ef96-4a66-89c2-4de777213643">
      <Text>A ja san </Text>
      <Text>mislila</Text>
      <Text> da </Text>
      <Text>idu</Text>
      <Text> u San</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cbb5c3c3-3c63-45fe-a4ef-595ac21690ed">
      <Text>Francisco.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4a1f1039-2803-4736-bf7e-95779134dd57">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="c07fa0c8-b92b-4931-b3f0-ccc7ad9b1da6">
      <Text AdornmentStyle="-1">Misusovo</Text>
      <Text>. </Text>
      <Text>Pročitala</Text>
      <Text> san ti u</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e5ca6bd7-5984-4f13-a82b-88a56d100101">
      <Text AdornmentStyle="-1">dnevniku</Text>
      <Text> </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>ono</Text>
      <Text> o </Text>
      <Text AdornmentStyle="-1">pederluku</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character" id="38a2c444-780d-48de-bfa2-0f08ea88f478">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0ec7f932-7e35-4991-a8ef-bc7e795f7eff">
      <Text AdornmentStyle="-1">Molin</Text>
      <Text>? </Text>
      <Text>Šta</Text>
      <Text> mi </Text>
      <Text>čitaš</Text>
      <Text>?! To </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>moje</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="fcb9fffb-5667-4c5e-8b11-609a88e4c0a5">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f85212d0-11b1-4884-a68c-8e4e94d8e3d3">
      <Text>To ti </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>zbog</Text>
      <Text> </Text>
      <Text>droge</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="4504c308-3249-4f6e-9f67-738fc217c6a0">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="8999e565-fe44-425f-a5aa-5163b40942ec">
      <Text>Ja se </Text>
      <Text>ne</Text>
      <Text> </Text>
      <Text>drogiran</Text>
      <Text>. </Text>
      <Text>Droga</Text>
      <Text> </Text>
      <Text>suši</Text>
      <Text> lice,</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b0629273-fe62-407f-9e91-847a27707276">
      <Text AdornmentStyle="-1">pa</Text>
      <Text> </Text>
      <Text>izgledaš</Text>
      <Text> </Text>
      <Text>starije</Text>
      <Text>. A </Text>
      <Text>šta</Text>
      <Text> </Text>
      <Text>misliš</Text>
      <Text> da su </Text>
      <Text>tablete</Text>
      <Text> </Text>
      <Text>za</Text>
      <Text> </Text>
      <Text>smirenje</Text>
      <Text> </Text>
      <Text>puno</Text>
      <Text> </Text>
      <Text>bolje</Text>
      <Text>? To </Text>
      <Text>te</Text>
      <Text> </Text>
      <Text>usporava</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">poglupljuje</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="f58dd6c5-4473-4d4d-8884-0374c5d7bc81">
      <Text>DIANA (</Text>
      <Text>SARKASTIČNO</Text>
      <Text>)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="82835941-9eda-40ab-9e86-6a2c637d0e89">
      <Text>Je, </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>tako</Text>
      <Text> </Text>
      <Text>kako</Text>
      <Text> ti </Text>
      <Text>kažeš</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f92818f5-90dd-4768-a1a1-edf2d0d0c036">
      <Text>Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="44dfaf76-e516-49b5-9f2b-8ad809bf7f61">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2043fa8f-dcb3-42c9-9aaa-3dd5655a7ed6">
      <Text>U </Text>
      <Text>životu</Text>
      <Text> ti </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>najgore</Text>
      <Text> </Text>
      <Text>kad</Text>
      <Text> </Text>
      <Text>znaš</Text>
      <Text> </Text>
      <Text>šta</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="3831fc77-fc77-4df5-a40b-8773acffbd8f">
      <Text AdornmentStyle="-1">oćeš</Text>
      <Text> i </Text>
      <Text>kad</Text>
      <Text> </Text>
      <Text>ne</Text>
      <Text> </Text>
      <Text>znaš</Text>
      <Text> </Text>
      <Text>šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">oćeš</Text>
      <Text>. Al </Text>
      <Text>isto</Text>
      <Text> </Text>
      <Text>je</Text>
