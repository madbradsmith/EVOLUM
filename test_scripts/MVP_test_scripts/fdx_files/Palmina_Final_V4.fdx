      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fb2889d0-db5b-46e5-a63f-345e88be0ae9">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">kako</Text>
