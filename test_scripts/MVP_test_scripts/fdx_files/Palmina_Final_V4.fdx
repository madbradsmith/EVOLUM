      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="513730ec-a72b-4074-b68a-804b32a5ec61">
      <Text>A ti </Text>
      <Text AdornmentStyle="-1">Palmina</Text>
