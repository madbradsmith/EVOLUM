      <Text>Ne </Text>
      <Text AdornmentStyle="-1">mogu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">vozin</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Jedino</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ako</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">neki</Text>
