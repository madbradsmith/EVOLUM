    <Paragraph Type="Dialogue" id="e699f59f-ea55-473a-aabd-12188929586a">
      <Text AdornmentStyle="-1">Naravno</Text>
      <Text> da </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text>.</Text>
