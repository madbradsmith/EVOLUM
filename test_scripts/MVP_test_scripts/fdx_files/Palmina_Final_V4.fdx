      <Text AdornmentStyle="-1">prošli</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="08ae55b2-c91f-477f-a469-056274c9475a">
      <Text>put? </Text>
      <Text AdornmentStyle="-1">Jel</Text>
      <Text> dobra?</Text>
    </Paragraph>
    <Paragraph Type="Action" id="cc9bf4dc-c530-440e-a58b-2bd2d5d908e6">
      <Text AdornmentStyle="-1">ZLATKO</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pošmrće</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jednu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">crtu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kokaina</Text>
