      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="13ad405d-dfae-458a-8625-d266e0055bef">
      <Text>Eno </Text>
      <Text AdornmentStyle="-1">sila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="137a7829-3665-4c76-bdad-1afdb31706b4">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="88b6389a-1027-44c9-9782-4e4adfda4ceb">
      <Text AdornmentStyle="-1">Palmina</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nema</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mačke</Text>
      <Text>.</Text>
    </Paragraph>
