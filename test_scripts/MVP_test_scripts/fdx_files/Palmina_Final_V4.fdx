      <Text AdornmentStyle="-1">triba</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ić</Text>
      <Text> kući, </Text>
      <Text>brojiš</Text>
      <Text> i </Text>
      <Text>brojiš</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">al</Text>
      <Text> </Text>
      <Text>nema</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Brkice</Text>
      <Text>. I tad </Text>
      <Text>čuješ</Text>
      <Text> </Text>
      <Text>ženski</Text>
      <Text> </Text>
      <Text>glas</Text>
      <Text> </Text>
      <Text>kako</Text>
      <Text> </Text>
      <Text>te</Text>
      <Text> </Text>
      <Text>doziva</Text>
      <Text> </Text>
      <Text>iza</Text>
      <Text> </Text>
      <Text>gomile</Text>
      <Text>. "</Text>
