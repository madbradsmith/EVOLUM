    </Paragraph>
    <Paragraph Type="Dialogue" id="23f49f77-20a0-414b-aeb6-4ebfb0fb5f0c">
      <Text AdornmentStyle="-1">Kako</Text>
      <Text> ćeš </Text>
      <Text AdornmentStyle="-1">vidit</Text>
      <Text> i </Text>
      <Text AdornmentStyle="-1">čut</Text>
      <Text> </Text>
