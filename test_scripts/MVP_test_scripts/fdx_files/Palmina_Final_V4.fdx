      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="f60869d7-1ff1-413e-ac13-7d21c3404559">
      <Text>ANDREJ i </Text>
      <Text>PERE</Text>
      <Text> se </Text>
      <Text>rukuju</Text>
