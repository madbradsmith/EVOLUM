      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="142d2b1d-e688-439a-b623-a0238808423b">
      <Text>A </Text>
      <Text AdornmentStyle="-1">koja</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ta</Text>
      <Text>?</Text>
    </Paragraph>
