    </Paragraph>
    <Paragraph Type="Character" id="84fd1557-9b10-4cd6-88a2-e60ef5cc44ff">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="805297c6-17db-4dbd-b9cc-246dacd0bd0e">
      <Text>Ić ćeš. </Text>
      <Text AdornmentStyle="-1">Vidin</Text>
