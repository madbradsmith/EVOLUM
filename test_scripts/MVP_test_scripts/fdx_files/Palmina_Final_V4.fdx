    </Paragraph>
    <Paragraph Type="Dialogue" id="9c330299-1d40-40f7-af7e-6332682673ed">
      <Text AdornmentStyle="-1">Kad</Text>
      <Text> san se </Text>
      <Text AdornmentStyle="-1">rastavlja</Text>
      <Text> s </Text>
      <Text AdornmentStyle="-1">prvon</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ženon</Text>
      <Text>,</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="2619685a-0bc2-4c76-8622-7d7fd8e1abd2">
      <Text AdornmentStyle="-1">Tihanon</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">tribalo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">odluči</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kome</Text>
      <Text> će ić </Text>
      <Text AdornmentStyle="-1">zgrada</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">koja</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">papirima</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">njena</Text>
      <Text>, al </Text>
      <Text AdornmentStyle="-1">koju</Text>
      <Text> san ja </Text>
      <Text AdornmentStyle="-1">platio</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Nismo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tili</Text>
      <Text> ić na sud </Text>
      <Text AdornmentStyle="-1">nego</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">smo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ljudi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">popričali</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Dogovorili</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">smo</Text>
      <Text> se da će </Text>
      <Text AdornmentStyle="-1">pribacit</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zgradu</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">mene</Text>
      <Text>, a da će </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dobit</Text>
      <Text> kuću. I </Text>
      <Text AdornmentStyle="-1">zove</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mene</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">knjigovođa</Text>
      <Text>, da </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Tihana</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pribacila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">zgradu</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">sestru</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Sve</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">uzela</Text>
      <Text>. Al </Text>
      <Text AdornmentStyle="-1">koliko</Text>
      <Text> god </Text>
      <Text AdornmentStyle="-1">puta</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">izdala</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">nikad</Text>
      <Text> se </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mogu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">naviknit</Text>
      <Text> na </Text>
      <Text AdornmentStyle="-1">taj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">osjećaj</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Znaš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> mi </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ostavila</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">Papigu</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Kad</Text>
      <Text> san u kući </Text>
      <Text AdornmentStyle="-1">moran</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">slušat</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">prvo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ženu</Text>
      <Text>, pa </Text>
      <Text AdornmentStyle="-1">papigu</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">sve</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ponavlja</Text>
      <Text>.</Text>
    </Paragraph>
