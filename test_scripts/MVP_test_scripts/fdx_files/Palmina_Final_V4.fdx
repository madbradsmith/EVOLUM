    <Paragraph Type="Dialogue" id="cf7feaad-9a36-4743-84d8-4d8ce9341dda">
      <Text>da </Text>
      <Text AdornmentStyle="-1">donese</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">trave</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">parkić</Text>
