    </Paragraph>
    <Paragraph Type="Character" id="7782d124-ef42-4649-892e-7754fd869b4c">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="956269fa-896c-49e4-840f-7cd771d7ed65">
      <Text>Yeah? Who's playing?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3ff2f36d-2624-4d6f-9f7a-f114edf27517">
      <Text>MINA</Text>
