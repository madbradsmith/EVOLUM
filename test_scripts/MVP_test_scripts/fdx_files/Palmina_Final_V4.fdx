      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a498cde8-ab38-4190-94ca-8eba66b24c1d">
      <Text AdornmentStyle="-1">Možda</Text>
