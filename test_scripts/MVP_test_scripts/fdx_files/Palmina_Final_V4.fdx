    <Paragraph Type="Action" id="370a83d6-7041-464e-8825-ea56ce8b3fb0">
      <Text>Dvije</Text>
      <Text> </Text>
      <Text>tinejdžerke</Text>
      <Text>, ANA i MARIJA, </Text>
      <Text>sjede</Text>
      <Text> i </Text>
      <Text>pričaju</Text>
      <Text> na </Text>
      <Text>klupi</Text>
      <Text> </Text>
      <Text>ispred</Text>
      <Text> </Text>
      <Text>zgrade</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e0d1c0ba-abb8-477a-9b51-5ed492588a78">
      <Text>ANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d35f93cb-757d-4273-b1b5-8f6f6d202a69">
      <Text>I </Text>
      <Text>zato</Text>
      <Text> </Text>
      <Text>znanstvenici</Text>
      <Text> </Text>
      <Text>smatraju</Text>
      <Text> da</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="86f47f05-c7d2-48ac-b8da-af3b88837e63">
      <Text AdornmentStyle="-1">nije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bia</Text>
      <Text> </Text>
      <Text>samo</Text>
      <Text> </Text>
      <Text>jedan</Text>
      <Text> Big Ben </Text>
      <Text>nego</Text>
      <Text> </Text>
      <Text>jedan</Text>
      <Text> u </Text>
      <Text>nizu</Text>
      <Text>. Da </Text>
      <Text>nema</Text>
      <Text> </Text>
      <Text>kraja</Text>
      <Text> i </Text>
      <Text>početka</Text>
      <Text> </Text>
      <Text>svega</Text>
      <Text>, </Text>
      <Text>nego</Text>
      <Text> da </Text>
      <Text>ide</Text>
      <Text> u </Text>
      <Text>krug</Text>
      <Text>. </Text>
      <Text>Postoji</Text>
      <Text> </Text>
      <Text>kraj</Text>
      <Text> </Text>
      <Text>amo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">reć</Text>
      <Text> </Text>
      <Text>kad</Text>
      <Text> se </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>ugasi</Text>
      <Text>, </Text>
      <Text>ali</Text>
      <Text> </Text>
      <Text>nije</Text>
      <Text> </Text>
      <Text>definitivan</Text>
      <Text> </Text>
      <Text>kraj</Text>
      <Text>, </Text>
      <Text>jer</Text>
      <Text> </Text>
      <Text>onda</Text>
      <Text> </Text>
      <Text>bude</Text>
      <Text> </Text>
      <Text>idući</Text>
      <Text> </Text>
      <Text>prasak</Text>
      <Text> i </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>ispočetka</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="cda11708-b817-4055-bf9c-c18145f5a580">
      <Text>MARIJA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="482fbc4d-96c1-4906-83f0-d1b9de7fdc50">
      <Text AdornmentStyle="-1">Jel</Text>
      <Text> </Text>
      <Text>misliš</Text>
      <Text> da </Text>
      <Text>onda</Text>
      <Text> </Text>
      <Text>sve</Text>
      <Text> </Text>
      <Text>bude</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e6c752b5-5c36-4dd8-93c6-f9390f5437fa">
      <Text AdornmentStyle="-1">drugačije</Text>
      <Text> ili </Text>
      <Text>isto</Text>
      <Text>? Ne </Text>
      <Text AdornmentStyle="-1">virujen</Text>
      <Text> da </Text>
      <Text>nakon</Text>
      <Text> </Text>
      <Text>svakog</Text>
      <Text> </Text>
      <Text>praska</Text>
      <Text> </Text>
      <Text>slijedi</Text>
      <Text> </Text>
      <Text>identičan</Text>
      <Text> </Text>
      <Text>razvoj</Text>
      <Text> </Text>
      <Text>događaja</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ko</Text>
      <Text> </Text>
      <Text>prošli</Text>
      <Text> put i </Text>
      <Text>onaj</Text>
      <Text> </Text>
      <Text>prije</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="298eb02c-423b-47ef-a501-1bd713a4a2e5">
      <Text>ANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d748d1b0-5c8f-4f69-91cf-587454ac344b">
      <Text AdornmentStyle="-1">Mislin</Text>
      <Text> da </Text>
      <Text>nije</Text>
      <Text> </Text>
      <Text>identično</Text>
      <Text>, </Text>
      <Text>ali</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="9ff5986e-d8f7-4503-8723-bb91e05d205d">
      <Text AdornmentStyle="-1">koliko</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drugačije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">može</Text>
      <Text> bit? To </Text>
      <Text AdornmentStyle="-1">ne</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">znan</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Drugačije</Text>
      <Text> da se </Text>
      <Text AdornmentStyle="-1">razvije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drugačiji</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">život</Text>
      <Text> to da. Al </Text>
      <Text AdornmentStyle="-1">drugačije</Text>
      <Text> da su </Text>
      <Text AdornmentStyle="-1">zakoni</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">fizike</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drugačiji</Text>
      <Text>, pa da </Text>
      <Text AdornmentStyle="-1">svemir</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">izgleda</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drugačije</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">od</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">našeg</Text>
      <Text>, to </Text>
      <Text AdornmentStyle="-1">nebi</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">znala</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="a8b28cf3-832d-4af2-9dfd-9eff4c9f4796">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Type="Action" id="3fd645d6-e0b4-4b02-bd8e-8b89a510133b">
      <Text>PERE</Text>
      <Text> </Text>
      <Text>dolazi</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="962dca21-26a7-4819-8a08-12cc50656f3d">
      <Text>PERE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="46fbf9ef-ca6e-44ef-8cea-47d9e7e852e7">
      <Text AdornmentStyle="-1">Eej</Text>
      <Text> cure </Text>
      <Text AdornmentStyle="-1">diste</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="a80c5067-598c-43e4-b877-18d8a8828867">
      <Text>MARIJA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b6d49b84-794b-40d5-b418-e3de1ba48347">
      <Text AdornmentStyle="-1">Jese</Text>
      <Text> mi </Text>
      <Text>znamo</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="6c9ad21b-521a-4a9f-b9f6-924eacc40c8b">
      <Text>PERE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="a87ad205-246e-404f-9018-76d5bdb24854">
      <Text>Ja san </Text>
      <Text>Pere</Text>
      <Text>. </Text>
      <Text>Gleda</Text>
      <Text> san </Text>
      <Text>te</Text>
      <Text> </Text>
      <Text>sa</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5d9e3dfe-5c1f-4c35-8411-977625b5db42">
      <Text AdornmentStyle="-1">balkona</Text>
      <Text AdornmentStyle="-1">.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c925d199-b014-4667-b126-26ff965e1697">
      <Text>PERE</Text>
      <Text> </Text>
      <Text>pokaže</Text>
      <Text> </Text>
      <Text>rukom</Text>
      <Text> na </Text>
      <Text>balkon</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="e2d742e5-a347-4900-81b9-3f4b48b9291e">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Type="Action" id="36c09e08-7ce3-4d70-9edc-1bc449ecfece">
      <Text AdornmentStyle="-1">VUJO</Text>
      <Text> </Text>
      <Text>piški</Text>
      <Text> s </Text>
      <Text>balkona</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Transition" id="42d9b936-2634-4134-a9d8-19f46fb8aa9a">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Type="Action" id="73181088-3034-4361-a18a-3802cb10b4e7">
      <Text>Reakcije</Text>
      <Text> </Text>
      <Text>ANE</Text>
