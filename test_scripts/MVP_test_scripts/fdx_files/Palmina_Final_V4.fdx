      <Text AdornmentStyle="-1">pogleda</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">iza</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sebe</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2a8a29e4-30c1-4401-97ec-71721798f50a">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="dd2a69ba-6b34-4e75-8ed1-cc677a2cc345">
      <Text>Ti </Text>
      <Text AdornmentStyle="-1">si</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">učiteljica</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">demona</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="9c93231f-9973-472c-b4c9-a580b13c38ec">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="74a1068e-a2b3-4744-8421-4d200348a862">
      <Text>A ti </Text>
      <Text AdornmentStyle="-1">iskačeš</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">iz</Text>
      <Text> torte </Text>
      <Text AdornmentStyle="-1">za</Text>
      <Text> 50 </Text>
      <Text AdornmentStyle="-1">eura</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e8a117d7-b6c1-455c-8539-2273c585b8d1">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="04127aa3-f953-4351-8c86-3567e14a5ca0">
      <Text>To </Text>
      <Text AdornmentStyle="-1">je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bilo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">jedanput</Text>
      <Text>. Ma. Ne </Text>
      <Text AdornmentStyle="-1">pogađa</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d8bb3830-028d-4f0a-a93f-4514a38f4c84">
      <Text>me to.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="2e2fcde7-f971-48cb-92d5-bb986327c55d">
      <Text AdornmentStyle="-1">Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ada25b7c-6bdc-4b21-b11c-ca049e41eb81">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="aad2b0ab-1a54-4e09-aab8-e88bc9a506fa">
      <Text>Ja san </Text>
      <Text AdornmentStyle="-1">ponosna</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">kučka</Text>
      <Text> i </Text>
      <Text AdornmentStyle="-1">pička</Text>
      <Text>.</Text>
