      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b682f4bd-d0b3-4fcb-b1ac-aa66458467e1">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d9f19a48-f07c-4b25-8a63-4204426baa30">
      <Text AdornmentStyle="-1">Koja</Text>
