    <Paragraph Type="Dialogue" id="03b9f4d3-8f28-4dda-8b1a-a5a8bb5bcaa2">
      <Text AdornmentStyle="-1">filmove</Text>
      <Text AdornmentStyle="-1">.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="3fadeb25-fb89-4481-b02b-9154576df756">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="888c56b3-d06e-4d97-b9b8-28c985844277">
      <Text>Ma </Text>
      <Text AdornmentStyle="-1">uvik</Text>
      <Text> </Text>
      <Text>radu</Text>
      <Text> </Text>
      <Text>isti</Text>
      <Text> film. O</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="48bc3498-57a3-4625-979d-372401b51392">
      <Text AdornmentStyle="-1">kriminalu</Text>
      <Text AdornmentStyle="-1">,</Text>
      <Text> </Text>
      <Text>ratu</Text>
      <Text> ili </Text>
      <Text>nogometu</Text>
      <Text>. Al bar </Text>
      <Text>nešto</Text>
      <Text>. A mi?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="5915bfbd-c866-4fa2-bc06-1171cc1e1b44">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="67f5de20-cd20-4877-87bf-3e332f3ac65b">
      <Text>Pa mi se </Text>
      <Text>bavimo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">turizmon</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action" id="c3d9bd9b-5f02-46bd-98ea-e6520aef52c4">
      <Text>Pauza</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="e6709b1f-559e-4a39-8dc0-a001c44113e0">
      <Text>ManIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cda71ccf-48e7-4dd3-b044-77149f383155">
      <Text>Kako</Text>
      <Text> </Text>
      <Text>psihoza</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ca2ad752-be35-4268-a495-9da4c3e5b654">
      <Text>PaLMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4312fd09-8018-4bac-a3f7-7c0d86290773">
      <Text>Najdraže</Text>
      <Text> </Text>
      <Text>nestvarno</Text>
      <Text> </Text>
      <Text>šta</Text>
      <Text> san </Text>
      <Text>bila</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">vidila</Text>
      <Text> mi </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text>ta</Text>
      <Text> </Text>
      <Text>majmunska</Text>
      <Text> </Text>
      <Text>mačka</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="8a670fad-4661-4823-b944-65be724f7432">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="fdb7c0f0-b92f-47a0-94aa-43b7643fe2c7">
      <Text>Da, ma </Text>
      <Text AdornmentStyle="-1">razumin</Text>
      <Text>. A </Text>
      <Text>šta</Text>
      <Text> </Text>
      <Text>misliš</Text>
      <Text> </Text>
      <Text>od</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="179dc85c-ac1b-4d29-b4b7-8fef96e1dea3">
      <Text AdornmentStyle="-1">čega</Text>
      <Text> </Text>
      <Text>je</Text>
      <Text> to?</Text>
    </Paragraph>
    <Paragraph Type="Character" id="50ec8e1c-a811-4a00-a363-067424051365">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="b7271115-e001-477c-aa69-f642ac72ae43">
      <Text>Ne </Text>
      <Text>znan</Text>
      <Text>. </Text>
      <Text>Bila</Text>
      <Text> san </Text>
      <Text AdornmentStyle="-1">trizna</Text>
      <Text>. Biće</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="e576f44a-66fe-444a-b548-d3ba2e113814">
      <Text AdornmentStyle="-1">stres</Text>
      <Text AdornmentStyle="-1">.</Text>
      <Text> Sad mi </Text>
      <Text>je</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pribacilo</Text>
      <Text> na babu.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="792646bb-302b-4488-ae3a-5af18e718516">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5a7f2614-621f-49e0-904a-27a109df3c16">
      <Text>Baba </Text>
      <Text>Roga</Text>
      <Text>, da.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="b2936361-237e-4a7d-a8ff-2d149d2ba2bc">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="5e5ec484-5cc7-44ce-a759-de1ae8e83641">
      <Text>Nije</Text>
      <Text> </Text>
      <Text>ni</Text>
      <Text> </Text>
      <Text>ona</Text>
      <Text> </Text>
      <Text>loša</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="2e7d79be-82af-45d0-abad-d79e4a161dba">
      <Text AdornmentStyle="-1">MANIRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="4de82386-cb47-4d5f-beab-dd7fd1659f4f">
      <Text>Pa </Text>
      <Text AdornmentStyle="-1">bolje</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ona</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nego</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">onaj</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">čovik</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">šta</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">te</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">prati</Text>
      <Text> u </Text>
      <Text AdornmentStyle="-1">mraku</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="c648bab3-cb8b-4321-85bb-4a3e0961bf3a">
      <Text AdornmentStyle="-1">PALMINA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="0d90c29a-8ce1-465c-8bbd-551456762538">
      <Text AdornmentStyle="-1">Baš</Text>
