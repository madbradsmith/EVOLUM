<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="5">

  <Content>
    <Paragraph Number="1" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. CEMETERY - DAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A HEADSTONE reads: CHANTAL LAWRENCE -- 1976 - 2009 --LOVING WIFE AND MOTHER -- GONE TOO SOON. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>FLOWERS are placed at the grave by JOANNA LAWRENCE, 17, she has a sultry, earthy, seductive demeanor.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you, </Text>
      <Text RevisionID="1">mom</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She goes to leave and checks her phone. </Text>
    </Paragraph>
    <Paragraph Number="2" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="1" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>Angle: phone screen -- an article WITH </Text>
      <Text RevisionID="1">MICHAEL</Text>
      <Text> AND WHITNEY’S PICTURES: “real estate broker weds self-made cosmetic line bachelorette”</Text>
    </Paragraph>
    <Paragraph Number="3" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="1" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. whitney’s home - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The immaculate, cookie cutter home, sits off by itself in the California countryside. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The nearest neighbor is half a mile away. </Text>
    </Paragraph>
    <Paragraph Number="4" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="AFJ">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - back yard - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A small family barbecue is in full swing. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY </Text>
      <Text RevisionID="1">HUGHES/LAWRENCE</Text>
      <Text>, 40’s, beautiful wand her sister, CASSANDRA</Text>
      <Text RevisionID="1"> CLARK</Text>
      <Text>, late 40’s, put out fresh chips. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">MICHAEL</Text>
      <Text> </Text>
      <Text RevisionID="1">LAWRENCE</Text>
      <Text>, late 40’s, dapper and Cassandra’s husband TERRANCE CLARK play football with a small group of kids. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitnEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, we’re going make some more lemonade! Anybody want anything?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, babe, can you bring me a beer?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TerrANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Make that two. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CassANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Two beers coming up! </Text>
    </Paragraph>
    <Paragraph Number="5" Type="Scene Heading">
      <SceneProperties Length="1" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - kitchen </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, in the middle of making lemonade, laughs at the sight of </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> playing with her boys.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Whitney</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He’s amazing, isn’t he?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Cassandra</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He’s something. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(sensing the tone)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh God, what does that mean, </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nothing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Your nothing is never just nothing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just -- don’t you think 4 months is a little fast, Whit?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Of course it is. But love is love, and I’m not getting any younger. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just tell me you got him to sign the prenup. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m in love, </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>, not in stupid. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, I’ll drop it. He is great with the kids. They’re going to have him worn out by the end of the day. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He better not be, we’re still newlyweds</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Keep that to yourself.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The two sisters laugh. The door bell RINGS.</Text>
    </Paragraph>
    <Paragraph Number="6" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. WHITNEY’S HOME - </Text>
      <Text RevisionID="1">foyer - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney OPENS the front door to REVEAL -- JOANNA.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(innocent)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hi, I’m looking for </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> Lawrence, is he here? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney notices Joanna</Text>
      <Text RevisionID="1"> right away.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLE ON -</Text>
      <Text> </Text>
      <Text RevisionID="1">Joanna’s </Text>
      <Text>suitcase in </Text>
      <Text RevisionID="1">her </Text>
      <Text>hand. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah. How’d you know?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(realizing)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’ve seen pictures. And your dad has told me a lot about you. I’m Whitney, his wife.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know. It’s nice to meet you Whitney.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m so sorry, come on in.</Text>
    </Paragraph>
    <Paragraph Number="7" Type="Scene Heading">
      <SceneProperties Length="2" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whiTNEY'S HOME - foyer - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna walks in and looks around. Whitney calls for Michael.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael?!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael walks in from outside.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hey, dad. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael is surprised to see Joanna.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna, wow, this is a surprise! What’re you doing here? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael hugs Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know I should’ve called, but I thought, it would be better if we talked, in person. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Is everything okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Granny Linda died. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What? Oh no, I’m so sorry. I should call and check on her family.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">They’re all taking it pretty hard right now. I wouldn’t call. You know they’re not too fond of you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Good point. Come here.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael hugs Joanna.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MiCHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">How are you? I know that was your favorite grandmother.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah she was. But that’s only because your mother hated me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She didn’t hate you. You just weren’t her favorite.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael and Joanna give a semi laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m guessing Granny Linda was your mother’s mother?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Wow. I’m so sorry for you loss. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It’s okay. That’s why I couldn’t make it to the wedding. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">How’d she--?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Heart attack. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh my God. How are you holing up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m okay. It’s just crazy living with someone and seeing them everyday, then all the sudden they’re gone.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know the feeling. So do you have anywhere to stay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">My Aunt Debra offered for me to move in with her and her family, but she has six kids. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well I’m glad you came here. You’re absolutely staying with us. No, questions. We can set you up in the guest room. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Let me introduce you to your new brothers.</Text>
    </Paragraph>
    <Paragraph Number="8" Type="Scene Heading">
      <SceneProperties Length="1" Page="5" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - living room - momENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael sits hand in hand with </Text>
      <Text>Whitney</Text>
      <Text RevisionID="1">, and her</Text>
      <Text> two boys, BRIAN (BK) HUGHES, 1</Text>
      <Text RevisionID="1">7</Text>
      <Text>, and </Text>
      <Text RevisionID="1">ERIC</Text>
      <Text> HUGHES, </Text>
      <Text RevisionID="1">14, across from Joanna, awkwardly looking around.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Boys. This </Text>
      <Text>is my daughter, </Text>
      <Text RevisionID="1">your stepsister, </Text>
      <Text>Joanna</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> presents Joanna to the family. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hi, I’m </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> shakes Joanna's hand. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(re: Brian)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And this strapping gentleman, is Whitney’s oldest son, Brian. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian and Joanna shake, and he is awestruck by her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, everyone calls me, BK. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No we don’t. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shut up, I meant my friends. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">N</Text>
      <Text>ice to meet you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna turns to Whitney.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Your house is beautiful. When my dad told me that you two were dating, I ordered some of your products off line. They were really good. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You didn’t have to do that, I could’ve sent you some, for free.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">The girls share a little moment. </Text>
    </Paragraph>
    <Paragraph Number="9" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. WhiTNEY'S HOME - livING ROOM - coNTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna notices an URN. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What’s this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">Whitney</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">My mother’s ashes. She passed away a little over a year ago. We were really close, so I like to have her here with me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh wow, that’s sweet. I wish we would’ve done that. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">There’s a beat. The Joanna starts to tear up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Are you okay? I didn’t mean to upset you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No it’s okay. It’s just been a lot.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael notices.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You know what? I have an idea. </Text>
    </Paragraph>
    <Paragraph Number="10" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY’S HOME - basement - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text>, Brian and </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> move the last of the boxes into a pile in a corner, while Joanna unpacks her clothes. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She drops a pair of panties. Brian notices. She notices him noticing. She picks them up, leaving Brian flushed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So, what do you think? You have a little more privacy down here. Your own bathroom, and a door, so you can come an go as you please. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This’ll work. Thanks for all this. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No problem, that’s what family’s for. There’s a blow up mattress in the closet. You and I will go shopping this weekend, for a bed and dresser set, for you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, great. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m really glad you’re here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, me too. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael and Joanna hug.</Text>
      <Text> </Text>
      <Text RevisionID="1">All the guys </Text>
      <Text>exit and Joanna's happy expression instantly changes. </Text>
    </Paragraph>
    <Paragraph Number="11" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whiTNEY’S HOME - master bathroom - nigHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney downs some kind of prescription pills, just as </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> enters.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We got </Text>
      <Text RevisionID="1">Joanna</Text>
      <Text> all settled in, down there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh, good. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I </Text>
      <Text RevisionID="1">wanted to </Text>
      <Text>apologize. We didn’t have time to talk about any of this, and </Text>
      <Text RevisionID="1">my daughter just showing up --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It’s okay. I’m fine with it Michael. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">A</Text>
      <Text>re you</Text>
      <Text RevisionID="1"> really?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney turns to </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> and wraps her arms around him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yes. </Text>
      <Text>I am. </Text>
      <Text RevisionID="1">Your daughter</Text>
      <Text> showing up unexpectedly, was a surprise. But, we’re a family now, and these things happen. We just got to roll with the punches. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The two lovingly hug. </Text>
    </Paragraph>
    <Paragraph Number="12" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="8" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. loS ANGELES SKYLINE - mornING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The SUN rises over the city. </Text>
      <Text RevisionID="1">Time has passed.</Text>
    </Paragraph>
    <Paragraph Number="13" Type="Scene Heading">
      <SceneProperties Length="2 3/8" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney'S HOME - basement - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The basement room is completely redecorated now in an almost gothic, green, motif. Drawings and Painting fill the walls. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is at an easel, painting, when Brian KNOCKS and bashfully starts to descend the stairs. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, can I come in?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, come on. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lunch’s almost ready. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, thanks.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hope you like roast beef sandwiches. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian notices the Painting.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">CLOSE ON - The painting. There’s a little girl in the grass, standing next to two tombstones. It’s very dark.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Is that you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yes. It represent the two women I loved most in my life, dying. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wow, you’re really talented. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Appreciate it. I apparently get it from my mother. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian notices a picture on Joanna's dresser. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(re: picture)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is that her?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna hands the picture to Brian and the two sit on her bed admiring it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE: PICTURE -- of </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>, toddler Joanna and </Text>
      <Text RevisionID="1">EVELYN.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, that’s her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re mom was really pretty. You look just like her. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(realizes his blunder)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I mean -- Do you miss her?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna goes back to painting. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, I guess. Sometimes I have to look at pictures just to recall her face. But there’s times when I get lost thinking about her or wondering how she feels about different things. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like what?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna goes into an apparent daze as she continues to paint. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like if she’s angry or hates the drunk driver that killed her. If she’s scared to be forgotten. Does it upset her that </Text>
      <Text RevisionID="1">my </Text>
      <Text>dad moved on.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Wow. That’s a lot to think about. I wouldn’t know what to do if something like that happened to my mom.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well what about your dad? What happened to him?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Nothing bad. He’s still alive. We just never see him. My mom said he lives in Texas with his new family. He left right after Eric was born so I don’t really miss him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You learn to move on right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah. I guess so.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Still hurts though.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna snaps out of her daze. </Text>
      <Text RevisionID="1">She smiles at Brian.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re sweet. Tell them, I’ll be right up, okay? I just want to finish this, first. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that Brian exits as Joanna seems to drift back into her daze. </Text>
    </Paragraph>
    <Paragraph Number="14" Type="Scene Heading">
      <SceneProperties Length="2" Page="11" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitNEY’S HOME - kitCHEN - later - daY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney has </Text>
      <Text>STACKS OF MAKEUP spread out on the kitchen table</Text>
      <Text RevisionID="1"> as Joanna enters. Michael is dancing by the counter adding some finishing touches to the sandwiches. Whitney is pouring some lemonade in the cups. Eric is sitting ready to eat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MiCHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Look who decided to join the party.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Dad, you’re so extra.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael laughs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re just in time. Lunch is almost ready.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian enters.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Mom, Mike. Can Dante’ spend the night? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I don’t see why not.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(to Michael)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Is that okay baby?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MicHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You heard the woman of the house.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thanks.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna is looking at the stacks of make up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Wow. </Text>
      <Text>What’s all this? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Whitney</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh that’s nothing. Just some of the samples I’m preparing for my pitch  meeting I have coming up? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pitch meeting?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, I’m meeting with some execs from Walmart. If all goes well, they’ll start carrying my products in their stores. That would mean world wide distribution. That would be huge for us. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(impressed)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">That’s so cool. You know you’re such an inspiration to young girls like me. Who knows, maybe one day I’ll be just like you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well you’re beautiful, and Michael told me how creative and smart you are. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MicHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I sure did.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">If you really work hard and put your mind to it, I’m sure you can accomplish anything you want.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well </Text>
      <Text>I hope you're hungry</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna peruses through the make-up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Starving. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey so, I was thinking, maybe this weekend, you and I could go have a girl’s day. You know, go get our nails done, maybe a facial, or something. What do you say? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">That sounds cool.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">They all take their seat at the table as one big happy family.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text RevisionID="1">DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="15" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="13" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">EXT. whITNEY'S HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Establishing.</Text>
    </Paragraph>
    <Paragraph Number="16" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whiTNEY’S HOME - master bathROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael and Whitney are sleeping. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna enters and quietly searches, through drawers and then the medicine cabinet. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">She finds Whitney’s prescription pills. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLE: BOTTLE -- the label reads: “FLUVOXAMINE”</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael turns over in the bed to get comfortable. Joanna quickly puts the pills back, and hurries out the room.</Text>
    </Paragraph>
    <Paragraph Number="17" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="13" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">EXT. whiTNEY'S HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">We hear video games playing from the outside.</Text>
    </Paragraph>
    <Paragraph Number="18" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="13" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whiTNEY'S HOME - BRIAN'S BEDROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian and his best friend DANTE’ are playing video games when Joanna walks in. She’s wearing some little shorts and a cute top. Dante’ can’t keep his eyes off her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hey BK. Do you know if your mom has any Tylenol? My head is killing me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I don’t know. Ask her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She’s sleep, and I didn’t wanna bother her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">daNTE’</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(flirty)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Sup </Text>
      <Text AdornmentStyle="-1" RevisionID="1">mah</Text>
      <Text RevisionID="1">?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna chuckles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(mocking Dante’)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Sup </Text>
      <Text AdornmentStyle="-1" RevisionID="1">mah</Text>
      <Text RevisionID="1">? You really talk like that? And that works for you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I mean. You tell me if it’s working.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I think a simple hello, how are you would be better.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DanTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh my bad. Hello. How are you? I’m Dante.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">That’s better.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian laughs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You just got checked bro.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DaNTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Shut up Brian.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna smirks.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DaNTE’</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(flirty)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You know they say a massage can relieve a headache. I’m known to give a good rub down.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna rolls her eyes. She turns around and walks out.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">DANTE’ POV - He watches her walk away. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You not </Text>
      <Text AdornmentStyle="-1" RevisionID="1">gon</Text>
      <Text RevisionID="1">’ tell me your name?!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Bro come on man that’s my sis.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well your sis is a baddie. I gotta hit that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Shut up.</Text>
    </Paragraph>
    <Paragraph Number="19" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="14" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">EXT. whiTNEY'S HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Establishing.</Text>
    </Paragraph>
    <Paragraph Number="20" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - bathroom - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael is in the middle of shaving. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">Whitney (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(screams)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No! </Text>
    </Paragraph>
    <Paragraph Number="21" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JACOB">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. WhitnEY'S HOME - living room - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael, quickly enters.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JaCOB</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Whit?!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">He finds Whitney, crying and struggling to scoop the ashes back into the urn. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Who did this? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">miCHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh, honey--- </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael helps Whitney carefully scoop up the ashes. Joanna, Brian, Dante’ and Eric enter. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh my gosh let me help you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">miCHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It’s okay, I got it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLE ON - Eric as he looks at Joanna.</Text>
    </Paragraph>
    <Paragraph Number="22" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">EXT. whiTNEY'S HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Establishing. We hear Whitney’s voice.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">Whitney (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I can’t believe this.</Text>
    </Paragraph>
    <Paragraph Number="23" Type="Scene Heading">
      <SceneProperties Length="2 2/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. WhitNEY'S HOME - MASTER BATHROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> is at the mirror brushing his teeth, when Whitney enters, to take her pills. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m so sorry baby.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney takes a moment.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Eric told me he saw her open the window. I get it. Accidents happen. But the fact that she just acted like she didn’t do it is a little bit troubling.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well maybe it’s because she was scared to say something. I mean wouldn’t you be a little nervous if it were you? Put yourself in her shoes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I guess you’re right. At least we were able to get most of the ashes, I can always get a new urn. And please don’t tell Joanna that Eric told me. He doesn’t want her to not like him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I won’t. And I appreciate you being so understanding. I know this is unexpected. But Joanna is a really good child.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She seems like it. Which makes me wonder, why didn’t you take her after her mom died?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael looks at Whitney. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">There’s a reason why.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> has Whitney sit down and he shuts the bedroom door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(quietly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You see, I -- um -- geez, I haven’t talked about all this in years. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney pulls </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> down to sit beside her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, it’s okay, baby, you can tell me anything. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> takes a deep breath.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I told you her mother was killed by a drunk driver, but I </Text>
      <Text RevisionID="1">never</Text>
      <Text> told </Text>
      <Text RevisionID="1">anyone </Text>
      <Text>what happened afterwards. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m listening.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">Michael</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It was five years ago, right after the accident. I was a mess without her mother, and so was she. So I started drinking. Heavy. Sometimes I would black out at hotels and leave Joanna all alone at the house for days. A little 12 year old girl. No money, no way to get food. But Joanna was a smart girl. She was a survivor. One day she was walking to the grocery store to get something to eat. It was one of my black out episodes, and she was picked up by the cops. Long story short. They took her away from me and she went to go live with Eve’s mother.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh my God. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She </Text>
      <Text RevisionID="1">loved me so much. Joanna would have never told on me. But it was for the best. I wasn’t good for anyone during that time.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney embraces </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh baby, </Text>
      <Text RevisionID="1">I’m so sorry you both had to deal with that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I don’t know I’m kinda hoping now this can be a second chance for me. I wanna prove to Joanna that I can be the dad she deserved.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re an amazing person and a good father to my boys. Anything you need to help with Joanna, I’m here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thank you baby. I love you so much.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I love you too.</Text>
    </Paragraph>
    <Paragraph Number="24" Type="Scene Heading">
      <SceneProperties Length="2" Page="18" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RHONDA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. restaurant - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney and Casandra are at a table,</Text>
      <Text RevisionID="1"> with their friend RHONDA, </Text>
      <Text>drinking</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDR</Text>
      <Text RevisionID="1">A</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait, he’s just now telling you about this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">rhonda</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He was probably ashamed.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But we’re talking about his wife. He should’ve came clean about this before he popped the question. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t fault him for not telling me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">rhONDA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Are you insane? After all you went through with your first marriage? I would be extra cautious.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael is different than James. </Text>
      <Text>It just makes me worry about Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Rhonda</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I would be worried too.</Text>
      <Text> </Text>
      <Text RevisionID="1">T</Text>
      <Text>here’s no telling how that incident shaped her mentally. </Text>
      <Text RevisionID="1">I mean she did break your moms Urn.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She didn’t break it, she left the window open and the wind knocked it over. It was an honest mistake.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">RHONDA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">But she lied about it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She didn’t lie. She just didn’t tell me because she thought she’d get in trouble.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">cASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Speaking of trouble. H</Text>
      <Text>as she </Text>
      <Text RevisionID="1">gotten into any trouble in her past?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael</Text>
      <Text> hasn’t mentioned it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">RhONDA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Well we see there’s a lot Michael hasn’t mentioned. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Stop it Rhonda.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CASSANDRA’S overly protective side shows. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I can have Terrance look into it, if you want.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">There’s nothing to look into. Michael told me everything there was to know.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">New information about him and his daughter. Baby there’s always more to the story than what we’re told. I’ll just have Terrence do some digging into them, it can’t hurt.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No. Michael is an amazing man with a sweet daughter. Nothing more to the story.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah but don’t you think it’s a little odd that he waited until the girl showed up at your house to tell you? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No one expected her to show up </Text>
      <Text AdornmentStyle="-1" RevisionID="1">Cass</Text>
      <Text RevisionID="1">. And at least he was honest and told me. He didn’t have to.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>RHONDA raises her glass. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Rhonda</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y</Text>
      <Text RevisionID="1">ou know what Whit, y</Text>
      <Text>ou’re right, you should let it go. Let’s toast to why we’re really here, and that’s to wish Whitney good </Text>
      <Text RevisionID="1">energy </Text>
      <Text>and all the positive vibes, in the world, for her big pitch, Monday. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Rhonda, Cassandra</Text>
      <Text RevisionID="1"> </Text>
      <Text>and Whitney TOAST, and drink.</Text>
    </Paragraph>
    <Paragraph Number="25" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - master bedroom - mornING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>AN ALARM CLOCK BUZZES - it reads 6:30AM. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney awakens and turns it off. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> rolls over beside her, with a morning kiss. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Up and </Text>
      <Text AdornmentStyle="-1">at’em</Text>
      <Text>. Today’s the big day. I’ll start breakfast. </Text>
    </Paragraph>
    <Paragraph Number="26" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="20" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. office building - day - establishing</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Professionals enter and exit the building. </Text>
    </Paragraph>
    <Paragraph Number="27" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="SECURITY GUARD">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. office building - lobby - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, along with two MODELS, both without makeup, approach the reception desk. </Text>
    </Paragraph>
    <Paragraph Number="28" Type="Scene Heading">
      <SceneProperties Length="2 1/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ASSOCIATE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="BUSINESSWOMAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MODEL #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MODEL #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MR. ROBERTSON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. conference room - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney has set up her presentation, sales charts, promotional images and Powerpoint. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>MR. ROBERTSON enters, accompanied by a group of businessmen and women. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Mr. Robertson</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mrs. Lawrence, I presume. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney gleefully shakes his hand.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mr. Robertson, it’s nice to finally meet you in person</Text>
      <Text RevisionID="1">.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MR. ROBERTSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Likewise</Text>
      <Text RevisionID="1">.</Text>
      <Text> I’ve been looking forward to this one. Well, lets get started.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mr. Robertson and his associates sit around the conference table. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wonderful. I’ve taken the liberty to place my business prospectus, there in front of you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mr. Robertson, and the others associates, watch as Whitney applies primer to Models#1. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ASSOCIATE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh wow, this is nice. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>As you can see, all of my primers have golden undertones. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney moves to Model #2 and applies a different primer. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Businesswoman</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And you said you use all natural ingredients?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. I rely heavily on a coconut oil and aloe vera base. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Model #1 is fanning herself, trying to hold her composure. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Mr. ROBERTSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>According to our researchers, you’ve done very well for yourself, so tell me, why change your sales strategy now, and get in bed with us? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s simple, Mr. Robertson. You</Text>
      <Text RevisionID="1">r</Text>
      <Text> stores can reach the young, low income, black girl, that I can’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MR. ROBERTSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Great answer. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Model #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Um -- Whit? I’m sorry, but I think I need to go wash this off. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Mr. ROBERTSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why, what’s wrong?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MODEL #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think I’m having some kind of reaction.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Model #2</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh my goodness, me too. I thought I was going crazy. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’re talking about? --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Model #1 stands in a panic, followed by Model #2. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MODEL #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s really sorry, Whit! But, it-- it feels like my face is on fire!! Oh my God! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney gives both women face wipes. They try to rub the makeup off, but a bit BLOODY FLESH comes off as well. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MODEL #2</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">AAHHHH</Text>
      <Text>! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>AsSOCIATE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Someone call 911!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney can only stand by in horror as Model #2 DASHES out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mr. Robertson gives Model #1 the pitcher of water, and she SPLASHES it on her face. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Model #1 turns, REVEALING -- her scared, bloody, cheeks and forehead. </Text>
      <Text RevisionID="1">She screams! </Text>
    </Paragraph>
    <Paragraph Number="29" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. Whitney’s HOME - eVENING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters, fighting back tears. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> approaches. </Text>
      <Text RevisionID="1">He notices Whitney’s emotions. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Is everything okay?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney erupts in emotion. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I--I -- I don’t know what went wrong -- they -- oh, God. --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> quickly embraces Whitney. She cries in his arms.</Text>
    </Paragraph>
    <Paragraph Number="30" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="23" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - maSTER BATHROOM - later</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, dressed for bed, takes her pills. She suddenly startled by a presence in the doorway. It’s Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Dad told me what happened. I’m sorry your big deal didn’t go through. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna slyly eyes the pill bottle. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks, Joanna. There will be other opportunities. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So does your offer still stand?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What offer?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>A girls day?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Um -- yeah. If you want, we could do it on Saturday. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’d like that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Me, too. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well, good night. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good night, Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is slightly uplifted. Joanna exits with a concealed, sadistic, smirk.</Text>
    </Paragraph>
    <Paragraph Number="31" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="24" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitneY'S HOME - MASTER BATHROOM - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A HAND quietly LIFTS Whitney’s PILLS from the medicine cabinet. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CLOSE OBSCURE ANGLES: a PILL CAPSULE is pulled apart. The contents dumped out. TABLETS are CRUSHED. The WHITE POWDER fills the hollowed capsules.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The PILL BOTTLE is silently put back in the cabinet. </Text>
    </Paragraph>
    <Paragraph Number="32" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="24" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. day spa - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney and Joanna are getting a pedicures and shoulder massages together. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is definitely what I needed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Me too. So, did dad tell you why I’ve been living in Louisiana? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, caught of guard --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He -- brought it up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And what did he say? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just that </Text>
      <Text RevisionID="1">he hit a pretty rough patch</Text>
      <Text> after your mom passed, </Text>
      <Text RevisionID="1">which is why you went to stay with your grandmother.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess that’s the gist of it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I want you to know that you don’t have to worry about anything even close to that happening here.</Text>
      <Text RevisionID="1"> Your father is in a really good place. And the past is the past. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Aww, thanks, Whit. I appreciate that. But I</Text>
      <Text RevisionID="1">’m not</Text>
      <Text> worried about that </Text>
      <Text RevisionID="1">happening </Text>
      <Text>at all. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney and Joanna continue with their pedicures and massages in silences. </Text>
    </Paragraph>
    <Paragraph Number="33" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="25" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. day spa - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney and Joanna exit the salon. Whitney suddenly stumbles into Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You okay? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah. I -- just got really light headed. </Text>
      <Text RevisionID="1">Do you think you can drive?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Sure. I have my license.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney gives Joanna the car keys and Joanna helps Whitney to the car. </Text>
    </Paragraph>
    <Paragraph Number="34" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="25" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CHAD">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - MASTER BEDROOM - momeNTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> gingerly helps Whitney into bed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Easy. Easy. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Whitney</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I told you</Text>
      <Text RevisionID="1">.</Text>
      <Text> </Text>
      <Text RevisionID="1">Y</Text>
      <Text>ou don’t have to fuss over me. I’ll be fine. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Joanna said that you practically fell on your face, coming out the spa. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah well</Text>
      <Text RevisionID="1"> lucky for me she was there.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He takes off her shoes. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m going to go cancel my business trip. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? Why?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What do you mean? Between what happened at your meeting and you </Text>
      <Text RevisionID="1">falling out today? N</Text>
      <Text>ow’s not the time for me to be gone.</Text>
      <Text RevisionID="1"> I need to be here to take care of you.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael</Text>
      <Text> don’t be ridiculous. You’ve been planning this trip for months. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well what am I supposed to do, Whit? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Take the trip. It will give Joanna and I some more time to spend together and bond. I’ll be fine, trust me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Should you at least go to the Doctor and make sure everything is okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Trust me. I have the boys and Joanna. They’ll take care of me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. </Text>
      <Text RevisionID="1">Well I’ll think about it. Until then, w</Text>
      <Text>hy don’t you go ahead and get some rest while I get dinner started. Okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> kisses Whitney on the forehead and exits, turning the light off on his way out. </Text>
    </Paragraph>
    <Paragraph Number="35" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - kitchen - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna slyly takes Whitney’s purse aside and fishes out a credit card, then pockets it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ERIC, angrily approaches Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What are you doing?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Minding my own business. Something you need to do better at.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What did you do to my mom?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What are you talking about?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She was totally fine and she leaves with you and all the sudden she falls out?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Listen here chief. I’m gonna say this once. Be careful who you accuse. You don’t know me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">And you don’t know me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Don’t get on my bad side okay.</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I can be a dream or your worst nightmare. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna walks away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m watching you.</Text>
    </Paragraph>
    <Paragraph Number="36" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="27" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. whitney’s home - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Every thing seems peaceful. </Text>
    </Paragraph>
    <Paragraph Number="37" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="27" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s HOME - MASTER BEDROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A HAND pulls an OUTFIT out of the closet. </Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>FaDE TO:</Text>
    </Paragraph>
    <Paragraph Number="38" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whITNEY'S HOME - MASTER BEDROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney awakens in a cold sweat. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> still slumbers beside her. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: The room is dark and hazy. The CLOCK reads -- 3:3</Text>
      <Text RevisionID="1">0</Text>
      <Text>AM. A SHADOWY FIGURE DARTS ACROSS FRAME. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End POV. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney looks around the room -- but no one is there. Then --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: we PAN ACROSS the room and BOOM -- the DARK FIGURE is standing at the foot of the bed. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End POV. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, Whitney SPRINGS awake, panting. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> awakens, too. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Babe, are you okay? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? Yeah -- I -- I must’ve had a nightmare. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, lays her head back down.</Text>
    </Paragraph>
    <Paragraph Number="39" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="28" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. convenience store - late night </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A WOMAN, that seems to be Whitney, wearing big shades and the dress from Whitney’s closet, pushes a shopping cart down the isle. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She loads rope, a plastic tarp, a gas can, matches and a </Text>
      <Text AdornmentStyle="-1">TAZER</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>AT THE CHECK OUT COUNTER -- the woman SCANS the items herself. The Woman is REVEALED -- to be Joanna, in a wig disguised as Whitney.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE: SECURITY MONITOR -- this looks just like Whitney  shopping in the middle of the night. </Text>
    </Paragraph>
    <Paragraph Number="40" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="28" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. conVENIENCE STORE - parking lot - late night </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The disguised Joanna loads the grocery bags into the trunk of her car. </Text>
    </Paragraph>
    <Paragraph Number="41" Type="Scene Heading">
      <SceneProperties Length="2 7/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - kitchen - morning</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters, still groggy, on a business call. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Whitney</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into phone)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, I’ll be fine. I’m just going to take some time away from the office. You know, clear me head a little, after everything that happened. Did we cover the girl’s medical costs? Okay. Yeah, sure hold on. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney grabs her purse and searches through it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into phone)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I -- uh -- I can’t find my card. Give me a second. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(loudly to household)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Has anyone seen my credit card? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian zips by. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No</Text>
      <Text RevisionID="1">pe.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna casually enters searching through the refrigerator. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into phone)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey let me call you back. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric enters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Eric baby have you seen my credit card?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">He’s about to say something when Joanna shoots him a look.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Nope, haven’t seen it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna? Have you seen it?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is instantly annoyed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why’re you asking me? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well because, the last time I remember using it, was at the spa, when I was with you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna steps closer to Whit, getting in her face. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I have to say, Whit, I don’t appreciate your little passive aggressive accusation. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>First of all, I didn’t accuse you of anything, I just asked you a simple question.</Text>
      <Text RevisionID="1"> Just like I asked my boys the same thing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh please, cut the shit! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey! Watch your mouth in my house</Text>
      <Text RevisionID="1"> little girl!</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s what this is really about isn’t it?! </Text>
      <Text RevisionID="1">Your house? And I’m not your little girl.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> enters with alarm. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey! Hey! Hey! What</Text>
      <Text RevisionID="1">’s</Text>
      <Text> going on in here?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Your wife is trying to accuse me of stealing her credit card! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">whiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I did not acc--</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> presents the card. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You mean this card? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(shocked)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. Where was it?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In there on the coffee table. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney goes to apologetically turn to Joanna, but Joanna doesn’t want to hear it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Save it. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(calling out)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>BK, </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>, let’s go! I’ll be in the car! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, Joanna storms out. Whitney is left at a loss, looking to </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> who’s also visibly irritated. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t accuse her, </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>. She just</Text>
      <Text RevisionID="1"> flipped on me out of nowhere. I asked all the kids had they seen the card, not just her.</Text>
      <Text> </Text>
      <Text RevisionID="1">You need to check her, she’s out of line!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know, that’s not even like you to accuse someone. But Joanna’s a teenage girl who just lost her grandmother. Her Emotions are all over the place. Who knows, maybe she’s on her time of the month or something. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael laughs. This breaks some tension. Whitney giggles as well.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I was worse at 17. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’ll talk to her and see what’s going on.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay baby thank you. I appreciate you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">They kiss. </Text>
      <Text>With that, </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> exits</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Number="42" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="31" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. skyline - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The MOON hangs high in the starry sky. </Text>
    </Paragraph>
    <Paragraph Number="43" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="31" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - </Text>
      <Text RevisionID="1">eric’s room - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> awakens, but is still visibly groggy. </Text>
    </Paragraph>
    <Paragraph Number="44" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="31" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - hallWAY - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> exits the bathroom and notices, further down the hall, that the attic door is open and the stairs are pulled down. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He curiously goes to investigate. </Text>
    </Paragraph>
    <Paragraph Number="45" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="32" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. Whitney’s home - attic - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> enters to find the outside window open. </Text>
    </Paragraph>
    <Paragraph Number="46" Type="Scene Heading">
      <SceneProperties Length="1 5/8" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - rooftop - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> peeks out of the open window to find Joanna sitting on the roof sipping on a beer</Text>
      <Text RevisionID="1"> and smoking a joint.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">erIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What are you doing out here?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Startled, Joanna turns. </Text>
      <Text RevisionID="1">She quickly puts out the joint.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh geez! You scared me. </Text>
      <Text RevisionID="1">I couldn’t sleep.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re not supposed to be up here doing that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Doing what?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m not 5. I saw you smoking weed.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(charming)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Listen Eric. Why don’t you come out here with me. I feel like we got off on the wrong foot. And since we are brother and sister now. I wanna establish a bond with you. So we can keep our own little secrets. What do you say? Truce?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna puts her hand out. Eric takes a moment. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re just being extra nice so I don’t tell on you huh?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Is it working?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">A little.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Then.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Truce.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">He shakes her hand. Joanna grabs a beer from her six pack and opens it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You ever tried beer before?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Im’ 14, why would I have tried beer?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I tried my first beer at 12. Here.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna hands </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> the beer</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Try it. You’ll like it. They say real men drink beer.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric</Text>
      <Text> takes a sip and isn’t able to hide his expression of disgust. But he awkwardly keeps drinking anyway. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ErIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Not too bad.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna laughs. Eric laughs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I won’t tell if you don’t.</Text>
    </Paragraph>
    <Paragraph Number="47" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="33" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. WhiTNEY'S HOME - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: Everything is a hazy blur. We’re in motion, moving forward. -- Distorted doors and walls disappear. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney walks down the hallway.</Text>
    </Paragraph>
    <Paragraph Number="48" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="33" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - roOFTOP - nigHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna checks </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>’s beer and sees that he’s almost done. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whoa, look at you. Here let me get you another one. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ErIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I feel weird. You sure I need another one?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Trust me. With beer you at least need two to feel it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Eric laughs. </Text>
      <Text>Joanna goes to grab </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> another beer, but this time, she slyly pulls a pill from her pocket and drops it in the bottle, then hands it </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Number="49" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - MASTER BEDROOM - same time</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> awakens to find that Whitney is not beside him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(groggily)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Babe?</Text>
    </Paragraph>
    <Paragraph Number="50" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - roofTOP - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna and Brian continue drinking. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know, most </Text>
      <Text RevisionID="1">kids</Text>
      <Text> complain about being an only child. They say it’s lonely. But I never minded it. Hell, actually I enjoyed it. Never had to worry about sharing my toys. Got </Text>
      <Text RevisionID="1">all </Text>
      <Text>the attention and affection I could’ve </Text>
      <Text RevisionID="1">ever </Text>
      <Text>wanted. Then, dear old dad had to go and screw all that up. Now, he’s over here playing super</Text>
      <Text RevisionID="1"> </Text>
      <Text>dad with you guys. And something about that just doesn’t sit right with me. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna looks over to see </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> passed out. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And I’m stuck with this mess to clean up.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna gets up and pulls an unconscious </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> to the edge of the roof. She sits him up, inching closer to tossing him over the edge. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna is just about to push Eric forward when --</Text>
    </Paragraph>
    <Paragraph Number="51" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">FRONT PORCH - Whitney stumbles and falls over the chair on the porch, making a loud crashing noise. Michael walks outside.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>WHITNEY! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna looks down to see </Text>
      <Text RevisionID="1">Michael. </Text>
      <Text>She quickly pulls </Text>
      <Text RevisionID="1">Eric </Text>
      <Text>from the edge of the roof</Text>
      <Text RevisionID="1">, just as Michael looks up.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">MICHAEL POV - No one is on the roof.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney </Text>
      <Text RevisionID="1">comes to.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the hell are you doing?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(disoriented)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I-I-I don’t know. How’d I get out here? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Jesus! Were you sleep walking? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? I -- I -- don’t know. I was dreaming that I--</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">My gosh baby you could have really gotten yourself hurt.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry, I don’t know what happened. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> embraces Whitney and they head back to the house. </Text>
    </Paragraph>
    <Paragraph Number="52" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="35" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. whitney’s home - dawn</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">A few days later. </Text>
      <Text>The morning rays peek through the trees. </Text>
    </Paragraph>
    <Paragraph Number="53" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CHAD">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - LIVING ROOM - morNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The family and Joanna say their goodbyes to </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> as he heads out of the door with his suitcases in hand. </Text>
      <Text RevisionID="1">Everything seems to be normal.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Alright guys, I’ll see you in two weeks. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Aight pops.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Later. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DanTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Bye Mr. Hughes.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna kisses and hugs </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bye dad, have a safe trip. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bye sweetie. You guys be good. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(then, quietly to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t feel right about leaving right now.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Go. I’ll be fine. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whit, you weren’t fine the other night. I hate to even think of what would have happened if I wouldn’t have been there. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I promise that it won’t happen again. From now on I’m locking the bedroom door, just in case.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(Joanna catches this)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay? So don’t worry. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. You sure? Because I don’t mind cancelling. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sure, now get out of here, before you miss your flight? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh now you’re kicking me out? Alright, I’m going. Love you. Bye guys! See you soon! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> playfully kisses Whitney and dashes out. </Text>
    </Paragraph>
    <Paragraph Number="54" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="37" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PHARMACIST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. pharmacy - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is handed a new batch of her prescription pills from the PHARMACIST. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PHARMACIST</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There you go, Ms. Hughes, I mean, Mrs. Lawrence. Have a nice day. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks, you too. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Her phone RINGS. She answers. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>INTERCUT WITH: </Text>
    </Paragraph>
    <Paragraph Number="55" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="37" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CHEMIST">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. LAB office - DAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A CHEMIST is calling while looking at a test sample. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Chemist</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mrs. Lawrence?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CHEMIST</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hi, this is “Quick-Chem-labs” calling with the test results from the make-up samples you sent us. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney exits the store and heads to her car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. Did you figure out what was wrong with my product?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CHEMIST</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes, ma’am. Most of the samples you sent us were perfectly fine, but there were others that contained a high amount of sodium hydroxide, mixed into the--</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sodium hydroxide?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CHEMIST</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lye, ma’am. As you know, lye can be highly toxic. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How would lye get in-- ?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney suddenly realizes. </Text>
    </Paragraph>
    <Paragraph Number="56" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="38" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - kitCHEN</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney looks out the kitchen window and sees Joanna laying out in the backyard, tanning. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She immediately searches under the bathroom sink. </Text>
    </Paragraph>
    <Paragraph Number="57" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="38" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - basement bathroom</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney frantically searches the medicine cabinet and underneath the sink. </Text>
    </Paragraph>
    <Paragraph Number="58" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="38" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - basement </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She quickly searches through Joanna's dresser drawers and under her bed. Then, she hears the SCREECH of a </Text>
      <Text RevisionID="1">A </Text>
      <Text>GARBAGE TRUCK. </Text>
    </Paragraph>
    <Paragraph Number="59" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="38" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. WHITNEY’S HOME - MOMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney RACES outside. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>WAIT! WAIT!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>But she’s too late, the GARBAGE TRUCK is already down the block. </Text>
    </Paragraph>
    <Paragraph Number="60" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="38" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whiTNEY'S HOME - liVING ROOM - MOMENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters, disappointed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lose something? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney TURNS startled. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(startled)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, I -- was looking for this --cleaner that I had that might’ve accidentally got mixed in with my makeup samples. You wouldn’t know anything about that would you? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nope. Not a thing. You should probably be more careful with what you leave </Text>
      <Text Style="Underline">lying</Text>
      <Text> around, though. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, Joanna smugly exits to the basement, leaving Whitney fuming.</Text>
    </Paragraph>
    <Paragraph Number="61" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">EXT. reSTAURANT - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Establishing. We hear Whitney and Cassandra talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thanks for meeting me on such short notice.</Text>
    </Paragraph>
    <Paragraph Number="62" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. restaurant - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney and Cassandra are talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael is out of town and I -  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">-- Spit it out, what’s the emergency?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I changed my mind. I do want you to ask Terrence to look into Joanna for me if you could.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Of course, right away, but why the sudden change of heart?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I don’t know. I just have a funny feeling. I mean before, she was super sweet and I thought we were getting along fine.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay, so what happened?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Remember when I told you about the disaster at work with my products?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">So I talked to my chemist this morning and they told me that there was lye in the samples. So I remembered Joanna was the only one who was around my samples. So when I went to check the garbage to see if there was anything I left. She tells me I should probably be more careful with what I leave “</Text>
      <Text RevisionID="1" Style="Underline">lying”</Text>
      <Text RevisionID="1"> around. At first I didn’t think anything of it, but the other day I was searching for my credit card and I asked her had she seen it and she just flipped on me. I don’t know maybe I’m going crazy.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No, you’re not. I told you something was up with that kid. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You sure I’m not over thinking this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m sure. And if someone is gonna be in your house you need to know all about them. I’ll have Terrance just do a quick background check on her and see what he finds.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thank you </Text>
      <Text AdornmentStyle="-1" RevisionID="1">Cass</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Of course.</Text>
    </Paragraph>
    <Paragraph Number="63" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="40" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whiTNEY'S HOME - BRIAN'S BEDROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian and Dante’ are playing video games. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Bro where’s ya step sis?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Probably in her room downstairs, why?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DaNTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She’s on one bro. We been </Text>
      <Text AdornmentStyle="-1" RevisionID="1">textin</Text>
      <Text RevisionID="1">’ back and forth. She sent me this pic.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ shows Brian the picture. We don’t see it, but Brian does. His eyes get wide.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Dude I don’t wanna see that. She’s my sister.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Ya’ll ain’t blood bro why you actin all funny about it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian pushes the phone away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re nasty bro.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I gotta pee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Why you </Text>
      <Text AdornmentStyle="-1" RevisionID="1">tellin</Text>
      <Text RevisionID="1">’ me? You know where the bathroom is.</Text>
    </Paragraph>
    <Paragraph Number="64" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="41" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">INT. whITNEY'S HOME - hALLWAY - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ sneaks out of the room. He walks down the stairs.</Text>
    </Paragraph>
    <Paragraph Number="65" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="41" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DANTE’">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whiTNEY'S HOME - BASEMENT - daY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ walks down into Joanna’s room.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DaNTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna? Hello?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">There’s no answer. Dante’ walks over toward the bed. He’s looking at a few of Joanna’s paintings.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLES ON - Some of her paintings. Very dark and sinister. One of them is of a boy falling off the roof of a house. Dante’ is curious.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DaNTE’</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(to himself)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Brian ya sis is weird bro.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ backs up and bumps into the dresser. A picture falls over. Behind the picture is a little journal. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I bet it some real juicy stuff up in here.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ grabs the book and starts reading it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">CLOSE ON - Dante’ as his expression changes. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">DANTE’</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What the --? I gotta tell Brian.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Dante’ turns around. WHACK! Dante’ falls to the ground.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGEL ON - Joanna standing there with a metal statue. She grabs Dante’s phone and texts Brian.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1" Style="Bold+Italic">“Moms needs me at the house asap. I’ll catch up with you later bro”.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna gives a snarling look as she stares at Dante’s dead body. </Text>
    </Paragraph>
    <Paragraph Number="66" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="42" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">EXT. park - bridge - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna looks around. There is no one around. She tosses a large bag over the bridge. </Text>
    </Paragraph>
    <Paragraph Number="67" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="42" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">EXT. park - basketball courts - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian and Eric are playing basketball with friends at the park. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLE ON - Joanna as she walks up to the basketball court.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Wohoo! Go Brian! Go Eric!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian blushes and misses his shot. Eric laughs at him. Joanna laughs.</Text>
    </Paragraph>
    <Paragraph Number="68" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="42" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">Ext. caSSANDRA'S HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Cassandra, in a business suit, catches Terrance, in a Police uniform, as he exits from the house.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Off to work?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TeRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Duty calls. How’d brunch with Whitney go? She doing okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">As a matter of fact, about Whitney, can you do me a favor?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What’s up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You remember Michael's daughter, Joanna?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Can you run a check on her? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She’s still a juvenile, isn’t she?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah, I think so. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Then, if she has record, it’s probably sealed. Why do you want me to run a check on her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I can’t get into it right now baby but just trust me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay, will do. Get me her full name.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I will. Thanks, hun. Pizza tonight?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Works for me. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Cassandra walks into the house while Terrance goes to his car.</Text>
    </Paragraph>
    <Paragraph Number="69" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="43" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - living room -</Text>
      <Text RevisionID="1"> dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna</Text>
      <Text RevisionID="1"> is on the couch watching TV as </Text>
      <Text>Whitney enters</Text>
      <Text RevisionID="1">. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey</Text>
      <Text RevisionID="1">, how was your day?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It was okay. Work as usual.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">brIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna took us to the park to play basketball earlier.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ErIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah it was fun.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thank you Joanna how thoughtful.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JoANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I gotcha.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Everything is normal. Almost too normal. Whitney gets a call.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I gotta take this.</Text>
    </Paragraph>
    <Paragraph Number="70" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - maSTER BEDROOM - momenTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters, shuts the door, </Text>
      <Text RevisionID="1">and answers </Text>
      <Text>her phone</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" RevisionID="1">Cass</Text>
      <Text RevisionID="1">?</Text>
    </Paragraph>
    <Paragraph Number="71" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. cassaNDRA'S HOME - dining room - evenING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Cassandra is preparing the table while Terrance is taking off his uniform top. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You’re on speaker. It’s me and Terrance.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TerRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hey Whit.</Text>
    </Paragraph>
    <Paragraph Number="72" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - maSTER BEDROOM - eVENING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">INTERCUT CONVERSATION -</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hey guys, what’s going on?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">teRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">So I was able to pull some strings and get info on your stepdaughter. Joanna Lawrence isn’t her real name. It’s actually Maggie Dillon. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">whiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">teRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah, that’s why I couldn’t find any type of online presence when I first checked her out, so I dug a little deeper. She apparently started going by Joanna Lawrence some years ago. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">whiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Does she have a juvie record?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">teRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Just a few minor infractions, nothing too alarming. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney closes her eyes and takes a deep breath. Then</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">whiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What about Michael?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">tERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">We’re still running a background on him, but so far, Michael checks out clean. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yeah a clean liar.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Stop it </Text>
      <Text AdornmentStyle="-1" RevisionID="1">Cass</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney sighs relief.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">whiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thank you guys so much. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Anything for you sis. Just be careful. Maybe you should talk to Michael about why he’s been lying to you about his daughter’s name.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I will.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney hangs up the phone. She calls Michael.</Text>
    </Paragraph>
    <Paragraph Number="73" Type="Scene Heading">
      <SceneProperties Length="2 6/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. HOTEL ROOM - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> answers his ringing cell phone. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">INTERCUT CONVERSATION -</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey babe, </Text>
      <Text RevisionID="1">I miss you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why didn’t you tell me that Joanna isn’t even her real name, </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s right, I know that her real name is Maggie Dillon. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Who told you that?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> asked Terrance --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait, you had your sister’s cop husband do a background check on my daughter?! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Yes. Something is off about Joanna. She changed her name for a reason and you’re lying to cover it up and I need answers now Michael! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay Whit. You’re right. I wasn’t completely honest with you. Yes,</Text>
      <Text> she changed her name. That wasn’t my decision, it was her grandparents! </Text>
      <Text RevisionID="1">During the time I was getting drunk, I was dating a woman named Heather. I thought it would help me get over the pain of losing Joanna’s mother. But it ended up taking a turn for the worst. Heather was abusive to Joanna. Physically. When Joanna tried to tell me I didn’t believe her until I caught her in the act. That’s why Joanna was taken from me. Heather went to jail. Joanna</Text>
      <Text> didn’t feel safe when </Text>
      <Text RevisionID="1">Heather</Text>
      <Text> was released from jail, so </Text>
      <Text RevisionID="1">her grandmother</Text>
      <Text> thought it would be a good safety precaution for her to change </Text>
      <Text RevisionID="1">her name.</Text>
      <Text> I didn’t tell you because it wasn’t my business to tell. I figured once Joanna feels comfortable enough with you, she’d tell you herself. But that obviously won’t be happening now! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re saying it’s my fault that she doesn’t feel comfortable? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No. All I’m saying is that Joanna has trust issues. And if she’s been acting out, it’s probably something that triggered her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael I’m so sorry. Poor Joanna, now I feel like a complete jerk. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Don’t baby it’s okay I should have told you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You should have told me a lot before we adopted your daughter.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What’s that supposed to mean?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">It means, </Text>
      <Text>there’s been a series of strange occurrences since she moved in. </Text>
      <Text RevisionID="1">M</Text>
      <Text>y mother’s urn, my presentation. The chemists found lye in my make-up, </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>! Lye! Now how could that have gotten in there?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’ve got to be freaking kidding me! Are you listening to yourself? What reason would Joanna have to do those things? Huh? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know, but that doesn’t mean  she didn’t</Text>
      <Text RevisionID="1">!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And it doesn’t mean that she did!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You just said she could be triggered and acting out. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, I’m not doing this with you</Text>
      <Text RevisionID="1">. </Text>
      <Text>I love you. But </Text>
      <Text RevisionID="1">I also love my daughter. Let’s just try to work things out as a family. I know we already got married quickly and Joanna surprising us didn’t make our blended family life any easier.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael. We can get through this. You just have to start being honest with me. If we don’t have trust, we don’t have anything.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I promise you baby no more secrets.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay. I love you Michael. I’ll try my best to be a better mom to Joanna until you get back.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Thanks baby. I love you too Whitney.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text RevisionID="1">DISSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="74" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="48" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - livING ROOM - morning</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna</Text>
      <Text RevisionID="1"> is </Text>
      <Text>on her way out the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Brian, </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>, come on! Let’s go! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Where are you guys going?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">To the movies.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You didn’t check with me first.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna daringly steps closer to Whitney. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I talked to my dad. He said it was okay. And yesterday I took the boys to the park and it wasn’t a problem.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I don’t think it’s a good idea for you to take them anywhere without your father or me present.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Why? </Text>
      <Text>You afraid that they wouldn’t be safe with me or something?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t say that --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re acting like I’m the negligent one here, Whitney. I mean, after all, I’m not the one who almost </Text>
      <Text RevisionID="1">hurt herself sleepwalking. Maybe too much pill popping?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney clinches her fist.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’re you going to do, hit me? I’m sure my dad would love to hear about that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, I’m not going to hit you. But you’re right, your dad is going to want to know about this. So why don’t we wait to finish this discussion, once he’s here</Text>
      <Text RevisionID="1">.</Text>
      <Text> Maggie? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna glares at Whitney, with the mention of her real name. The two stand eye to eye. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Keep playin with me little girl and it’s gonna be trouble for you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian enters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriaN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, what’s going on?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text RevisionID="1">(clearly upset)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nothing, </Text>
      <Text RevisionID="1">Joanna was just telling me that she won’t be able to take you guys to the movies so I’ll take you. She has other plans. I’ll be in the car!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney grabs her keys and steps past a fuming Joanna to exits. </Text>
      <Text RevisionID="1">Joanna pretends to be sad.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You alright?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I’m okay</Text>
      <Text>. I’ll see </Text>
      <Text RevisionID="1">you guys later.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna tosses her bag down and heads back into the home. </Text>
      <Text RevisionID="1">Brian exits confused.</Text>
    </Paragraph>
    <Paragraph Number="75" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="50" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - bathroom - </Text>
      <Text RevisionID="1">day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna opens Whitney’s medicine cabinet and grabs Whitney’s pills.</Text>
    </Paragraph>
    <Paragraph Number="76" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="50" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">eXT. whiTNEY'S HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Establishing.</Text>
    </Paragraph>
    <Paragraph Number="77" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="50" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whITNEY'S HOME - BRIAN'S BEDROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">There’s a knock on the door. Brian looks up. Joanna is there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Can I come in?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Sure.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna walks in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So, your mom really went left on me this morning. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Brian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah</Text>
      <Text RevisionID="1">. I know something was up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe I should just find another place to stay until my dad gets back. </Text>
      <Text RevisionID="1">I don’t wanna cause anymore trouble. I mean the Urn was enough.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">But that was an accident.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know. But still. I should have just told your mom I opened the window.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">But you didn’t know. And you </Text>
      <Text>shouldn’t have to do </Text>
      <Text RevisionID="1">stay anywhere else</Text>
      <Text>. I’ll talk to my mom again, and get her to chill. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks B</Text>
      <Text RevisionID="1">rian</Text>
      <Text>. I’d appreciate that. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna gives Brian a seductive kiss on the cheek. She exits.</Text>
    </Paragraph>
    <Paragraph Number="78" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="51" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - dining room - evenING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, Brian, </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>, and Joanna eat dinner in an awkward silence. </Text>
    </Paragraph>
    <Paragraph Number="79" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="51" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. Whitney’s home - bathroom - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, ready for bed, takes her medication for the night.</Text>
    </Paragraph>
    <Paragraph Number="80" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="51" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - basement bathroom - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna takes the blade out of her disposable razor. </Text>
    </Paragraph>
    <Paragraph Number="81" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="51" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - ERIC'S ROOM - momENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney sits on the edge of Eric’s bed.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Son, if you ever want to tell me anything, no matter what it is, you can tell me and you won’t get in trouble for it. Okay?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I know mom. But everything is cool.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Okay. Good night, baby. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney lovingly kisses Eric on the forehead, turns off the bedroom light, and exits. </Text>
    </Paragraph>
    <Paragraph Number="82" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="52" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text RevisionID="1">INT. whitney’s home - brian’s bedroom - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney KNOCKS and pokes her head in. Brian is on his bed texting. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">Whitney</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hey, I’m waking you up at 6:30 whether you’ve had a full night’s rest or not. So I suggest you put your phone away and get some sleep. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brian rolls his eyes and turns away from Whitney. Whitney suddenly SWOONS, under the affect of something. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">She retreats and shuts the door. </Text>
    </Paragraph>
    <Paragraph Number="83" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="52" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - stairwell - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is seated on the bottom step in a silk robe, waiting</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Number="84" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="52" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - maSTER BEDROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney enters</Text>
      <Text RevisionID="1"> the room. She feels a little weird. She grabs her head and sits on the bed. She opens and closes her eyes and shakes her head, </Text>
      <Text>visibly feeling the affects of something. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She </Text>
      <Text RevisionID="1">gets up and </Text>
      <Text>stumbles into the light switch, turning it off. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: the room is spinning. We FALL onto the bed. End POV.</Text>
    </Paragraph>
    <Paragraph Number="85" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="52" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. WHITNEY’S HOME - HALLWAY - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>An ominous SHADOW creeps down the hall. </Text>
    </Paragraph>
    <Paragraph Number="86" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="52" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - maSTER BEDROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: through a dim haze we somewhat make out a SHADOW moving through the darkness. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End POV. </Text>
    </Paragraph>
    <Paragraph Number="87" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="53" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - brian’s BEDROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>There’s another KNOCK at the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Brian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, mom, I’m going to bed! Jeez!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>This time it’s Joanna that steps in, wearing a barely there neglige’.   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, it’s just me. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian is almost breathless at the sight of her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh hey, what’s up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I was just wondering if you’ve had a chance to talk to your mom, or not. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, not yet --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(disappointed)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh, okay. Well, whenever you get the chance. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna goes to leave. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I can do it now, if you want.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Could you? That’d be cool, because there’s still a few more days until my dad gets back and I don’t want things to stay as awkward as it was at dinner, earlier.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian leaps from bed and hurries to the doorway. </Text>
    </Paragraph>
    <Paragraph Number="88" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="53" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - hallway - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, no worries. I’ll take care of it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna barely moves forcing the two to stand close, their bodies touching. Joanna leans in even closer. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks BK. I really appreciate it. You’re a good guy, you know that? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(nervously)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Of-- of course. That’s what family’s for. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna takes a step back and heads down the hall. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(whispering)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Right. Well, let me know how it goes. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, Joanna is gone and Brian continues on to Whitney’s bedroom. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He KNOCKS on the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey mom? I really need to talk to you. I still think it’s wrong how you’ve been acting towards Joanna. Even tonight at dinner, you -- Mom? Hey, mom you awake? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian turns the bedroom doorknob. </Text>
    </Paragraph>
    <Paragraph Number="89" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="54" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - MASTER BEDROOM - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian slowly opens the door and enters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BriAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mom? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He sees Whitney lying motionless on the bed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey mom, can you wake up. I really need to talk. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian FLIP the light switch and --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>SWISH PAN TO: WHITNEY, ON THE BED, LAYING IN A POOL OF HER OWN BLOOD. HER WRISTS ARE SLIT. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>MOM!! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian quickly takes Whitney in his arms to find that she’s barely conscious. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(faintly)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>B-- B-- Brian -- ? What’s happening?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>JOANNA!? JOANNA HELP ME!!!! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna hurries to the room. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s wrong?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Seeing Whitney, Joanna SCREAMS! </Text>
    </Paragraph>
    <Paragraph Number="90" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="55" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="COP">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DOCTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hospital - waiting room - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A COP is talking to Brian, who’s now covered in blood, and Joanna, while </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> is feet away </Text>
      <Text RevisionID="1">pacing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Cop </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And are you sure your mother hasn’t done anything like this before?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Brian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I mean, she does suffer from depression, but she’s never been suicidal. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>COP</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, that’s all I need. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Do you know when Whitney is going to be released? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>COP</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s generally standard procedure in cases like this, for the patient to be held for 72 hours. Do you guys have someone coming to pick you up? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Actually, I can --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra and Terrance suddenly race in. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Aunt </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She immediately embraces </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> and Brian, but shoots a look of scorn towards Joanna. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A DOCTOR approaches. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CasSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh you poor babies. How’s you</Text>
      <Text RevisionID="1">r</Text>
      <Text> mother? Where -- where is she? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Doctor</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I take it you’re -- ?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cassandra. I’m their mother’s sister. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well good news is, she’s fine. In stable condition. Bad news is we’re going to have to hold her for a few more days as a precaution while we run further tests. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I understand, can we see her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s actually only asking for you, at the moment. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh okay. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to the boys)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll be right back guys. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Doctor escorts Cassandra further into the hospital. </Text>
    </Paragraph>
    <Paragraph Number="91" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="56" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hospital - whitney’s room - momenTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra enters to find Whitney, in bed, strapped a heart monitor, with her wrists bandaged, and sobbing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>, you gotta get me out of here. I -- I didn’t do this -- you gotta believe me. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra hugs Whitney who has grown erratic. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CassANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh, honey, look at you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know what happened. One minute I was </Text>
      <Text RevisionID="1">in my bathroom taking my medicine, </Text>
      <Text>the next I was here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whit, they think you tried to commit suicide. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But I didn’t</Text>
      <Text RevisionID="1">! </Text>
      <Text>It -- it had to be Joanna, somehow. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You think she tried to kill you? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I -- don’t know. None of this makes any sense. Oh God, I don’t want the boys to see me like this. Look, they’re not going to let me leave here. Can you take the kids with you until I get out?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Of course. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And keep them away from Joanna</Text>
      <Text RevisionID="1">. </Text>
      <Text>She could be planning to hurt them, or something. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, don’t worry, honey. We’ll take them home with us. </Text>
      <Text RevisionID="1">But if you really think this little girl is capable of something like this, she needs to be locked up. What does Michael feel about all this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">I haven’t talked to him yet. I don’t want to worry him until I know for sure.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">True. Well get some rest. We got the boys.</Text>
    </Paragraph>
    <Paragraph Number="92" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="57" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hospital - WAITING ROOM - momENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra approaches the family. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Brian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can we go in and see her now? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No. She’s tired, honey. She’s going to get some rest. But she wants you guys to come home with us, until she feels better. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But I want to see</Text>
      <Text RevisionID="1"> my mom.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra lovingly bends down to </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know, baby, and she wants to see you, too, but she’s just really tired right now. I promise you’ll see her soon, so until then, you’ll be staying with aunt </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> and uncle Terrance, okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is this just a family affair, or is everyone invited to the slumber party?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Brian</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Joanna, of course you can--</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Joanna)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Actually, she just mentioned Brian and </Text>
      <Text RevisionID="1">Eric</Text>
      <Text>. I suppose Joanna, that you’re old enough to look after yourself</Text>
      <Text RevisionID="1"> at the house while Whitney is in the hospital.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Aunt </Text>
      <Text AdornmentStyle="-1" RevisionID="1">Cass</Text>
      <Text RevisionID="1">, that’s messed up. Joanna is family.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s cool, Brian. Really. She’s right, I can take care of myself. You guys go get some rest. </Text>
      <Text RevisionID="1">I’ll be at home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra and Terrance pull a hesitant Brian out as they all exit, leaving Joanna behind. </Text>
    </Paragraph>
    <Paragraph Number="93" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="59" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. hospITAL - WHITNEY'S ROOM - later</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney weeps in bed. Frustrated, she rolls over -- to see JOANNA staring at her from the door window. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney scowls and Joanna smirks -- then, exits. </Text>
    </Paragraph>
    <Paragraph Number="94" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="59" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - basemenT - morning</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna rises out of bed. She seems almost excited. </Text>
    </Paragraph>
    <Paragraph Number="95" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="59" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - garage - morning - montage  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna takes the convenience store bags out of her trunk. </Text>
    </Paragraph>
    <Paragraph Number="96" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="59" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - living room - day - montage cont.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna moves furniture and spreads out the plastic tarp. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End montage. </Text>
    </Paragraph>
    <Paragraph Number="97" Type="Scene Heading">
      <SceneProperties Length="1 5/8" Page="59" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="COP">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DOCTOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hospital - whITNEY'S ROOM - morninG</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Doctor enters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DoCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good morning, Mrs. Lawrence. I hope you were able to get some rest these last few days. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Would you be able to if everyone thought you were crazy and tried to kill yourself?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well about that. Seeing the state you were in, the last we spoke, I put a rush on your toxicology report, and well, I got the results in this morning. I have to admit that they’re troubling, to say the least. As a woman of your standings, I shouldn’t have to tell you, Mrs. Lawrence, that mixing recreational drugs with antidepressants is a very dangerous game. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">Wh</Text>
      <Text>-- what’re you talking about? I don’t --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s all right here in black and white, Mrs. Lawrence. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know what you’re talking about! I’ve never done drugs in my life! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Than how would you explain us finding cocaine, Diphenhydramine, and Temazepam in your system, along with your prescribed medication? That combination is beyond a recipe for disaster. It’s very likely, that in mixing those drugs together, you could’ve been in an alternate state of mind, and then inadvertently attempted suicide. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? No! I’m telling you, I --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Either way, Mrs. Lawrence, the police are here, and they’d like a word with you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Cop enters and the Doctor exits. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CoP</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mrs. Lawrence, first let me start by saying that you are not under arrest, but your case has been passed on to social services. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DOCTOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No! I am a good mother! This is all my step-daughter’s doing! </Text>
      <Text RevisionID="1">Call my husband. Now!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>COP</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, she said that you might say that. Now, you want to tell me about an incident a few weeks ago, where you </Text>
      <Text RevisionID="1">were sleepwalking outside your home?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is in tears, stunned, by the accusation. </Text>
    </Paragraph>
    <Paragraph Number="98" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="61" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRIAN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ERIC">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="NEWSCASTER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. casSANDRA'S HOME - living room - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian </Text>
      <Text RevisionID="1">Eric </Text>
      <Text>are watching TV, when the NEWS comes on. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE: TV -- where a NEWSCASTER reports:</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Newscaster</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We have breaking news out of Orange County, this afternoon, where the body of missing teen, </Text>
      <Text RevisionID="1">Dante’</Text>
      <Text> Owen, has been discovered in a local park. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(the volume is turned up)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>While details are still sketchy at this moment, it is believed that he might have ventured into a restricted area of the park and tragically fallen from the abandoned, James Davis Bridge. We now take you to reporter, Elizabeth Shaw, who’s on the scene, for more details.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Brian and </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> look at each other in shock.</Text>
      <Text RevisionID="1"> Brian starts to cry.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BrIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Oh no. Not Dante’. That’s my best friend. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ErIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">This is crazy. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">ERIC</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna took us to that same park the other day. She disappeared for like 15 minutes and then came back. You think she did this? I mean the last time Dante’ was seen, was at our house.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Brain realizes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">BRIAN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Hell no. I’m calling Joanna right now.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">ANGLE ON - Cassandra.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">No. Don’t call anyone right now.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">The boys looks at Cassandra.</Text>
    </Paragraph>
    <Paragraph Number="99" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="62" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>ExT. police station - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance is on the phone with Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, I hear you babe, and trust me, </Text>
      <Text RevisionID="1">I think weird things have been happening since she’s been here but it’s nothing to bring her in on for </Text>
      <Text>questioning</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>INTERCUT WITH: </Text>
    </Paragraph>
    <Paragraph Number="100" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="62" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. CASSANDRA'S HOME - BEDROOM - CONTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra is pacing back and forth, while on the phone with Terrance.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">caSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>-- </Text>
      <Text RevisionID="1">Then figure something out.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">TeRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Baby even if I did. Y</Text>
      <Text>ou know I can’t do that, without her legal parent or guardian present. And with </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> out of town and your sister in the hospital, my hands are tied for the time being. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh God, Whitney. I have to tell her. Hey, can you get me all the information you have on Joanna?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sure, but there’s not much. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What about her mom? </Text>
    </Paragraph>
    <Paragraph Number="101" Type="Scene Heading">
      <SceneProperties Length="2 6/8" Page="62" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hosPITAL - WHITNEY'S ROOM - evenING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra enters with a file and a bag of clothes. Whitney is a mix of sorrow and rage.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re talking about taking my kids away, </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know we won’t let that happen. I brought you some sweats of mine, for when you’re released.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I still have another 2</Text>
      <Text RevisionID="1">4</Text>
      <Text> hours in here. They said they found cocaine and a bunch of other drugs in my system. I swear I’ve never, in my life --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know, honey, I know. Listen, </Text>
      <Text RevisionID="1">Dante was found dead. H</Text>
      <Text>is body was found this morning in </Text>
      <Text AdornmentStyle="-1">Hammel’s</Text>
      <Text> Park beneath the old James Davis Bridge. The cops are thinking it was an accidental fall, but I overheard </Text>
      <Text RevisionID="1">Brian</Text>
      <Text> and </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> talking. </Text>
      <Text RevisionID="1">Dante’ </Text>
      <Text>was las</Text>
      <Text RevisionID="1">t</Text>
      <Text> seen </Text>
      <Text RevisionID="1">at your house before he went missing. Then </Text>
      <Text>Joanna</Text>
      <Text RevisionID="1"> took the boys to that same park. Eric said she disappeared for 15 minutes then came back.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think she killed him. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney gasps in shock.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">What? Have you told ---</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They can’t question her until either you get out of here or </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> gets back. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh God, </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>. He’s never going to agree to that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think there’s something else you should see. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra hands Whitney the file. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Its </Text>
      <Text RevisionID="1">Evelyn</Text>
      <Text> Lawrence’s case file. Joanna's mother. You said, she was killed by a drunk driver, but it says here that Joanna's mother was the one inebriated. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney flips through the file. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">C</Text>
      <Text>ocaine, Temazepam, and Diphenhydramine in her system too</Text>
      <Text RevisionID="1">.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">But why would Michael tell me --? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know, maybe </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> was too ashamed to admit that his wife was an addict. </Text>
      <Text RevisionID="1">And let’s be real girl Michael hasn’t been honest about anything regarding his past.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">You think Joanna had something to do with her mother’s death?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Who knows at this point. Anything is possible.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How could she have given me this crap without me knowing it?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Think. Did she cook? Make you a protein shake? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney tosses the file in frustration.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No. No. She’s never -- </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(finally realizes)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My pills. She’s seen me take them everyday. She must’ve gotten ahold of them and poisoned them or something.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That has to be it. If she doctored your meds, then her fingerprints would have to be on the bottle and maybe even the capsules. If I can get those to Terrance --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra retrieves the file and goes to exit.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait, where’re you going?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>To your house, to go get your pills. While I’m doing that, I think it’s time for you to call </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>, and let him know what’s </Text>
      <Text RevisionID="1">really </Text>
      <Text>going on. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, but </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>, if she’s as dangerous as you say -- </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(patting her purse)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know I’m not going empty handed. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> exits and Whitney pulls out her phone and dials. </Text>
    </Paragraph>
    <Paragraph Number="102" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="65" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoteL ROOM - evenING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> answers his phone to hear Whitney on the other end weeping. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hello?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Michael</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Honey, what’s wrong? </Text>
    </Paragraph>
    <Paragraph Number="103" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="65" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. Whitney’s home - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra approaches the front door and KNOCKS hard. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>After a beat, Joanna answers, consciously keeping the door as closed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CassANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I need to grab, Whitney’s pills. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now’s not a good time. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I wasn’t asking. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra goes to enter, but Joanna stops her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why don’t you wait here, and I’ll grab them for you? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra pushes he</Text>
      <Text RevisionID="1">r</Text>
      <Text> way in. </Text>
    </Paragraph>
    <Paragraph Number="104" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="66" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CASSANDRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - entryway - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra enters and gets in Joanna's face. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Stop playing with me, little girl. I know what you’re game is. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is almost amused. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My game?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CASSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I read your mom’s case file. I know how she died. And I’m willing to bet, once I get her pills, they’ll tell me that you’ve been trying to take my sister out the same way. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Cassandra steps further into the home seeing what Joanna has done. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaSSANDRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What in the world have you --</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, Joanna </Text>
      <Text AdornmentStyle="-1">TAZES</Text>
      <Text> Cassandra and she collapses. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna picks up the case file and thumbs through it, then she grabs Cassandra’s car keys. </Text>
    </Paragraph>
    <Paragraph Number="105" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="67" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - living room - moments LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is dragging a bound Cassandra by her ankles onto the plastic tarp, when she looks out the window and sees a POLICE CRUISER pull up. </Text>
    </Paragraph>
    <Paragraph Number="106" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="67" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PARTNER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>I/E. police cruiser - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance is at the wheel with his PARTNER in the passenger.</Text>
      <Text RevisionID="1"> </Text>
      <Text>Terrance is on the phone. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TeRRANCE</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into phone)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, Whit. I’m here now. I don’t see her car, but I’m going to go inside and call you back. Okay. Bye. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to partner)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, so I’m going to go check to see if my wife is in there. Stay here, I’ll be right back. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Partner</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Want me to call this in, just in case?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance thinks for a beat. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not yet, but stay on the radio. I’ll hit you, if I change my mind.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance exits the car. </Text>
    </Paragraph>
    <Paragraph Number="107" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="67" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PARTNER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. whitney’s home - momentS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance approaches the front entrance to find the door slightly ajar. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TerranCE</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The doors open. I’m going inside. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Partner (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(through radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Copy that. </Text>
    </Paragraph>
    <Paragraph Number="108" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="67" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - enTRYWAY - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance enters the now dark home, he tries to turn on the lights, but they don’t work. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Joanna, you home? It’s me, uncle Terrance! You left the door open! -- </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> are you in here? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance sees that the home is in shambles as he continues in. </Text>
    </Paragraph>
    <Paragraph Number="109" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="68" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PARTNER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - liVING ROOM - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance goes to pass the room, but sees Cassandra bound on the plastic tarp. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TerRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">CASS</Text>
      <Text>!! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance races to Cassandra and works to untie her hands. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TerRANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh God, baby, what happened to you?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terrance is oblivious to Joanna's shadowy silhouette creeping up behind him. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He reaches for his shoulder radio --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Terrance</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, I need--</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Then, WHAM! -- Terrance is STRUCK in the back of the head with a </Text>
      <Text RevisionID="1">glass vase!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He COLLAPSES on top of Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ParTNER (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(from radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Come back. Terrance, I didn’t get all that. Come back. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna lifts Terrance’s gun from its holster. </Text>
    </Paragraph>
    <Paragraph Number="110" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="68" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PARTNER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>I/E. polICE CRUISER - momENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Alarmed, Terrance’s partner, is on his shoulder radio. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ParTNER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Terrance? Say again, copy?!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He is oblivious to Joanna's shadowy figure DARTING behind the car as he picks up the CB radio receiver. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ParTNER</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(into CB radio)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Dispatch, this is unit--</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="-1">BLAM</Text>
      <Text>!! Terrance’s Partner is shot through the driver’s side window. </Text>
    </Paragraph>
    <Paragraph Number="111" Type="Scene Heading">
      <SceneProperties Length="1" Page="69" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PHONE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hosPITAL - WHITNEY'S ROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is on her phone. A Voicemail picks up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Phone</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’ve reached Cassandra </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitnEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She hangs up and calls again. This time someone picks up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhiTNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1">Cass</Text>
      <Text>, thank God. Are you--</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Joanna talks in a low, sinister tone.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sorry, </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> can’t come to the phone, right now. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Joanna? What’ve you done with --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Come play, Whitney. Come play. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is not a game, Joanna. Now where’s --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You have two choices, Whit. Either you come play, right now. No more cops, or surprise visitors. Just you. Or, I go find the boys and play with them, instead.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, Joanna hangs up. Whitney takes a beat to catch her breath. Then --</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, bitch. Okay. You want to threaten my family? Okay. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney rips out her IV and goes to take off her heart attachments</Text>
      <Text RevisionID="1">.</Text>
    </Paragraph>
    <Paragraph Number="112" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="70" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hospital - momentS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney exits the hospital and hurries down the street with her phone in hand. </Text>
    </Paragraph>
    <Paragraph Number="113" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - living room - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Now Terrance has been bound and gagged along with Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna fills a syringe with a mysterious substance from a medical vial. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This has just become a damn family affair. I hope I have enough party favors for everyone. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna INJECTS Terrance in the leg with the substance and he immediately passes out. </Text>
    </Paragraph>
    <Paragraph Number="114" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitney’s home - later</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A car stops in front of the home and Whitney gets out of the back seat. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The car drives on. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney sees the parked police cruiser, with the broken glass. She takes a beat to take in what’s to come. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Then, she heads to the home. </Text>
    </Paragraph>
    <Paragraph Number="115" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - entRYWAY - momentS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney cautiously enters the dark home. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She sees that the home is in shambles and hesitantly continues in. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney sees both Cassandra and Terrance on the living room floor. She goes to rush to them, but stops -- almost knowing, someone is behind her. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney TURNS -- Joanna SCREAMS and LUNGES at her with the syringe in hand. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The two tussle back and forth, Joanna struggling to stab Whitney with the needle. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re only making this harder on yourself. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney</Text>
      <Text RevisionID="1"> </Text>
      <Text>is forced against the kitchen door frame. In the scuffle, a GLIMMER from the HILT of a BUTCHER KNIFE in it’s wood block, catches Whitney’s eye. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney finally over powers Joanna, PUSHING her to the ground. -- She hurries to the kitchen for the knife, but Joanna TRIPS her on the way in. </Text>
    </Paragraph>
    <Paragraph Number="116" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="71" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - kiTCHEN - coNTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney STUMBLES in and FALLS on the glass covered floor and SCREAMS in pain. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>In an instant, Joanna is on her, again trying to inject her with the needle. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Trust me, you’re really over complicating this, Whit. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney tries to fight Joanna off, but the more she struggles, the more the glass digs into her flesh. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(straining)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, Joanna. Don’t do this. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna puts all her weight behind the syringe and Whitney slowly gives against the force. The syringe punctures her shoulder, and Joanna presses the plunger. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CLOSE ON: THE SYRINGE -- as the liquid seeps out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney instantly succumbs to the affects of the drug. Her body goes limp, but Whitney is still conscious. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>See? Now, was that so hard? Goodness gracious! You’re becoming more trouble than you’re worth. If you knew what all I had to do, just to make all this work, I think you’d be a little more cooperative. </Text>
    </Paragraph>
    <Paragraph Number="117" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="72" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. JOANNA'S home - stairwell - night - flashBACK </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A BODY tumbles down the stairs of the home and LANDS on the bottom platform. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Its SLOWLY REVEALED to be an ELDERLY WOMAN, Joanna's Grandmother. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna, with suitcase in hand, coldly steps over the body and exits as her grandmother takes her last breath. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End </Text>
      <Text RevisionID="1">FLASHBACK -</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Number="118" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="72" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitney’s home - KITCHEN - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to scene. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, now let’s go join the rest of the family. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Then, she grabs Whitney’s ankles and drags her out of the kitchen. </Text>
    </Paragraph>
    <Paragraph Number="119" Type="Scene Heading">
      <SceneProperties Length="2" Page="72" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitneY'S HOME - liVING ROOM - conTINUOUS</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna continues to drag Whitney in by her ankles. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y’all really made this harder than it had to be. Seriously. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna pulls Whitney beside Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: We see that Cassandra’s eye’s are open and alert, but she can’t move. Joanna turns our gaze to her. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End POV. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re probably wondering what I hit you with. It was a more concentrated dose of Temazepam. It’s one of the main ingredients of the little cocktail that some of your pills were replaced with. I can’t believe y’all figured that part out so quickly. Don’t worry, it’s not going to kill you. See, your sister and Terrance are still alive. Now their just a little easier to manage. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna grabs rope and ties Whitney’s hands together. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t want to tie this too, tight. We don’t want you mess up your grand finale. We’re just waiting on the guest of honor, then we can get started. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna dashes out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney can do nothing but blink, as tears streak from her eyes. Then, -- there’s a subtle twitch in her FINGERS. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna returns with the large GAS CAN and she casually doses the room in gasoline. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This was all suppose to be so easy, Whit. A simple murder/suicide. I was supposed to make it look like you took out your family, offed yourself, then, burned your own house down. The headlines would’ve read, “mentally unstable businesswoman, murders family and kills herself.” </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney sees that Joanna had a gun tucked into her waistband the whole time. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It would’ve been a tragic </Text>
      <Text AdornmentStyle="-1">blurp</Text>
      <Text> in the media, maybe even trended for a day or two</Text>
      <Text RevisionID="1"> on Social Media</Text>
      <Text>, and then we’d all be able to move on. But, no. Y’all had to go and complicate things. Now, look at this mess. You got cops involved. Your sister, your brother-in-law. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(bends down to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t you see, none of this was personal, Whit. You’re just a victim of circumstance. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Then, -- the sound of the front door opening -- </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
      <Text> (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whit?! Joanna?! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(quietly to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like the guest of honor has arrived. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney’s eyes widen with hope. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> enters, and is momentarily stunned. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Joanna! W</Text>
      <Text>hat the hell is going on here? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">There’s a small beat. Then Michael’s personality shifts.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MiCHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">And w</Text>
      <Text>hy aren’t they all dead, yet?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney expression goes from hope to horror. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There you go, is it starting to sink in now, Whit? This was always his plan. </Text>
    </Paragraph>
    <Paragraph Number="120" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="74" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>I/E. </Text>
      <Text RevisionID="1">MICHAEL'S</Text>
      <Text> car - day - flashback </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>To when </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> and Joanna where having their heart to heart. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s just, I’ll be going out of town, in a few weeks, and I don’t want things to fall apart when I do. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s wrong? Don’t you trust me?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Of course I trust you, but this is the biggest job we’ve ever pulled, and I want to make sure your comfortable doing what needs to be done. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like killing kids? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, like taking out the kids. They’re our only road block. With Whitney gone, and them out the way, we’ll inherit everything. If we want to win, sacrifices have to be made. </Text>
    </Paragraph>
    <Paragraph Number="121" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. whitney’s home - bathrOOM - night - flashBACK </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>To REVEAL -- that it was really </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> pulled Whitney’s pills out of the medicine cabinet. </Text>
    </Paragraph>
    <Paragraph Number="122" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. WhITNEY'S HOME - kITCHEN - niGHT - flashBACK </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>To REVEAL -- that it was </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> who filled the pill capsules at the kitchen table. </Text>
    </Paragraph>
    <Paragraph Number="123" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. WHITNEY’S HOME - BASEMENT - NIGHT - FLASHBACK </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>To REVEAL -- </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> tosses Joanna a WIG and one of Whitney’s outfits. </Text>
    </Paragraph>
    <Paragraph Number="124" Type="Scene Heading">
      <SceneProperties Length="2 2/8" Page="75" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whITNEY'S HOME - lIVING ROOM - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to scene. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is terrified by the revelation. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> immediately goes to work, picking Terrance up off the floor and sitting him up on the couch. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I told you, this wasn’t personal. Daddy dearest here set his sights on you over a year ago. Usually his marks were little old ladies, looking for one last thrill. He’d set the op, work his magic, the old bag would mysteriously keel over, then we’d get the inheritance or life insurance or both, and keep it moving. But you, you were special. Mrs. Self-made millionaire. Just enough money to steal, not too much to draw attention. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> turns his attention to Cassandra, picking her up and sitting her beside Terrance. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give it a rest, Magg</Text>
      <Text RevisionID="1">ie</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, we had to change my name a few years back, because the old man, got his hands a little too dirty. He was worried that the police were going to catch on to what he does and come asking questions. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Enough with the games! We have to finish this! Where are the boys? Are they here? </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(re: </Text>
      <Text AdornmentStyle="-1">Cass</Text>
      <Text> and Terrance)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And what the hell are these two doing here?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like I said on the phone, there were complications. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney has even more subtle movement to her hands. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The only complication that matters is getting those boys here, now! If they’re still alive, none of this will matter. I knew I shouldn’t have left all of this up to you. We gotta get this plastic mess up out of here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t you just hate it when he does that, Whit. Talks down to you like you’re just a tiny ant in his world. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney is now able to turns her head. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITNEY’S POV: We sees Cassandra’s PURSE under the couch. Inside, we see the glimmer of her own gun. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>End POV. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Grow up, Mag</Text>
      <Text RevisionID="1">gie</Text>
      <Text>. We’re on a time crunch here. Go call Brian and get him and </Text>
      <Text RevisionID="1">Eric</Text>
      <Text> to come home. I’ll handle the rest of this. Tell me, you at least got a gun. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna pulls the gun from her waistband. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Right here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good, hand it over. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> holds out his hand, but Joanna doesn’t hand him the gun. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They weren’t the complication, daddy dearest. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(picks up case file)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This file is. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the hell is that?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s a case file from mom’s accident. The one you told me she was killed in. </Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You see, Whit, </Text>
      <Text RevisionID="1">Heather</Text>
      <Text> wasn’t just dad’s first girlfriend after my mom died. She was also supposedly his first mark. At least, that’s what I was told. Because </Text>
      <Text RevisionID="1">Heather</Text>
      <Text>... </Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>Cut to:</Text>
    </Paragraph>
    <Paragraph Number="125" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="77" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. road - day - flashback </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>SLOW PAN -- to THE OTHER CAR involved in </Text>
      <Text RevisionID="1">Evelyn's</Text>
      <Text> car accident. A distraught </Text>
      <Text RevisionID="1">Heather</Text>
      <Text> is beside the car, bruised and remorseful. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...was the woman behind the wheel. </Text>
      <Text RevisionID="1">Heather</Text>
      <Text> was the one that supposedly killed my mom. </Text>
    </Paragraph>
    <Paragraph Number="126" Type="Scene Heading">
      <SceneProperties Length="2 4/8" Page="77" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JOANNA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LILITH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MICHAEL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. whitNEY'S HOME - liVING ROOM - nighT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to scene. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna is suddenly irate. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But that’s not true, is it dad? This says that mom was the one under the influence! This say’s she’s the one that passed out behind the wheel! That she’s the one that hit </Text>
      <Text RevisionID="1">Heather</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We don’t have time for this, Mag! Give me the gun!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It says that she had a mixture of cocaine, Benadryl and </Text>
      <Text AdornmentStyle="-1">Temazapam</Text>
      <Text> in her system when she died. That’s your special little cocktail, Pop.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We can discuss this later, now give me the damn gun! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Did you kill mom, dad? Was she just another mark? Was I just a complication that got in the way? What if I had been in the car, too. Or would that have even mattered?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I will tell you everything you want to know, after we’ve finished this job! Now give me the gun! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fine. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna gives in and hands the gun to </Text>
      <Text RevisionID="1">Michael</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now, do what I told you to do and go call Brian. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna seems like she’s pulling her phone from her pocket but she’s pulling something else out instead. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> picks Whitney up off the floor. He stands her up and puts the gun in her hand. She GRIPS it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, she’s already starting to regain feeling, Mag. You must not have given her enough of the drug. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, is still to weak to resist as </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> turns her around and makes her aim the gun at Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, I didn’t give her all of it because I wanted to save some. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney whimpers as </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> lines Cassandra up in his sites. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>For what? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>It’s the SYRINGE that Joanna has in hand. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>For you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, Joanna STABS </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> in the back with the needle. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The gun FIRES -- but misses Cassandra. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney falls, along with the gun. </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> PULLS the needle from his back. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Joanna grabs the gun, but </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> TURNS and POUNCES on her in a rage. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’re you doing?!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The affects of the drug begin to take hold of him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Being my mother’s reckoning! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The two tussle. Whitney regains more feeling, she crawls to the couch, reaching under. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Jacobs knees buckle, but he still has Joanna in his grasps. The two wrestle and strain over control of the gun. Then -- </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="-1">BLAM</Text>
      <Text>! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>There’s a still BEAT of confusion, because the shot didn’t come from Joanna's gun. -- It came from Whitney, who grabbed Cassandra’s gun from under the couch. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">MICHAEL</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Joanna)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maggie? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>It hit </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> in the back, but as he falls to the ground -- we see that the shot went through him and into Joanna's </Text>
      <Text RevisionID="1">chest</Text>
      <Text>, as well. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JOANNA</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Whitney)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>See, Whit? I told you to trust me? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With that, Joanna falls as well, landing beside her father. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael</Text>
      <Text> reaches for Joanna's hand and she in turn reaches for his. Their fingers touch just as he fades. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, regaining her strength, stands with her gun still aimed at the pair. She goes to </Text>
      <Text RevisionID="1">Michael</Text>
      <Text> and Joanna, nudging them with her foot to make sure they’re dead. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Then, she tears away her ties and moves to untie Cassandra and Terrance. </Text>
    </Paragraph>
    <Paragraph Number="127" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="80" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. whitNEY'S HOME - momENTS LATER</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney helps Terrance and Cassandra out of the home. </Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>Fade to:</Text>
    </Paragraph>
    <Paragraph Number="128" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="80" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="OFFICER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITNEY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. whitNEY'S HOME - later</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Police cars and emergency vehicles have filled the road. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney, Terrance and Cassandra are huddled together, at the back of an ambulance. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The TRUNK of Terrance’s POLICE CRUISER is opened, and his wounded, but alive partner is pulled out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Another P</Text>
      <Text RevisionID="1">A</Text>
      <Text>TROL CAR pulls up, with Brian and </Text>
      <Text RevisionID="1">Eric </Text>
      <Text>inside. The children are let out and they race to their parents. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Whitney embraces her boys and hugs them with all the strength she has. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Michael's</Text>
      <Text> body is wheeled out of the home on a gurney.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Another OFFICER approaches Terrance. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>OFFICER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">Sorry Mrs. Hughes, but your husband didn’t make it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>WhitNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What about the </Text>
      <Text RevisionID="1">Joanna? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">OFFICER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She was rushed to a nearby hospital. Her condition is critical.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">WHITNEY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She needs to be locked up. You’d be surprised what she’s capable of.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text RevisionID="1">OFFICER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text RevisionID="1">She’s contained m’am. Trust me, she isn’t going anywhere. You all have a great night.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">Whitney hugs her son’s even tighter. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text RevisionID="1">CAMERA - Pans up to the sky.</Text>
    </Paragraph>
  </Content>

