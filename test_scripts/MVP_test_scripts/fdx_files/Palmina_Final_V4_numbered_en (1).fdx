    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f4ee1e77-e5be-4346-a538-f8d052ff7fa2">
      <Text>You </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">I'm</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">talking</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">about</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Everything</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">about</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> no one </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0fb93160-1849-4a92-82c8-c0a7616d8419">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f2b919f0-13af-4221-9b84-4d330ceb8329">
      <Text>No one </Text>
      <Text AdornmentStyle="-1">knows</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">calm</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">down</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Where</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1beba35f-841a-4eb9-9115-93d198bc0c41">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e0ab74ab-52f6-43e0-bd2f-af6ef1fb6d6f">
      <Text AdornmentStyle="-1">Outside</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d327ae0a-b85c-45f1-8c57-d5067a3ad6cb">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="dce910df-08ab-4672-b1ee-3f564833055c">
      <Text AdornmentStyle="-1">Why</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">don't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">go</Text>
      <Text> home? </Text>
      <Text AdornmentStyle="-1">It's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">two</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">morning</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="20cd5d65-ab45-441f-b89d-05da6a059335">
      <Text>Short break.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="584b3dca-1fc3-4719-93a3-4121eea1b51f">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c48f28cc-461a-4806-a36b-b671cbc3f9af">
      <Text>Manira, </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">if</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">she</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">knows</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="1b86b8fe-ebf1-4036-9aeb-ef1b510be99c">
      <Text AdornmentStyle="-1">CUT</Text>
      <Text> TO:</Text>
    </Paragraph>
