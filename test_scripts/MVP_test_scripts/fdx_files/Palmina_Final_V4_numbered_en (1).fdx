    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="63" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="38d4311c-7116-4421-b2cc-b0e2f89fb368">
      <SceneProperties Length="2" Page="62" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
