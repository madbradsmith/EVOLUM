      <Text AdornmentStyle="-1">Don't</Text>
      <Text> do </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">little</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Vejo</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">has</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">mutt</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">we'll</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">give</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">him</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">parrot</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">slaughter</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="0938dace-a920-4ba5-afc7-fcf042c9d523">
      <Text>Short break.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="56d3396f-5e18-4b37-9cd8-a2511423d52d">
      <Text>ZLATKO</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e483d4d7-9152-43ca-883b-1772dce4c95c">
      <Text>You </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text> Ante, </Text>
      <Text AdornmentStyle="-1">this</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">man</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">saved</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">my</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">life</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">war</Text>
      <Text>. He </Text>
      <Text AdornmentStyle="-1">carried</Text>
      <Text>  me 8 </Text>
      <Text AdornmentStyle="-1">kilometers</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">camp</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="41184fcb-308d-4964-abd0-16c8391873ad">
      <Text>ANTE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b7a5e6ca-a05f-4915-aa34-4c71d6b73a2e">
      <Text>Andrej </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> human. </Text>
      <Text AdornmentStyle="-1">Shall</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> do a </Text>
      <Text AdornmentStyle="-1">toast</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="c06c898f-2170-4cd9-98cb-550fe78f9f45">
      <Text>ANTE </Text>
      <Text AdornmentStyle="-1">waves</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">his</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">hand</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">shows</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">three</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">fingers</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">waitress</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a73d56f4-8a85-4abd-a30a-4770f4bc0ffa">
      <Text>ZLATKO</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="20cea0b4-3b37-44af-a098-67068d3470c9">
      <Text AdornmentStyle="-1">What</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">toasting</Text>
      <Text> to?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="11f96d98-396e-4a45-8e4e-ad4ec4f49193">
      <Text>Short break.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="fe2f905c-ad44-4fa5-9229-689a3488b95f">
      <Text>ANDREJ</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b8e8168e-ebf6-4e86-9853-28655538fadb">
      <Text>To everything good.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="ec9407f6-cec5-44e7-9a20-9cf4f1864365">
      <Text>The waitress brings 3 shots.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="01c84c08-fc0e-4539-8481-28af5b602477">
      <Text>ANTE, ANDREJ and ZLATKO clink their glasses and drink.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="9573534c-a903-450a-b8ce-27e5702988e9">
      <Text>ANDREJ takes the rolled-up 20 euros and sniffs the line in one go.</Text>
    </Paragraph>
