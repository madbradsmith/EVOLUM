      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">closes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eyes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="3dcf3fdb-6861-42dd-bf8f-00570fe27cc6">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">meditating</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> drone </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">spinning</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">around</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character" id="ef34541b-4db8-4465-bdb6-5e4853ecb9a5">
      <Text>PALMINA (</Text>
      <Text AdornmentStyle="-1">VOICEOVER</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">ECHOES</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">OF</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">WHISPERS</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">OVERLAPPING</Text>
      <Text>):</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="d6f88db6-7c51-41bd-afcd-c6a9a1276393">
      <Text>You are </Text>
      <Text AdornmentStyle="-1">not</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">tree</Text>
      <Text>. You </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">move</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="f97f67e1-ea03-4dda-82ea-bd017859d1d0">
      <Text>I am </Text>
      <Text AdornmentStyle="-1">not</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">tree</Text>
      <Text>. I </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">move</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="cf336d0b-b82b-4c6b-82e4-a73345db7b97">
      <Text>You are </Text>
      <Text AdornmentStyle="-1">not</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">tree</Text>
      <Text>. You </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
