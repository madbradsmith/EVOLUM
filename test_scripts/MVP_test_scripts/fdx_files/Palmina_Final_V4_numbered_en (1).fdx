      <Text>"Why can't you get it up?"</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6b85b6b5-7819-4375-bdcc-9a562e2c2a5d">
