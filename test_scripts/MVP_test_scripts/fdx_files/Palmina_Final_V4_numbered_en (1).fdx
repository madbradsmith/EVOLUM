      <Text> </Text>
      <Text AdornmentStyle="-1">low</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">effort</Text>
      <Text>. I </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">stuff</Text>
      <Text> </Text>
