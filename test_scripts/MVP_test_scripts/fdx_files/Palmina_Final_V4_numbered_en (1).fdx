      <Text>. </Text>
      <Text AdornmentStyle="-1">BALCON</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">NIGHT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="8f4e02a1-fcb5-4f8e-8273-48569a1e3b96">
      <Text>PERE </Text>
      <Text AdornmentStyle="-1">lost</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">thought</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">looking</Text>
      <Text> at </Text>
      <Text AdornmentStyle="-1">someone</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> front </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">building</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="8a414709-cd86-4746-96dc-3b4a6de28832">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="23" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="2ec61563-bc1c-40d9-afa6-d57a6f128a9a">
      <SceneProperties Length="1 2/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ANA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARIJA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PERE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
