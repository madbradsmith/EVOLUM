      <Text AdornmentStyle="-1">Watch</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">out</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">he'll</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">fall</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">out</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="1f80f6e8-c599-4123-9498-e9158fb8d976">
      <Text>They throw him into a pit.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="b0107e01-42fb-4e83-b51f-beb29dcd11c0">
