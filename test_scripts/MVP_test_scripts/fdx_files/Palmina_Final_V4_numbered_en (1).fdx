    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="97d0e7c6-b021-4207-9596-26aca1674c02">
