            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. CAR - DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="e81e951b-744a-4f66-ab64-47b19905d17f">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pushing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">nails</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">into</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">thighs</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">leaving</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">marks</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="0e906019-66fc-4ade-87c3-d01f11def6d6">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Type="Character" id="825e2268-c2eb-481c-a710-acfb4342ff1c">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue" id="48ca124c-727b-460b-a6b1-6a33010dd4bb">
      <Text>Do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">neighbor</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">who</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">used</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">man</Text>
      <Text>, but </Text>
      <Text AdornmentStyle="-1">now</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">woman</Text>
      <Text>? Luka, Luce </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">now</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">his</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">name</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">It's</Text>
      <Text> terrible </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">people</Text>
      <Text> do to </Text>
      <Text AdornmentStyle="-1">themselves</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">these</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">days</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Where</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">this</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">world</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">going</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1690c74b-f29a-4e4b-ba21-687eae557349">
      <Text>PALMINA (</Text>
      <Text AdornmentStyle="-1">UNINTERESTED</Text>
      <Text>)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="15484522-119a-4bfe-9566-50486ab65c8f">
      <Text AdornmentStyle="-1">Yeah</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="dca61260-e2af-4e5c-afbc-44189923769a">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1482ff36-b5cc-48c4-8801-301eb383c057">
      <Text>Do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">faggots</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">go</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">hell</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">And</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lesbians</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">too</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="879e394c-660a-43a3-b9b8-818edd64b593">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="445d1e76-d809-4460-925d-da7db5046026">
      <Text>I </Text>
      <Text AdornmentStyle="-1">thought</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">they</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">go</Text>
      <Text> to San Francisco.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="cb116fca-c9fe-46ad-8325-956a0b1fe341">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="0ba49fbe-6624-4f0b-95c1-4497168ad9d5">
      <Text>My God. </Text>
      <Text AdornmentStyle="-1">I've</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">read</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">all</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> gay </Text>
      <Text AdornmentStyle="-1">stuff</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">your</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">diary</Text>
      <Text>-</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0d405537-1620-419a-afae-2a19bf4b7245">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c004612a-09b6-404e-8402-ea773d2e0409">
      <Text AdornmentStyle="-1">What</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">What</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">doing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">reading</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text>?! </Text>
      <Text AdornmentStyle="-1">That's</Text>
      <Text> mine!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a84b00f6-2a13-45f7-a23c-30227ffbbac8">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a77e14ab-59ae-4896-bbbd-1e1fbf75c33e">
      <Text>That's all because of the drugs.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="64c83dd4-9ae6-4ab0-9996-2f6a31733925">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="73afaf96-05ba-47f1-9e4f-3a48baea2599">
      <Text>I don't do drugs. Drugs dry out your face, make you look older. And what do you think that tranquilizers are much better? They slow you down, make you stupid.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7613164e-43f3-4bdc-ba4f-667ae7df31cd">
      <Text>DIANA (SARCASTICALLY)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c61600e9-1bd1-4dfd-8654-2e04288774bd">
      <Text>Yeah, everything is exactly the way you say it is.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="87e32ad7-290b-4697-b1e4-8d117da50935">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a4c2e6ed-39bf-4848-9fab-342e9a487be5">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1714243d-e21f-496d-ad08-21ff429ecaff">
      <Text>The worst things in life are when you know what you want, and when you don't know what you want. But it's worse when you don't know.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="fc48e9fc-55be-40f5-99fc-1fbefc6dd86b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5b220031-d8d5-45b9-8a30-42885f78990c">
      <Text>I'm young.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="23250c3a-f49a-432a-ba6a-a7aad6cf862d">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="af273c71-395e-4e11-a3e5-d6350356eaae">
      <Text>And what do you invest your time in?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2f9b7cf2-891f-43d2-88e2-622cd3372b39">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="ca5a3f24-4cd5-4555-9553-48d2004511a1">
      <Text>I invest in myself.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a5c1bf37-8c84-486c-b0a3-44e94f4e2f37">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="29551ad6-8fce-49bb-bf0c-3a7e1877e9d6">
      <Text>Ahh you. You buzz a lot, but you give little honey. It's best to find a guy who has a lot of money when you're so incompetent and fucked up. Some good guy who will put up with you being evil. When I was a model, I hung out with Claudia Schiffer. I did Vogue in Milan, I only dated millionaires. Every time we went out, the guy would be in a suit and tie, and I had a great time. I traveled; Dubai, Paris, Cancun, Maldives, Bali, and what about you? You get up at noon, hang out with lesbians, go out with poor people. Nothing but horror. Horrible. You are who you are with. I was a star at your age.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6e89ef9a-3116-49bb-87ec-da403625dfa9">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="258e9a61-5e98-43b2-8326-f96b47a9b668">
      <Text>Yes, you were this famous.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="b874d922-d01c-4379-a5da-52f368731ab4">
      <Text>PALMINA snaps her fingers like you do when you try to remember something you forzlatkot.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="322751a6-1722-46b0-b792-f549919c9719">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="741541ef-de3c-4abc-86bc-1177c39312d7">
      <Text>Oh my, what's her name? She speaks bad English. What was she called? Tsk.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="17e6d81f-8a80-489f-bc8a-7545719ea173">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d4401755-e916-46b3-9767-46f0693e10a3">
      <Text>I don't give a fuck who knows my name. I told you nicely, I had fun. You're wasting your time.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="4491b375-9b69-4ab9-8dc1-39909e8a04c4">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="106fccc3-b2a0-4e30-ae6b-eca356f3ea37">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e8835dd0-d985-4135-9251-b1e7b1703eb0">
      <Text>And where is that guy from?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7b12062b-4471-4622-9d1a-5a2db0085ed9">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="44c4e266-2b14-4ee7-b993-1748d577514d">
      <Text>He's Hungarian.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c5caef12-103e-4b99-a964-9291f7667770">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5e49b22d-ac51-4011-b530-df1ba147f40b">
      <Text>Don't you know everyone who has attacked us?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0a9cf8db-6232-4dd4-9e32-ed3bfd75590c">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a58dab49-60c7-4b9e-84ea-77e52244bec7">
      <Text>You also didn't like the local guy.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="29678cc6-38c0-4f60-807e-ffa19afe6b6c">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4a0eedaa-30ce-4c6e-be77-aa5eaf05dc08">
      <Text>Yes. From Ljubuški. And do you know why they canceled the bus from Ljubuški?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c2b78987-0e99-41d9-a379-75ab64bedda2">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="21feb832-cb95-4e03-bac0-4093618773ef">
      <Text>Why?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d98380af-1778-4746-a5c8-7c413b0dd8f9">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="53843908-075e-44ca-b24f-ce276b902d3e">
      <Text>Because they would leave diapers full of shit on the beach, the whole city would smell like piss, bags on the floor, garbage. When I would return home, my hair would smell like polony.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eb270b63-632e-47aa-9b2c-89973bba15ad">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c795638d-8ee0-40c2-8887-acc9341c5c83">
      <Text>Not all of them are like that. You just like to generalize.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c669847d-c147-42e4-8b7a-4829e29386d4">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b0867ff3-cde6-48af-a165-478948d4871b">
      <Text>So when was the last time you saw each other? You and the Hungarian.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8d12bdaa-c848-4779-a86b-75209678057d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6f3c3d74-c291-40a2-bd32-6a3fd78c92d7">
      <Text>I saw him at a concert, he kissed my hand. And then I saw him on a bike, and he gave me a fist bump.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="5b9ec4b0-a91b-4332-88d8-a57a085b9cfa">
      <Text>Short pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2aa5356a-87b9-4f7d-9e15-3c3f77238824">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d056af49-4df0-4310-bc75-0a80c0ff9afa">
      <Text>And? Is he suffering? Can you see in his eyes that he's suffering?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6a5a7510-c25d-4900-abf7-d9fcc4da6e9d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="963f35db-4475-4393-98bc-9b66d0e826ea">
      <Text>It doesn't matter. We aren't seeing each other anymore.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1430f55d-9679-4fd9-80a7-7867dd635a20">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3019e402-7f95-4a94-baea-06e177fe14ca">
      <Text>Why?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="001365f9-a49a-4b80-859e-626007d0523b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9f679835-dd8c-489a-97f0-57d606317454">
      <Text>That's it.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="36c18ebe-10eb-4132-8639-c3d4b10bcc05">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="aa261f32-be97-46a9-9c49-84d66eb606c8">
      <Text>That's it? That's it when you have a losers mentality.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="7ab02c69-6a1a-42e1-ae55-edc9c0ce9ef7">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="244809eb-ee7d-4ead-b5e1-427a77f9bfbf">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e2add2dd-7849-492d-a8f5-dcfbe9ebf2bf">
      <Text>And what now?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8f37fe15-6988-4254-854f-cc7cd02f86b7">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="628dbe81-3ad8-4962-ae8f-f694fd80350e">
      <Text>I don't know.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e8e0beaf-084e-437e-805b-ef2b65d6d2b2">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="40168224-b920-4894-8a19-e1a0b88ef1e6">
      <Text>You, it seems to me, are looking for depth in the shallows.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="53d5e71c-6039-48a6-a661-2a0cad0bd736">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c1e02348-012c-4bab-919c-40672aab6330">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b4a785d4-a3f3-42ef-a5bc-4b6b86671870">
      <Text>Look for the ones who live abroad.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a26276db-066b-4a9b-b8a7-82d9a2f96ab5">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6f9ad1b8-376e-43c0-b905-e8ba67576aeb">
      <Text>But mom, I don't live abroad.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5e7d2082-2cc5-4913-b188-c856733c6969">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5f83d105-5b0e-4e83-b2bb-8462e8478913">
      <Text>It doesn't matter, you will.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="3055126a-6f9d-4e61-97da-d3a14ad255e1">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2d386ca4-0562-4caa-9877-cc22b43916c2">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a550f5cf-683c-4c05-9aa6-d2ac07335373">
      <Text>French?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="975c14cd-116c-4a9e-9540-a9ec60015dbc">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4e022a3c-6cd9-4ee1-bc11-30c45ca54919">
      <Text>Don't bring me those faggots..</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="71110d66-c162-4ac9-869c-216af307031e">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e71776f6-ce78-4102-9a12-7b53ab90d822">
      <Text>Argentinian?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="0b4f2d5b-a67d-463f-a625-41eb8a766c3b">
      <Text>ROMILDA crosses herself.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="9643df4a-b47f-4b0f-8a34-12a16a59e865">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9289ee36-f4e3-4d99-a43d-b1d80822e301">
      <Text>Okay then, I'll marry a criminal. Just like you.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="705843c7-7351-4498-87f8-a57d7871a6ac">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9bd2a771-912c-4fe0-9dc9-aa83d53ca453">
      <Text>Aa, shut up.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="aa7ccd27-9edc-4e6c-96d8-8e0531b58cd2">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c5b617ae-8798-4247-8058-5d1b51dfa81e">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="27bb106c-4902-40e4-894e-a3674e8b4c3f">
      <Text>You could act a little stupid sometimes, no one goes for an impregnable fortress.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="cc113524-a92d-4533-bab5-dc99e9ecf46b">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a456c99c-f6f5-4b39-8a58-c7f2d92e186c">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3070a33c-2494-48c4-9d84-e92c7de1ad58">
      <Text>How was the funeral?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5a9b7c52-2750-4d4d-824a-8b329b3978a9">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="db668998-e00c-4058-a408-23b7f360f579">
      <Text>The funeral was really great. There were a lot of people, but they didn't cry, she had been sick for a long time, especially in the head. I was wearing that navy blue dress with lace. And I saw Anita, she told me that Manira will come.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="93527b0b-7f67-445a-be0f-6c8ba4c1ffa9">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7590434f-b8be-4e8b-ab34-aa6289b14622">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e07ec1db-0923-4be3-abde-0c9f7939142f">
      <Text>Yeah, we talked.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="740fc8af-a675-4980-9ece-6b20f4f9e289">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6303045f-c3b5-4650-a428-a61cd46b4746">
      <Text>Well, nice. Old friends.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1777ac40-04d5-4066-8e5e-a5ab6f3733b6">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5e25dd0d-e9bc-4e27-b117-da34cbdcde2a">
      <Text>We're going to go somewhere.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0a8f9645-977e-4763-8a2d-0a392e86512d">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5ed199ee-9302-45ee-af48-ffc26aa803ca">
      <Text>Where?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5de65dfa-5d9e-4a26-8078-dca7aa94c6a2">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="61165eba-4074-4755-b47d-171e5d1b3c9f">
      <Text>We'll take a trip.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="55462fe9-1e0b-4197-851d-a2ab6837d05e">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="72f751fb-6410-4251-acda-3e6453984f79">
      <Text>What kind of trip? Where will you go?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="60c73292-bde9-477c-806a-47b5b8379f8a">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fce5a959-2c53-492b-a844-4e9534a369cd">
      <Text>I don't know, a few days somewhere.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="178c71c6-f0d9-4c8c-811a-bde8ac2480d0">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3d1f9852-ffa0-40be-a307-7005fea6d02e">
      <Text>Where will you sleep?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="da0d28cc-966c-463a-9a99-cdf3d061a1cb">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e183981b-c21e-44af-b91e-e41dbb569c22">
      <Text>In the car.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f20fe4ab-3d97-4ddf-b5df-ec2f8343a425">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="bbdca54a-157a-4020-8537-cdcd6d2dec17">
      <Text>You won't take my car. You can take the old one.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6a297cd7-38ea-47f0-8da1-5e0a02b9d497">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="49a57fef-8366-461a-9eb7-7c4a73e499e9">
      <Text>Fine.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="537bee0d-c6ab-434a-ac20-5471e621d01c">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="93d076a2-033f-41fe-bdc3-8eb306c6d2b1">
      <Text>If I remember well, something is leaking, I don't know if it's oil or water, so check that. If it's missing, add more.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="65af5a74-6979-4b2b-bde3-47ea8c8c7639">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9b5da72b-48ba-4ddd-8994-0a3b481dc319">
      <Text>I will.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d1918e51-4b8f-4631-a8f5-732381ed0bf5">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d10054bc-2137-4304-b092-91f0d9b0e67b">
      <Text>And when will she come?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="829711a3-c3bc-4e96-aec6-b25e47ec12dd">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="0123f270-62ce-4350-848f-f5766f586399">
      <Text>Sunday.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="b7898f4c-47e8-4909-837c-166c201a173e">
      <Text>Short pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1204e595-95d7-4a96-98d5-1677622da5c5">
      <Text>DIANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="aac44582-9b76-4455-8b83-17ca7ec24689">
      <Text>And her mother pretends to be someone. Every time I pass her porch, she's reading the Bible, but always on the same page.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="945eb31a-7b4e-4303-b72e-c24044131741">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="6" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="c6379330-3aa2-4090-9e4d-efc54c48fb79">
      <SceneProperties Length="4/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EVERYONE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. CHURCH - MORNING</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="414f47dc-372b-4fe8-be7c-9f0e7fdbf0f6">
      <Text>ROMILDA, MANIRA and PALMINA are standing up at Sunday mass.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="eca60473-4b8a-4f7c-a6c6-2efdd83c31d3">
      <Text>Everyone is praying "Our Father" out loud.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5a0e87e2-4d84-42ff-862d-12c1d6822297">
      <Text>PALMINA (TO MANIRA)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a3288927-b70a-4e0a-b403-5e3c3aea110b">
      <Text>I need to take a shit.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="5b967bf8-88a7-4b96-95ff-1261a61db9b3">
      <Text>A short pause before everyone says Amen.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a364b8ba-90d6-4dcb-8ce0-9cf2f2862b51">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="718c9e38-7216-4ed2-9cac-0cd6723a472f">
      <Text>Fuck, I shit myself.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="abc75441-b2cf-4d4d-99e9-3901c440d8bd">
      <Text>EVERYONE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="0f58ac70-77cb-4d72-b514-51fe28aad62c">
      <Text>Amen.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="713befbb-e5d3-484e-8efd-e9a053535017">
      <Text>"PALMINA" on screen.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="70efd030-1f4e-4d2c-90ab-2c608e8e8024">
      <Text>PALMINA and MANIRA laugh.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="95245ac0-a8ba-43fd-96c1-80ffc30c0d19">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="7" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="51e2c6cb-b73d-4e6a-8cf5-32adce922545">
      <SceneProperties Length="1 1/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. CONFESSIONARY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="fc4dfe8c-b198-4323-80cb-4c548b3abe75">
      <Text>PALMINA is confessing, while MANIRA pretends to be the priest.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f363b062-7082-4ae5-a28f-e52a875aba02">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="09dad06b-2197-4888-8a70-af8c3eaee46e">
      <Text>What are your sins, young lady?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c33cadc7-b8e7-46e6-8daa-98f6d4e68372">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e5f8d47a-3004-4bb9-9dec-7742a9f24fe9">
      <Text>I have as many as you want. I'm full of hate. Can I smoke in here?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0856a5b1-85dc-4a11-b7d2-6efb8ad43aae">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="84c8a96d-6a77-4081-ac66-674f0e6f3488">
      <Text>Of course not.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f454c8bd-9bc9-4a39-9fb8-a065d1c3784b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="44e8f41a-76e2-4bc3-be05-cbf03ee2dc2b">
      <Text>Tsk.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2af5cea1-e79c-4017-8b16-63e45ade7c65">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e8c1bed5-ad32-4ab2-bc4e-841e19574981">
      <Text>Hate? You need to get rid of that. And what exactly do you hate?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0725ff70-4f92-4a61-9f72-2c15fd2ffb2f">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c919bbf7-c538-4a3e-a4c6-fb197f5c88ae">
      <Text>The system. I'm a punk.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6e390ca9-d156-43c4-b120-8b513db209e3">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5fe37250-1bbd-4e44-887d-10b329af8ddb">
      <Text>What does that mean, young lady?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ef2c34c0-338e-4396-8d8c-1ad2bd40a7e5">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d7370c75-5e0a-4581-9b49-1935cfdc45dc">
      <Text>It means I'm on this side for a reason, and I don't want to nor will be on the other side.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="fcc9d437-a34e-4d73-beb2-357be62684b2">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fc40a1f3-aef5-406a-9c58-01b47df75b34">
      <Text>Are you insulting my side, girl?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="724dbb8f-9c08-44a0-a386-0398ae1290a9">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="cef7f0a7-c890-4d67-b7a8-1c0762c5dde8">
      <Text>What else.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="daf53435-8f3f-4ca1-b109-cadc41c95234">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="42505ffb-e504-407b-8103-73bd1020d24a">
      <Text>How can you do that? You need to be a good young lady, or Jesus won't love you.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="08c9dd52-6626-405f-8fe9-73004a26fc11">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fe91dbb7-d577-4ed5-9b7e-cc68ec826ac5">
      <Text>I already see he is not that into me. I look bad in the winter. I look bad without makeup.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="aacf6f0b-a6b7-4396-9649-d89a074b8d11">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4bdf374b-0899-4eb0-bdd1-b78488183a39">
      <Text>Poor nutrition, a lot of work and walking, the Sun, and illness affected everyone's appearance, including Jesus Christ.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="5513243c-add1-49e2-ad8f-ee13268891ef">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="8" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="068014bc-254a-4d3d-b376-fac4315ed09d">
      <SceneProperties Length="2 6/8" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. STAIRS IN FRONT OF THE CHURCH - MORNING</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="90d60bf0-a11b-45f0-aef0-1778199f5df9">
      <Text>PALMINA AND MANIRA are sitting on the steps in front of the church and talking.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e18a3d5c-b7a9-4bf3-9dff-35b1188c4832">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c49f2ece-3653-41f6-8e25-dcc7d3fdc498">
      <Text>I'm not Catholic anymore.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="53082eba-65d1-4eab-a7d3-7bb34fafae92">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c879c85d-09b5-46a5-9a3b-6ac24fd45f06">
      <Text>Oh yeah? And what are you now?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c83162c5-4f26-46ec-9b0b-29c9d31e24d7">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="bd80d5c4-0059-48de-9ad9-b0211b896365">
      <Text>Nothing.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="a780e37b-2bf1-4c01-b54d-af01abe6dd89">
      <Text>MANIRA lights a cigarette and gives another one to PALMINA.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="57525c77-233c-4076-a809-468b9959fe36">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="ce49bcc8-dde5-424b-9ec9-8c401675ec49">
      <Text>Well, no one here is Catholic by religion. Only by nationality.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8ad004e0-7f35-41c8-99f5-c39455e8da9e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="80df9fd2-67bf-466d-9e0e-0c414efea104">
      <Text>What do you think, do they believe in God?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d6deff4b-b9d6-4c82-8c17-94e8403e2745">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="800c1e50-4377-4934-a1ae-feba0d486782">
      <Text>And what do you think, do they believe in evolution?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="54599349-6e06-4718-af6d-0be0037e3a9a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="15a96127-e62c-4aed-9ff6-bc58814d6dc4">
      <Text>People here don't think about that stuff.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="72c48aff-934b-40fd-924a-3e9745e507a4">
      <Text>PALMINA and MANIRA are looking at each other, then looking around.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="18ced6c1-1e0e-4ac8-b9d7-6c80b93584e5">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6a48b37e-5047-4e16-835c-695a751e0f2c">
      <Text>My mom told me that Antea gave birth.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="138672aa-7090-4814-a871-72d86f26319c">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7cd616ba-654a-4b2c-8ffc-451691652fe5">
      <Text>I know. With 19.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ba057cdb-4d1f-4602-9dbb-fa63e9b799ed">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3fed9f5f-41e3-41be-9c0f-8a1d649b4071">
      <Text>Crazy.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ab7f1bad-3f07-4177-a799-6bc8f556e2ef">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="85121c04-c16c-4658-829f-6e6ad1a026ef">
      <Text>His name is Viktor.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c04f2a0b-7fd2-4405-97d4-7ded5f2aec77">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5c5d907c-efe4-4727-b0b2-013c4222d914">
      <Text>The boyfriend or the kid?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="79b4f1b6-e436-4000-8828-c2f9404a15bd">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c71731fd-76ff-42cf-8b3d-7a728c5c0355">
      <Text>The kid.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="507217e8-e687-4539-8407-317981fe0b3f">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7272e541-f1b0-40f1-bc4c-bf637b742ee2">
      <Text>Terrible. And who's the guy?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7273241d-ba97-48a5-8206-746b9226ca21">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="8a3d455f-d9a7-4932-bdd3-78ad51ef3007">
      <Text>You know him, he's a year older than us. The one who is all in the same color.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b421167e-d7e9-4b6f-908b-0d3f2d87675e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="617df851-46b4-4834-b26b-6f1be3e3e3db">
      <Text>Ohh, the one that's all light brown.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f9ee84d8-563d-4f3a-8dca-c48acc911ee2">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="30d53f04-acde-481a-a9e5-bcdaf6350a63">
      <Text>Yes, who said he would see where football takes him.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c3bca6c1-5e51-4c52-b772-5cf6240c5c4d">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="08e9e626-053f-4fb3-8b0b-96671741afd2">
      <Text>Brother, if he hasn't taken you by now.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5cf52e78-f539-43ef-957e-bf0222328086">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="61c27427-0b98-4ffa-8916-f76a80ec610f">
      <Text>Then I don't really know.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e01d014f-e85b-4f61-abb9-67174f7e3db9">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d316e7a0-78d8-4e08-8172-8e2d9ca5a014">
      <Text>Well, what did you and I do? At least they made a baby.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="9c8cbaa4-a26d-48cc-98fa-cab52751ac0b">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="76f63e56-cf52-45d6-b917-f4e618afaefa">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="55bb4849-0248-48dd-9024-48d114d90862">
      <Text>What would you do?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6ab2d386-bfb6-471a-a0b7-0729d84af004">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="860f6663-3aa8-4837-8dc3-580dd1ea940c">
      <Text>Divorce rich. And you?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7a83526d-3307-4e29-9773-eb46d4d90094">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4f32d3c4-400f-4e03-94b2-a57cecf3037e">
      <Text>I'm going to Bolivia. I've dreamed of going there ever since I was little.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="226dc8c4-d9f9-4787-aa62-147df3e3c16a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="64ef52e9-b8d6-471f-9169-846638515210">
      <Text>And what are you going to do there?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c20dd932-3d81-4389-aefe-201f732c20b4">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e2235ad5-f962-4f1b-8e02-ab4069d1412c">
      <Text>I'll train vultures, or I'll be a waitress.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0e2d8b7a-0a31-4de3-b85f-0b7effdf38b5">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c74fe694-eb2b-4743-baf1-9be470f16314">
      <Text>Oh yeah?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="0d28d7a5-b96b-448a-8cde-7470233a93e5">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6116942a-c6d4-41fe-b950-c94310d4930c">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="475d6f4f-6e0a-4c61-8a98-1a77ed08c2d3">
      <Text>Eee Tomo cheated on his girlfriend.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c390a68f-5c49-40a9-ae85-51d96a365f81">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="8584aa05-12e4-4153-b54b-e10c9a1a24dd">
      <Text>Tomo?!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ffe6705a-63cb-4100-8486-b9b0e3a1638e">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="823c1cf2-441d-45e3-8948-769a1a02ad2d">
      <Text>With her best friend.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f1a26ed6-a1f8-467b-b9de-299ca5831e51">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9959fb05-963a-4c80-9f75-1134d8aee0f6">
      <Text>Pfff. What kind of friends are those?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6efd9d05-08fa-494d-b38c-d117a7885bce">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f37b8d89-6519-4968-88b6-93812f89c32f">
      <Text>They have no sense of community.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="bd5b788e-6705-4980-9cab-38f0befe0370">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="89f6b8d6-63a4-4701-91c5-7c8e2809e27b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e282d01d-bb22-461a-85c4-6d9f16def421">
      <Text>Do you know Luce?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a95cf225-c1b1-4680-acb0-e2a47202ad0a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d3219457-92f0-423f-92c4-afe7343586e1">
      <Text>Rivas?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eb860293-95ed-422d-8bc7-59a5b2a12d4d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="07a45241-c383-46c5-905f-5fe2513edf75">
      <Text>Yeah. I went out with her a couple of times.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eb78d315-afaa-44db-8e6b-e5a0b950eba6">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="758d6933-fd10-4987-94b7-24337ca1476d">
      <Text>And? What's she like?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="889d1da0-6d37-40bb-84aa-339a9c7a66f9">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="995be09a-9de7-4280-9c19-2138d3af4017">
      <Text>She works as a prostitute.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2a59651e-48cc-4782-8c3f-b84809af2820">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="8d49239b-4fc9-4209-8b99-cd191ef4ed03">
      <Text>So what? At least she's working, you're unemployed.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="ef32c181-b27a-48c2-a88b-ca1c211681d9">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="9" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="764c1480-cf6e-42e4-a54a-cb2341994f8f">
      <SceneProperties Length="1 1/8" Page="11" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. CAR - AFTERNOON</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="abe40a4b-218a-4d4e-b965-db2c5024db62">
      <Text>MANIRA is driving. PALMINA is sitting in the passenger seat.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="af87ac97-cb26-42a0-a14c-b5ac92380f68">
      <Text>MANIRA changes the radio channel to the next one every two seconds. After 10 changes, she turns off the radio.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="6a33d67a-28ee-4b44-a4c0-581afc5b0116">
      <Text>30 seconds of driving in silence.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ca69c52b-0e9c-4827-80ed-c5fb7e865d1d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d0b397d8-34b5-4052-8204-d002607d1e5b">
      <Text>Aah.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="43668ab2-0fd9-4bb7-bfd7-2cd0139f6b7e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d6a0d54a-9990-4936-a108-22703956924a">
      <Text>What?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0b03c72e-f756-4f67-aad1-656bb345628e">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c7c1c3c3-1084-4ae4-80b5-f7cfdfb4ff01">
      <Text>I forgot to change my tampon. It's been half a day and I haven't changed it. Stop here.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b87ee352-936c-4fcc-a4ee-e606f8a98ae0">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f71d93a8-6a61-4880-a085-54a169594d4d">
      <Text>I don't have where. When there is a road widening.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="af5c27e1-f943-4326-82c9-e4626a3013a2">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5394f9ce-9158-49e5-8312-562e2aefcc93">
      <Text>I can get poisoning from that stale blood.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3e02ed24-887e-4f8c-b881-63441c170429">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="016c8c45-e92d-4f7e-94c3-46be4ebbde0a">
      <Text>Just a bit until we find a place to stop. Nothing's gonna happen.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eca872ff-c17f-48a1-99f6-d1124c09b2c6">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e06cb6fc-741c-447e-8aa5-23442d3f760b">
      <Text>Well, we don't know that. Stop here, you can turn on all fours and that's it-</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="23ff96dd-9082-4aee-8ed6-0595e3804d6b">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b89ac9b3-d913-4b4d-9583-4f683bf15b9b">
      <Text>-I can't stop here, someone will hit us from the back.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="ba25316e-a63b-485d-b4bb-ba3662f08893">
      <Text>PALMINA puts her right hand in her panties and takes out a bloody tampon. She throws it out the window.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="1bc251f3-fde4-474f-aa86-17bb27fc0228">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f7703be3-50eb-485b-91d1-50693cd369cd">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="addf1715-35ab-4f58-9604-fbb20b40d68c">
      <Text>And where are we going?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c1ca967f-ee00-4292-a01d-5566c7b05d00">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9a5c00f4-6987-4db5-a885-52d95525bc88">
      <Text>I don't know.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="7c364c9a-614f-4d28-aad8-a2b3ed572b95">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="10" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="740760be-dca6-42cf-9019-bb2dbcf80946">
      <SceneProperties Length="2/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. GAS STATION - AFTERNOON</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="564b0dd5-5963-4536-8be5-8a9ebdc4f0e9">
      <Text>CLAUDIA and CARRIE, two foreigners, park an expensive car</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="0922ba5f-cb79-47a8-8c57-c18d82f1cd73">
      <Text>right next to PALMINA's car, they get out of the car and walk into the store.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="11" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="f09c1414-c7f5-49b1-ba84-72bfc413be31">
      <SceneProperties Length="2/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. GAS </Text>
      <Text AdornmentStyle="-1">STATION</Text>
      <Text> STORE - </Text>
      <Text AdornmentStyle="-1">AFTERNOON</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="6ab85493-19c4-494b-98db-e76f12f76c4c">
      <Text>CLAUDIA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> CARRIE are </Text>
      <Text AdornmentStyle="-1">talking</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">loudly</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">standing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">directly</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">across</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">from</Text>
      <Text> PALMINA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MANIRA </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> same </Text>
      <Text AdornmentStyle="-1">section</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">store</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="52fc1bae-0f57-4088-9e78-2527e48421c0">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MANIRA roll </Text>
      <Text AdornmentStyle="-1">their</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eyes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="3e149beb-c769-475d-9746-2c9d3d25de7f">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="12" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="a19dc374-739f-467e-ac79-ca47952e0968">
      <SceneProperties Length="1" Page="12" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="VAL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">EXT</Text>
      <Text>. GAS </Text>
      <Text AdornmentStyle="-1">STATION</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">AFTERNOON</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="1955e7be-5320-4520-ba38-23e1fca3e94e">
      <Text>VAL smoking a </Text>
      <Text AdornmentStyle="-1">cigarettes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">standing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text>, PALMINA 2 </Text>
      <Text AdornmentStyle="-1">meters</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">apart</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">chewing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">gum</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="29cd45c3-758c-43fc-94d3-e3dc92e3698f">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">throws</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lighter</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">floor</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">while</Text>
      <Text> VAL </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">not</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">looking</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="72fb77a3-cb6a-4348-b247-b736132b43bd">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="16d6fbc5-37db-4d1a-a823-336a32f2ccc7">
      <Text AdornmentStyle="-1">Hey</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">dropped</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="73eadd04-a8e4-40d0-88a6-cad15d58145b">
      <Text>VAL</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="09eaf03a-6a07-4d2f-8d27-f5e92dcdda68">
      <Text>Oh, </Text>
      <Text AdornmentStyle="-1">thank</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="f340cecd-6375-4387-9ea7-85a6f7ae8a74">
      <Text>VAL </Text>
      <Text AdornmentStyle="-1">bends</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">down</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">picks</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lighter</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">puts</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">his</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">pocket</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="4e6651c7-2ce7-4d0f-b67f-8d08e5aeb68c">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">rolls</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eyes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2fdbab63-07a4-42ba-8326-8defd71ee208">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="520e9252-e967-44d8-87ba-5e21aadeb36d">
      <Text AdornmentStyle="-1">Gentlemen</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">right</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c36a3c41-2151-4920-a16a-27f22b7f7f35">
      <Text>VAL</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="376bd60e-3bf4-4a18-b7b0-543ff9698356">
      <Text>Aah. Do you want it?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="92e68c37-9eb7-4e26-9524-51b2061b6845">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7737c0fe-e2c2-49a2-9176-892bca8111b9">
      <Text>No.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b6f9e321-2480-4c44-b80f-b665b8fb1ad1">
      <Text>VAL</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="45050b52-0cac-4c07-b058-1db3331bb17f">
      <Text>Here.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="27af61ff-81c4-4803-bb7e-76bd76d11f87">
      <Text>VAL gives the lighter to PALMAINA.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="4e78c80b-d37e-4596-8910-3649d7d5f087">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b5f5ba32-c035-4cbe-a3a7-9d130d350902">
      <Text>Thanks.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="11291b36-31f2-4608-92eb-d4a25da7f51e">
      <Text>PALMA </Text>
      <Text AdornmentStyle="-1">drops</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lighter</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="cf1caa8f-954e-4248-b9f3-7a16af70cf66">
      <Text>VAL </Text>
      <Text AdornmentStyle="-1">enthusiastically</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bends</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">down</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">picks</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lighter</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">passes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> to PALMINA.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5272cf5e-d7c7-4f68-bdf4-657c96ade545">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c62fb555-2de6-47bc-8908-6a0255b89982">
      <Text AdornmentStyle="-1">Your</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">ass</Text>
