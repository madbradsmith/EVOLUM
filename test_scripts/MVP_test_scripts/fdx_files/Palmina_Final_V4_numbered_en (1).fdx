    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="b222bbe1-6937-443c-bbb3-4f3023d632a8">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">sits</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">passenger</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">seat</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">rolls</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">cigarette</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">lights</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">picks</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">bloody</Text>
      <Text> tampon </Text>
      <Text AdornmentStyle="-1">from</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">floor</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> car </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">throws</Text>
      <Text> </Text>
