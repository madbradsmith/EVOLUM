      <Text AdornmentStyle="-1">Where</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">going</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">throw</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">him</Text>
