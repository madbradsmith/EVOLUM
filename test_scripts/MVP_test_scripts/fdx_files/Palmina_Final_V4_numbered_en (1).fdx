      <Text AdornmentStyle="-1">guitar</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">heard</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">playing</Text>
