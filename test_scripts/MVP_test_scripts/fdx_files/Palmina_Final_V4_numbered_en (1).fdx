      <Text AdornmentStyle="-1">lighter</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> a 10 kuna </Text>
      <Text AdornmentStyle="-1">bill</Text>
      <Text>.</Text>
