      <Text AdornmentStyle="-1">VUJO</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">clean</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">blood</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">around</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">apartment</Text>
      <Text> for 2 </Text>
      <Text AdornmentStyle="-1">minutes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
