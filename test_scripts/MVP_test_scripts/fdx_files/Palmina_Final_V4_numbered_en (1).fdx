      <Text AdornmentStyle="-1">euros</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">from</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stepping</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">bread</Text>
      <Text>.</Text>
    </Paragraph>
