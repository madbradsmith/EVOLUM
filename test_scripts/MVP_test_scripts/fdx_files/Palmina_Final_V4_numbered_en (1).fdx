          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. CAR - DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="1b69450b-f349-4865-986a-f449ec40b95c">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">driving</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="d69304dc-237d-4ce3-92bc-1a475377dfd0">
      <Text>DUJE </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">hitchhiking</Text>
      <Text> at a bus stop </Text>
      <Text AdornmentStyle="-1">by</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">roadside</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="5a5f1562-ae3f-4af8-b48a-60dc37f2bfea">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">sees</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">him</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stops</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1ac38a8b-202d-4be8-880d-54e678c9e927">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e9f18303-41b4-4b60-bc47-5446797aaaf4">
      <Text AdornmentStyle="-1">Hey</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">where</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">going</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ecddb7f5-20ca-49d5-94f9-59cec30d1305">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="beeb30ca-2e11-4677-b0cf-9a58a06c4edf">
      <Text>To </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> bus </Text>
      <Text AdornmentStyle="-1">station</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0eca6171-5672-40f2-8edb-f87814a1676d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fe513107-acd0-41c8-9083-5e30039cd5c0">
      <Text AdornmentStyle="-1">Jump</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a609453d-4cd2-4764-bb66-3522338e623d">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a5c4ee36-006a-4b5c-9e3b-6a033e63c20b">
      <Text AdornmentStyle="-1">What's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">your</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">name</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="14886682-386f-45ae-9772-fb1e8582b5bd">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c53fe720-45da-4cf4-9dbb-544dd4ada75d">
      <Text>Dujan.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5e3de242-998e-491d-82d5-458b76e1c06f">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="576ab032-e061-4f2f-875d-2041ef12f259">
      <Text>What a name.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e020c60e-ce9a-41b0-856f-906ea4d4229b">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1cffed1c-c35a-42d2-88cc-8f2eb78aeb73">
      <Text>Yeah, really. I'm Manira.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="447a34b9-af40-4faa-ba73-5fa1a96ae8e3">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="562f11b3-bb51-49c8-8e53-cbff1cf74c43">
      <Text>I'm Palmina.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7a0c8e39-686e-4337-af71-c1b244858e3f">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="67da7439-96e4-4afe-86ce-2f1363115ac9">
      <Text>And you two are saying what a name huh?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="50d945ba-3110-42ad-ba89-6a51381507d4">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c045deca-ef73-494e-b71a-d14f15fadd98">
      <Text>You're right.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2dd0936d-6201-4e6a-8589-a07180d3de91">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7dba8f63-380a-4be8-8a05-0d23b822046d">
      <Text>And where will you go?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="df5335e8-f506-408b-b176-a6828e7acc18">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="42c52009-2e5a-46cf-90dc-be3857ba9a0a">
      <Text>To see my brother in Austria.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="36b28ab6-1e34-4115-8168-3eebe16ee1ee">
      <Text>MANIRA (DUJEU)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1495e9fd-2cf3-4c55-999f-15892bd7630d">
      <Text>Yeah? We're also going to Vienna soon, I've already been there one winter.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7877442f-83b5-4f3a-8c31-6776f1f9d31e">
      <Text>PALMINA (DUJEU)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e37b447e-7c0e-467a-b9cd-c4ab508111ca">
      <Text>And to which city?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6c25813e-4655-4582-ad2a-d9128c0216a3">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="96364d55-336c-4313-a396-eefd8cd9a943">
      <Text>It's not Vienna, he's close to Germany. Salzburg.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="9b9f6430-7c95-4411-a300-962fcdb91d60">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a3186002-b7dc-4fcf-bb67-9e38bf456784">
      <Text>I know, but I've never been. What does your brother do?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="170ad9cd-1651-4239-8f0d-33bf6d5f2873">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d0f63176-8bf9-4dd5-a578-8e599cea8fad">
      <Text>IT.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="480e6a2d-9756-4192-b2e0-a507f6b1e864">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="97b84231-e144-4066-88a0-e31a5a0d7a8f">
      <Text>Crazy, I would do that too if I weren't against technology.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6eb5ee0e-efe1-4f3a-864e-e775f3b2c7c5">
      <Text>PALMINA (DUJEU)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="cf728e5f-7e64-4b0a-9534-0940fef8e9a3">
      <Text>Are you hungry?</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="d462d8bb-6730-4a69-8eb9-9626f1371d2a">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="67" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="8a12a245-df0a-4fd5-86a4-db8cb7bb9a6b">
      <SceneProperties Length="1" Page="65" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DUJE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. STUDENAC - DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="8b5969c1-ecb3-43f5-9ba2-17c7354a2d5e">
      <Text>PALMINA and MANIRA stand in front of cheeses and salami.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b3d666ae-9df7-4979-915a-e6e3d6f196c3">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="08fa2e99-9c25-4c18-9ae3-dcb4647db7bf">
      <Text>Can I get 16 grams of mortadella with olives?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1b9c7fa3-20be-4af6-8402-9ffd19bd57c7">
      <Text>MANIRA (PALMINI)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="04350877-67be-4a2a-ad3d-cba4fa74e683">
      <Text>Decagrams.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="01c01d1a-ef43-422d-bd7c-bdbcac1b6d2c">
      <Text>PALMINA (MANIRI)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e7114522-89a1-4ca7-97f7-6b6e1753cbf0">
      <Text>Decagrams. She understood.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="4d899b2f-6bbc-4793-80e2-edf4716fc9d4">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="cd31e0fe-f196-4dbc-bda1-327e6b5e746b">
      <Text>I don't eat meat. Only čevapi.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="726d9f17-ade9-404a-a6d7-e4aacf41188b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="a7198081-e08a-4a2d-bc6f-64208b130864">
      <Text>Well, we will eat it.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="e9e221cb-6cf4-45d3-9d86-6b1a60201cc9">
      <Text>PALMINA steals a tube of mayo.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="41207bf8-ec50-462e-97d0-f167c9db3475">
      <Text>DUJE steals cheese.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="9578678b-be7c-4fa0-bfd8-deafa8bf11a1">
      <Text>MANIRA takes 2 lemons in her hand.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e82760cb-75b7-4ea7-8109-45bcfb7df064">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fdd3fee3-1b49-4f0d-b22d-e607ef03e284">
      <Text>What do you need lemons for?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1b5d191b-e673-4b9d-ad60-f02088860c37">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1536a30d-adfb-402c-9078-9144bdc21311">
      <Text>For lemonade.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="7b84cdae-bd8e-4816-8aee-f5fb51e83894">
      <Text>At </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">cash</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">register</Text>
      <Text> MANIRA </Text>
      <Text AdornmentStyle="-1">pays</Text>
      <Text> for </Text>
      <Text AdornmentStyle="-1">lemons</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">bread</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">mortadella</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">with</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">card</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="751b436a-79b5-4414-8b30-4244f68ce36d">
      <Text>PALMINA (MANIRI)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d2719a25-574b-4415-a540-467b034540b4">
      <Text>Are </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">sigma</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3078d2b1-8779-40f2-98d3-e279f789fa38">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="801f4973-a308-42b8-a8f4-4020bb1abb80">
      <Text>I am.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="93834bbe-c021-48fd-b696-57c5d3b7a944">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c2fb5f8d-3973-4889-bc46-86adf673a27e">
      <Text>Me </Text>
      <Text AdornmentStyle="-1">too</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Dujan</Text>
      <Text>, are </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">sigma</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7ac01c4d-be3f-4905-95e1-04dd2e7f5629">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="baeac8db-4e63-426c-947d-9631f5e4f57e">
      <Text AdornmentStyle="-1">What's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="783091de-c199-4922-9fa6-d28678e9e93f">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="68" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="f2652f97-8534-4724-ab2a-c08d0214e501">
      <SceneProperties Length="3 2/8" Page="66" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DUJE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">EXT</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">MEADOW</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">WITH</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">OLIVE</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">TREES</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">SUNNY</Text>
      <Text> DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="07dfb8c3-311f-461e-9ba9-13de114ccb39">
      <Text>PALMINA, MANIRA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> DUJE are </Text>
      <Text AdornmentStyle="-1">sitting</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">grass</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eating</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sandwiches</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="10756c5a-af3d-4314-a269-3c2ce988f2b5">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c6fe03cf-d7e5-48b6-b5c3-f1a138b65d9b">
      <Text AdornmentStyle="-1">That's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">get</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">when</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">listen</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> Studenac </Text>
      <Text AdornmentStyle="-1">version</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> Luka Nižetić. Luka Nižetić </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> do "</Text>
      <Text AdornmentStyle="-1">Thinkin</Text>
      <Text>' </Text>
      <Text AdornmentStyle="-1">About</Text>
      <Text> You", but Frank Ocean </Text>
      <Text AdornmentStyle="-1">can't</Text>
      <Text> do "Proljeće je a u meni nemir" </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> 10 </Text>
      <Text AdornmentStyle="-1">parallel</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">universes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ac3e1de6-aabd-4d03-bd42-8ab241d36214">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5cb70cce-2c01-4cf5-b571-229446c88cda">
      <Text AdornmentStyle="-1">That's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">true</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="ce9975eb-882a-4a54-ba96-3bc1c9335ff6">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="09765ff8-cd42-4e76-af96-a1821e77da63">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fc3d0e24-9b17-4641-ab35-349e810bf323">
      <Text>Do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">believe</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">reincarnation</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3ad73ab9-6126-41be-aaa6-76dc81899a89">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e6825bec-3f5b-462a-9ad7-ad674ed91850">
      <Text AdornmentStyle="-1">Well</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">first</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">all</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">We</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">conscious</Text>
      <Text>. But </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">consciousness</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">Where</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="62d20ba0-f7ff-44cc-b915-9f2c53b265d2">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e036dc8b-ec05-4577-869a-4ce256ca4bd2">
      <Text AdornmentStyle="-1">Our</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brain</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="dfbbe404-e6ca-4884-a674-b580f0b73d84">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c8b1d468-c33e-46b8-903c-3539f358fd55">
      <Text AdornmentStyle="-1">Let's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">say</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">reincarnated</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">then</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">different</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brain</Text>
      <Text>, a </Text>
      <Text AdornmentStyle="-1">different</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">body</Text>
      <Text>, a </Text>
      <Text AdornmentStyle="-1">different</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">consciousness</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">What</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">then</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brought</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">us</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">next</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">life</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="64a01141-08c0-4bf7-9ec2-6802be9931bf">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="adf22d1a-c624-4b04-9d19-060c5e0d7209">
      <Text AdornmentStyle="-1">It</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">can</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">only</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">energy</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d3921a81-ba4e-4cc8-94b0-965712fc55e1">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="96a93c59-34f3-42f9-b1c4-a7f76026fedd">
      <Text AdornmentStyle="-1">And</Text>
      <Text> how are </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">energy</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">if</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> are </Text>
      <Text AdornmentStyle="-1">someone</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">else</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a4a17100-5942-463b-b8ac-281b5168ea73">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="02be8b22-8f36-4f20-8b48-8c4f540c5be8">
      <Text AdornmentStyle="-1">Well</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">transformed</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="627fb9d4-84b6-4c59-aa8a-54fff6f0e7b7">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="ee997220-6981-49a7-92b1-3a0c17294b6f">
      <Text AdornmentStyle="-1">When</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">die</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">worms</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">eat</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">us</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">given</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">energy</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">this</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">way</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="cee5b717-3f1f-44e3-b613-14a13bbb310f">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d0c35588-b4f3-41c6-ab03-7ad38abeced8">
      <Text AdornmentStyle="-1">Yes</Text>
      <Text>, but </Text>
      <Text AdornmentStyle="-1">where</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">reincarnation</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">then</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="63b784c6-ea87-409a-8fe9-7433943bf631">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e2e15f9a-31dd-4a4c-8e8a-aa8f530da61f">
      <Text>And can a worm be reincarnated? Why should only conscious beings be able to reincarnate, or only humans?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8e8b69ce-725a-40b2-b01a-bff9b2df3aa0">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1f7024e5-7d9a-48fc-a793-cc1e8f924349">
      <Text>That's not right.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eb4700c1-4c04-4cb1-b691-8cc9530ac4aa">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b5c0769d-e44d-4f4c-8200-623cd863b881">
      <Text>I was a mermaid in a past life.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c1980cc0-286c-4753-bbe9-52b139b8544a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="425425fe-611a-408d-ae28-f80a20055452">
      <Text>I don't know what I was in my past life, but in the next one I will be a nepotist.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a39403d4-b7ae-4771-91bc-2a9b8da8bcf7">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="687375d5-52bc-4b2b-953c-37feefd385ac">
      <Text>I was a pterodactyl, the flying dinosaur.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7360e51b-e190-41db-9a57-223051449517">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f7200f14-75e2-4447-95e9-4a4f76ee6dea">
      <Text>I wish you had seen that guy who was riding with us before you.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="35059577-1afe-4c2c-acbf-7282412ca340">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4e21dd93-86c6-4a04-8486-7caf031ea7bf">
      <Text>The guy takes out a bottle of brandy from his bag and asks if we want to drink. 2 in the afternoon. Well, we drank, but only out of respect, because he is an older man.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="962f7fca-dbfd-4c6e-aac0-b225ea25690b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="040d3188-6bb5-410b-a5ff-2aa3234f19aa">
      <Text>Dujan, do you drink?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="bba470f4-b373-4f95-a3ee-d7eef88a040b">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b8cc8f12-6890-4621-9d47-0630a248bd1d">
      <Text>Sometimes.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="226080fe-5b8c-4797-b559-eb1157899216">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d8f9868d-bdbd-4f2e-87f1-7662b9402348">
      <Text>We have more brandy. Should we get drunk?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="4859bd16-ac79-4966-983b-464b1e065765">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="65b9b1bd-2d66-40ee-ac9f-5dba4e3983cf">
      <Text>We should.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="867bcd48-7e1f-4ab5-b3c4-00b670330a66">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="17421d7a-c767-41c5-9865-3af82b498b1d">
      <Text>PALMINA brings a bottle of brandy and lemons.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="9f748ccc-0488-48ab-b6dd-1e4d9202d969">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="38fc7123-90da-41dc-9025-1cec3abc8ff4">
      <Text>Who wants a shot and a lemon in the eyes?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6269d61c-edb3-4422-bc25-6edf990157ff">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="30c909bc-bcc6-4905-b7f2-5d216b5c6574">
      <Text>I won't.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="915600ee-30da-4907-8f86-f92593ee4154">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="33d1065d-857c-46ef-b7bd-091a32a403a6">
      <Text>Will you?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="601b9010-4d63-48b5-9a64-7bcf12601c9d">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c52f35c3-27a2-4147-b5f1-9b71e235342d">
      <Text>I will. Does anyone have a knife?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0666c983-3e05-436a-bf40-563f2902e2c1">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="65447a68-c4e0-4881-9507-6a1df75aba58">
      <Text>I do.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="cc05a4af-f00e-43fe-afd7-883cc0d52d67">
      <Text>DUJE took out the same pocket knife he used to stab ANDREJ.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="2c0a7edb-55cb-4e71-9dc7-094d231bf307">
      <Text>PALMINA cuts the lemon into slices.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="6766dd7d-f024-4b58-a58a-41bc5fc0d6aa">
      <Text>PALMINA takes a bottle of brandy, takes a sip and squeezes a lemon into her eye.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="934ae71a-f6cb-4333-bc60-4823f1cabb14">
      <Text>DUJE and MANIRA clap.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0341d265-e14c-4295-8702-396e118bad5c">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="76b82765-3584-4f6c-b58a-f78940a6b7cb">
      <Text>Bravoo!!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="268dfb13-c4d0-45fc-9e18-b8dddf50247c">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="520fea2a-0e0b-4d06-9bb9-8ceebed850f1">
      <Text>Bravoo!!</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="34a0fe37-259b-4ff8-a403-6f92e0b8d6d3">
      <Text>PALMINA listens to the conversation between DUJE and MANIRA, sucks on a lemon, eats the lemon peel, cries because of the acid in her eyes. Lots of tears.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="599dc61e-41b6-44f9-a864-7bd96de025fb">
      <Text>MANIRA drinks a shot of brandy.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="4d743c1d-0c99-4e91-827b-3e695ced4036">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e9a97d06-2a7a-45fc-a5c9-5288ce665c00">
      <Text>Do you have a girlfriend?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="9372fadb-66cd-4785-a711-750b9603e2fe">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6c5ad75e-b3ef-4167-895d-137113dd55cc">
      <Text>No.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="44e9ca6f-c68a-469d-b000-8091be60edf1">
      <Text>DUJE </Text>
      <Text AdornmentStyle="-1">drinks</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">shot</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brandy</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="a9ee42a9-b78b-4de0-8794-788cd28fdf23">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9b900d6b-38ea-4da3-aeee-220926b955ee">
      <Text AdornmentStyle="-1">When</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">get</Text>
      <Text> one, </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">better</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">than</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">think</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">should</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">And</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">twice</Text>
      <Text> as </Text>
      <Text AdornmentStyle="-1">involved</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="95cd1a17-95d7-4506-97f0-51aaab0151ee">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="382452fc-2905-4cd2-a123-e8e28c32b3b0">
      <Text>Do </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">boyfriends</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="0f6a2cd1-0b49-48f5-bb6e-d00be0831870">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="21421b06-87d2-4d19-a7b9-291e68e409bd">
      <Text>No, </Text>
      <Text AdornmentStyle="-1">because</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we're</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sick</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">head</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="da73160f-650c-4305-82c2-dbd00a86ef14">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MANIRA </Text>
      <Text AdornmentStyle="-1">laugh</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">look</Text>
      <Text> at </Text>
      <Text AdornmentStyle="-1">each</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">other</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="30ab2f15-5122-411a-836b-7355d5214190">
      <Text>PALMINA (</Text>
      <Text AdornmentStyle="-1">DUJEU</Text>
      <Text>)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="131e75e1-c684-47b2-9c74-188ceb54b7cc">
      <Text AdornmentStyle="-1">And</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">will</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">when</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">grow</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b0707894-a139-4a50-9027-ce2983a37f23">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="aad26c41-d054-41fa-b53f-65f6a66373eb">
      <Text>I </Text>
      <Text AdornmentStyle="-1">don't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">know</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="66609ae5-8554-4a40-8d92-e871130f4ffc">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="69" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="1459cebf-dab7-46df-b219-ad5145100906">
      <SceneProperties Length="3/8" Page="69" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. CAR, </Text>
      <Text AdornmentStyle="-1">MEADOW</Text>
      <Text> - </Text>
      <Text AdornmentStyle="-1">EVENING</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="71f53d78-d2cf-4ec8-a0bf-69f14366d25c">
      <Text AdornmentStyle="-1">Everyone</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drunk</Text>
      <Text>. MANIRA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">driving</Text>
      <Text>. DUJE </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sitting</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">passenger</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">seat</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="2749d9ae-5832-42f4-9548-e08bf239d37e">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">lying</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">windshield</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">looking</Text>
      <Text> at MANIRA.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="d23275d5-90fc-4583-81a8-52ee71494863">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">laughs</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">goes</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">kiss</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">glass</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="fa17bc3c-47ac-43d9-bae0-499e049c84bd">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MANIRA </Text>
      <Text AdornmentStyle="-1">kiss</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">glass</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">between</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="fe93fedf-3cea-4a17-a268-73510568b795">
      <Text AdornmentStyle="-1">DUJEA</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">looks</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">curiously</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">with</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">small</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">grin</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="fe65ac05-9ca7-4d5c-9b5a-02881fa0cb85">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="70" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="2000b9bf-af1c-4917-ac3a-68d69174cd9e">
      <SceneProperties Length="1 5/8" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DUJE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. MEADOW - DUSK</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="9471ec61-e813-4f5b-a62d-eaa5e12e5d29">
      <Text>The car is parked, the headlights are on.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="1cce22ab-a9e6-421f-a473-a70fbe48c702">
      <Text>DUJE, MANIRA and PALMINA are drunk. They are all laughing out loud.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e5b53193-a338-47cd-acb0-a1e64bc7f73a">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7a5ec46e-43a5-4298-8679-d26584316548">
      <Text>Those skinny jeans. Aii.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="effe59f0-99b6-4e64-bf36-30dd0cf4ab4e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="45e440c3-ce16-4528-80af-37cdf5087fca">
      <Text>I can get to know him and like his personality, but I just can't get over the skinny jeans.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="84be78a6-1b66-4366-a9ce-b28ae2e704f7">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="ec9c9c94-57b8-463f-8eb2-6768448bb822">
      <Text>Dujan, why do men wear tight pants?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="9cdf583a-29d4-4a24-9934-efda3d9dd2ec">
      <Text>DUJE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="524282c8-2ee5-4829-bac5-ebe23283096a">
      <Text>I don't know.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e1e3de14-d917-4717-8ca6-9157d7e94c1a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="0dbe9d71-b395-4e6a-bd23-bb475d3e211c">
      <Text>Because they lack testosterone. Okay, Alen can do it, he's punk, but that Denis, oh my, bro. Terrible.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3bfd4edc-0103-46f8-876c-d97569abdb67">
