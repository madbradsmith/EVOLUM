      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7f3caf10-9a0a-40ff-8b1c-b4ba8d7f7e32">
      <Text AdornmentStyle="-1">What</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="40529d6e-c734-4242-87bb-c237a91415d1">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7bc7df9e-ddbc-4174-840c-ce8f3f676dfc">
      <Text AdornmentStyle="-1">This</Text>
      <Text> one American </Text>
      <Text AdornmentStyle="-1">guy</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">has</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">fetish</Text>
      <Text> for </Text>
      <Text AdornmentStyle="-1">bread</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">getting</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">crushing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">by</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">women's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">feet</Text>
      <Text>. He </Text>
      <Text AdornmentStyle="-1">pays</Text>
      <Text> me to </Text>
      <Text AdornmentStyle="-1">send</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">him</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">videos</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">my</Text>
      <Text> bare </Text>
      <Text AdornmentStyle="-1">feet</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stepping</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">bread</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Two</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">months</Text>
      <Text> ago he </Text>
      <Text AdornmentStyle="-1">bought</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">sneakers</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">jerked</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">off</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">inside</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sent</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text> to me to </Text>
