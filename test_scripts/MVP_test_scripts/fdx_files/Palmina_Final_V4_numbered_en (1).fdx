    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="2d2058eb-a0d2-45f9-be3f-11bbcd246721">
      <Text>And what does freedom mean to you?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c698dbfe-d554-4db2-a2e2-6e242f6e20b5">
