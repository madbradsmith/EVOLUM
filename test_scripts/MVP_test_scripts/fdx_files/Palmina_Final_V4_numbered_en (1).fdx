      <Text> - </Text>
      <Text AdornmentStyle="-1">NIGHT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="8b2c114a-501d-48b0-8e8a-688cf6e5453a">
      <Text AdornmentStyle="-1">Two</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">teenage</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">girls</Text>
      <Text>, ANA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MARIJA, are </Text>
      <Text AdornmentStyle="-1">sitting</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">talking</Text>
      <Text> on a </Text>
      <Text AdornmentStyle="-1">bench</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5cb52c4d-7775-46ea-a9f1-ff8ab1690b74">
      <Text>ANA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6430f40e-d235-4ecd-a960-f68b897c18d5">
