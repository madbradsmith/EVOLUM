    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="6f5087a2-7c16-4915-85f1-3a035a4fd766">
      <Text>ZLATKO </Text>
      <Text AdornmentStyle="-1">jerks</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">off</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">cums</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">choking</Text>
      <Text> on </Text>
      <Text AdornmentStyle="-1">Luce's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">piss</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="f1e4297a-db28-4ce4-b56c-010006ddc272">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="31" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="91ae1a87-a83c-4eec-b91b-94ce651c9b0d">
      <SceneProperties Length="2/8" Page="35" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. IN </Text>
      <Text AdornmentStyle="-1">THE</Text>
      <Text> CAR - </Text>
      <Text AdornmentStyle="-1">NIGHT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="4035832d-a870-4e17-a10c-ebaa225b0af8">
      <Text>ZLATKO </Text>
      <Text AdornmentStyle="-1">drives</Text>
      <Text> home </Text>
      <Text AdornmentStyle="-1">drunk</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">silence</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="69f579fb-f298-4f7a-9736-57f8faeaa5f4">
      <Text>ZLATKO </Text>
      <Text AdornmentStyle="-1">parks</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">turns</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">off</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> car </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> front </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">house</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">sits</Text>
      <Text> for 5 </Text>
      <Text AdornmentStyle="-1">seconds</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">silence</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">then</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">starts</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">crying</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="2fd30f75-40e9-4833-bfd1-250dad4fda93">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="32" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="0d4e929d-603b-4406-b081-515ea251ebc4">
      <SceneProperties Length="7/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">EXT</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">PARKED</Text>
      <Text> CAR - </Text>
      <Text AdornmentStyle="-1">MORNING</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="d68ff8e1-bf89-4b4a-85d0-15d78c2a375b">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> MANIRA </Text>
      <Text AdornmentStyle="-1">listen</Text>
      <Text> to Radio Brač.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="297fde2a-0e90-4011-9a8a-fb49b535fa6f">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">drinks</Text>
      <Text> water </Text>
      <Text AdornmentStyle="-1">from</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">plastic</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="390d0e05-d10d-4f4d-8eb4-436af8ddb786">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">stretches</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="6ad853d7-3082-4b39-bc80-39ab2982ba59">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">drinks</Text>
      <Text> water </Text>
      <Text AdornmentStyle="-1">from</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">plastic</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="8b5bcd94-9cae-4ac2-a8a7-41912f1e4887">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">changes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">clothes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="a67e4583-f408-45b7-b565-5751a1fdc3ae">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">waves</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">hand</Text>
      <Text> at MANIRA to </Text>
      <Text AdornmentStyle="-1">give</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">her</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> water </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="153f1c67-e725-4350-9cdf-facf8fd04a04">
      <Text>PALMINA pours water under her armpits and on her hair.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="bc04f8f2-2465-4b20-8b0c-0b5757388a68">
      <Text>MANIRA changes clothes and pours water on herself. She puts on a T-shirt that says "Ideally bad".</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="00640b73-f2e2-4e51-bed5-ac75dca2467e">
      <Text>PALMINA eats an apple.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="b53759ca-18cb-4767-a082-1c9c572c8cce">
      <Text>MANIRA eats a banana.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="10dd3364-d326-44b0-91ba-673aed918a2e">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9420fc23-b21a-4d1f-b033-51f407dd1194">
      <Text>Let's eat and look at each other.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="5891f5c6-f996-4c59-9e45-04e22cb75fdc">
      <Text>They eat and look at each other for a minute.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="aea38c7c-8b18-4414-b747-430cb939aa7e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b5803142-ec29-45d8-9de2-e6acd5eed37b">
      <Text>I need to pee.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="f8521cb9-6c61-40d6-9f5f-7fbdfba1f957">
      <Text>PALMINA is brushing her teeth by the car on the left.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="41232244-ac81-49cf-b801-6235453aa91e">
      <Text>MANIRA is peeing on the right side.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="83e9f67b-7635-4797-b10d-14f0911163a4">
      <Text>PALMINA opens the hood and pours water. Closes the hood.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="c2ca36da-64d6-43d8-95a8-658cf5555366">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="33" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="89d38487-8fd4-45c1-bf29-422e7c6faee9">
      <SceneProperties Length="3 7/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. CAR - MORNING</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="e84c86f4-7bf9-4766-82fc-6816e5dfe7ac">
      <Text>PALMINA is driving.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d238346e-af85-4bc6-8e47-70952148f34d">
      <Text>MANIRA (READING FROM HER PHONE)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="be0f6ce2-2e01-44ed-9192-4f055f701467">
      <Text>"The truth about star Karolina revealed; She went on a trip to Makarska with her two children. The car Karolina was driving fell off a cliff into the sea. She managed to pull Borna to the surface, and Tomislav drowned. Then everyone thought she had drowned too, so she went to Vienna..."</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b3b82cfc-3cc7-423d-87e3-d131d25c6668">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4a37c165-a672-4db0-8426-ba5f148504b5">
      <Text>Ha, and what was she doing there?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="cb7f1472-96ca-476e-84bc-ed2fa3cc1fb7">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="2438b612-7d64-4fdc-a17c-aaf4fab165f7">
      <Text>She worked as a kindergarten teacher.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="43d44ed3-5855-4709-9ee5-4dde95a97826">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6b1274e7-64ff-43db-944b-63243e3ae0dc">
      <Text>No shit?! She always seemed like a psychopath to me.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="4add67b7-7a76-43f3-9175-522c1625b88c">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b8518fe5-991d-4c5b-b1e1-7729d63fd3f8">
      <Text>To me too.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="cfa7056f-5a60-4461-b49f-691e5cfbd8bd">
      <Text>Pause.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8c8e9fad-b0f2-4150-9443-7d679941a5a6">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="84041615-dbe2-4785-914d-2717b6d0c5e9">
      <Text>That would happen to you.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5a79602d-4e33-4148-8747-30aa558836c1">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="bef095f0-61bf-42fc-aa9f-8aa2a89a2ba5">
      <Text>To me? I passed on the first try.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="59933ee0-2466-40a1-bc63-d278a2cb2a43">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="2f8e0dd5-325d-4748-84bf-92f78f1c56d6">
      <Text>Only a policeman's daughter can get that, and us mortals four or five times until they milk us empty, like cows.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b7643151-1714-4e2e-ac61-59d5faf20af8">
      <Text>PALMINA (LOOKING AT MANIRA)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="26c1711b-acde-4d42-9f59-7184397c9981">
      <Text>Sssssss.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="eaa35d72-6797-4d19-a4a4-b9e803d6ee26">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="e2fdc84c-bfc3-40a8-98c5-fdff4482f077">
      <Text>Yeah, yeah.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="59a9de90-d400-41a9-8940-673b75249a6f">
      <Text>MANIRA leaves her phone aside.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="fb6a369b-76da-49cb-a81c-dff64b9cfb38">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="442939e3-7c31-4dc6-9957-343f804fde62">
      <Text>Do you vote?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1791ee42-56e7-4704-ade0-085e78a17436">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="addb5a26-19ff-4aca-8076-3b7fd9f4e6b0">
      <Text>If voting changed anything, they wouldn't let us vote.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e59ff67a-8431-486d-9ec5-98520749d7b9">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f57b34df-22b9-4ff4-a949-0270018a96a3">
      <Text>Well, it doesn't change because we are not one of the chosen ones.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f9f769c8-85d7-44c2-b6bc-50b84b47d7d6">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="79670ef6-44ec-4eb2-a975-fc6f2c32c558">
      <Text>Fuck it.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5ac25176-a1fa-4c3b-8893-718b25bd6459">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c830515d-c5e5-4c51-bb11-b221b687af88">
      <Text>But that's what they want from us - apathy. That we don't care, that we surrender.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1704c21a-f98d-4d20-847f-4c164eafa486">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3fbb5100-5f27-48d7-8abb-62561f0dfe3e">
      <Text>I'm an anarchist. And I hate bureaucracy.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f0d2522d-addf-488c-bb54-a30f147bc3ef">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="46713fcb-cfbf-4c3d-bd1d-d0116bff336b">
      <Text>There's also bureaucracy in Austria.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8fb04033-3761-47f6-b9a8-91591c36db7b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="9519be7d-64e5-404c-9e7f-938a71f9b227">
      <Text>Okay. But they make up for it with other things.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ce5dbd23-864d-4fab-98c2-b6125fc1bb6b">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="af77148c-980c-412e-80b4-9e042c6086d1">
      <Text>Well, you'll see when you come.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="013d7dd6-8e77-4bc3-b152-cfaf14e21a5b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="26b5413d-0bdd-454b-bf1e-1a19e475aa17">
      <Text>You said you like it there.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e5f7e48f-dcbf-46e1-bfd5-ed955dae575a">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="54366434-cecd-4fa4-8c85-0bdb338fe321">
      <Text>Yes. You'll meet Zaira. Her mother is Italian, her father is Bosnian, and she's German.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="b554066d-e737-4ee9-ae7d-aa81dda4c715">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="217bf4ad-7ee4-499f-91f8-024103c17f5f">
      <Text>Aha.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2ea5b74f-c375-453e-856a-2977749fde21">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="10838c93-f30e-4323-932a-f652bceecc56">
      <Text>It'll be good. We'll be together.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e2157a0f-6647-457b-8c9c-304ff3eb4610">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="ee61af45-5e74-4f04-8cec-24cb2f73fe16">
      <Text>It will be cold too.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6f04abf7-0390-49b9-8fc8-b8bfdd56221c">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="812aa194-d5bd-4cc9-858f-619c19c7806f">
      <Text>Well, you put on a good jacket, what?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="425b7451-63d2-4ef6-878b-85ec0851b1e4">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d73285ee-48d5-4cb7-b48d-b8f73d81fa03">
      <Text>I don't want to spend my best years under a jacket.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="16666d7a-a75f-4620-9983-ef2bc137802e">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1fe63ae7-165e-41a9-8949-6ceca2ee2526">
      <Text>You be an anarchist, so don't.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="75c42dc8-0aad-4341-8115-07fbf6b61860">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="0aa43c6c-56d7-4912-a7c6-94582781daa9">
      <Text>Anarchism is possible because of human nature. You can teach a man anything from a young age.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="cb7bb2a2-404f-4c92-b0d4-26d0c60fc542">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="5af4eaa4-3cb5-4cb3-80cf-96f93e3a2e80">
      <Text>Yeah, you see how they taught us that this is normal.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7d6e3638-6d5b-4eaf-87d1-81ceca247491">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="7920dcbc-0c99-4161-9502-85b925d654f2">
      <Text>It's not normal for anyone.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="7e50fd8e-9bcb-4dbd-a919-1a591f3393e3">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="8c7797f7-cc27-46bc-9d21-ebe6e0b2839a">
      <Text>When will it burst?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="aca46675-5e4a-47f8-8d86-717d0560b5ea">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="230946a8-175a-422c-b39f-38040f65200f">
      <Text>I would like it to burst while we are alive.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e744c4ee-64e0-4365-8333-0deb4827a978">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d4f3159d-c4bf-4c18-a77b-d4b3cfaac9a4">
      <Text>I would like us to be part of the bursting.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="5c019bfa-c4ca-497e-a145-d89a53528486">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="1e3b870c-c32b-4640-8df5-e44d226b84a8">
      <Text>Will it crackle or will it explode?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3c1c20cf-2e69-41c2-aa17-7b7d5b9d3b03">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="dc976109-4fb7-415e-85b8-470a24fbb461">
      <Text>Maybe it won't happen at all. Those who want a bigger change aren't in politics, they're doing creative things. They are in the arts.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="cba842de-4681-4dc0-b894-0add87629f66">
      <Text>PALMINA and MANIRA smile.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="338842b7-8b13-43fc-ad5b-392c4816ef67">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="bd860705-40b2-43d0-8445-2f255591bfc8">
      <Text>And people are scared. What if there's a collapse? Not everyone has their own garden.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="af15ac70-34f3-4458-8384-b9e3e546589b">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c2d85131-f8a2-49d3-af43-ca0db8f5c184">
      <Text>Do you know Plato's allegory of the cave? A man does not remain a prisoner in a cave because he is in the manifested world, but because he thinks that is all there is, because he knows nothing else. And how will they come out of the cave and look into the light, when the light will hurt their eyes?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="561f8c74-f234-4cad-9160-a54177aa012f">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="d88cac4d-a534-47e2-9e1e-ff23a74256fc">
      <Text>Well, anarchism will not happen here 100 percent. They don't flinch for anything here. When there was a protest for gays, everyone got mad because two men kissed.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="5b09ee29-d959-4d74-aa4b-f86c10ad7d4e">
      <Text>PALMINA and MANIRA smile.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="3ca424ff-7e6a-4600-ac99-2ebb75a7d038">
      <Text>PALMINA (LIKE FAR RIGHT BIGOT)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="781d83f1-e6b9-4625-b50e-f667daeefed0">
      <Text>"Hmm, I have nothing against that, but they should keep it inside their four walls"</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="2f012699-b76a-4108-8bd1-f9193d054ea6">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="548f2ba8-d6a1-414d-9fdb-f4ee6a1a6cdf">
      <Text AdornmentStyle="-1">Well</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">that's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">because</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">they</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">those</Text>
      <Text> 4 </Text>
      <Text AdornmentStyle="-1">walls</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">their</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">heads</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">I've</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">never</Text>
      <Text> had </Text>
      <Text AdornmentStyle="-1">any</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">walls</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Someone</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">told</Text>
      <Text> me </Text>
      <Text AdornmentStyle="-1">what's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">point</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">protesting</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">that</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">we</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">have</Text>
      <Text> more </Text>
      <Text AdornmentStyle="-1">important</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">things</Text>
      <Text> to protest </Text>
      <Text AdornmentStyle="-1">about</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Well</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">yeah</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">Nothing</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">right</Text>
      <Text>. Here, </Text>
      <Text AdornmentStyle="-1">go</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> protest. You </Text>
      <Text AdornmentStyle="-1">don't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">want</Text>
      <Text> to? You </Text>
      <Text AdornmentStyle="-1">won't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text>? </Text>
      <Text AdornmentStyle="-1">Then</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">shut</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">up</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">suffer</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="f8f52b96-bfe1-42d7-b5d5-62b4b383678c">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="fcec0c4c-8fd3-400f-a21f-578017e7986f">
      <Text AdornmentStyle="-1">Exactly</Text>
      <Text>. But </Text>
      <Text AdornmentStyle="-1">young</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">people</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">aren't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">interested</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">politics</Text>
      <Text>. </Text>
      <Text AdornmentStyle="-1">It</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">affects</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">indirectly</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">so</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">doesn't</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bother</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text>, but </Text>
      <Text AdornmentStyle="-1">what</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">happens</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">when</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">starts</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">affect</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">them</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">directly</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="60d935ce-3a85-40c3-96c6-a6cf009c4fdd">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="dc3aceae-0157-4d01-bd19-1f7efc890785">
      <Text AdornmentStyle="-1">They'll</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">be</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">in</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">Austria</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">anyway</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="5578b9bf-1eaa-4c69-ab8d-fd2378444098">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="34" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="63717ac1-82ad-4f05-9677-a0ba3adcd84b">
      <SceneProperties Length="2/8" Page="39" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="-1">EXT</Text>
      <Text>. BUS STOP - DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="bc0bce07-f4f8-4e45-bdc8-ae6208918bf2">
      <Text>MATE </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">trying</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">hitchhike</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">back</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">his</Text>
      <Text> place. </Text>
      <Text AdornmentStyle="-1">He's</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">talking</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">himself</Text>
      <Text> for 2 </Text>
      <Text AdornmentStyle="-1">minutes</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">out</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">loud</Text>
      <Text> (</Text>
      <Text AdornmentStyle="-1">improv</Text>
      <Text>).</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="caf15a8f-eebe-47ff-8689-4114c807efa5">
      <Text AdornmentStyle="-1">CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" Number="35" RightIndent="7.26" SpaceBefore="24" Spacing="1" StartsNewPage="No" Type="Scene Heading" id="154b588a-3002-4800-b45e-df5187ded86b">
      <SceneProperties Length="2" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MANIRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MATE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PALMINA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" OutlineLevel="0" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No"/>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="-1">INT</Text>
      <Text>. CAR - DAY</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="bc3e0c61-23d6-42f3-a9e7-e68da0ee9f2e">
      <Text>PALMINA </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">driving</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">she</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">sees</Text>
      <Text> MATE, </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">stops</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="40aa6720-f14f-4d41-9898-133871ff4a3c">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="90c6ce33-77a0-4a2b-8677-20fbf1cc3af3">
      <Text AdornmentStyle="-1">Good</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">afternoon</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="893ea712-8127-4834-ab8e-45cb0df87332">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="eb93c03b-ae86-4af3-b3b8-e40eff30453e">
      <Text AdornmentStyle="-1">Where</Text>
      <Text> to?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="655587d6-5216-4276-ac80-453860a94efc">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="204432b6-0358-40ca-a65c-335250e18611">
      <Text AdornmentStyle="-1">I'll</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tell</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">you</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">when</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">is</Text>
      <Text>, </Text>
      <Text AdornmentStyle="-1">next</Text>
      <Text> to one </Text>
      <Text AdornmentStyle="-1">peach</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tree</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="04cc835c-3605-426a-8ef3-129fb8e951ed">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3c9239f7-3c74-4bb6-b0f6-3a522325d297">
      <Text>Okay, get in.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="4bd676d9-28c5-47e1-9ba0-5b67e1a31882">
      <Text>MATE gets in the car.</Text>
    </Paragraph>
    <Paragraph Alignment="Right" FirstIndent="0.00" Leading="Regular" LeftIndent="5.50" RightIndent="6.86" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Transition" id="9f50eb39-8af7-4ac2-ab9b-3b2cf9dc3ec0">
      <Text>CUT</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="218c3b01-097d-43bb-bdb9-2b8d6cce644b">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="48300ee2-3318-468e-895a-e063f9c88b2e">
      <Text>How are you girls doing? What're your names?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="652bd42c-dbe9-4d2a-9a5a-aa72bc659520">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="b3c1bd0e-94a8-4e54-8a3c-2e8f2ff238e5">
      <Text>Palmina.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8a2317a8-1cb4-4316-bd44-48661af4b15d">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="067dc4b0-6233-4248-b397-9e48f8b339f9">
      <Text>What a crazy name, Palmina.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="17cb56cc-b813-499d-9628-3ac6976ee094">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="eb739b66-3c7b-43c0-8b80-c7052ddcadd3">
      <Text>Manira.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="150568d3-5237-4738-9c9c-c6633accb5bf">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="f4daaa43-66e6-41fb-b8e1-b74109b29007">
      <Text>Oh, even crazier Manira. How did that happen?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="43ae9ff6-3a3f-460f-ac4d-53f2dd1538ce">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="08f63bb5-5a5e-4d87-bf76-2539ccdc788b">
      <Text>They wrote it down wrong. I was supposed to be Marina.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="6512dcc3-e990-4be6-9652-97a3d544797a">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6b774a94-bf4c-4eed-bdb6-c909d6888004">
      <Text>That happened to me too. I was supposed to be Bogdan but I ended up being Mate. And where are two girls named Palmina and Manira going?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="8cf3e642-6106-49eb-881d-b762aed88e0a">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="59602540-ac76-4208-b823-5ce7ae55fc0d">
      <Text>We're going for a spin.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="1cc8e8b2-1d17-4bd5-ae35-dd65a5687302">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="3b07bf6a-fe36-432d-8f89-fad608fea842">
      <Text>How nice, a free spirit. I used to be like that too.. Would you like to drink something? I have alcohol.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="caf6d416-b5cf-4540-901f-7f0da8fd0a3c">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6d34fb13-1fba-4169-aca9-ea8523cff496">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="88fbbc03-07e5-4c78-b0b9-c2200670fda7">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="4af83c03-91b0-4ac3-b2f9-83ad3fc031bf">
      <Text>And you Palmina?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="d4751345-bcbd-4144-9516-f5cf1302dbbb">
      <Text>PALMINA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="6ccddd63-1ee4-4234-8ae5-060f933fc19f">
      <Text>I can't, I'm driving. Only if it's some good alcohol.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="e04890b0-7144-45cc-99b8-b9f068533837">
      <Text>MATE (LOOKING AT BAG)</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="08148033-431b-4dcc-b54c-3bebc4b13099">
      <Text>It's good. Pomegranate brandy.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="caab7754-5c66-445c-8ee0-f00093eddba0">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="65f6d9fd-01c2-4ea5-a2eb-22c80cae4f3e">
      <Text>Uu, I </Text>
      <Text AdornmentStyle="-1">never</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">tried</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="e309f27a-5af4-4fe5-8ddd-5e08d5e5f268">
      <Text>MATE </Text>
      <Text AdornmentStyle="-1">gives</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">large</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">glass</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">of</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">brandy</Text>
      <Text> to MANIRA.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="a46663da-6d81-4dd4-b154-7553b07cc7c8">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">sniffs</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">drinks</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">gulp</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="66c7b206-0fb9-44ae-8d10-d894f5884892">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="785f1e8b-f0b9-4575-87c7-5753f64c6442">
      <Text AdornmentStyle="-1">Is</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">good</Text>
      <Text>?</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="c6023c76-4f5c-41f1-9248-c5113f46fa48">
      <Text>MANIRA</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="041f551b-328f-4f7e-a278-246b10787a5c">
      <Text AdornmentStyle="-1">Excellent</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="1.50" RightIndent="7.26" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Action" id="444760a1-3cd7-44a5-9c57-4d8e4d5df9f0">
      <Text>MANIRA </Text>
      <Text AdornmentStyle="-1">gives</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text> to PALMINA, PALMINA </Text>
      <Text AdornmentStyle="-1">takes</Text>
      <Text> a </Text>
      <Text AdornmentStyle="-1">gulp</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">and</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">returns</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">the</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">bottle</Text>
      <Text> to </Text>
      <Text AdornmentStyle="-1">MOTHER</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="3.50" RightIndent="7.01" SpaceBefore="12" Spacing="1" StartsNewPage="No" Type="Character" id="ecfaed12-9864-4538-a16e-c501b8c5519d">
      <Text>MATE</Text>
    </Paragraph>
    <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="2.50" RightIndent="5.76" SpaceBefore="0" Spacing="1" StartsNewPage="No" Type="Dialogue" id="c5918107-6df1-48d1-91f1-a14c41304e4a">
      <Text AdornmentStyle="-1">I'm</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">gifting</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1">it</Text>
      <Text> to </Text>
