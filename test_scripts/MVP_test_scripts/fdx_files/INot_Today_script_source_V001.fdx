<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="1">
  <Content>
    <Paragraph Type="Character"><Text>﻿NOT TODAY!</Text></Paragraph>
    <Paragraph Type="Action"><Text>Notes Integration – Build 1 Source Script</Text></Paragraph>
    <Paragraph Type="Action"><Text>Written by</Text></Paragraph>
    <Paragraph Type="Action"><Text>MadBrad Smith</Text></Paragraph>
    <Paragraph Type="Character"><Text>OPENING</Text></Paragraph>
    <Paragraph Type="Character"><Text>BLACK.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Industrial ambience.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Wind pushing through chain link</Text></Paragraph>
    <Paragraph Type="Action"><Text>somewhere outside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Machinery humming behind thick</Text></Paragraph>
    <Paragraph Type="Action"><Text>walls.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then—</Text></Paragraph>
    <Paragraph Type="Character"><Text>BANG!</Text></Paragraph>
    <Paragraph Type="Action"><Text>A heavy industrial door SLAMS</Text></Paragraph>
    <Paragraph Type="Action"><Text>open.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>EXT. FACTORY PARKING LOT – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>MALIK TURNER (early 30s, Black) steps out into the night. Construction vest. Work boots. Helmet in one hand. End-of-shift exhaustion in his body.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He rolls his neck.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Cracks his shoulder.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The parking lot is dimly lit. Patches of yellow sodium light. Long shadows across cracked asphalt.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The camera slowly moves backwards as Malik walks toward it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He keeps walking.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Quiet.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tired.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Focused.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He passes the camera.CUT.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik opens the door and gets in.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He tosses the helmet to the passenger seat.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Starts the car.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A podcast begins playing.</Text></Paragraph>
    <Paragraph Type="Character"><Text>HOST (V.O.)</Text></Paragraph>
    <Paragraph Type="Action"><Text>You’d be surprised how much</Text></Paragraph>
    <Paragraph Type="Action"><Text>illegal activity happens in</Text></Paragraph>
    <Paragraph Type="Action"><Text>rideshare vehicles.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik glances at the rearview</Text></Paragraph>
    <Paragraph Type="Action"><Text>mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Empty back seat.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then he turns to check physically.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Still empty.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He nods.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He pulls out his personal phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Four notifications.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Two voicemails.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Two texts.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He plays the first voicemail.</Text></Paragraph>
    <Paragraph Type="Character"><Text>WOMAN (V.O.)</Text></Paragraph>
    <Paragraph Type="Action"><Text>Mr. Turner, if you do not arrive</Text></Paragraph>
    <Paragraph Type="Action"><Text>before nine PM the rental</Text></Paragraph>
    <Paragraph Type="Action"><Text>assistance will be given to the</Text></Paragraph>
    <Paragraph Type="Action"><Text>next applicant.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik sighs.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Next voicemail.</Text></Paragraph>
    <Paragraph Type="Character"><Text>LANDLORD (V.O.)</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik, I need that rent handled.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik rubs his face.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then he checks the texts.</Text></Paragraph>
    <Paragraph Type="Action"><Text>BABY MAMA: Can you cashapp me</Text></Paragraph>
    <Paragraph Type="Action"><Text>$200?</Text></Paragraph>
    <Paragraph Type="Action"><Text>SON: You coming tomorrow? Coach</Text></Paragraph>
    <Paragraph Type="Action"><Text>said I might start.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pauses.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then sets the phone down.</Text></Paragraph>
    <Paragraph Type="Character"><Text>PREP FOR RIDESHARE</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik grabs body wipes.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Wipes his face, arms, and neck.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Changes shirts.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Puts on rideshare jacket.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Podcast clicks off.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Soft music replaces it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He pulls out of the lot.</Text></Paragraph>
    <Paragraph Type="Character"><Text>COFFEE SHOP STOP</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>EXT. COFFEE SHOP – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pulls in.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Checks rideshare app.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nothing yet.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He heads inside.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. COFFEE SHOP – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pours coffee.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Keeps glancing at the rideshare app. A customer ahead of him talks loudly.</Text></Paragraph>
    <Paragraph Type="Character"><Text>CUSTOMER</Text></Paragraph>
    <Paragraph Type="Action"><Text>Man I had a rideshare driver fall asleep at a red light once.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Cashier laughs.</Text></Paragraph>
    <Paragraph Type="Character"><Text>CUSTOMER</Text></Paragraph>
    <Paragraph Type="Action"><Text>I had to wake him up!</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik smirks quietly.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Pays.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Leaves.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik sits.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Coffee in hand.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Watching the rideshare app.</Text></Paragraph>
    <Paragraph Type="Character"><Text>PING.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Ride request.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He accepts.</Text></Paragraph>
    <Paragraph Type="Character"><Text>THE RIDE</Text></Paragraph>
    <Paragraph Type="Action"><Text>The night begins.</Text></Paragraph>
    <Paragraph Type="Character"><Text>FIRST PICKUP</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel and Rico enter.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel gets in first, already on</Text></Paragraph>
    <Paragraph Type="Action"><Text>her phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico follows with the hard-shell</Text></Paragraph>
    <Paragraph Type="Action"><Text>case tucked carefully beside his</Text></Paragraph>
    <Paragraph Type="Action"><Text>leg.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The door shuts.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik checks the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik checks the mirror again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Just for a second.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nothing has changed.</Text></Paragraph>
    <Paragraph Type="Action"><Text>That somehow makes it worse.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico rests one hand on the case.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik looks away.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then back again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Double take.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Quick glance over shoulder.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico doesn't notice.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel scrolls with the focus of somebody already behind schedule.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik watches both of them for one beat too long. He puts the car in drive.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Low music underneath everything.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody says anything for a second.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then—</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik’s phone lights up.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel never looks up from her</Text></Paragraph>
    <Paragraph Type="Action"><Text>phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Her thumb moves again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The route changes again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik catches it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Says nothing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel stays unreadable.</Text></Paragraph>
    <Paragraph Type="Action"><Text>That unreadable calm starts</Text></Paragraph>
    <Paragraph Type="Action"><Text>feeling like its own kind of</Text></Paragraph>
    <Paragraph Type="Action"><Text>answer.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik clocks that.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city glides by in fragments through the windshield. Rico looks out at a passing row of trees.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Acer saccharum.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik hears it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Doesn't respond.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel keeps typing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik checks the mirror again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The case is still there.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Still closed.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Still giving him nothing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He swallows that thought and keeps the ride moving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel and Rico enter.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico places a long hard-shell case beside him.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik notices in mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Looks away.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Looks back.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Double take.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Quick glance over shoulder.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico doesn't notice.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RUNNING STOP ADDITIONS</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik’s phone lights up.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel never looks up from her</Text></Paragraph>
    <Paragraph Type="Action"><Text>phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>This behavior repeats during the</Text></Paragraph>
    <Paragraph Type="Action"><Text>ride.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik begins noticing.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Another stop.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Another adjustment.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Every time the app changes, Rachel stays calm.</Text></Paragraph>
    <Paragraph Type="Action"><Text>No apology.</Text></Paragraph>
    <Paragraph Type="Action"><Text>No explanation.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Just one thumb moving across the</Text></Paragraph>
    <Paragraph Type="Action"><Text>screen and the route changes</Text></Paragraph>
    <Paragraph Type="Action"><Text>again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik looks at the dashboard.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then at the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then back at the road.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He tries to stay professional.</Text></Paragraph>
    <Paragraph Type="Action"><Text>But the pattern starts getting</Text></Paragraph>
    <Paragraph Type="Action"><Text>under his skin.</Text></Paragraph>
    <Paragraph Type="Action"><Text>One extra stop is one thing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Three starts to feel like something else. The low music keeps playing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Traffic thickens.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Red taillights stretch out in front of them.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Another stop.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik finally shifts in his seat.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Not enough for anybody else to</Text></Paragraph>
    <Paragraph Type="Action"><Text>clock.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Just enough for us to see he's no</Text></Paragraph>
    <Paragraph Type="Action"><Text>longer comfortable.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel adjusts her grip on the</Text></Paragraph>
    <Paragraph Type="Action"><Text>phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Still says nothing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik looks up at the mirror</Text></Paragraph>
    <Paragraph Type="Action"><Text>again.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The case.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel’s face lit by her screen. The back seat now feels busier</Text></Paragraph>
    <Paragraph Type="Action"><Text>than it should.</Text></Paragraph>
    <Paragraph Type="Action"><Text>And somehow quieter.</Text></Paragraph>
    <Paragraph Type="Action"><Text>That quiet makes it worse.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Streetlights drift across the windshield. Malik keeps his eyes on the road.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He shifts slightly in his seat.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Checks the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Back to the road.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Checks the dashboard.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Back to the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He tells himself to relax.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Doesn't.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The music stays low.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the car seems worried. That bothers him more.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik’s phone lights up.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel never looks up from her</Text></Paragraph>
    <Paragraph Type="Action"><Text>phone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>This behavior repeats during the ride.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik begins noticing.</Text></Paragraph>
    <Paragraph Type="Character"><Text>PASSENGER DIALOGUE</Text></Paragraph>
    <Paragraph Type="Character"><Text>EXPANSION</Text></Paragraph>
    <Paragraph Type="Action"><Text>TIFFANY. Then DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>More passengers join.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>Man I swear this city got a different energy at night.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>Everything does.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nah I'm serious though. Night time Chicago feels like somebody turned the volume</Text></Paragraph>
    <Paragraph Type="Action"><Text>down but the tension up.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>That was almost poetic.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RACHEL</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>Don't get used to it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>.The conversation grows.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev talks about proposing to his fiancé.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany vents about work. Rico randomly identifies plants outside the window.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik listens.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Observes.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Suspicion builds.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I’m telling you, if I do it, I gotta do it right.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then do it right.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That’s easy for you to say. You not the one about to buy a ring.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>That’s because I have common sense.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>See? This why you single now.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>And this is why she making you wait.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RACHEL</Text></Paragraph>
    <Paragraph Type="Action"><Text>We’re still good on time. Malik glances at the dashboard. That sentence lands heavier than it should.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Can y’all not do this the whole ride?</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I’m serious though. It gotta be a story.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>No, it has to be honest.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>It can be both.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Liriodendron tulipifera.</Text></Paragraph>
    <Paragraph Type="Action"><Text>There he go.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>I’m not even asking this time.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tulip tree.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That helped nobody.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel checks the app.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik hears it again.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>All I’m saying is I don’t want it to feel regular.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>Everything good is regular before</Text></Paragraph>
    <Paragraph Type="Action"><Text>people put pressure on it.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That sounded like you practice</Text></Paragraph>
    <Paragraph Type="Action"><Text>speeches in mirrors.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>That sounded like you need a plan.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I got a plan.</Text></Paragraph>
    <Paragraph Type="Action"><Text>What is it?</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That’s private.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>Translation: he has nothing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel almost smiles at that.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik sees it in the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Small. Quick. Gone.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He keeps listening.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Everybody in the back seat feels</Text></Paragraph>
    <Paragraph Type="Action"><Text>connected in a way he can’t read.</Text></Paragraph>
    <Paragraph Type="Action"><Text>And because he can’t read it, he doesn’t trust it.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Platanus occidentalis.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Man.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>What is that?</Text></Paragraph>
    <Paragraph Type="Action"><Text>Sycamore.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I swear if the trees know your government name, you need help. Rachel shakes her head.</Text></Paragraph>
    <Paragraph Type="Action"><Text>For one second the car almost feels light.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then Malik checks the case again. And the feeling disappears. More passengers join.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then DEV.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The conversation grows.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev talks about proposing to his</Text></Paragraph>
    <Paragraph Type="Action"><Text>fiancé.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany vents about work.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico randomly identifies plants</Text></Paragraph>
    <Paragraph Type="Action"><Text>outside the window.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik listens.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Observes.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Suspicion builds.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BATHROOM STOP</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev suddenly needs the bathroom.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pulls into a gas station.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev runs inside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel and Tiffany whisper</Text></Paragraph>
    <Paragraph Type="Action"><Text>quietly.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik watches them through the</Text></Paragraph>
    <Paragraph Type="Action"><Text>mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Not casually.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Carefully.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He studies who talks to who.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Who interrupts who.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Who ignores what.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The pattern still doesn't make</Text></Paragraph>
    <Paragraph Type="Action"><Text>sense to him.</Text></Paragraph>
    <Paragraph Type="Action"><Text>That makes him keep watching.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The paranoia grows.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Every ordinary thing starts</Text></Paragraph>
    <Paragraph Type="Action"><Text>sounding coded.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A whisper sounds like planning.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A bag sounds heavier than it</Text></Paragraph>
    <Paragraph Type="Action"><Text>should.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A stop added on the app feels</Text></Paragraph>
    <Paragraph Type="Action"><Text>intentional.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik knows he might be reading too much into it. He also knows nights like this can turn fast.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>EXT. GAS STATION – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Fluorescent light.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Bug-zapper buzz.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A couple of people hanging around the entrance with nowhere urgent to be.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik eases the SUV into a spot.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I’ll be right back.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>You better be.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>Why you talking to me like you my</Text></Paragraph>
    <Paragraph Type="Action"><Text>manager?</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>Because somebody has to.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev hops out and jogs inside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The door closes behind him.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – PARKED – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Now it’s quieter.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel leans closer to Tiffany.</Text></Paragraph>
    <Paragraph Type="Action"><Text>They talk low.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik can’t hear the words.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Only the shape of secrecy.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico keeps looking out the window like he’s in a different movie.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik watches the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel hands Tiffany something small.</Text></Paragraph>
    <Paragraph Type="Action"><Text>From the front it looks wrong.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Maybe folded paper.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Maybe a card.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Maybe cash.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany looks at it and slides it into her bag. Malik’s jaw tightens.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Hosta.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik glances back.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico points toward a planter near the gas station window.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Hosta.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik gives the tiniest nod like he heard him.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He keeps watching Rachel and Tiffany.</Text></Paragraph>
    <Paragraph Type="Action"><Text>They stop whispering the second they feel the silence.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany looks out the opposite window.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel checks her phone again.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik looks at the dashboard. Then at Rachel in the mirror. Still calm.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Still no explanation.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The gas station door swings open.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev comes back carrying chips and a drink.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>Anybody want anything?</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody answers.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev clocks the tension.</Text></Paragraph>
    <Paragraph Type="Action"><Text>…Okay.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>He gets back in.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The ride keeps moving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>And now Malik is fully inside his</Text></Paragraph>
    <Paragraph Type="Action"><Text>own suspicion.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Streetlights drift across the windshield.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik keeps his eyes on the road.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The music stays low.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the car seems worried.</Text></Paragraph>
    <Paragraph Type="Action"><Text>That bothers him more.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev suddenly needs the bathroom.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pulls into a gas station.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev runs inside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel and Tiffany whisper quietly.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik watches them through the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The paranoia grows.</Text></Paragraph>
    <Paragraph Type="Character"><Text>THE REVEAL</Text></Paragraph>
    <Paragraph Type="Action"><Text>Eventually Malik discovers the</Text></Paragraph>
    <Paragraph Type="Action"><Text>truth.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The passengers are organizing a</Text></Paragraph>
    <Paragraph Type="Action"><Text>community fundraiser.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The mysterious stops were supply</Text></Paragraph>
    <Paragraph Type="Action"><Text>pickups.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico’s case contains gardening</Text></Paragraph>
    <Paragraph Type="Action"><Text>tools.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>EXT. COMMUNITY CENTER – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pulls up outside a modest community center. The place is alive in a quiet way.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Folding tables.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Plastic bins.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Volunteers carrying chairs.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A banner halfway taped up at the entrance.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel gets out first.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany grabs a box.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev hops out with the chips under one arm and a stack of printed signs under the</Text></Paragraph>
    <Paragraph Type="Action"><Text>other.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico carefully lifts the hard-shell case.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik watches all of it from behind the wheel. Still not understanding.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Then Rachel crosses to a volunteer and trades a clipboard for a bundle of name tags.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany pulls tablecloths from a tote.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev starts joking with two older women carrying cases of water.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody is hiding anything.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody is running.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody is looking over their shoulder.</Text></Paragraph>
    <Paragraph Type="Action"><Text>It is the least criminal scene Malik has seen all night. Rico sets the hard-shell case on a folding table. Unclips it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Inside:</Text></Paragraph>
    <Paragraph Type="Action"><Text>gardening shears,</Text></Paragraph>
    <Paragraph Type="Action"><Text>gloves,</Text></Paragraph>
    <Paragraph Type="Action"><Text>small hand tools,</Text></Paragraph>
    <Paragraph Type="Action"><Text>labels for plants.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nothing illegal.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nothing dangerous.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Just supplies.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik sits there with that realization.</Text></Paragraph>
    <Paragraph Type="Action"><Text>All night he has been building one story in his head. And this is another one.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel comes back to the driver’s window.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RACHEL</Text></Paragraph>
    <Paragraph Type="Action"><Text>Appreciate you sticking with us.</Text></Paragraph>
    <Paragraph Type="Action"><Text>She hands him an envelope.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik takes it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Looks inside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Cash.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Enough to matter.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He looks past her at the room</Text></Paragraph>
    <Paragraph Type="Action"><Text>coming together.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Kids’ tables.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Snack boxes.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Plants.</Text></Paragraph>
    <Paragraph Type="Action"><Text>A handmade sign.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev catches him looking.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>You thought we was doing crime,</Text></Paragraph>
    <Paragraph Type="Action"><Text>didn’t you?</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik doesn’t answer.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev laughs.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That’s crazy.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Tiffany passes behind them carrying rolls of tape.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>He absolutely thought that.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Even Rachel lets herself smile</Text></Paragraph>
    <Paragraph Type="Action"><Text>now.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico closes the empty case and</Text></Paragraph>
    <Paragraph Type="Action"><Text>walks toward a planter bed beside</Text></Paragraph>
    <Paragraph Type="Action"><Text>the entrance like this</Text></Paragraph>
    <Paragraph Type="Action"><Text>was the plan all along.</Text></Paragraph>
    <Paragraph Type="Character"><Text>ENDING</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik finally lets out a breath he’s been holding for half the movie.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Eventually Malik discovers the truth.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The passengers are organizing a community fundraiser.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The mysterious stops were supply pickups.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rico’s case contains gardening tools.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BABY MAMA HOUSE</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik pulls up.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Son waits in the window.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik walks up with food bag. Door opens.</Text></Paragraph>
    <Paragraph Type="Character"><Text>SON</Text></Paragraph>
    <Paragraph Type="Action"><Text>Love you Dad.</Text></Paragraph>
    <Paragraph Type="Action"><Text>They hug.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Son runs inside.</Text></Paragraph>
    <Paragraph Type="Action"><Text>BABY MAMA appears. Hey.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Hey.</Text></Paragraph>
    <Paragraph Type="Character"><Text>MOTHER MALIK</Text></Paragraph>
    <Paragraph Type="Action"><Text>She starts closing the door. Malik stops it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Hands her $200.</Text></Paragraph>
    <Paragraph Type="Action"><Text>She looks at the money.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Thank you. Door closes.</Text></Paragraph>
    <Paragraph Type="Character"><Text>MOTHER</Text></Paragraph>
    <Paragraph Type="Character"><Text>FINAL DRIVE</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik drives away.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Music low.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He mouths the words.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The chorus hits.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Now he sings.</Text></Paragraph>
    <Paragraph Type="Action"><Text>He stops at a stop sign.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Takes off his jacket.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Throws it into passenger seat.</Text></Paragraph>
    <Paragraph Type="Action"><Text>People on the corner hear the</Text></Paragraph>
    <Paragraph Type="Action"><Text>music.</Text></Paragraph>
    <Paragraph Type="Action"><Text>They vibe with it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Light turns green.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik drives.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Chicago sliding past outside.FADE OUT.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT Traffic drifts around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody in the back seat seems concerned. Malik keeps driving.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The city keeps watching.</Text></Paragraph>
    <Paragraph Type="Scene Heading"><Text>INT. MALIK’S SUV – MOVING – NIGHT</Text></Paragraph>
    <Paragraph Type="Action"><Text>Traffic thickens around them.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody says anything for a stretch. That silence has weight.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik checks the mirror.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Dev notices.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>You keep looking back there like we owe you money.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Don’t start.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>I’m not starting. I’m observing.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RACHEL</Text></Paragraph>
    <Paragraph Type="Action"><Text>Can everybody just let him drive.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Taxodium distichum.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>See, now the tree man starting.</Text></Paragraph>
    <Paragraph Type="Character"><Text>TIFFANY</Text></Paragraph>
    <Paragraph Type="Action"><Text>What is that one?</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>Bald cypress.</Text></Paragraph>
    <Paragraph Type="Character"><Text>DEV</Text></Paragraph>
    <Paragraph Type="Action"><Text>That sound fake.</Text></Paragraph>
    <Paragraph Type="Character"><Text>RICO</Text></Paragraph>
    <Paragraph Type="Action"><Text>It is not fake.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik says nothing.</Text></Paragraph>
    <Paragraph Type="Action"><Text>But he hears all of it.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The dashboard glows in the dark.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The map reroutes.</Text></Paragraph>
    <Paragraph Type="Character"><Text>BEEP.</Text></Paragraph>
    <Paragraph Type="Character"><Text>NEW STOP ADDED.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Malik sees it immediately.</Text></Paragraph>
    <Paragraph Type="Action"><Text>His grip on the wheel tightens</Text></Paragraph>
    <Paragraph Type="Action"><Text>just a little.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Rachel finally looks up long</Text></Paragraph>
    <Paragraph Type="Action"><Text>enough to notice that he noticed. Then she looks back down.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The music keeps playing low.</Text></Paragraph>
    <Paragraph Type="Action"><Text>Nobody explains anything.</Text></Paragraph>
    <Paragraph Type="Action"><Text>The car keeps moving.</Text></Paragraph>
