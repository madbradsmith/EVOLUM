<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="5">

  <Content>
    <Paragraph Number="1A" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="1" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. beACH HOUSE - BATHROOM - niGHT</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We see two women in a bathroom fighting, but we can’t really tell who they are. One of them grabs a gun.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We cut to black. We hear a gunshot and a woman scream!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="Bold">TITLE CARD: “WOMAN”</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="1" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="1" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. skyline - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We see a beautiful aerial shot of the Los Angeles skyline.</Text>
    </Paragraph>
    <Paragraph Number="2" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="1" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. fancy restaurant - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMERA - Pans from the sky, onto a beautiful restaurant.</Text>
    </Paragraph>
    <Paragraph Number="3" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="VOICE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WAITER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. faNCY RESTAURANT - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - A waitress, carrying a tray of food over to a nearby table where we see our leading lady, SKYLER HASTINGS, 30’s beautiful, confident woman, sitting alone.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The waiter sets the food down at a nearby table. Skyler checks her watch.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She looks up. She sees a bouquet of long stem RED ROSES in her face. A voice from behind the roses speaks.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Voice</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Congratulations baby.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The roses move revealing Skyler’s husband KENNETH HASTINGS, handsome, clean cut man. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Kenneth</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sorry I’m late. Traffic.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Skyler</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kenneth you’re never on time. But I still love my handsome husband.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well at least you know I’m consistent.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you for the roses. My favorite.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So, I did good?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler blushes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You did. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth leans in for a kiss. He looks Skyler deep into her eyes. You can see the love these two have for each other is real.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you so much Skyler Hastings.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you too Kenneth Hastings.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No one deserves this promotion more than you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh thank you baby.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So. How does it feel? Finally moving up at the firm. It’s long overdue.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah. Ten years now, I better had got a bump up.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler laughs. Kenneth sits. He catches a nearby waiter.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Excuse me</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">.</Text>
      <Text> But can I have a bottle of your finest champagne.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Waiter</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yes </Text>
      <Text>sir, I know just the bottle.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Only the best for the best right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Somebody is trying to get some tonight.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think you’re correct.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both share a laugh.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DisSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="4" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="3" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. club - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing. We hear new music bumping!</Text>
    </Paragraph>
    <Paragraph Number="5" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. faNCY RESTAURANT - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>In the middle of the dance floor, we see Skyler and Kenneth dancing with each other, sweaty, having a great night with just the two of them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We haven’t done this in a while.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sometimes you gotta just let your hair down and live, not just be alive! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You right about that.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler looks deep into his eyes. They share a kiss.</Text>
    </Paragraph>
    <Paragraph Number="6" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. clUB - bathroom - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Kenneth make love against the door of the bathroom. They climax. Both of them start laughing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(out of breath)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That was amazing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkyLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In a club bathroom? I feel like we’re back in college.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you so much.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you too handsome.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The passion the two share is written all over their faces. </Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="7" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="4" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hastings home - moRNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMERA - Pans across a beautiful mansion with a couple fancy cars parked in the driveway.</Text>
    </Paragraph>
    <Paragraph Number="8" Type="Scene Heading">
      <SceneProperties Length="2" Page="4" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - bedroom - bed - moRNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler sleeps in her all white bed, under her fluffy blankets.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - An all dressed up Kenneth in a tailored suit. He has two cups of coffee in his hand.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He walks over to the bed and sets on of the coffee’s down on Skyler’s night stand.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good morning sleeping beauty.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler shuffles a little in her sheets. She rises up out of the blanket to look at her man.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I had a little too much to drink last night.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You had a lot of too much to drink Sky.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both share a giggle.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good thing is you don’t have to be in the office at 7AM like me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well that’s what happens when you’re the boss.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Not the boss yet. Hedge fund manager ain’t the boss. Because if I were the boss, I could go into the office whenever I wanted. “If” I even went in at all.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well manager. </Text>
      <Text>You’re a leader</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, and that’s better than being the boss. Plus, you make the big bucks.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Aww Sky you always know how to make everything sound better.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth leans in for the kiss. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Enjoy your coffee baby.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I got my own little Starbucks right at home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s right. And as long as you got me you don’t ever need nothing else.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler looks at her man.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re right about that.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They share a kiss.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you, I’ll call you when I get to work.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler grabs the side of her stomach. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You okay babe?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah you know my side has just been bothering me lately.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We should get that checked.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No thanks. I hate doctors. I’ll be fine it’s nothing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay baby well I’ll call you on my break.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay baby. I love you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Love you too.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth exits. Skyler takes a sip of her coffee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ooh that’s good.</Text>
    </Paragraph>
    <Paragraph Number="9" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="6" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hASTINGS HOME - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="10" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="6" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - kitchen - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler enters the kitchen on the move, coffee in hand, a Sports Magazine in the other.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She checks her watch, takes her last sip of coffee, puts the cup on the counter and walks out.</Text>
    </Paragraph>
    <Paragraph Number="11" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="6" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. the firm - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="12" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="6" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. thE FIRM - hallway - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler steps off the elevator, ready for work. Her walk is mean and her confidence is high. All the employees around, acknowledge her with “hellos” and “congratulations”. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler smiles and waves on her way to her new corner office.</Text>
    </Paragraph>
    <Paragraph Number="13" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="6" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. the FIRM - skyler’s office - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks up to her office. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ON THE DOOR - It reads; </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="Bold">Skyler Hastings, Executive Agent.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler smiles. She walks inside the office.</Text>
    </Paragraph>
    <Paragraph Number="14" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. skyler’s office - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Inside waiting for Skyler is her assistant KIM McDONALD, 30’s beautiful with a big personality.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Kim</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hello Ms. Executive Agent. How does it feel girl? You </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">movin</Text>
      <Text>’ up in the game. I’m so happy for my </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">friieennnd</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you girl. It feels good to be recognized you know? Especially as a woman in this male dominating game.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well you did sign the number one NBA draft pick. I mean how many “women” can say they did that?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know one that can.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The women both do a special handshake.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Honestly Sky, this office is next level. I’m proud of you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Kim. One day it will be yours when I move up to partner.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ohh girl, that’s the plan.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well speaking of the number one NBA draft pick. He’s here to see you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give me five minutes to take this all in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You got it boss.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kim exits. Skyler looks around. She takes a moment to embrace her new office. She walks around to the desk and sits behind it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And they said a Woman couldn’t do a man’s job.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Note: (We hear Skyler’s voice over the next scene)</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nike offered 50 million up front. They were the highest offer. </Text>
    </Paragraph>
    <Paragraph Number="15" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEBORAH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="JEFFERY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. skYLER'S OFFICE - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler talks, as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">JEFFERY</Text>
      <Text> DUNCAN, 22 year old Basketball rising star, sits across from Skyler with his mom DEBORAH DUNCAN, 50’s tough.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Adidas and Under Armor both were a little under 15. But Sneaker House is willing to give you a 20% stake in the entire company for perpetuity.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JEFF</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">E</Text>
      <Text>RY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That sounds good.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deborah</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>50 million dollars upfront sounds better. I say we take the money. We don’t know what the future will be with this new company.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s one way to think about tings. and you’re not wrong for that. 50 million is a lot of money. But that 50 million is an advance that will need to be paid back at some point. So you’ll be in debt before you even start your NBA career. So you either bet on yourself with the new company or you settle for a 50 million dollar loan. Your choice.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>There’s a small beat. Then Deborah smiles. She looks at </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Jeffery</Text>
      <Text>, then back at Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBORAH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’re gonna go with the Sneaker House deal. I trust that my son won’t regret it, and that he’s in the right hands.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This deal is going to change his life.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBORAH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You good with it son?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">JEFFERY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I trust you mom. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBORAH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And I trust Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll get them on this after noon to start paperwork.</Text>
    </Paragraph>
    <Paragraph Number="16" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="9" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. the FIRM - HALLWAY - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Jeffery and his mom are exiting the office. Skyler says goodbye.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text>Kim walks up with her iPad ready to take notes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay I need Mr. Cunningham from Sneaker House on right away. We need to close this out no later than Wednesday. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got it. Anything else?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. Drinks tonight at the Lounge. Make sure Camilla’s there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Gotchu.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And some Ginger Ale. My stomach is killing me.</Text>
    </Paragraph>
    <Paragraph Number="17" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="9" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. the lounge - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A nice lounge/bar Establishing. Nice cars are out front. Skyler pulls up and get out. She walks in.</Text>
    </Paragraph>
    <Paragraph Number="18" Type="Scene Heading">
      <SceneProperties Length="2 4/8" Page="9" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="CAMILLA/KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. the lounge - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMERA - Follows Skyler to a nearby table where Kim and CAMILLA JAMES, beautiful, confident woman in her 30’s, Skyler’s best friend, both are waiting for her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sorry I’m late guys. I had some last minute office work.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Camilla</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Girl please it’s Friday night. Me and Kim are already three drinks in. You right on time.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Ayyyyeee</Text>
      <Text>. Well I need to catch up then.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Have a seat. Kim ordered the appetizers.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You got the potstickers?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know I did.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A waiter brings a round of drinks to the table. He puts two drinks in front of Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Time to catch up girl.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They all laugh. The waiter walks away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So what’s going on Cam? </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">How are things over at Room One?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well the company is doing a big shift. Instead of social media marketing, they’re going into management, which I know nothing about. But you know me, I can learn anything and be good at it girl.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">That’s what I always admired about you. You can be good at everything. You know me I’m just good at one thing.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KiM</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">But you’re the best at it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">(to Kim)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Thank you Kim.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">(to Camilla)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">So y</Text>
      <Text>ou and Lance still planning that trip to Tahiti? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CamILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know that man don’t know how to do nothing else but spoil me. I’m so blessed. He’s everything girl.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Kim</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And here’s where I feel like the third wheel. The only one not married. You love sick puppies.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh don’t worry K, I got somebody that’s perfect for you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No offense Cam but your taste in men is a little sketchy.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please my Lance is amazing, handsome, loving.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And yours. But when it comes to </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">hookin</Text>
      <Text>’ ya girl up. You’re like zero for 10.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I have to agree with Kim on this one. The last guy you set Kim on a date with had 6 kids and three baby mamas. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh please he had a good job and was that fine.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Kim</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He brought three of his kids with us on the first date.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe he wanted y’all to bond.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla laughs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know what, you wrong for that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t worry Kim patience and prayer is all you need. And when Mr. Right walks into your life, you will know it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler raiser her glass.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>To Mr. Right.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla and Kim raise theirs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA/kim</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>To Mr. Right.</Text>
    </Paragraph>
    <Paragraph Number="19" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. the LOUNGE - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMERA - Pans from the lounge, onto the night sky. </Text>
    </Paragraph>
    <Paragraph Number="20" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. city of los angeles - niGHT/day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We watch the sun rise over the city.</Text>
    </Paragraph>
    <Paragraph Number="21" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="12" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hastINGS HOME - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="22" Type="Scene Heading">
      <SceneProperties Length="2 2/8" Page="12" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is in bed sleeping.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Skyler at the door, walking in with coffee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wake up sleeping beauty.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks over and puts the cup of coffee on the night stand by where Kenneth is still sleeping. Kenneth rolls over.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What time is it?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>9.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me get another 30 minutes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, you said to wake you up at 9. You know we have plans baby, and I don’t like to be late.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>After you make the coffee</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">,</Text>
      <Text> I’ll get up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Already done.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wow, my baby is always on top of it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I would be on top of you if you would wake up.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth grabs Skyler and pulls her in the bed.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How bout we cancel the plans and plan a bedroom day.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think I can get with that plan.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">They kiss.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">So have you thought about it yet?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">What?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler playfully hits Kenneth.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Don’t act like you don’t know what I’m talking about.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Okay, okay, yes. I thought about adopting. But I don’t know. Maybe kids just wasn’t in the cards for us. But I love you. And I’m happy with you, regardless of you not being able to have kids. It doesn’t make me love you any less. And I don’t wanna talk about this today. I wanna talk about my beautiful wife.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler tears up.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Thank you baby. You’re so amazing. You always know the right thing to say. I’m so blessed.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Not as blessed as me.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">They kiss again. </Text>
      <Text>The two kiss and fall under the blankets. Skyler’s phone rings. She climbs from out of the blanket and looks at her phone.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CLOSE ON - Phone. It says “Bestie” calling with a picture of Camilla smiling.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler presses the ignore button and goes back under the blankets. But the phone rings again.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Frustrated. Skyler grabs her phone again.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s Camilla babe I gotta take it. She doesn’t ever call twice unless it’s important.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler picks up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Girl this better be good, you interrupting husband and wife time.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, Skyler’s impression changes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? Oh my gosh are you serious? okay, just calm down Cam, I’m on my way.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler hangs up the phone. She looks at Kenneth. He knows it’s something bad.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>SMASH CUT TO:</Text>
    </Paragraph>
    <Paragraph Number="23" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. camilla’s house - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We see a beautiful house with a few nice cars in the driveway. We hear Camilla crying.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I can’t believe this.</Text>
    </Paragraph>
    <Paragraph Number="24" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="14" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. camilla’s house - living room - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla is a mess. She has a bunch of tissues next to her on the couch. Skyler sits right next to her, rubbing her back.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I never would have ever thought Lance would cheat on me. Like what, am I not good enough?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t you do that Cam. You’re more than enough. He’s the one that’s not good enough for you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Then why is he the one who slept with someone else?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because he’s an idiot. And lost the best woman any man could have.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just don’t know what to do Sky.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> I took a leave from my job, I can’t work, I can’t eat. I just wish this was all a dream and that I would wake up already. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Come here.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler just rubs Camilla’s back as she cries on her lap.</Text>
    </Paragraph>
    <Paragraph Number="25" Type="Scene Heading">
      <SceneProperties Length="2 3/8" Page="15" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. hASTINGS HOME - dining room - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is sitting at the dinner table. There’s candles lit. Skyler enters with a roast.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So we’ve been married for 8 years. Whenever I get this treatment, there’s something that goes with it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Baby why can’t I just cook for my husband and it not be something?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because you don’t cook unless it is something. And it must be something big because you also lit candles.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay you’re right. I need to ask you something.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Anything babe.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s Camille.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What about her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s getting a divorce. Her husband cheated on her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? Lance? Mr. Perfect himself? I can’t believe it. With who?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>With his boss.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Christine? Oh gosh this is too much. Christine ain’t even a baddie. Plus she’s like 20 years older than him. I’m surprised her stuff still work.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay I’m sorry. Let me stop.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just feel so sorry for her. Her entire life is about to change.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s so sad. So what does any of that have to do with you buttering me up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well I was thinking she can stay with us? Just for a short time until she feels better. She can’t stay there, everything is in Lance’s name and he’s not leaving.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Baby I can barely deal with you. I can’t handle two women in the house. Can’t she get a hotel? She can afford that right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kenneth be serious. She’s a wreak right now. And she needs to be with people she loves. I don’t think it’s wise for her to be alone right now.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But babe.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please honey.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth takes a deep breath.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess she can stay in the guest house.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, she’s your best friend since </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">you guys</Text>
      <Text> w</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ere </Text>
      <Text>in college. I would never expect someone like you to leave your friend hanging.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh my gosh thank you so much for understanding baby.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler grabs Kenneth’s face and kisses him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re the perfect man.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Only for the perfect woman.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They share another passionate kiss.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="26" Type="Scene Heading">
      <SceneProperties Length="2 4/8" Page="18" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hASTINGS HOME - back house - mORNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla wakes up. She looks out the window. She looks a mess. There’s a knock on the door. Camilla looks toward the door.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Come in!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>In walks Skyler and Kenneth. Skyler is holding a cup of coffee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know you like yours black with no sugar.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla starts crying.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lance liked his coffee black. I just went along with it. I was never a coffee person.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler looks at Kenneth. She hands Kenneth the coffee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Our home is yours Cam. We’re here for you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Ken.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll let you two talk.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth exits. Skyler grabs Camilla’s hand.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How you holding up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is the worse thing that’s ever happened to me. I feel numb like I don’t even exist.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry Cam. I can only imagine how you must feel. You and Lance have been together longer than me and Ken. I couldn’t imagine how I’d feel if Ken did something like this.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well with your perfect man, and perfect life, you’ll never have to go through this. He only has eyes for you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kenneth is a good man. But no one is perfect. We have our differences.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Are you kidding me? You guys are like the ideal couple. People could be envious. Honestly, I always wanted Lance and I to be like you two. Perfect. But we just weren’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam no one is perfect.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler looks at Camilla.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m just saying, some people could look at your life and want it. And here I am intruding on your fairy tale life with my problems.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Listen. Kenneth and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I</Text>
      <Text> are your family. We’re here for you. You’ll be fine.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know I’m sorry, I’m just going through a lot of emotions. Just ignore me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Listen. I know this is hard. You can stay as long as you need to. And you don’t have to worry about anything. We gotchu.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They embrace.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll take a glass of wine if you have it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh say less. You know Kenneth has an entire collection. I’ll break out the good stuff.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler gets up. She grabs her side and winces in pain.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You okay Sky?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m good, just lower back pain, but I’ll be fine. Listen. Kenneth has his annual fundraiser tonight. Why don’t you come, </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">it’sll</Text>
      <Text> be fun, get your mind off of things.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know. You guys go, I’ll just stay here and be bored.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Since when does Skyler Hastings take no for an answer?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh girl and I have just the outfit for you.</Text>
    </Paragraph>
    <Paragraph Number="27" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - FOYER - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth and Skyler are dressed fancy. They look amazing. Kenneth has on a black tux with a white tie, while Kyler dazzles in a white gown.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You sure she should go? I mean Lance is one of our main sponsors. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I thought you said he wasn’t gonna be there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know but what if he shows up? Don’t you think that will be a little awkward.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well it’s too late now Ken I already convinced her to go</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, and you said he wasn’t coming earlier. Make up your mind.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, we hear Camilla clear her throat.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Camilla as she stuns in a grew gown. Both Kenneth and Skyler’s mouths drops. Camilla looks absolutely gorgeous. You can see Kenneth’s attraction to Camilla, although he tries to hide it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wow, you. You look amazing Cam.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Didn’t I tell you that was the one girl. You </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">killin</Text>
      <Text> it right now. Whaaat? Who are you and what did you do with my best friend?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Camilla laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Stop it girl.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No really. You look amazing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s right Cam, you look beautiful.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well thank you both. And thanks Sky for inviting me. I feel I may need this.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler doesn’t see it, but Kenneth and Camilla make quick eye contact. It’s not just friendly either. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. Look at the time. Shall we all get going ladies?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let’s go.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They all exit the home.</Text>
    </Paragraph>
    <Paragraph Number="28" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="22" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. mansion - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> The pool and fountains run the beautiful waters.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="29" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="HENRY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. manSION - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>It’s a black tie event. The party is elegant. Everyone is dressed their best. You can see the money spilling off everyone in attendance. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">People in black vest, walk around serving cocktails and </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">horderves</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Skyler and Kenneth as they mingle with people.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The band playing good music.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is pulled aside by HENRY BRADSHAW, 60’s African America male.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Henry and Kenneth talk over to the side.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Henry</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Great job Ken. You’ve already raised 25 million.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well I’m very confident we will hit the mark of 50.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe even more.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s the idea.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Henry winks. He pa</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ts</Text>
      <Text> Kenneth on the shoulder.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HeNRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Enjoy the rest of your night.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - Camilla as she grabs a martini off one of the plates being served as they walk by. She downs it quickly as Skyler approaches.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Slow down girl, we just got here. And you know how you get with too much alcohol.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You know I drink more when my anxiety is high.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I know. But you and liquor have never gotten along well.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You right about that.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">The girls laugh.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I notice you been drinking a lot more lately.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I know it’s just this whole thing with Lance. But I’ll slow down.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You better. And especially in this kind of environment, it might be better to not drink.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Thank you Sky. It really means a lot for you to be there for me right now.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">That’s what friends are for.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla smiles.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You’re the definition of a best friend.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DISSOLVE TO:</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="29A" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="23" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LANCE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. mANSION - niGHT - laTER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth is talking with a colleague, </Text>
      <Text>as Camilla approaches. She’s a little tipsy. She hugs Kenneth. Kenneth feels awkward and kinda pushes her away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KenNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, hey. Are you good? Maybe a little too much to drink?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just wanted to thank you and Sky for letting me stay here and allowing me to come out tonight. It really helped.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well like I said, we’re here for you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla rubs Kenneth’s hand. Ken looks at Camilla. He takes his hand back.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Should I call you an Uber?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No I’m fine, I just need a restroom.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s right over there.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keneth points to the rest rooms. Camilla gives Kenneth a flirty smile.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Great. I’ll be right out. I mean it. Thanks.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla walks away. Kenneth takes a deep breath.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Camilla as she walks towards the ladies room. She bumps into LANCE, her ex-husband.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Lance</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam. He- Hey. How are you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lance. What the hell are you doing here?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>LANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I wasn’t supposed to come tonight. I missed my flight so I decided to show my support for Kenneth. And I didn’t expect to see you here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well you came, now you can go.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> You’re dead to me, you cheater!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>LANCE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please don’t make a scene Cam. I. I’m really sorry about everything.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Excuse me, I gotta go.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla hurries away</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Skyler, who notices. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>SKYLER POV - Lance standing there.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler follows Camilla over to </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">the side.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps"></Text>
    </Paragraph>
    <Paragraph Number="30" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="25" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">eXT. manSION - niGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla is crying in the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">corner</Text>
      <Text>. Skyler </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">walks up</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam? </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">you okay?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps"></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla doesn’t respond.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I saw Lance. I’m so sorry you had to run into him. I din’t know he was coming.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I just wish I could disappear forever.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh Cam</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler grabs Camilla and embraces her. Skyler picks Camilla’s head up and looks at her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Let’s get out of here. This event is boring anyway. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler grabs her side.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You okay Sky?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah I’m fine. I’m good.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly Skyler passes out.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="31" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="26" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. hoSPITAL - hallway - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth rushes through the hallway. He rushes into the room.</Text>
    </Paragraph>
    <Paragraph Number="32" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DR. REYES">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoSPITAL - ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is in the room with Skyler, who’s in the bed, and Camilla, standing over by the door.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam what happened?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We were talking and all the sudden she grabbed her side, and then passed out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>DOCTOR REYES 40’s walks in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Dr. reyes</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay Mrs. Hastings. Your blood work came back. Turns out you have kidney stones. Now normally these aren’t too serious. Just a small </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">emergency surgery to remove the stones, </Text>
      <Text>and you’re good.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So she’s gonna be okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well Mr. Hastings, these are very common. She’ll be fine. There’s nothing to worry about. Sometimes they pass through, but with the size of this one, we need to perform surgery to remove them. But I can assure you, she’ll be okay.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Great. That’s great news.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So after the surgery I can go home the same day?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Dr. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>As a matter of fact yes, most times you go home the same day, unless there’s complications. But I assure you there’s nothing to worry about. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Doctor.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So what happens next?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Dr. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She should go home, get some rest. We will schedule her surgery in the next few days.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Skyler)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But take it easy Mrs. Hasting. Drink lots of water.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What about coffee? I gotta have my coffee.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler laughs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Coffee is okay. Not too much though okay.</Text>
    </Paragraph>
    <Paragraph Number="33" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The car pulls up.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth gets out and rushes over to the passenger side to help Skyler out of the car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you baby.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla hops out the back seat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You good? I know you’re helping me but now I gotta help you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The girls share a laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s what besties are for right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Period.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They all walk inside.</Text>
    </Paragraph>
    <Paragraph Number="34" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="28" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. sunset </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The sun sets over the city and rises again.</Text>
    </Paragraph>
    <Paragraph Number="35" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="28" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>eXT. hoSPITAL - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="36" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="28" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. hoSPITAL - ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is in the room prepped for surgery. She’s in scrubs, laying in the bed. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Kenneth, who’s also in scrubs, right next to her, holding her hand.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Camilla, as she gives a forced smile.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DISSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="37" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DR. REYES">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoSPITAL - waiting room - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth and Camilla both sit, anxiously in the waiting room.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Dr. Reyes walks out. Kenneth and Camilla both get up and walks over to the doctor.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So how’d it go? Is she good?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Dr. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. The surgery was successful, but there was a small complication. The stones were a little larger than we originally thought.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So what does that mean?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nothing to worry about. We are just going to keep her a few days for a safety precaution, and she’ll be able to go home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So she has to stay in the hospital for two more days?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth sighs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can I see her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REYES</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sure.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I’ll wait out here.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Okay.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="38" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="29" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoSPITAL - ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is lying in the bed, hooked up to an IV. Kenneth enters.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey babe.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey baby. So they told you I gotta stay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah. But it’s just to make sure you’re okay.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I feel fine. I need to be going home. I’m missing important business being here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">The Doctor said at least a week baby. </Text>
      <Text>You need to listen to the Doctor’s. It’s time to slow down. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know. But you know me, I hate not being able to do what I want.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well in a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">week </Text>
      <Text>you’ll be back to normal.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So where is Cam gonna go while you’re in the hospital?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What do you mean?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I mean is she staying at a hotel? I don’t want her staying with me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why not baby I already told her she could stay with us. I can’t just un invite her now.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well things were different when you told her that. I’m sure she’ll understand. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ken don’t do that. She’s my best friend and she’d in the middle of a divorce. I can’t just put her out.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess that’s true. Well other than work, i’ll be here as long as visiting hours will let me be. She can do whatever she wants at the house. She has </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">instacart</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nah, she’s family. I got her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you.</Text>
    </Paragraph>
    <Paragraph Number="39" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="30" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hasTINGS HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A tired Kenneth walks in the house and drops his keys on the table. He hears music coming from the kitchen. He also hears singing. He takes off his coat and walks into the kitchen.</Text>
    </Paragraph>
    <Paragraph Number="40" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="31" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - KITCHEN - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>To Kenneth’s surprise, a half dressed Camilla is bending over looking inside the refrigerator, singing to the music. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla is startled. She quickly turns around and accidentally spills her drink on her breast. Now you can see through her shirt. Camilla is a little tipsy.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh my gosh! I’m so sorry Ken I didn’t think anyone was home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s okay. Just.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth looks at Camilla’s sexy half dressed body.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s my fault I should have announced myself.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t be silly this is your house. I should be in the guest house. I just. I was thirsty so I came inside to grab some wine.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s fine. I’ll just.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both try to walk away from each other but end up bumping into one another awkwardly.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla rushes away toward the back house. Ken takes a deep breath. He gathers himself and walks toward the stairs.</Text>
    </Paragraph>
    <Paragraph Number="41" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="31" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth lays in bed alone, starring at the ceiling. He gets a few flashbacks in his mind.</Text>
    </Paragraph>
    <Paragraph Number="42" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="31" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - KITCHEN - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>- A half dressed Camilla is bending over looking inside the refrigerator. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>- They both try to walk away from each other but end up bumping into one another awkwardly.</Text>
    </Paragraph>
    <Paragraph Number="43" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>BACK TO PRESENT -</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KENNETH - Turns around and faces the window. He picks up his phone and calls Skyler. No answer.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The doorway. Camilla stands there holding a bottle of wine and two glasses. She’s now in a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">cute little top with no bra and booty shorts</Text>
      <Text>.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Hey. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry Ken, I feel bad for earlier. I really didn’t think anyone was here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s all good.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just made a little bite to eat</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. </Text>
      <Text>You hungry?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I</Text>
      <Text>’m a little hungry.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Ken </Text>
      <Text>I don’t want things between us to be weird. I mean come on, we’re practically family.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ken softens.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s true. </Text>
    </Paragraph>
    <Paragraph Number="44" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="32" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing. We hear laughing.</Text>
    </Paragraph>
    <Paragraph Number="45" Type="Scene Heading">
      <SceneProperties Length="1 7/8" Page="32" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - liVING ROOM - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ken and Camilla are on the couch eating a nice meal, sipping wine, both a little drunk. Kenneth finishes up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks. This hit the spot.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla takes his plate and walks into the kitchen. She pours herself some more wine. She walks back and sits on the couch. They both drink as they talk.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So Sky comes home tomorrow. You excited?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah, it has been weird without her home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know the feeling. Lance and I did everything together. A moment without him felt like an eternity.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I really am sorry Cam. I know you guys really loved each other. I just don’t get why he would do this.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well I loved him. Not so sure how he felt about me after what he did.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, things happen. People make mistakes. Doesn’t mean he didn’t love you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know I try to tell myself that over and over so I can sleep at night. The thing is, I could have passed it off as a mistake, if it was just “one” mistake. But he asked for a divorce.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> I mean I just feel like am I that horrible of a person for him to wanna leave me?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Cam, you’re beautiful, smart, and you’re a great person. If Lance couldn’t see that, then he didn’t deserve you anyway.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">That means so much coming from you.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">There’s a moment. It’s broken quickly with Kenneth changing the subject.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">So, do you think he’s gonna be with her?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I can only assume so</Text>
      <Text>. And that’s what I can’t get over. All the times we shared together. All the ups and downs we went through to make it to the other side. I guess they meant nothing.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla starts to cry. Kenneth </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">grabs her and lets her cry on his chest</Text>
      <Text>. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">He grabs her shoulders and looks at her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, you’re gonna get through this. And like Sky promised. We’re here to help you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks Ken. You’re </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">such </Text>
      <Text>a good man. Sky is so lucky to have you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth smiles. Camilla </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">slowly moves in and kisses Ken on the cheek. She </Text>
      <Text>gets up and walks toward the back door to leave.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thanks for listening.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Anytime.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla walks out of the room. Kenneth downs his glass of wine.</Text>
    </Paragraph>
    <Paragraph Number="46" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="34" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="47" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The clock. It reads; 3:30AM.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A hand, gently caresses Ken’s shoulder. Ken turns around to see the hand belongs to CAMILLA.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What are you doing?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shhh.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla pulls her finger up to Ken’s lips and seductively moves her finger from his lips, down to his chest. Camilla then kisses Kenneth. As much as Kenneth wants to fight, he can’t. He gives in and starts kissing her back.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="48" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - bEDROOM - BED</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth wakes up. He turns to see CAMILLA, sleeping right next to him. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">He says to himself.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">This can’t be real.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla wakes up.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Hey.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Cam, what happened last night?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We happened.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla tries to rub Kenneth’s shoulder. He quickly moves.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Don’t. </Text>
      <Text>Skyler will kill us both.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">It’s a little too late to think about Sky don’t you think?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I need you to leave now. Whatever happened last night was a mistake. I had way too much to drink and I honestly don’t even remember any of it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">This hurts Camilla.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">No you wanna act like you don’t remember? So what are you saying? I wasn’t good enough? Guess I’m just not good enough for anyone.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Ken feels bad for the comment.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">That’s not what I meant.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Then stop acting innocent Ken.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly Ken’s phone rings.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CLOSE ON - The phone, it’s Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t say anything.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla puts her finger up to her lips and smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey babe.</Text>
    </Paragraph>
    <Paragraph Number="49" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoSPITAL - ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is all ready to leave the hospital.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey handsome. You on your way?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>INTERCUT PHONE CONVERSATION BETWEEN SKY AND KEN -</Text>
    </Paragraph>
    <Paragraph Number="50" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to Ken.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You already know baby I’m getting ready now.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> I miss you and can’t wait to see you baby I’ll be there soon. Okay, I love you.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="51" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hosPITAL - ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">On </Text>
      <Text>Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you too.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler hands up. She smiles.</Text>
    </Paragraph>
    <Paragraph Number="52" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="36" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to Ken and Cam.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Like I said. We made a mistake. I love Skyler and would never hurt her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">But you did.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">(beat)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Hurt her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I want you to get out of my house!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Cheater!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m telling Sky you can’t stay here anymore.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really? And I’ll just tell her that you screwed her best friend </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">at</Text>
      <Text> her lowest point. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We are both just as wrong in this situation.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah but who do you think she’ll be more mad at? Huh? Me or you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Are you insane?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Actually I’m not. I can’t believe me and my best friend are in the same predicament. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I said get the hell out of my house, before I throw you out!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">!</Text>
      <Text> I’m hurt</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. </Text>
      <Text>because the man I fell in love with hurt me. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">But then</Text>
      <Text> you saw me</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> last night</Text>
      <Text>. You saw my pain and you wanted to help. And you helped me last night Ken</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> and I thank you for that. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla gets an attitude.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">But like you said, it was a mistake.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla gets up. Kenneth grabs Camilla.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Sky can never know about this.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why would I want her to know that I slept with her husband? No. We keep this as our little secret. You go pick up Sky from the hospital and continue with life as normal. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You don’t need to be here when we get back.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla exits.</Text>
    </Paragraph>
    <Paragraph Number="53" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="38" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hoSPITAL - WAITING ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth sits, waiting. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The door as it opens. Skyler walks out. She’s super happy to see her man. Kenneth is happy as he can be, knowing the situation. They meet and hug in the middle of the waiting room. Skyler kisses Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey baby, I missed you so much. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I missed you too baby.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How’s Cam?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s uh. Actually she’s good. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">She said she wanted to be alone so she’s getting a hotel.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh no Ken</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. I already told you she shouldn’t be alone right now.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">S</Text>
      <Text>he’ll be good</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. Once you’re better you can go see her at her hotel, okay.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They hug again.</Text>
    </Paragraph>
    <Paragraph Number="54" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - foyer - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Kenneth both walk inside the home to a beautiful floral arrangement. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is in shock. Skyler is in awe.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh my gosh Ken this is beautiful. Thank you. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler kisses Kenneth. She rushes over to the arrangement in the middle and reads the note.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The noter. It reads; </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="Bold+Italic">“To my Sky. I missed you so much. Welcome home baby.”</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Baby this is amazing. You’re the best man any woman could ever have.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth plays along.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And you’re the best woman.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They hug.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KENNETH POV - Camilla stands down the hall, staring. She gives Ken a grin and puts her finger up to her lips as to say “SHHH”.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">walks in. She</Text>
      <Text> </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">has some sexy bottoms on.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Cam, you’re here? Ken said you went to a hotel.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I stayed to see you when yo got home.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well good, I’m not letting you stay at a hotel. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I don’t want to over stay my welcome. But, I mean I’ll stay if you want Sky, if it’s okay with you Ken?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Sure. Our house is yours, as long as you need.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="55" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="40" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. thE FIRM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="56" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="40" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. thE FIRM - skYLER'S OFFICE - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is in her office talking to Kim.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And Turner was caught in the mailroom with Tracy. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shut up. Turner and Tracy? But they walks around like they hate each other.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well apparently they don’t.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Both ladies laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s so good to have you back. It’s been dead around here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kim you act like I been gone for months, it’s only been a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">week</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well it felt like months.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(beat)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t wanna dig, but how’s Cam? She doing better?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>As a matter of fact yes. She’s a lot better. She’s at least up and moving again. It’s been cool having her company.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well you was in the hospital for a few days right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s that supposed to mean?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sayin it couldn’t been that cool, you wasn’t even there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shut up Kim, you’re crazy.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> Stop putting wrong thoughts in my head.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Anyway. You got a 12 o’clock lunch with Madison from the Lakers, they wanna talk about </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Jeffery</Text>
      <Text> deal terms. And we also have drinks </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">at the lounge </Text>
      <Text>tonight at 7. Don’t be late this time.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I won’t.</Text>
    </Paragraph>
    <Paragraph Number="57" Type="Scene Heading">
      <SceneProperties Length="1" Page="41" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">the lOUNGE - dAY</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Camilla as she and Kim sit at the table. Skyler shows up fashionably late as usual. She finds the women at the table. She walks over.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey ladies.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Kim</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Late as usual.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You said 7 Kim it’s 7:15, everyone knows you get a 15 minute grace before you’re actually late.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CamILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I already ordered you a drink.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y’all know I got a date tonight so I can’t stay long.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is this the Agent?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yep. He don’t got no kids, never been married and loves sports. And did I mention the man got deep pockets.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>All the girls laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay Kim I see you. Okay lets take a shot. For Kim finally going on a real date.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>To Kim and her real date. And it’s well deserved.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The ladies raise their shots.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>TRANSITION SHOT -</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Two shot glasses come back down to the table.</Text>
    </Paragraph>
    <Paragraph Number="58" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="42" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">iNT. the LOUNGE - niGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Camilla are both now at the table without Kim. They’re a couple shots in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky I been wanting to tell you something.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah girl anything.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I found someone.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really? What? When?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I mean it’s someone from my past. But I think we can have a future.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">From your past? Is it Kevin Daniels? I always thought you had a thing for him.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">No it’s not KD. I don’t wanna say anything right now until it’s more serious. But I just wanted you to know. I think this could be something.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler grabs Camilla’s hand.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Whoever it is </Text>
      <Text>I’m </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">really</Text>
      <Text> happy for you Cam.</Text>
    </Paragraph>
    <Paragraph Number="59" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="43" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - kITCHEN - mORNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks into the kitchen to see Skyler and Camilla talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good morning babe. Hey Cam.</Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text>(to Skyler)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Baby you didn’t make the coffee this morning. It was your turn.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I</Text>
      <Text>’m so sorry honey I forgot. Cam got up early </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">and made coffee, </Text>
      <Text>we started talking</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, and you know how that can go</Text>
      <Text>. I can make some now if you want.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth looks at Camilla. She gives a sinister grin.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nah it’s fine, </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I</Text>
      <Text>’ll</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text>grab some </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">at </Text>
      <Text>work.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth kisses Skyler and exits. Once he leaves, they start back talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You guys are such an amazing couple.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">skYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yeah Ken is the best. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler takes a deep breath and sighs.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I just wanna give him the world.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So it doesn’t bother you that you can’t </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">give him </Text>
      <Text>kids?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">There’s a beat.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I’m sorry Sky, I didn’t mean it like that ---</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">--- No it’s fine. Yes. Everyday.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Does it bother Ken? I know how much he wants a son.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler makes a face of concern.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? How do you know he wants a son?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh the other night when you were in the hospital we were just talking about it. It wasn’t like a specific conversation, he just mentioned that he would have loved to see a little him running around.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla chuckles. Skyler gives a fake smile.</Text>
    </Paragraph>
    <Paragraph Number="60" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is in bed. Kenneth comes out of the bathroom </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">with just his boxers on, </Text>
      <Text>ready for bed as well. He gets into bed and goes for a kiss. Skyler moves her face and looks at Kenneth. Ken is confused.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KenNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay what was that about?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler has a full attitude.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You tell me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. I</Text>
      <Text> don’t know what you’re talking about.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Talking? You seem to be doing a lot of that lately.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, what is this </Text>
      <Text>about?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You told Camilla you wanted a son?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Huh?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t play stupid with me Ken. And what were you guys doing talking anyway?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay now you sound ridiculous. Camilla is your best friend, she’s like family. She’s staying here because you begged me, and now you don’t want me to talk to her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t want you to talk to her about things you don’t talk to me about!</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> You know kids is a touchy subject.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You’re right baby I’m sorry.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Sorry isn’t good enough.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="61" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - beDROOM hallway - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Right outside the door we see Camilla listening.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH (O.S.)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I’m sorry. It was just a harmless conversation. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="62" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Back to Skyler and Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She asked me if there was something I always wanted and so I told her I always wanted a son. I’m sorry but I didn’t realize that conversation was on the menu for us. I know how hard it is already on you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ken you can talk to me about anything.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>From now on I will okay. I promise.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They hug.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text>Skyler turns off the light. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Kenneth as he turns and faces the opposite way. His expression says it all.</Text>
    </Paragraph>
    <Paragraph Number="63" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="46" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. hasTINGS HOME - mORNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We hear the shower running.</Text>
    </Paragraph>
    <Paragraph Number="64" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="46" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - BEDROOM - BATHROOM - SHOWER - mORNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The steam is high. Kenneth is showering.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The bathroom door as a hand locks it slowly.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CLOSE ON - The clothes hamper. A pair of RED panties drops inside the hamper.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>IN THE SHOWER - A hand gently rubs Kenneth’s back. Kenneth automatically thinks it’s Skyler. He gets into it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The hands, as they go from his back to his chest, and down further. Kenneth turns around to reveal;</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMILLA standing there</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. </Text>
      <Text>Kenneth tries to say something but she quickly puts her hand over his mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Say</Text>
      <Text> anything I’ll make a scene. You wouldn’t want her to catch us in the act now would you? How would it look if she came in right now. What would she do, what would she say?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Cam you can’t do this. We can’t do this.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You mean to tell me you don’t want me right now?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth is a little curious. But tries to fight his temptation.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Please don’t do this.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Make love to me right now. If you don’t I’ll tell her everything. And I bet my story will be a little better than yours. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla slowly pushes her lips to Kenneth. She kisses him. He doesn’t kiss her back. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">She starts to yell out.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth quickly and aggressively puts his hand over Camilla’s mouth. He turns her around.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE - Outside the shower, we see a hand n the glass.</Text>
    </Paragraph>
    <Paragraph Number="65" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="47" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing.</Text>
    </Paragraph>
    <Paragraph Number="66" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="47" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - KITCHEN - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is in the kitchen making some breakfast as Camilla enters with a small laundry basket of clothes. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Morning bestie. I was actually doing some of my laundry today, you have any that needs to be done?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please Cam, you’re a guest. I’ll do it. Just drop that basket in the laundry room and I’ll take care of it when I do me and Ken’s. And thanks for the reminder.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No problem.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Camilla’s sinister grin as she walks toward the laundry room.</Text>
    </Paragraph>
    <Paragraph Number="67" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="47" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BATHROOM - daY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is separating the laundry. She finds the RED panties that clearly aren’t hers. She thinks to herself.</Text>
    </Paragraph>
    <Paragraph Number="68" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="48" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth pulls into the driveway.</Text>
    </Paragraph>
    <Paragraph Number="69" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="48" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - fOYER - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks inside.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Babe I’m home early!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In the kitchen!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks over toward the kitchen.</Text>
    </Paragraph>
    <Paragraph Number="70" Type="Scene Heading">
      <SceneProperties Length="1 5/8" Page="48" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - KITCHEN - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks into the kitchen. Skyler is cooking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Smells good in here baby.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I made your favorite. Meatloaf.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay baby I see you with the skills.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I was doing laundry this morning and I found these.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler pulls out the pair of red panties. Kenneth looks at them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hope those are clean.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Does it looks like I’m in the mood for jokes Ken?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I</Text>
      <Text>’m sorry baby but why are you holding a pair of underwear in the kitchen?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> Are you planning on modeling them for me later?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I found them in our hamper this morning.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay that’s where all the dirty clothes are.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well they’re not mine.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth takes a deep breath.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sorry baby. You found out.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Found out what?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text>bought you some lingerie and I wanted you to wear it for me. I must have tossed it in the hamper accidentally.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really Ken?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah. What you really think I would bring another woman’s drawls home with me? Come on now Sky</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> you trippin’</Text>
      <Text>. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You know I love you and you don’t have to worry about anything like that.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I love you too.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now can a brother get some meatloaf?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks over to Skyler and grabs her. He kisses her. This breaks the tension.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KENNETH POV - Camilla walks is watching them. She walks away with an attitude.</Text>
    </Paragraph>
    <Paragraph Number="71" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="49" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - guest house - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>It’s raining. We see Camilla laying on the couch drinking wine.</Text>
    </Paragraph>
    <Paragraph Number="72" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="50" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - GUEST HOUSE - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>There’s a knock on the door. Camilla gets up to open it. It’s Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey. Finally came to your senses?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I came to tell you that you have to leave. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What? What are you talking about? Where’s Sky?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She had to go into the office for a board meeting. Which is enough time for you to get your t</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">h</Text>
      <Text>ings and leave! I don’t want you here when she gets back.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> This stops now. You betrayed your friend and put me in a horrible circumstance with my wife.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why are you doing this? We had a deal?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> You coward.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh yeah. Deal. We had one. But you broke that deal with t</Text>
      <Text>he red panties</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">.</Text>
      <Text> Really Cam? Are you purposely trying to get us caught?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She needs to know about us Ken.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There’s no us! There’s me and my wife! What happened between me and you was a mistake that will never happen again okay! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Was the shower a mistake? It sure didn’t feel like it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Get </Text>
      <Text>the hell out of my house before I call the Police.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla takes a beat. She sees that Ken is serious.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. Have it your way Kenneth. Just give me a second the grab my stuff.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll let Sky know you had to go. If you tell her anything I swear I’ll bury you in a ditch you can’t get out of. Are we clear?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Crystal.</Text>
    </Paragraph>
    <Paragraph Number="73" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="51" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler gets into bed. Kenneth is waiting for her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She didn’t say what the emergency was?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No. She just told me she had to roll, and that she would be at a hotel if you needed her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hope she’s okay. Let me call her.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth stops her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why don’t you stop worrying about Cam and focus on your husband.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth starts kissing Skyler’s neck. She can’t resist. They fall into bed kissing.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="74" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="51" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - moRNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks in with a cup of coffee.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Top of the morning my love. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth puts the cup of coffee down on the night stand. </Text>
      <Text>Skyler slowly wakes up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really? I thought it was my morning.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It was but after you put it on my last night I felt like I needed to say thank you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They both laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you Mr. Hastings.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you too Mrs. Hastings. I gotta get to work.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh Cam texted me early this morning. She said she’s safe and at the Hotel Q downtown. She invited me over tonight. She said she has something urgent to talk to me about.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth is suspicious.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really? Did she say what it was?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nope. But I’m meeting her tonight at 6.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well I hope everything is okay.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth kisses Sky.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll call you when I get to work babe.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth exits.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We hear a loud knock on a door.</Text>
    </Paragraph>
    <Paragraph Number="75" Type="Scene Heading">
      <SceneProperties Length="1 7/8" Page="52" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hotel room - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla opens the door in a sexy lingerie outfit, as if she was expecting him. Ken walks in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I figured that little message to Sky would get you here. So what can I get you? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the hell is wrong with you Cam! I don’t know if I didn’t make myself clear, but I’m married</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">! </Text>
      <Text>To Sky. And nothing is gonna change that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I disagree. Everything is about to change when I confess to Sky what we did.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re not gonna say anything to Sky. I already told you what I would do.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yeah but once she knows it doesn’t matter what you do to me. Your life as you know it will be over. Sky will leave you and you’ll only have me to come running back to after that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t care what happens to me and Sky. I will never run to you. I don’t love you. You were the biggest mistake I ever made!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We were no mistake Ken, don’t you see? We were always meant. Now we can finally see what life would </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">be if it was us together.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re sick. And for the record my life is exactly where it needs to be.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> I’m done.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ken tries to walk away. Camilla catches him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You can’t just walk out on me like this! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Instinctively, Ken turns around, accidentally elbowing Camilla in the jaw. Camilla drops to the floor.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh gosh I’m sorry Cam.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ken drops to the floor to help her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CamILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get out! Get the hell out!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth starts to leave.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I hate you!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">The feeling is mutual.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla picks up her phone.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">What are you doing?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">calling Sky.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Do it and it will be the last call you ever make.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla throws her phone on the ground.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re not gonna just screw me and dip on me that easy</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">!</Text>
      <Text> I ain’t goin for that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know what fine. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Do you. Bye Cam. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth exits. Camilla screams!</Text>
    </Paragraph>
    <Paragraph Number="76" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="54" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. hasTINGS HOME - establishing - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We hear Skyler screaming at the top of her lungs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My best friend?!</Text>
    </Paragraph>
    <Paragraph Number="77" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="55" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - kiTCHEN</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is at her limit. Kenneth is trying to plead his case but doesn’t have too much to say.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Baby please listen to me. I’m sorry.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You wasn’t sorry when you was inside her was you?! I could kill yo ass!</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> Her too.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler picks up a bottle and throws it at Kenneth. Kenneth moves. The bottle breaks on the wall.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hate you! I can’t believe you did this! Why Ken, why?!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know! I was drunk! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh really that’s your excuse?!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You invited her into our home! I never wanted her here in the first place.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh so now it’s my fault?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m not saying it’s your fault, I’m saying I made a mistake. And I’m sorry. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Are you serious?! Her underwear was in our hamper. In our room Kenneth! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please just listen to me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me explain. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Explain!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I came home. Camilla was being all weird. So she came and offered me wine and food to kinda make things less weird. We drank. I fell asleep. Next thing I know she’s in the bed when I woke up in the morning. I swear Sky I don’t remember touching her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get out.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky please.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get out!!!! Now!!!!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks away. Skyler cries her eyes out.</Text>
    </Paragraph>
    <Paragraph Number="78" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="56" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. los angeles city skyline - sunset</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The sun goes down.</Text>
    </Paragraph>
    <Paragraph Number="79" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="56" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JERRY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. jerry’s crib - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Establishing of a nice apartment. We hear voices talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">jerrY (V.O.)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>With Cam?! How dumb are you bro?</Text>
    </Paragraph>
    <Paragraph Number="80" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="56" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="JERRY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. jerRY'S CRIB - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>This place belongs to JERRY STOKES, 40’s, Kenneth’s best friend since grade school. Jerry is talking. Kenneth is listening.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Jerry</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And I get it, Cam is a baddie don’t get me wrong. But nigga it’s your wife’s best friend, who already got cheated on by her husband, which can I say I never liked Lance anyway. What was you thinking?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I was so drunk I don’t even remember. The first time anyway.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JERRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Did she drug you? Who forget’s a nut? Come on bruh. And</Text>
      <Text> it was a second time?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She forced me. She snuck into my shower and told me she would scr</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">e</Text>
      <Text>am for Sky if I didn’t. I had no choice.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">JERRY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Nigga please, you wanted to hit that. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">It wasn’t lie that J.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Jerry shakes his head.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">JERRY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Damn bruh, </Text>
      <Text>you in deep. I just don’t understand out of all the women, why Cam?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Honestly Cam been coming for me since she moved in. I tried to ignore the signs but I guess I wasn’t strong enough.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth takes a deep breath.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe deep down inside I also wanted to. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Ever since I met Cam, it’s always been something there, but I always tried to ignore it. And I love my wife. Sky is my everything. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JERRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Apparently not if you stepped out with her BFF.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Come on man that ain’t funny.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">JERRY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I know, I know. My bad, let me stop. </Text>
      <Text>So </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I guess you and Cam had some </Text>
      <Text>unfinished business? Is that what you’re saying?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m saying I’m a man and I made a mistake. I just wish I could talk to Sky. But she ain’t tryna hear nothing I gotta say right now.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>JERRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">whatchu</Text>
      <Text> </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">gon</Text>
      <Text>’ do?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> Cause you ain’t gettin out of this one easy.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="81" Type="Scene Heading">
      <SceneProperties Length="2" Page="58" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. park - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler is at the park, sitting on a bench. She checks her watch. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KIM walks up and sits beside her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey girl.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey Kim. So what was so important that we had to meet here? We couldn’t do it at the office?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well. Don’t be mad at me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What are you talking about?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s talking about me.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler looks at Kim.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry but you should hear him out. He’s your husband Sky. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If you wasn’t my girl I would fire you right now.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know, but we both know that ain’t </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">gon</Text>
      <Text>’ happen.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kim smiles and gets up. She walks away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good luck Ken.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth walks over. Skyler gets up to try to leave.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky wait. Just hear me out okay.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t wanna hear anything you have to say.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sorry!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler freezes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I never meant for this to happen. I was drunk</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. </Text>
      <Text>And Cam kept threatening to tell you if I didn’t go along with it. I was scared. Scared you would leave me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkyLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In our house Ken? Why? Why would you do this to me? To us?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know. But what I do know is I love you. And I will do any and everything in my power to fix this with you.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> No matter how long it takes.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She told me y’all had a thing before you and I met. Is that true?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Hell no! She’s lying baby.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How am I supposed to beli</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">e</Text>
      <Text>ve you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because I’m the one telling you</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">. Just like I’m the one who told you what happened. I made the biggest mistake of my life. But I told you. As hard as that was for me, knowing I could lose you. </Text>
      <Text>You din’t have to find out from anyone else. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">And same with this. Camilla is lying.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>There’s a beat. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I forgive you Ken</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">.</Text>
      <Text> </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">B</Text>
      <Text>ecause I love you. But I can’t take you back. At least not now. I need some time.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> A lot of time.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks away, leaving Ken there to think.</Text>
    </Paragraph>
    <Paragraph Number="82" Type="Scene Heading">
      <SceneProperties Length="1" Page="60" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. kim’s apartment - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kim and Skyler both sit and sip wine.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KiM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So you forgave him, but he on punishment?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Something like that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Girl you need to stop playin and take him back. He made a mistake. No one is perfect Sky.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But we were. I don’t know if I can look at him the same anymore. And Cam? Ooh I better not see her cuz if I do, it’s </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">gon</Text>
      <Text>’ be </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">poppin</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">So now you a gangsta chick? </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kim laughs.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Your </Text>
      <Text>head isn’t in the right place. You can stay here as long as you want until you can think clear.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> But if you do need to get it </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">poppin</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, you know I will beat her ass, just let me know.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Kim.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s okay. Now that Cam is gone Ima slide right into that bestie seat.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Both women laugh.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I do have to go back to the house and grab some things. I’ll be back in a few hours.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KIM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Ok. You need me to roll with you? No gangsta.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">They both laugh.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="83" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="61" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - FOYER - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks into the home. She hears Camilla’s voice say;</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA (O.C.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In here baby!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks into the living room. </Text>
    </Paragraph>
    <Paragraph Number="84" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="61" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. hASTINGS HOME - LIVING ROOM - NIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler sees a half dressed Camilla on the couch. She has on one of Kenneth’s button down shirts with just panties on</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">, drinking out of a bottle. She’s drunk.</Text>
      <Text> She looks over at Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh hey Sky. Ken and I weren’t expecting you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Bitch g</Text>
      <Text>et the hell out of my house before I kill you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla slowly gets up from the couch.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh Skyler. Don’t be so harsh. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You’re drunk and that’s never good for you. You need to leave now before I call the Police. You got a lot of nerve.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh Skyler, you’re so dramatic. But</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I understand how it feels to be replaced. Remember it happened to me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is that what this was about? You wanted my life, so you slept with my husband?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I actually never planned this to happen. You were gone, and we just connected. He made me remember what it felt like to be touched by a real man.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> And I reminded him what it feels like inside of a real woman. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla rubs her own stomach.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">One that works.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler rushes Camilla. Tackling her to the ground. The two women start to fight.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler jumps on top of Camilla and throws a couple punches. Camilla retaliates and kicks Skyler off of her. Skyler is in pain. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla takes the opportunity to jump on top of Skyler. Camilla pulls Skyler’s wig off. Skyler looks at Camilla’s stomach. She kicks her as hard as she can in the stomach. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - The door as Kenneth rushes in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sky!? Babe!?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He hears the rumbling. He rushes into the living room.</Text>
    </Paragraph>
    <Paragraph Number="85" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="62" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - LIVING ROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth rushes in to see Skyler on top of Camilla, wailing on her. Camilla is unconscious. Kenneth rushes over and grabs Skyler off of Camilla. Camilla isn’t moving.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Baby that’s enough, you’re gonna kill her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler is breathing heavy. </Text>
      <Text>Kenneth checks Camilla’s pulse.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s still breathing. But we have to get her an ambulance quick.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler kicks her one more time. Kenneth pulls Skyler back.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Sky chill!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She was in my home. It was self defense.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes but baby she could die if she doesn’t get help.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fine.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth picks up his cell and calls 911.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes, I have an emergency, my address is 5656 </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Jerico</Text>
      <Text> Drive.</Text>
    </Paragraph>
    <Paragraph Number="86" Type="Scene Heading">
      <SceneProperties Length="2" Page="63" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="OFFICER RANDLE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. hoSPITAL - lobby - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>OFFICER RANDLE, is in the lobby talking to Skyler and Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>offICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So Mrs. Hastings, you said she broke into your home?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes. I came home from my friends house and she was there, uninvited. She attacked me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Do you know why she attacked you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because she’s crazy I don’t know!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please keep your voice down Mrs. Hastings I’m just trying to get the report complete. SO you said she was staying with you guys at some point, but then she left? Mind telling me what happened?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s none of your damn business. She was there then she left, what does that have to do with anything?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know where all the hostility is coming from Mrs. Hastings.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>keNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Listen. She was staying with us because her and her husband were getting a divorce. So while she was with us, something happened, a family matter and so we made her leave. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But then she came back and attacked you?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, it’s complicated okay. The bottom line is my wife went home, and Camilla was there. She had broken into the house.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well there was no forced entry sir.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe she used the key she had I don’t know. Will you just tell us what we need to do to get a restraining order against her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well right now it looks like she’s the one who needs the restraining order.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Randle gives a little chuckle.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just kidding. Look. I’ll file the report. Someone will be in touch with you guys for the next steps.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you officer.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ofFICER RANDLE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No problem.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Officer Randle walks away. Kenneth grabs Skyler and hugs her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Everything is gonna be okay baby, I promise.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler looks at Kenneth.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I want you to stay with me tonight.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You sure?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yes. But you’re sleeping on the couch.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler buries her head into Kenneth’s chest.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DiSSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="86A" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="65" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DETECTIVE BENSON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. the FIRM - sKYLER'S OFFICE - dAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler is sitting at her desk with DETECTIVE BENSON, 40’s cool guy. Kim sits on the couch.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler is sighing some papers. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">So this means I’ll be protected?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DeTECTIVE BENSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">This is a form of protection yes. This means that Mrs. James is not allowed within one hundred yards from you or your husband.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">What about Kim? Is she protected as well?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KiM</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yeah what about me? I don’t wan this crazy hoe coming after me.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DeTECTIVE BENSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yes, Ms. Davis is added to the order as well. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Parenthetical">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">(to Kim)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Ms. Davis if you can sign as well, then I’ll be on my way.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kim walks over and signs.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DeTECTIVE BENSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You two have a lovely day. My number is on the back of the card I left, if you need anything just give me a call.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Detective Benson exits.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KiM</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Period! That’s how you do things. Let that crazy hoe come around now, she </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">gon</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> have some problems.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I just hope this nightmare is really over.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KIM</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well don’t worry about it Sky. You and Ken are back together, y’all doing good. Thank God cause I didn’t want you at my house no more. You </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">stoppin</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> my action.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yeah your couch wasn’t it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Both women laugh.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="86B" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="66" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. haSTINGS HOME - diNING ROOM - nIGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Dinner is on the table. Kenneth walks in with a plate of food. He has on a apron and a chef hat. He lays the plate in front of Skyler who’s seated at the table.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Here you are my Queen.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Thank you handsome.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">No thank you.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">There’s a beat.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">For taking me back. For giving me another chance to make it right. I’ll never stop being sorry for what </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">happend</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> Sky.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Listen. I don’t wanna talk about it anymore. It’s in our past. Let’s focus on our future.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler grabs her glass of wine and lifts it up.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">To a new beginning.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth grabs his wine and lifts it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">To a new beginning.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth kisses Sky. She looks deep into his eyes. She kisses him back with passion. Kenneth lifts Sky up and continues kissing her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DISSOLVE TO:</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="86C" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="67" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. haSTINGS HOME - beDROOM - niGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler and Kenneth sleep peacefully in their bed.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">CAMERA - Pans over to Camilla sitting in the chair across from their bed watching them, drinking hard liquor.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="87" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="67" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - moRNIN</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">g</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Birds are chirping.</Text>
    </Paragraph>
    <Paragraph Number="88" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="67" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. hasTINGS HOME - beDROOM - BED - moRNING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler wakes up. She’s a little drowsy. She stretches. She’s wet. She feels herself. Everything is wet. She jumps up and looks around. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>THE ENTIRE BED - is wet with coffee. Skyler panics. She looks at the dresser. There’s a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">coffee cup with a </Text>
      <Text>note. Skyler grabs it and reads it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>THE NOTE READS; </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="Bold+Italic">Black coffee, just how you love it Sky ;-)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>SmASH CUT TO:</Text>
    </Paragraph>
    <Paragraph Number="89" Type="Scene Heading">
      <SceneProperties Length="2" Page="68" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DETECTIVE BENSON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - lIVING ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler sits with Kenneth on the couch. Across </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">from </Text>
      <Text>them </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">is</Text>
      <Text> detective </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Benson</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>detective BENSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So let’s start from the top. On the 911 phone call, you said that you woke up with spilled coffee in the bed?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DETECTIVE BENSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Doesn’t seem like much of a reason to call 911.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I called because I didn’t have coffee this morning and my husband was gone.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DETECTIVE bENSON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And where were you Mr. Hastings?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I was at work.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This woman was in ou</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">r</Text>
      <Text> house again Detective. After we got a restraining order.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>detECTIVE </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">bENSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well how do you know for sure it was her?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There was coffee all over the bed? Camilla was once my best friend. She’s the only one who knows about me and Ken’s coffee thing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DETECTIVE</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps"> BENSON </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Coffee thing?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Listen. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla</Text>
      <Text> was in my home and she’s playin games with my wife. We need her arrested.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DETECTIVE </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">bENSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Technically we don’t know for sure it was her. And without proof, I’m sorry there’s really not much we can do Mr. Hastings.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkyLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, unless you want this bitch to get hurt again, you need to do something!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DETECTIVE beNSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is that a threat Mrs. Hastings?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It ain’t a threat. It’s what’s gonna happen if I find her.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DETECTIVE beNSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">It’s not in your best interest to hand out threats in front of an officer Mrs. Hastings.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Listen, my wife is just upset. We just want to know what our options are to stop her from doing this again.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DETECTIVE beNSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll follow up on her whereabouts and see if it links her to within your home in the last 24 hours.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Detective.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What are we supposed to do in the meantime? Just wait for her to hurt one of us while you investigate?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">DETECTIVE beNSON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There’s really not much we can do if she’s not proposing a threat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is stupid.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler gets up and storms off. Kenneth looks at Randle.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know where the door is.</Text>
    </Paragraph>
    <Paragraph Number="90" Type="Scene Heading">
      <SceneProperties Length="0" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KIM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">Omitted</Text>
      <OmittedScene>
        <Paragraph Type="Scene Heading">
          <SceneProperties Length="1" Page="1" Title="">
            <SceneArcBeats/>
          </SceneProperties>
          <Text>INT. thE FIRM - SKYLER'S OFFICE - dAY</Text>
        </Paragraph>
        <Paragraph Type="Action">
          <Text>Skyler is sitting at her desk. She can’t really focus. She lays her head down as Kim walks in.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>KiM</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>You got your 12 o’clock with Julius Jackson.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SkYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>That was today? Please tell me you can move it.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>KIM</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Okay I can go out to the lobby and let Julius and his entire team know that they flew all the way from Atlanta for nothing. Sure.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SKYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Kim this is too much.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>KIM</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>You mean all this with Cam? What’s going on I never thought Cam to be a psycho.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SKYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Me either. I guess you really never know a person huh.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>KIM</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>It’s all good, you still have me.</Text>
        </Paragraph>
        <Paragraph Type="Action">
          <Text>Skyler smiles.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SKYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Thanks Kim. Send them in.</Text>
        </Paragraph>
        <Paragraph Type="Action">
          <Text>Kim exits. A few moments later, she arrives with JULIUS JACKSON, tall basketball player and his entourage of 6 people. </Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>KIM</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>I’ll be out here if you need me.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SKYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Thanks Kim.</Text>
        </Paragraph>
        <Paragraph Type="Action">
          <Text>Skyler addresses Julius and his team.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SkYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Gentlemen. Welcome to the Firm.</Text>
        </Paragraph>
      </OmittedScene>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Number="91" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="70" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">iNT. the FIRM - SKYLER'S OFFICE - dAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We see Kim going over schedules with Skyler. Skyler’s mind isn’t there. The sound fades out as we PAN into Skyler’s blank stare.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="92" Type="Scene Heading">
      <SceneProperties Length="0" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MR. FRANKLIN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">Omitted</Text>
      <OmittedScene>
        <Paragraph Type="Scene Heading">
          <SceneProperties Length="5/8" Page="1" Title="">
            <SceneArcBeats/>
          </SceneProperties>
          <Text>INT. the FIRM - mr. Franklin’s office - dAY</Text>
        </Paragraph>
        <Paragraph Type="Action">
          <Text>MR. FRANKLIN is in his 50’s. Very clean cut, tailored suit, clean shave. He’s upset with Skyler.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>Mr. FRANKLIN</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>This guy is supposed to be the next Lebron James and you let him slip through your fingers?! Why?! What were you thinking? You never slip like this.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SkYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>Ben if you could just let me explain.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>MR. FRANKLIN</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>There’s nothing to explain! You lost a possible billion dollar client. Do you know what that could have meant or this company?</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>SKYLER</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>I can get him back.</Text>
        </Paragraph>
        <Paragraph Type="Character">
          <Text>MR. FRANKLIN</Text>
        </Paragraph>
        <Paragraph Type="Dialogue">
          <Text>You better. Or you can kiss your partnership goodbye.</Text>
        </Paragraph>
      </OmittedScene>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Number="93" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="70" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. road - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler drives down the road in thought.</Text>
    </Paragraph>
    <Paragraph Number="94" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="70" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. haSTINGS HOME - day</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler pulls up to her home. She sits in her car for a moment.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Suddenly, BAM! A hand hits the window. Skyler is startled. She looks to see Camilla standing there. Skyler gets out of the car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You must want to get </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">a </Text>
      <Text>beat down again.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler no. Please I’m not here for that. I wanted to apologize. For everything I’ve put you through. I can’t imagine how it must be for you.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get off my property before I call the Police.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Who, You mean Detective Benson? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla giggles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll tell him you said hello tonight while he’s </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">blowin</Text>
      <Text>’ my back out to our favorite </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Tubi</Text>
      <Text> movie.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Leave! Now!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla turns to leave.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Okay. But just remember I tries to fix things.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla walks off.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="95" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="71" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. haSTINGS HOME - BEDROOM - BED - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Kenneth are talking.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She could have killed me Ken. And there was nothing I could do about it. We have to do something about her.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""> She was on our property. Literally what’s the restraining order for if she’s just gonna walk up on me like that.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeNNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know baby. So what do you wanna do?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know. I mean we can’t go to the Police because she’s screwing the Detective. I can’t kill her, even though that’s what I want to do, but I just can’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You’re not a killer.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler starts crying.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">know. I </Text>
      <Text>just. I’m so confused.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth grabs Skyler and comforts her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We hear a loud BANG on the door.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SmASH CUT TO:</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="95A" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="72" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">EXT. camILLA'S HOUSE - niGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We see Kenneth banging on the door. Camilla opens the door in her underwear, with a glass of liquor. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh honey, you’re home.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth barges in.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Hello to you too.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You need to stop this right now!</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Stop what?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Playin games with me and my family. This is over Cam. It ends now.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh Kenneth. Please stop playin like you don’t want me. You know I can give you a real family. Something Sky could never. A baby boy.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Listen. I don’t want you, or any family with you. I have a family already.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth gets close to Cam.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">One I’ll do anything to protect.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh, is that a threat?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">It’s a promise. This is your last warning.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth turns to leave. Camilla throws her drink at Ken. It breaks on the back of his head. Kenneth turns around in rage. He grabs Camilla and chokes her up against the wall.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You come near my family again and I’ll kill you myself. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth’s grip is getting tighter and tighter. He realizes he’s about to kill Camilla as she starts to loose control of her body. He lets go of her neck. Camilla drops to the floor. Kenneth just leaves. Camilla catches her breath. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="95B" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="73" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. haSTINGS HOME - LIVING ROOM - nIGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler and Kenneth are all packed up and ready to leave.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I think this was a great idea babe. The beach house for a few days. Get away. Nobody will bother us there.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">It’s perfect.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">They share a kiss.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="95C" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="73" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. caMILLA'S HOUSE - LIVING ROOM - niGHT</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla sits on the floor just looking into space. There’s blood all over her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">CAMERA - Pans down to her hand, holding a gun.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You deserved it Lance. You did this to me. And you had to pay. You and her.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - Lance with a bullet hole in his head. Right next to him is his mistress with a bullet hole in her chest.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - Camilla as she laughs.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Now I’m coming for you Ken. My Ken. I’ll get rid of Skyler for us so we can be a family.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text></Text>
    </Paragraph>
    <Paragraph Number="96" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="73" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. roaD - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Hastings SUV travels down the coast.</Text>
    </Paragraph>
    <Paragraph Number="97" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="74" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. suNSET - </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The sun sets over the coast side as they continue driving.</Text>
    </Paragraph>
    <Paragraph Number="98" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="74" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. beach house - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Ken pull up to the home. They get out and walk inside.</Text>
    </Paragraph>
    <Paragraph Number="98A" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="74" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">eXT. bEACH HOUSE - balcony - mORNING</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler sits on the balcony, enjoying the view. Kenneth walks out with two cups of coffee. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">This is what we needed.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Exactly what we needed.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Did you let your office know where you were?</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Nope. Just told them I’d be taking a few days off.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">What about Kim? </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I told Kim I was away, and to call me if anything urgent came up.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well my work is mobile so I’m good.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">No. No work for the next few days. Just me, you and this beautiful view.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">That’s all I need.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">The two sit back and enjoy their coffee.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="98B" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="74" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">EXT. beACH - SKY - sunSET</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">The sun sets over the beautiful water.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="99" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. beach - sky - moon - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The moon is full. The waves are crashing up against the shore. We hear water running.</Text>
    </Paragraph>
    <Paragraph Number="100" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. beACH HOUSE - bathroom - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The tub is filling up with water. The steam rises from the tub and creates a foggy mist in the bathroom, fogging up the mirrors.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We see SKYLER - in a bath robe as she feels the water to make sure it’s the correct temperature.</Text>
    </Paragraph>
    <Paragraph Number="101" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="75" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. beACH HOUSE - living room - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth lights some candles. He takes out an old record and puts it on the record player. A slow jam come on.</Text>
    </Paragraph>
    <Paragraph Number="102" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="75" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. beACH HOUSE - baTHROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The water is full. Skyler walks over to the door and closes it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Standing right behind her is CAMILLA. Startled, Skyler turns around. Camilla is holding a gun. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam. What are you doing here? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe I should ask you the same question? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is my house.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not anymore Sky.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why do you have the gun?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh this old thing? Just incase I need to use it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler slowly starts to back up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How did you even find us?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know Sky. There was once upon a time that you and I were friends. And we shared each other’s location.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler realizes that’s true.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CaMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You probably should have stopped sharing your location with me if you din’t want me to have it.</Text>
    </Paragraph>
    <Paragraph Number="103" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="76" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. beaCH HOUSE - LIVING ROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth lights the fireplace. He opens the refrigerator and grabs a snack.</Text>
    </Paragraph>
    <Paragraph Number="104" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="76" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. bEACH HOUSE - BATHROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla starts crying.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know you had it all. And I thought I did too. But Lance ruined it. He ruined my life and because of that I wanted to ruin yours. Because you were just so perfect. Always so perfect and I hated you for it!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla points the gun at Skyler.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cam nothing is perfect. We were never perfect. We just worked at it to make sure we were good. But apparently he loved you right? Otherwise he would have never slept with you. He loved both of us.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla puts the gun down.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know what, you’re right. Maybe I should</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">n’t</Text>
      <Text> hate you. Maybe I should hate him. Maybe I should hate all men because they’re all the same. I mean look at your perfect little Ken doll. He couldn’t keep his dick in his pants. Maybe he’s the one that should die, not you. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla thin about what you’re doing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CAMILLA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I did. And I just wanna be happy. And I was really happy with Lance. Until he broke me. Then once Kenneth made me feel alive again, I knew right then what I needed. It was Ken. I’m sorry it had to be your husband, but sometimes things happen that we can’t explain. Think about it Sky. I can give him what he’s always wanted. A child. Don’t you want him to be happy?</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style=""></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Keeeeeeen</Text>
      <Text>!!!!!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Camilla takes her eyes off Skyler for a second to look back. Skyler tackles Camilla. Camilla goes down. She drops the gun. It goes off and hits Skyler in the arm.</Text>
    </Paragraph>
    <Paragraph Number="105" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="77" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. beACH HOUSE - LIVING ROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Kenneth hears the gunshot. He rushes up the stairs.</Text>
    </Paragraph>
    <Paragraph Number="106" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="77" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. beACH HOUSE - BATHROOM - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler and Camilla tussle. Skyler is bleeding from her shoulder pretty bad. Camilla gets up. Just then, Kenneth barges in. He grabs Camilla and pushes her into the bathtub. Camilla scratches Ken in the face. Ken is bleeding. She kicks Ken in the balls. Ken falls over in pain. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ken gets up but slips in the water and hits his head on the tub. He’s knocked out. Camilla turns around and BANG! Skyler barely misses Camilla. She tosses the gun and rushes Camilla. They both fall in the tub. Skyler chokes Camilla until she passes out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>HIGH ANGLE - Camilla sinks down into the water with her eyes open.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>ANGLE ON - Skyler as she breaths heavy. Kenneth gets up off the floor. He grabs Skyler and hugs her tight.</Text>
    </Paragraph>
    <Paragraph Type="Transition">
      <Text>DISSOLVE TO:</Text>
    </Paragraph>
    <Paragraph Number="107" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="78" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. beACH HOUSE - niGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">EMT</Text>
      <Text> checks Skyler and Ken. Skyler’s flesh wound is bandaged up. She gets out of the truck and walks over to Kenneth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m so sorry I put you through this Sky.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SkYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sorry too. I should have never allowed another woman in our home.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess we both learned something.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They embrace.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SKYLER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I still ain’t taking you back.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Skyler walks inside the house and closes the door, leaving Kenneth outside.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KENNETH</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Really babe stop playin it’s cold out here. Stop playin.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We hear Kenneth begging to get in the house as the </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>CAMERA - Pans up to the full moon.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">CAMERA - Pans down to </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">9 MONTHS LATER - </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Number="108" Type="Scene Heading">
      <SceneProperties Length="1" Page="78" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="CAMILLA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KENNETH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SKYLER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">INT. beACH HOUSE - baby room - dAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - Skyler’s back as she is looking at a baby room, all decorated nicely. Kenneth walks in and grabs her from behind.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Baby be careful.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Oh my bad little Kenny.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Skyler turns around with a big belly. Kenneth goes down to kiss the belly.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KeNNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">You are gonna be a strong man, just like daddy.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SkYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Well right now I need his strong daddy to help me bring in this last dresser so this room is complete.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">KENNETH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">I’m on it.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Kenneth kisses Skyler and walks out of the room. Skyler just looks at the room. She rubs her belly.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">SKYLER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Mommy’s here.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - A baby monitor.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">CAMERA - Close on the Baby monitor. </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">We pull back to see another baby monitor sitting inside of a car.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">ANGLE ON - Camilla, sitting in the car outside the Beach house.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="AllCaps">CaMILLA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Yes. Mommy’s here.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="1" Size="12" Style="">Camilla smiles.</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Transition">
