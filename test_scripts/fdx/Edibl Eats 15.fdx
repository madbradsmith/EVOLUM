<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<FinalDraft DocumentType="Script" Template="No" Version="4">

  <Content>
    <Paragraph Number="1" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="1" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EMPLOYEE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="867">edibl eats #1 drive up window</Text>
      <Text> - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="836">car</Text>
      <Text> drives to pickup window as EMPLOYEE #1, wearing a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="840">clear face-shield</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="841"> with the Edibl Eats logo</Text>
      <Text> on it meets them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="842">EMPLOYEE #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats hero meal?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KEKE, a black, twenties, sweet as candy but hard as steel, face can’t be clearly seen because of her </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="838">tented face-shield</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="843">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes! With an extra red sauce.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke is given a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="839">bag with the Edibl Eats logo on it</Text>
      <Text>, opens it and then </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="844">honk’s</Text>
      <Text> horn. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>eMPLOYEE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Keke</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t get my extra red sauce. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EmPLOYEE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please check again. I’m sure I put it in the bag. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I looked, its not in here. I always order 2, it’s so good! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EMPLOYEE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look again, I’m sure you got it. An extra one’s two dollars. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m not paying for what I paid for.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EMPLOYEE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know for a fact I gave you one so if you want another its gonna be...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, okay... I’ll buy it!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Employee #1 extends the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="845">red sauce container</Text>
      <Text> to Keke who takes it, then grabs their wrist, pulls their head outside the window and hits them in the face-shield.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Told you I didn’t get... my extra red, sauce...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Employee #1 try’s to get away but can’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EMPLOYEE #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Help! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And you know...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="846">EMPLOYEE #2</Text>
      <Text> try’s to pull them back inside.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...I didn’t get it!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke lets go and quickly drives off. {Credits start}</Text>
    </Paragraph>
    <Paragraph Number="2" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="869">upscale urban neighborhood</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We See a busy intersection. PEOPLE coming in and out of prosperous </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="847">business storefronts</Text>
      <Text>. All of them are wearing some kind of </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="871">face-shield</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="848">well dressed LADY</Text>
      <Text>, </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="849">face-shield looks expensive</Text>
      <Text> with a designer label on it. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="850">Two GUYS</Text>
      <Text> have </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="851">face-shields attached to their baseball caps</Text>
      <Text>. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="852">GUY wears a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="853">rainbow colored face-shield</Text>
      <Text>.  </Text>
    </Paragraph>
    <Paragraph Number="3" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="2" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1210">bus passenger platform</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="859">6 WHITE PEOPLE</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="860"> are waiting on the bus</Text>
      <Text> platform. Some are watching WNG News anchor TOM COLLINS a white, stiff but warm announcer on </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="855">monitors</Text>
      <Text> or just listen via the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="856">speakers</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Number="4" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="2" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BUS ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1212">WNG news studio</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>All WNG news scenes in the script are shot on this set, to be edited into the various scenes of Tom delivering the news. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="857">ToM COLLINS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh how we long for the good old days when it was just the cold or flu season. It’s been 5 years since we first heard the word COVID. Now, simply called the virus season and it’s in full swing. Here’s Tonya with more on our old normal.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>An automated voice interrupts the news audio.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="556">Bus announcer</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bus is approaching. Stand clear of the edge of the platform. </Text>
    </Paragraph>
    <Paragraph Number="5" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BUS ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TONYA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="873">bus</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="858">10 WHITE PEOPLE on the bus</Text>
      <Text>, some watching the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="875">on-board monitor</Text>
      <Text> showing WNG News reporter TONYA, as the doors open.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="557">TONYA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because of improvements in Bio-Protective face-shields, anti-virus pills and touch-less tech the spread of viruses has </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">decreas</Text>
      <Text>... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="558">BUS ANNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Doors are closing. Doors are closing.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>As the door’s close DEON, a black thirties tough but fair construction worker, just makes it on. His hands protect a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="861">bag with the Edibl Eats logo</Text>
      <Text> on it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="559">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Made it! Me and you baby real soon.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>His </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="862">dirty construction clothes</Text>
      <Text> stand out from everyone’s office attire. WHITE LADY #1 gives him a “don’t sit here” look but check’s his bag of Edibl Eats. His </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="832">cellphone</Text>
      <Text> </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="833">dings</Text>
      <Text> as he sits in front of a monitor and gets cell.  </Text>
    </Paragraph>
    <Paragraph Number="6" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="3" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON’S TEXT">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DIANE’S TEXT">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TEXT OF DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. diane’s texting - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The name </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1208">DIANE floats just above the screen</Text>
      <Text>. Deon waves his finger through the name and the words of Diane’s text appear.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="560">Diane’s text</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Off work yet</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1214">Deon moves his finger like writing</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="561">Deon’s text</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DIANE’S TEXT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m breaking up with you </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="562">TEXT OF DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea right </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DiANE’S TEXT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>For real</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TEXT OF DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>WTF </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DIANE’S TEXT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My Ex going to NY. Asked me to go. I said yes </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TEXT OF DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Im comin over now</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DiANE’S TEXT</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not home + you all dirty, dusty. You were fun, we had fun but bye. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The cellphone goes dark. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ain’t that a...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon, looking towards the monitor see’s </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="863">three delicious looking golden fried food items</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Number="7" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="4" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EDIBL EATS ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. edibl Eates </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1218">TV commercial</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>This will play on the Bus monitor and TV in Deon’s apartment.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="829">EDIBL EATS ANNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats satisfy’s your hunger! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Some </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="865">silky red sauce</Text>
      <Text> drizzles on top of them. As it does, Deon pick up his bag, puts it to his nose and inhales. As he lowers it a slight smiles comes on his face.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EDIBL EATS ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...with the delicious taste of crispy, juicy...</Text>
    </Paragraph>
    <Paragraph Number="8" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="4" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EDIBL EATS ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="877">deon’s living room</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="879">A Edibl Eats meal is on a table</Text>
      <Text> as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="881">red sauce drizzles on</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="564">EDIBL EATS ANNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...goodness! Edibl Eats...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="565">Ron</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Its just you and me baby.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>RON, a twenties black hood-nerd, picks up an Edibl Eats. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looking so good!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>In the background behind the Edibl Eats in his hands, is a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="834">flatscreen TV </Text>
      <Text>mounted on a wall showing an Edibl Eats meal. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EDIBL EATS ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Too irresistible to resist!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... To resist. Mmmm!</Text>
    </Paragraph>
    <Paragraph Number="9" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="5" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RICK DAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1220">eDIBL EATS LOCATION #1</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="835">10 PEOPLE</Text>
      <Text> in line wearing face-shields, will be playing on WGN News, bus monitor and on Deon’s TV. Voice of RICK DAY, a white thirties upbeat reporter is heard. {Credits Finish}</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="566">Rick Day</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Rick Day here and lines like this are what it’s like everyday all across the country at Edibl Eats!</Text>
    </Paragraph>
    <Paragraph Number="10" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="5" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RICK DAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. business headlines - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>All </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="889">graphics</Text>
      <Text> for News Business headlines that play on the News, like “EDIBL EATS, Best Franchise in U.S. History.”</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>riCK DAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Since opening in 2022 its the fastest growing franchise in U.S. history. Growing bigger than KFC, McDonalds and Popeye’s combined...</Text>
    </Paragraph>
    <Paragraph Number="11" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="5" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RICK DAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1222">Photo</Text>
      <Text> </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="883">Terri in front of Edibl eats</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="885">Picture of TERRI ADAMS</Text>
      <Text> a black, forties goodhearted owner proudly smiling, standing in front of a Edibl Eats location. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RicK DAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ms. Terri Adams starting with just one Edibl Eats, has never looked back once she partnered with the Ingrowth Corporation to franchise.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to Reporter Rick Day, wearing a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="887">WNG face-shield</Text>
      <Text>, with the people in line behind him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RiCK DAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes, all of these people are waiting for a chance to sink their teeth into some Edibl Eats. Here and also on Wall Street...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="891">Stockmarket Graphic</Text>
      <Text>, showing Edibl Eats stock symbol next to a green arrow pointing up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmm...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RicK DAY (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats stock has been climbing like a rocket. Great buy for those who got in early...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV shows Rick, holding a bag with the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="893">Edibl Eats logo</Text>
      <Text> on it. He’s walking towards the people in line.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RicK DAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>In my hand is what everyone’s so excited about. </Text>
    </Paragraph>
    <Paragraph Number="12" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="6" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PETE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RICH">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RICK DAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. edibl eats location #1 - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Rick stops between Keke and her cousin PETE, black teen, act’s hard but is soft. Both staring at his Edibl Eats bag. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="567">RiCK DAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Tell me, are you both concern that Congress is discussing as we speak, that something may be in Edibl Eats making people want to eat it?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="568">KekE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Naw that’s some bullsh... Oops, other food places throwing shade, you know, they hating.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="569">Pete</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s right! Because me and my cuz, we been eating Edibl Eats for a minute and the only thing wrong is they lines are too damn long!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My peep’s been blowing up my phone waiting on me to get back. But all the fake news got people thinking they might close the stores. So now everybody’s out here.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RICK DAY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How long have you been in line?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PETE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Didn’t you hear me, too damn long!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It should be moving faster cause everybody knows what they want.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PETE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, some of what you got. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yup, put the red sauce on it first, makes it taste so good! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="570">RICH</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hold on, get back! I’m taking this back to the station... maybe. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ha, lucky we close to the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>pETE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, real lucky.</Text>
    </Paragraph>
    <Paragraph Number="13" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RICK DAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1224">dEON'S LIVING ROOM</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron sitting at the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="895">table</Text>
      <Text> eating. Scene on TV in the background shows Rick Day.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="571">RicK DAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>On that note, I’m out of here! Rick Day, WNG News. Back to you Tom. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to Tom Collins.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="572">TOM COLLINS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you Rich and good luck bring that back here. Even as Edibl Eats is enjoying their unprecedented success, Congress is meeting right now to decide if its enhanced to make people eat it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A picture of a black man with red liquid all over his face is over Tom’s shoulder. Ron’s eating is still heard. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Alarming incidents kept showing up on social media. Like this customer identified as Phil, who jumped over the counter with a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="899">baseball bat</Text>
      <Text> in hand and started eating as much Edibl Eats as he could.</Text>
    </Paragraph>
    <Paragraph Number="14" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="7" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="FACTORY EMPLOYEE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PHIL">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. cellphone footage - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Video from cellphone plays.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="573">pHIL</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmm, just one more!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="897">2 POLICE</Text>
      <Text> arrive but Phil fights them off. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PhIL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Leave me alone, just one more!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He grabs some and shoves them into his pockets and mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PhIL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmm...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Phil drops the bat and grabs a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="901">plastic bottle filled with red sauce</Text>
      <Text> and squirts a stream into his mouth. The Police grab him causing Phil to squirt red sauce all over his face.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="574">RON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ha, Mmmm.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PhIL</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmm...This mine, mine!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to WNG News set with Tom Collins.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Then there was this week’s disturbing story that brought lots of unwanted attention to the Edibl Eats Corporation...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Over his shoulder, a building with Edibl Eats logo on it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>At a distribution center, a fight broke out at lunch between workers over Edibl Eats, provided by management. </Text>
    </Paragraph>
    <Paragraph Number="15" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="8" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="FACTORY EMPLOYEE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. cELLPHONE FOOTAGE - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to cellphone footage of </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="903">3 Edibl Eats FACTORY EMPLOYEE’S</Text>
      <Text> fighting. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="905">2 gun shots</Text>
      <Text> are heard, the picture is blocked momentarily, then it reveals FACTORY EMPLOYEE #1 with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="910">hand </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="911">gun</Text>
      <Text> in one hand and Edibl Eats in the other.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="575">Factory employee #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Told you I wasn’t bull(beep) with y’all’s asses! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to Tom Collins.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>One person was seriously injured and one fatality. Oh, this just in. We’ll now take you outside the Edibl Eats headquarters, where their spokesperson MARK is making a statement.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>TV changes to MARK, a white forties warm but tense person. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="576">MARK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Here at Edibl Eats we stand behind our product and want to reassure our customers that this news is being created by our competitors...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>More red sauce...</Text>
    </Paragraph>
    <Paragraph Number="16" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="9" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPORTER DRONE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPORTER DRONE #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPORTER DRONE #3">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="913">edibl Eats office building</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mark is standing in front of a building with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="915">3 REPORTER DRONES</Text>
      <Text>, with mic’s extending out, hovering in front of him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="577">MARK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me state for the record that Edibl Eats is safe!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="578">Reporter drone #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So claims that your product is enhanced to make people eat it...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Are absolutely false! It’s the great taste that keep customers coming back. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="579">RePORTER DRONE #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Concerned about your meeting on Capital Hill later today?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, I’m looking forward to clearing our companies name and reputation. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="580">RePORTER DRONE #3</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats is a Genetically Modified Designer Food right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes, it’s created in a lab and people shouldn’t be concern because they’ve eating GMDF’s since 2022...</Text>
    </Paragraph>
    <Paragraph Number="17" Type="Scene Heading">
      <SceneProperties Length="1 2/8" Page="10" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BUS ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LITTLE BOY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MOTHER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TEXT OF DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. bus - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WE SEE the on-board monitor showing Mark.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="581">MARK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s a safe, nutritious solution to keep up with the demands of a growing population. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WE SEE Deon looking at the words over his cellphone.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="582">TEXT OF DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Call me back  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>His finger writes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TEXT OF DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I love you!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="583">Guy #1</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yo homie, they doing any hiring where you at?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon looks up to see GUY #1. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="917">10 BLACK PASSENGERS on bus</Text>
      <Text>. Deon sweeps his finger over cell and it goes dark. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="584">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Naw, but checkout Training for work.com. They got programs to get you trained and then hired. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon grab his bag and walks to the exit doors. He passes a MOTHER and LITTLE BOY, who smiles and points to his bag.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="585">LiTTLE BOY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Momma, I want some of that to eat! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="586">MoTHER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You had that for dinner yesterday.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="587">BUS ANNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>43rd King Drive next stop.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Little Boy fusses as Flatscreen monitor shows Tom Collins.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="588">ToM COLLINS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Designer Foods are saving the planet’s water supply and reducing pollution by... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="919">A PRETTY LADY</Text>
      <Text>, looks at Deon smiling. Deon returns smile as she looks at his Edibl Eats then back to him. Deon gives her a “in your dreams” look. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="921">Bus security camera</Text>
      <Text> POV.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...decreasing the use of animals as a food source. But push back from consumer protection groups want...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BUS ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Doors are opening.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Bus doors open and Deon walks off, protecting his bag of Edibl Eats as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="923">2 PEOPLE </Text>
      <Text>wait to get on. </Text>
    </Paragraph>
    <Paragraph Number="18" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="11" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="BRANDY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="POOK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1226">urbAN NEIGHBORHOOD STREETS</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We See </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="925">boarded up businesses and empty lots</Text>
      <Text>. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="930">5 BLACK PEOPLE</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="931"> </Text>
      <Text>going in and out of a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="933">liquor store</Text>
      <Text> and a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="935">store front church</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon see’s RAY an black twenties, do first then think thug, standing near his apartment building talking to his sidekick POOK a black hotheaded teen. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="937">Gang symbols are on their face-shields</Text>
      <Text>. Ray inhales deeply when Deon is near him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="589">rAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Smelled that a block away!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="590">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That is one big ass nose.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="591">pOOK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got that for us, right? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This two fist special? Yup.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ray stops Pook from responding. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ray</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Our ex-homie ain’t going nowhere. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PoOK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You on a short leash fool. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="945">Deon walks towards his apartment building</Text>
      <Text>. He sees BRANDY, a black twenties heart for the people with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="939">2 COMMUNITY WORKERS</Text>
      <Text> giving out </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="941">scan flyers</Text>
      <Text> as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="943">4 BLACK PEOPLE</Text>
      <Text> walk by. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="592">bRANDY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hi Deon. We’re meeting with the Alderman to get a grocery store in our neighborhood. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s wrong with the corner store?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BRANDY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>All they sell is sugar and salt!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whatever.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>BrANDY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Tell Ron and love my blog as much as you love Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ain’t gonna happen.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon walks towards his apartment building’s entrance. </Text>
    </Paragraph>
    <Paragraph Number="19" Type="Scene Heading">
      <SceneProperties Length="7 1/8" Page="12" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PEOPLE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPORTER DRONE #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPORTER DRONE #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SENATOR ARMSTRONG">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TOM COLLINS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. DEON'S LIVING ROOM - DAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron is still eating. TV in the background shows Tom.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="593">ToM COLLINS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This just in. We now take you to Capital Hill where Senator Armstrong, head of the committee investigating Edibl Eats, is about to make a statement.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>SENATOR ARMSTRONG, black fifties warm but serious, at </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="947">podium</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="594">Senator armstrong</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>While Edibl Eats started out as a great American success story, we need answers to these allegations that it may be genetically modified to create this appetite for their product. Until we can confirm, I’m proposing that we suspend the sale of Edibl Eats and close all their locations.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron looks up, his </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="949">mouth covered with red sauce</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="595">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV shows </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="951">3 Reporter Drones in front of Senator</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="596">REPORTER DRONE #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>When will this suspension start?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SeNATOR ARMSTRONG</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Once it passes the vote which will happen when I rejoin the meeting.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="597">REPORTER DRONE #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How long will the suspension force the closer of all Edibl Eats?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SENATOR ARMSTRONG</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Until our investigation is concluded. Thank you.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to Tom Collins.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is not the news executives at Edibl Eats wanted to hear or the millions of people who enjoy it. Stay tune as this story unfolds. Next, gang violence is up across...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ain’t that a bitch! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="953">Key opening sound of 1st lock on the door</Text>
      <Text>. Ron quickly clean up his Edibl Eats mess on the table. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Urban communities are under seize... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="955">Key opening sound of 2nd lock</Text>
      <Text>, Ron runs into </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="957">kitchen</Text>
      <Text>, throws it into the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="959">trash can</Text>
      <Text> and sprays some </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="962">air fresher</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="964">Key opening sound of 3rd lock</Text>
      <Text>, Ron runs back to his seat. The door is opened and Deon enters the apartment.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s up Unc, you home early.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="598">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey Ron. Home from class already? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM COLLINS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Arrests are few, people are fed up and police are overwhelm.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Class ended early. You won’t believe what they talking about on the news...ooh, Edibl Eats. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s the news talking bout? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats! Saying you shouldn’t be eating it because of how its made!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM COLLINS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>People are scared to be on the streets.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon sits the bag on the table and goes to wash his hands.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I really don’t care how its made. I only care about how good it taste.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The news said Edibl Eats is not safe to eat...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM COLLINS (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Violence in black and Latino communities has been increasing...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon walks to table and flashes a “whatever” look at Ron.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They saying somethings in it making you eating it!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon opens the bag, takes out </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="966">container holding the food</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You should listen to the news before you eat that.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon opens the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="968">red sauce container</Text>
      <Text>, pours it over </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="970">the food</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You should listen and not eat any.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron’s eyes get big as Deon takes a big bite.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Politicians are talking about it.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon turns off the TV. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>dEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not anymore.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It could be some fake news. We been eating Edibl Eats since it first came out and ain’t nothing wrong with us, right? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ain’t a thing wrong with me! Mmmm. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea we healthy and feel good. So, break me off some.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The news might be right. I’m willing to sacrifice myself for you bro. Mmmmm</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Jesus did that already. Hook me up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>From the smell when I came in, you just ate Edibl Eats with a side of mountain fresh spring flowers.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>A friend gave me a small piece for lunch. That smell just lingers.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon pours on some red sauce and keeps eating.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I would of saved you some but it tastes best when fresh, not reheated.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Also tastes best eating it when home from class early!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Or home from work before anybody! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Or when you don’t pay for it, the way you eat it most of the time!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know my moneys short because I’m in college full time...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon keeps eating.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But thats going to change once I get my degree.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, they hiring sociology majors left and right.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What I’m majoring in is important. The social conditions of our people is bad which leads to bad mental health. I want to help change that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You seem to be doing real good in sociology right now. Socializing at parties, on social media, social with the ladies. Brandy said hi. Yea you real good at social. It just don’t pay for nothing. Mmmmm</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Everybody’s not good at knocking cement off bricks like you.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Once I finish my apprentice program I’ll be building neighborhoods.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Construction ain’t my thing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Working hard ain’t your thing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I doing my thing! After I graduate from college I’m opening a community center to help our people. And you know my beats and rapping is good! So I don’t need that kind of job. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Jobs like construction, being a electrician or carpenter are what can fix our social conditions. Those were jobs our people had back in the day. Money from those jobs helped Marcus Garvey, Malcolm X, and Martin Luther King do the work they did.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just like your money is helping me!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You ain’t no MLK! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, whatever. So Brandy told you to tell me Hi? She got a real nice... blog. Give me some Unc. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh shit! I think I can taste whats wrong with it. Don’t risk it!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe I’ll go to Atlanta and stay with my mom.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Your mom put you out already and she moved there to get her life together. Plus I promised Cal I’d look after you when he went to prison. I was drunk when I said it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s why I’m in school, to help people like my mom and brother. To stay out of prison and off drugs. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea whatever. Here. Unless you want to wait to see if it’s safe?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Man I don’t give a damn what them fools talking about! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I thought you’d change your tune</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My man! Pass that red sauce.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>With each bite a look of pleasure covers their faces. They eat like wolves. Ron’s finished and looks at Deon.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey you gonna split the rest right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, right between my teeth.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron reaches for a piece but Deon slaps his hand away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Reach again you pulling back a nub.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m tired of your ass! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m knock you out and eat in peace! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon jumps up and they dance around the table like boxers.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How you gonna eat with no teeth?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Wild swings, Deon hits Ron in the stomach who then </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="972">farts</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn that stinks! No fair.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t believe you hit me! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pew, I regret doing it. I’m sorry. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon opens a window as Ron holds belly and turns on the TV. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="599">TOM</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>..to eat. Once again a decision has been made to close all Edibl Eats until confirmed its safe to eat...   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s what I was telling you! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Tom</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...sure the Ingrowth Corporation will file an appeal...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the hell! Its my right to eat whatever I want. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No word at this time when stores will be closed...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We got to stock up right now before they’re all close!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shouldn’t we wait for the results of the investigation?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon tosses the last piece of Edibl Eats in his mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ve just completed mine. Grab the garbage and get the funk out. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, lets go! Does smell bad.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ToM</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... Representatives from Edibl Eats feel this is a rush to judgement...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Scene on TV changes to</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1228"> 15 PEOPLE outside restaurant</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="600">People</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We want Edibl Eats! We want Edibl Eats...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn straight!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Ron exit. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TOM COLLINS (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Authorities are warning people to avoid going near any Edibl Eats. Police are being called in...</Text>
    </Paragraph>
    <Paragraph Number="20" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="19" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="974">urban street traffic</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="978">Rap music is heard</Text>
      <Text> as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="976">Ron’s car </Text>
      <Text>is driving through traffic. They pass vacant lots and closed businesses.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="601">RoN</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This some of my new stuff playing. </Text>
    </Paragraph>
    <Paragraph Number="21" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="19" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON AND DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. ron’s car - day</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="602">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not bad. Fools done pissed me off.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="603">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m getting me 2 no 3 orders!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just three! Man I’m bout to clean that joint out! All food got stuff that’s bad for you in it, now they want to fix it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, sugar bad for you but they not fixing that. Everything that tastes good got some in it. I can’t eat no cereal without it being sweet.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lots of black people got sugar diabetes.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I tried eating some cereal with no sugar once, tasted like I was eating some wet paper...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That politician tried to tax drinks with sugar in em, people voted her ass right out of office. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wish they would try to make me eat cereal with no sugar.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now they care about what we eat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="604">RoN and Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They must think we stupid!</Text>
    </Paragraph>
    <Paragraph Number="22" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. uRBAN STREET TRAFFIC - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The traffic is slowing down.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="605">Ron</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’re close to the Edibl Eats and traffic has slowed down. </Text>
    </Paragraph>
    <Paragraph Number="23" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="20" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="606">DeON</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Park and lets hustle there. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="607">RON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hold on, I know a short cut.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron turns off the main street and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="980">turns into the alley</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No traffic here. Slide up on it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They exit the alley close to Edibl Eats. The line is long.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The drive thru is longer than the one to the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hurry before it gets any longer! </Text>
    </Paragraph>
    <Paragraph Number="24" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="21" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="FAT GUY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #3">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LADY #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MANAGER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. edibl EATS LOCATION #1 - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Ron run over and join the line of PEOPLE.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="608">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How’s the line moving?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="609">lADY #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s not too slow. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="982">A FAT GUY</Text>
      <Text> carrying a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="984">six pack of beer</Text>
      <Text> joins them in line. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t wait!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="986">GUY #2</Text>
      <Text> exits </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="988">Edibl Eats with 4 bags</Text>
      <Text> in his hands. He winks at GUY #1 who is close to the entrance. After a moment, Guy #1 turns to face the people in line behind him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="610">GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yo! Whoever wants my place in line, what you got to offer!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="611">GUY #3</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll give you $20!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>LADY #2</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll give you $30 and buy you some Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey bro, remember me? I told you...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="612">Fat Guy</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give you </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="990">$40, a six pack of beer and a blunt</Text>
      <Text>!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>GUY #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You are the winner, come on!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Fat Guy jogs to Guy #1 and gives him the stuff. Guy #1 then quickly leaves. The Fat Guy is happy and celebrates.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="613">RON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That was gone be hard to beat Unc.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="992">2 PEOPLE exit Edibl Eats</Text>
      <Text> as the MANAGER peeps out.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="614">mANAGER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I regret to tell you that we are sold out and are now closed.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Manager quickly locks the doors. The Fat Guy rushes to the locked doors and see’s EMPLOYEE’S #1, #2 and Manager packing up the rest of the Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Fat GUY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This some bullshit, open this door!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He quickly turns to look for Guy #1 who is getting into </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="994">a car driven by Guy #2</Text>
      <Text>. The Fat Guy runs after them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Fat GUY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give me my stuff back!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Guy #1 from inside the car, holds up a blunt.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>GUY #1</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>A deals a deal playa!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The car drives off as the other People become very agitated.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This the main Edibl Eats in the hood. Let’s go to one that’s not so damn popular.</Text>
    </Paragraph>
    <Paragraph Number="25" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. uRBAN STREET TRAFFIC - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Music is playing as Ron’s car moves through the traffic. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="615">DeON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This original one should be better. Located in a hood that sucks. </Text>
    </Paragraph>
    <Paragraph Number="26" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="22" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. rON'S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="616">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It was the only land she could get.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="617">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I sure hope Ms. Adams is alright. This has to be tough on her. If it wasn’t for her I’d still be in a gang. Maybe even in prison. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’s probably on a island with all that money laughing at everybody. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon see’s </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="998">2 PEOPLE smoking cigarettes</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This some bull. They not stopping people from selling cigarettes! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And they will steal your lighter!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They know what cigarettes do but they still selling them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They ask for a lite, I’ll say nope. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sell em everywhere, no problem!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They will have a lighter and still asks yours!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They pull around the corner and the line is not that long.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>See, what I tell you. Lets hurry!</Text>
    </Paragraph>
    <Paragraph Number="27" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="23" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #4">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROBBER #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="ROBBER #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1000">edIBL EATS LOCATION #2</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Ron quickly join 4 face-shield CUSTOMERS in line.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="618">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The line is moving and we’re going to be inside the door in no time! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="619">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Time to load up before they close all of them down. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="620">Guy #4</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re closing Edibl Eats? Where you hear that at?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>On the news.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Guy #4</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>For real?! Let me check. </Text>
    </Paragraph>
    <Paragraph Type="General">
      <Text></Text>
    </Paragraph>
    <Paragraph Type="General">
      <Text>GUY #4 pull’s out his phone to check. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Everybody don’t know. Good for us.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>GUY #4</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wow, but that can’t be true. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text> ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You shouldn’t take a chance on eating this stuff. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>GUY #4</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is fake news. You can’t believe everything on the Internet. Anyway we’re inside now, smells good right?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Real good, I’m a shut it down!  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Me too!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1002">ROBBER #1 and #2</Text>
      <Text> rush into Edibl Eats #2 </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1004">carrying guns</Text>
      <Text>. Their </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1006">face-shields are dark tented</Text>
      <Text> so you can’t see their faces.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="621">ROBBER #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yo, nobody moves, nobody gets shot!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Aww man, don’t take my money.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="622">ROBBER #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fool we don’t want yo money. Give us all the Edibl Eats now!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1008">Store security camera</Text>
      <Text> shows Robber #1 jump over the counter. He forces EMPLOYEE’S #3 &amp; #4 to </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1010">put food into a large bag</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just take they money. Remember how much fun that was yesterday?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>rOBBER #2</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get all the red sauce too!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>GUY #4</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please, leave me some!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roBBER #2</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Here’s some.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He hits him with his </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1012">gun butt</Text>
      <Text>, knocking him to the floor. Robber #1 jumps back over the counter and they run out. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon steps over Guy #4.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Guess you believe us now.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He steps to the counter to a scared </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1013">Employee #3</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I want 5 large E.E’s and a Coke. It’ll be fresh and hot!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Employee #3 looks at him like he’s crazy.</Text>
    </Paragraph>
    <Paragraph Number="28" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="25" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Ron are sitting in the parked car. The </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1015">sound of a police siren</Text>
      <Text> is heard in the distance. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="623">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s this world coming to when robbers won’t steal good money but take food off your plate instead. Maybe you was right, we shouldn’t be out here trying to eat this.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="624">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We should of jump they asses! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t eat with a bullet in you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t think everybody knows they closing them all down. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>dEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What you talking about! Those robber’s sure knew. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If we go to a Edibl Eats that’s not in the hood... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like the one near where I work...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron put’s the car in gear and drives. </Text>
    </Paragraph>
    <Paragraph Number="29" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. uRBAN STREET TRAFFIC - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Music plays as Ron’s car is weaving through traffic. There are more businesses and less vacant lots in this area. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="625">DeON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They not stopping them from... </Text>
    </Paragraph>
    <Paragraph Number="30" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="626">DeON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Putting salt in everything.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="627">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ninja’s always robbing shit!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Remember when McD took the salt off of fries, they almost went out of business. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Steal yo food, yo shoes!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’ll let people pour salt right down they throats. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give them a reason, they’ll stickup the whole block at one time. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’ll be stealing salt next!</Text>
    </Paragraph>
    <Paragraph Number="31" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="26" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1231">busy street traffic</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Traffic’s slowed and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1017">5 PEOPLE </Text>
      <Text>are running towards Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="628">DEON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Awww shit.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="629">RoN</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Try my move again.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron makes a right, turns into </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1019">the alley</Text>
      <Text> and hits the gas. </Text>
    </Paragraph>
    <Paragraph Number="32" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="26" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Through the front windshield coming out the alley, they see Edibl Eats #3 and all hell is breaking loose. </Text>
    </Paragraph>
    <Paragraph Number="33" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="27" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1021">EDIBL EATS LOCATION #3</Text>
      <Text> - DAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1023">10 WHITE PEOPLE</Text>
      <Text> have stormed inside. </Text>
    </Paragraph>
    <Paragraph Number="34" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="COP">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITE LADY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. eDIBL EATS LOCATION #3 - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>WHITE COP </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1025">points his gun</Text>
      <Text> at White Lady #1 and 3 WHITE PEOPLE.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="630">Cop</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Stay back! Hurry up cook!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="631">WHITE LADY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He won’t shoot. We ain’t black. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She walks pass the Cop and grabs some Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>COP</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bitch! The rest of you stay...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The White people push pass the Cop capital riot style. </Text>
    </Paragraph>
    <Paragraph Number="35" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They are looking at the madness. Ron is recording on cell.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="632">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>These white people ain’t playing. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="633">DeON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No, no, no! I can’t loose you too. Let’s get in there before its...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Bursting out the</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1027"> store’s back door</Text>
      <Text> is Keke and Pete with lots of bags, chased by White Lady #1 and 3 more White People. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Check that out!</Text>
    </Paragraph>
    <Paragraph Number="36" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="27" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. urban street near Edibl Eats #3 - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>As Keke and Pete run, White Lady #1 throws </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1029">a fry basket</Text>
      <Text>, hit’s Pete in the head, he falls and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1031">drops his bag’s</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="634">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get em up, hurry!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke scoops up some bags as Pete tries to get the rest.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let’s go, run!</Text>
    </Paragraph>
    <Paragraph Number="37" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="635">DeON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know her. Her name’s Keke. Went to same high school. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="636">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The guy with her is fucked. </Text>
    </Paragraph>
    <Paragraph Number="38" Type="Scene Heading">
      <SceneProperties Length="2 2/8" Page="28" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PETE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITE GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WHITE LADY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. eDIBL EATS LOCATION #3 - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1033">Pete clutching his bag</Text>
      <Text> gets up but White Lady #1 pushes him down and tries to take it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="637">PeTE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get away, this mine!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="638">WhITE LADY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let go, you got lots! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Bag rips open, White Lady #1 grabs some and eats. Pete gets knocked back down by WHITE GUY #1 who run’s toward Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="639">WHITE GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give me that!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He reaches for bags but Keke karate kicks him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="640">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Keke! It’s Deon, over here! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke see’s 2 other White People running towards her. She runs towards Deon who opens the back door.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hurry!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She gets in the car, Deon jumps in as Ron drives away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We were there to get some.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="641">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Its too late. They said they were closing and all hell broke loose.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="642">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You said Edibl Eats in the White hood would be different.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They serious about they E.E. too. Think my cousin’s okay?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He got a lit beat down, should be Okay. I’m glad we got there when we did to save you from getting one. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s been a minute Deon. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea it has. Glad to run into you or you into me... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You still look the same.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke looks </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1233">sweaty, her hair’s a little messy</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Uh, you, you look the same too.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron looks back at Keke with all those bags of Edibl Eats.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You looking real good girl. You smell good too! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Watch where you driving.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We gotta go back for Pete.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Noway am I going back there!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just take me to our car. It’s a block over from all of that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We can do that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>For some of that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I ain’t giving you nothing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We just saved you from getting a...   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ron chill on all that! Let’s just help my friend.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon looks at Ron with the “wink eye” look.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Glad we showed up to help you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’d gotten away without your help. Turn down this street.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’d of been getting your... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I put my money on Keke. You saw that kick. You got skills girl!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, that was bad ass.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just one bag. But take me first.</Text>
    </Paragraph>
    <Paragraph Number="39" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="30" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1235">urBAN NEIGHBORHOOD STREET</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron’s car drives down a street with nice homes on it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="643">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There it is! Thanks for your help.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke tosses a bag near Deon but Ron snatches it up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="644">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Boy you better hand that...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron pull’s up to Pete’s car as he points ahead.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="645">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That Pete coming up the street with all those white people. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Down the street are </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1035">5 WHITE PEOPLE</Text>
      <Text> and Pete.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the hell?!... I need a brick.</Text>
    </Paragraph>
    <Paragraph Number="40" Type="Scene Heading">
      <SceneProperties Length="1" Page="30" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. neighborhood street - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke gets out the car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="646">DeON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ve seen that look before. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon gets out, as trunk opens. He shows her a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1037">lug wrench</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="647">Keke</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’ll work.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1039">Keke hit’s the window of Pete’s car</Text>
      <Text>, causing it to crack as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1041">the alarm goes off</Text>
      <Text>. Ron gets out the car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn, you always did have a interesting style about you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="648">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>As in a, thug kind of style?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke hit’s it again and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1237">glass explodes into the car</Text>
      <Text>. The People start running towards them.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>She opens the front door and reaches inside. The trunk pops open to reveal it’s filled with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1043">lots of bags of Edibl Eats</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, look, look...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I see, I see, I...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KekE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Put it in your car, hurry!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They load the Edibl Eats into the back seat. The People start running faster towards them, pushing Pete out the way.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They coming! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t believe Pete told! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s all of it, let’s go!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They jump into car and Ron takes off.</Text>
    </Paragraph>
    <Paragraph Number="41" Type="Scene Heading">
      <SceneProperties Length="2 1/8" Page="31" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Through the rear windshield they see the PEOPLE running after them. Pete can be seen stopping at his car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="649">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like Pete’s getting away. How did you all get so much? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="650">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We was making our regular Edibl Eats for breakfast run when my friend who works there said all stores might close today. So we started buying as much as we could. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Plan worked, except for Pete.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He should of took that ass whopping and kept his mouth shut. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="651">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, I’d of took it with a smile on my face.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I need y’all to take me over my sisters place. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Over your sister place?! Just you two gonna eat all this up?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And... Pete’s butt.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pete should be out the picture. Let us buy what was going to be his.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We gonna need all of this to live on. Don’t know how long this shut down is going to last. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Then we got to find us another Edibl Eats so we can get some. I don’t believe all of them are out. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s like that everywhere and getting worst. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You don’t know. You got yours, we still got to get ours. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>First take me to my sisters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That will cost you some more bags.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No way, I’ll get there on my own.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Alright, get out. See how far you’ll get with all that.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got a point, look out the window.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Through the car windows, </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1045">people are running towards Edibl Eats #3 </Text>
      <Text>looking desperate and from there looking angry.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Please take me to my sisters. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If all we got is this one bag then we need to get some more. I can eat this all... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>By myself.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lets go to the white suburbs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Right! We’ll have much better luck.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ain’t no Edibl Eats in the White burbs! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s one somewhere! You’re welcome to come.                 </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay. I’ll give you one more.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke tosses a bag to the front. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hope you choke on it!</Text>
    </Paragraph>
    <Paragraph Number="42" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT.</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1047"> ingrowth office building</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="652">MARK</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>When you said people will go nuts’s over the new formula...</Text>
    </Paragraph>
    <Paragraph Number="43" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="HENRY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1049">mark willson’s office </Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>MARK, sitting at his </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1051">desk</Text>
      <Text>, with HENRY a white forties heartless, company-man who’s looking out a window.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="653">MARK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t think you meant, going nut’s for real! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="654">HENRY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Try to remain calm Mark.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How the hell do you suggest I do that with all our locations closed and this investigation happening.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The people I represent will contain this, make sure someone is held accountable and then we’ll continue on with our work. So relax, the sales have been well worth this small bump in the road.   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Small bump in the road!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know it seems bad but the data from this is invaluable. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What data? The stores are closed. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The data from this reaction. Trust me, everything will be okay. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If this a small bump... Damn!</Text>
    </Paragraph>
    <Paragraph Number="44" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="34" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. rON'S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron’s car is driving through traffic. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="655">KEKE</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They crazy to stop making this.</Text>
    </Paragraph>
    <Paragraph Number="45" Type="Scene Heading">
      <SceneProperties Length="2 6/8" Page="35" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Everybody is enjoying eating their Edible Eats. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="656">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmmm, so good. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="657">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If this were a women I’d asked her to marry me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="658">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If this were a man, I’d be having his babies.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If this were a car, I’d be it’s chauffeur, for free.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Keke look at Ron and shake their heads.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Watch out!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1239">slams the brakes, almost rear ends another car</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>My bad! I got to pull over somewhere so I can focus.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron pull over on an urban street and parks. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It was already good but when they came out with the red sauce...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That took it to another level.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I once ate Edibl Eats while getting busy with this honey.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That ain’t right.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I once told my job I was sick and ate EE’s all day. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This over your job, I don’t blame you.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Was that the day you accused me of eating some before you got home? Called me a selfish asshole? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Best day ever!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I once ate some while I was sitting on the toilet. I was putting it in and pushing it out. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thats a shitty way to eat some.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>TMI girl. Now I got that image stuck in my head. You on the toilet with a order of Edibl Eats sitting on your lap and some thongs sitting on top of your ankles... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t be imagining me in my thongs. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmm but ain’t no bad way to eat it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I was imagining you on a toilet but now you’ve just replaced that image with you wearing some thongs... You looking good too. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Only my man is allowed to imagine me in some thongs.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If I was your man I wouldn’t have to imagine.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Keke make eye contact.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And we got lots left!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You ain’t got nothing left! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me buy some.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I ain’t selling you nothing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wasn't for us you wouldn’t have... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Dude chill out!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I didn’t need you or Deon! Then or right now. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Should of left you with Pete’s ass! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shut up Ron! Keke there’s no way I would of left you out there when I could of helped. Especially because we were close back in the day. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Close? Boy bye! I barely remembered your name. Fuck this, I’m grab all of what’s mine, yup all of it and getting the fuck out...  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Hand slaps hard on window next to Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="659">GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey! You are looking good!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like we got company.</Text>
    </Paragraph>
    <Paragraph Number="46" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="37" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="GUY #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PRETTY LADY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. rON'S parked CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Guy #1, Guy #2 and Pretty Lady looking at food in car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="660">GUY #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y’all got plenty to share!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pretty Lady looking in window at Deon and food on his lap.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="661">Pretty lady</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey cutie, I remember you. Open the door and let’s have some fun.</Text>
    </Paragraph>
    <Paragraph Number="47" Type="Scene Heading">
      <SceneProperties Length="1" Page="38" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="662">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, somebody remembers me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="663">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Sooo</Text>
      <Text> you still getting out?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="664">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hell naw, drive!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m still eating and I’m gonna slowly enjoy every bite.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Deon tell him to drive!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You barely remembered my name.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You and my brother Link were tight. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="665">GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I want to get to know you too.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Even after we joined different gangs we was still tight.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They try to rock the car back and forth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="666">GUY #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We gonna flip this car over if you don’t give us some! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But we didn’t get to see each other as much. Last time I saw you was at his funeral.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s when I knew I had to get out the gang. But you stayed in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And still a hood rat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And you still a asshole!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>See Unc... She remembers me.</Text>
    </Paragraph>
    <Paragraph Number="48" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. Ron’s car parked on street </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="667">GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They got Edibl Eats in here everybody. Lots of it in this car.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>2 more Edibl Eats Addicts start walking towards the car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="668">GUY #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They took it from everybody else! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="669">DEON</Text>
      <Text> (o.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s time to make a move. </Text>
    </Paragraph>
    <Paragraph Number="49" Type="Scene Heading">
      <SceneProperties Length="4/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. ron’s car</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron drives off as they try to jump on the car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="670">RON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fools! What’s the world coming too. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="671">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like more fools to me. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1241">Bottle burst on back of car</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ooh! I’m gonna circle back and run his ass over!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, we had a deal!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="672">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Right. Head to her sisters.</Text>
    </Paragraph>
    <Paragraph Number="50" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. urBAN STREET - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Car drives towards a house with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1060">6 NEIGHBORS</Text>
      <Text> on the front porch. Their </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1063">face-mask shields have the same symbol </Text>
      <Text>on them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="673">KEKE</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s Debra’s house up ahead but pull over right here.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron parks the car.</Text>
    </Paragraph>
    <Paragraph Number="51" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="39" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style=""> </Text>
      <Text>INT. rON’S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="674">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Why all these people at her house?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="675">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looking hungry and pissed off.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’ll wait here until I see her.  </Text>
    </Paragraph>
    <Paragraph Number="52" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="40" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEBRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PETE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1053">debra’s house</Text>
      <Text> - day </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra walks out the house and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1055">stands on porch</Text>
      <Text>. Some Neighbors give her ‘where it at’ looks as </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1058">her phone ring’s</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="676">dEBRA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Keke, where the hell you at?!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>INTERCUT PHONE CONVERSATION   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="677">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m close. Sounds like a lot of people are around you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>dEBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t worry about who is around me. Just get back here with that food. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete joins Debra on porch. She signal’s him its Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="678">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>There’s Pete! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="679">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn, he looks pissed.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll be there soon. Debra, it’s not safe if lots of people are around.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Only thing you need to be concerned with is getting back here!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete recognizes Ron’s car and points it out to Debra. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>deBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What Pete? That’s the car?! Girl you parked down the street?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s because you got all them people with you. They all gonna want some. Come down the street but leave them there. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>These our people. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The people on Debra’s porch notice that something’s up.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just you!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, me and Pete are coming over but this is some BS. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We wouldn’t have this problem if Pete didn’t take a bunch of people to his car to take it all.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He did what?! He told me you took it all with your friends. Left him to get beat up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s a lie! I took it before he could give it all away. Come over here but leave Pete’s butt there.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay, here I come. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra hangs up. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="680">PeTE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let get our food!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait here, I’ll check it out.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PeTE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What?! Wait?! You for real?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll wave you over. All y’all chill right here. I’ll be right back.</Text>
    </Paragraph>
    <Paragraph Number="53" Type="Scene Heading">
      <SceneProperties Length="1 3/8" Page="41" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEBRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. rON’S CAR - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon, Ron and Keke put their </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1066">empty bags</Text>
      <Text> under the car seat. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="681">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pete, all them people, not good.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="682">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wouldn’t be in this situation if he had some balls. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He did, before they stomped on em. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke lets her window down as Debra walks up.  Debra looks into the car, checks out Ron and Deon, who nod hi.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="683">Debra</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So Pete was gonna give it all away? That why there’s grease around y’alls lips. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Rod wipe the grease from around their mouth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I gave them a bag to split for bring me over here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just give me the rest of it...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra try’s to open the door but it’s locked. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...Girl open up this door.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll give you your bags but you got too many people around. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I told you not to worry about them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="684">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>People starting to act real crazy around some EE’s and...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t know you so I ain’t trying to hear what you got to say. I want the rest of that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t bring this near them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Little girl don’t play with me.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KEKE gives Debra </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1068">4 Edibl Eats bags</Text>
      <Text> through the car window.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sick of you and Pete. Grab the rest and come on.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra walks away.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know what’s bout to happen.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But I got to. </Text>
    </Paragraph>
    <Paragraph Number="54" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="43" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEBRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LADY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PETE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>ExT. sTREET NEAR DEBRA’S HOUSE - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra walks toward Pete who looks confused. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="685">PeTE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is that all you got? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete turns and shouts to the people on the porch.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PeTE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey, they got our food and won’t give it to us. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Neighbors start to walk towards Ron’s car.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="686">DEBRA</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Everybody chill, she coming with the rest.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PeTE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well these 2 bags are mine.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete takes 2 of the bags from her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fool you done lost your damn mind! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete walks away smiling as several Neighbors surround him.   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>PETE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This mine, there’s... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="687">gUY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is plenty to share right here! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Guy Neighbor takes a bag. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Guy nEIGHBOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good, plenty of red sauce.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Pete</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This time I’m getting mine! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pete snatches the bag back, it rips and everyone surrounds him grabbing food. A LADY NEIGHBOR walks toward Debra. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEBRA</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This mine...   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="688">LADY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lets eat!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Debra is pushed all around as People grab some food. Keke jumps out the car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="689">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Keke... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke pulls Debra from the pile, her mouth is covered with red sauce. She tries to force Debra to leave and is grabbed by Guy Neighbor but Deon shoves him off of her. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Everybody calm down! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Guy nEIGHBOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ve seen you before. You with that gang.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m not in any gang. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Guy nEIGHBOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bullshit! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="690">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He’s with me! </Text>
    </Paragraph>
    <Paragraph Number="55" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON’S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron looks at the craziness happening, then at the bags of Edibl Eats in the back seat, then at Deon. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="691">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get back here! </Text>
    </Paragraph>
    <Paragraph Number="56" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="44" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LADY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Ext. sTREET NEAR DEBRA’S HOUSE </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke looks at Debra and others eat food off the ground. Lady Neighbor grab’s Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="692">LADY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You heard your sister, go get that food!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="693">Keke</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get your hands off me!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1243">Guy Neighbor swings at Deon, who blocks</Text>
      <Text> and hits him. Keke pushes her into Guy Neighbor. They run and get in the car. </Text>
    </Paragraph>
    <Paragraph Number="57" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEBRA">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. ron’s car </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A fist pounds on the window. Its Debra with a crazed look in her eyes as she runs alone the side of car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="694">Debra</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thats my food, give it to me!</Text>
    </Paragraph>
    <Paragraph Number="58" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="45" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. rON’S CAR </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KEKE pushes two bags to Debra who grabs them and runs towards her house with some Neighbors following her. </Text>
    </Paragraph>
    <Paragraph Number="59" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>iNT. rON’S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="695">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I tried to tell you Deb. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They see Robber #1 chasing Pete, who is running with a bag of Edibl Eats under his arm and a piece in his hand. </Text>
    </Paragraph>
    <Paragraph Number="60" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="45" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. uRBAN STREET - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Robber #1 pulls out </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1070">a gun</Text>
      <Text>, aims and shoots. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1078">Pete falls forward from the force of the bullet hitting him</Text>
      <Text>, throwing everything in the air as he lands on the sidewalk. </Text>
    </Paragraph>
    <Paragraph Number="61" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="45" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>Ext. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1074">streetlight police camera</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>POV showing Pete laying on the ground.</Text>
    </Paragraph>
    <Paragraph Number="62" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="45" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. ron'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="696">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pete!!!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke opens the moving car’s door as Ron slams the breaks. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="697">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What the..!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>KEKE get’s out of the car in shock.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You shot Pete, you bastard! </Text>
    </Paragraph>
    <Paragraph Number="63" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="46" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. uRBAN STREET - sAME</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Robber #1 point’s the gun in Keke’s direction. Deon grabs Keke and they fall on the ground as he </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1076">fires 2 shots</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="698">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me go. I’m kill him!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon gets up with Keke and forces her into the back seat and Ron drives.  Robber #1 picks up the bag of Edibl Eats next to Pete and a piece on the ground. He takes a bite and runs off.</Text>
    </Paragraph>
    <Paragraph Number="64" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="46" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON’S CAR </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="699">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Are you hit?! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="700">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Peteee</Text>
      <Text>! Damn, Pete! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="701">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y’all OK?! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think so. I don’t see no blood.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They all have gone crazy, they have lost they minds. Debra is still back there, Pete is dead, I don’t know what to do. Oh God help me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sorry about Pete, he didn’t deserve to be shot over some food. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This some messed up shit out here! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron turns on the radio. </Text>
    </Paragraph>
    <Paragraph Number="65" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="47" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. radio announcer - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Record all of the announcer’s lines.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="702">Radio announcer</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... Stories like that are happening all over the country. Several reports of fighting in the streets and shootings. Stay away from all Edibl Eats as they are the hub of violence and looting...</Text>
    </Paragraph>
    <Paragraph Number="66" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="47" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>ExT. rON’S CAR DRIVING THRU TRAFFIC - day </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1080">People on the street </Text>
      <Text>are looking very tense. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="703">RADIO ANNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Authorities are demanding that everyone stay inside...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They see </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1082">a POLICEMAN</Text>
      <Text> crouched and hiding against a building quickly eating some Edibl Eats. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="704">RoN</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look! Its got everybody hooked. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RadIO ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>People showing withdraw symptoms...</Text>
    </Paragraph>
    <Paragraph Number="67" Type="Scene Heading">
      <SceneProperties Length="2 7/8" Page="47" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. rON’S CAR DRIVING</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="705">Ron</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They don’t have a clue what’s wrong.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="706">RADIO ANNOUNCER (V.O.)</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cramps in their stomachs, rage...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="707">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats ain’t got nothing to do with this. We been eating it all day and we good. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...friends, family turning on each other...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe we’ll change when we run out of what we got left.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="708">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What I got left! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...Random acts of violence are happening all across the city...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well whatever is left, I don’t want to shoot nobody over it. Do you want to shoot somebody. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron looks through rearview mirror at Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not yet.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...most violent areas are in Black and Latinx neighborhoods... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I do. I want to shoot the fool who shot Pete. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...but affluent areas are experiencing violence as well...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well that’s normal considering the circumstances. But just kill somebody over it. I have felt like beating the hell out of somebody. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, to be honest, me too. A couple of times for sure.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="709">AnNOUNCER</Text>
      <Text> (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...Law enforcement are warning everyone to stay off the streets until they are able to control the situation...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>rON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Cop’s control the situation!? They hooked on the situation too. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron turns off the radio.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The worst part is, I still want to eat some more of this stuff. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know, is that crazy?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The guy who shot Pete was already shooting people in the hood.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You right, he was already a killer, Edibl Eats didn’t make him one. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And it ain’t gonna have nothing to do with me when I shoot his ass. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Keke, I realize that you have been through a lot today. I feel like you should come with me to my place and chill until this blows over. I know you don’t really have a good reason to trust...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll go with you. You’ve had my back through all of this.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon looks into Keke’s eyes and smiles.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ll always have your back.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon looks at the bags of Edibl Eats next to Keke and him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Look, this is yours. However you say its going to go down, that’s the way it is.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let’s just eat what’s here and if we go crazy, we go together. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Sounds like a plan. Lets head home. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron looks in his rearview mirror and sees </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1084">a car weaving through traffic</Text>
      <Text> behind them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I see a car coming up fast.   </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke and Deon look back.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Shit! It’s dudes from my gang! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He thinks I’m still in a gang. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They don’t give a shit about that. They after this food fool! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron’s car starts slowing down. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Somethings wrong with the ride! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Through Ron’s rear window we see Lady Neighbor driving and Guy Neighbor in passenger’s seat with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1086">a gun</Text>
      <Text> taking aim. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Quick, put some bags against the window!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Keke press bags of Edibl Eats against rear window. </Text>
    </Paragraph>
    <Paragraph Number="68" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="50" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="LADY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. lady neighbor’s car - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="710">LADY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t shoot! Drive up next to em.</Text>
    </Paragraph>
    <Paragraph Number="69" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="50" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The car pulls up on side and as Guy Neighbor takes aim, they press bags of Edibl Eats against the windows. </Text>
    </Paragraph>
    <Paragraph Number="70" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="50" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="GUY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LADY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. lADY NEIGHBOR'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="711">LaDY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t shoot!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Guy Neighbor aim’s his gun, try’s to shoot but can’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="712">GuY NEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I can’t get a clean shot. Fuck it!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>laDY NEIGHBOR</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We need that food unharmed!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Lady Neighbor pulls him towards her, they scuffle, she loses control and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1246">slams the breaks almost hitting a car</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Number="71" Type="Scene Heading">
      <SceneProperties Length="1 1/8" Page="51" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. roN'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="713">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I, can’t believe that worked!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="714">DeoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now I know something ain’t right with this! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hope the people who did this get buried under the jail. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="715">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats first office near here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Need they black asses kicked. Messed people up like this.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got my first job there. I can’t believe Mrs. Adams had something to do with this. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She and her partner Mr. Palmer don’t seem like the types who would do something like this.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Out the windows they see </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1088">PEOPLE running</Text>
      <Text> everywhere. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The people on the streets are acting like some zombies. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hell, we been living like we surrounded by zombies before this happen. Gangs shooting so many people, keeps you looking over your shoulders. Scare to be on the streets, watch out over here or I saw some over there. If the gangs grab somebody there’re dead or become one of them. Neighborhoods like ours always been a scary place to live in.  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1090">Smoke starts coming from under the hood</Text>
      <Text> of Ron’s car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn! I can’t believe this is happening right now. My temperature gage is on red! I got to pull over. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron parks, pop open the hood and gets out.</Text>
    </Paragraph>
    <Paragraph Number="72" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="52" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. urban street - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron opens the hood and see’s smoke coming from the engine. He looks on the outside of the car and </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1093">see’s 2 bullet holes</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Number="73" Type="Scene Heading">
      <SceneProperties Length="3 2/8" Page="52" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron gets back in, slamming the door. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="716">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They killed my ride y’all. Told my brother I’d take care of it for him. Damn, damn, damn! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="717">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m sure he’ll understand. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="718">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Last place we want to be suck on is the streets. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>kEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Part of me want’s to leave this in the car but...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But we still want to eat it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How far are we from your place.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Too far to walk. Jumping on a bus is out the question. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I knew this was a stupid idea. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well you must be stupid </Text>
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">becau</Text>
      <Text>...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I have a idea. We’re not too far from the office of Mrs. Adams. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>rON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Think she’ll let us in. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I haven’t seem her in awhile but yea. Their job training program got me my job.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mr. Palmer is dope! We still stay in touch.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like friends in touch or his hands on your butt in touch? One will increase our chances of getting in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like my fist in your eye in touch. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s our best option right now.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I also need to know if they got anything to do with this.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hide the Edibl Eats in something. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Everyone looks around Ron’s car. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I found a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1095">plastic bag</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Me too.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How y’all gonna find stuff in my car and say its yours? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I just stuck my hand under the seat and claimed it.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, thanks. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You ain’t welcome. Guess I can wrap it up in my jacket. How far are we from his place?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>About two blocks. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looking at these people, I think the best plan is to blend in. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So act like, a crack head zombie? Like this? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe more like this. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Tilt your neck more Unc.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, that’s better. Your crack head look is good Keke, like you know.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Actually yo momma is my inspiration. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Bitch you done cross the line!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Who you calling a bitch, bitch!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait, wait a second! Keke, Ron’s mom is a recovering crack addict. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Oh, I didn’t know. Sorry Ron. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Forget about it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If you say I look like a real crackhead, then I know its true. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon snicker.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fuck both you all.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wait! I was just thinking, what if once on the street, this don’t work and we get surrounded. You know what we are going to be thinking?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Kill or be killed?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We screwed?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’ll be thinking, should of ate one more bag before we did this.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Everyone is quite as they think about it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>When you put it like that. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Makes since but it shouldn’t.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let’s just make sure we stay on the low and keep our eyes open.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They look out the car’s windows in every direction. </Text>
    </Paragraph>
    <Paragraph Number="74" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="55" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>EXT. rON’S CAR PARKED ON STREET - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1248">vacant lot, boarded up storefront on empty streets</Text>
      <Text>, only a few people in the distance.  </Text>
    </Paragraph>
    <Paragraph Number="75" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="55" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. rON’S CAR PARKED ON STREET</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They slowly open their bags while looking around. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="719">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Red sauce, makes me feel like a boss.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="720">roN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Help me forget about my ride which has died. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="721">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Makes my frown turn upside down.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>When sure nobody is looking, they take a quick bite. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hello my old friend, mmmmm. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmmmm, so good!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Come ease my pain. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They look out the car windows again and take another bite. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mmmmm. If loving you is wrong... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I don’t want to be right.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So good to me.</Text>
    </Paragraph>
    <Paragraph Number="76" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="56" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. roN'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>We see them looking out the windows in all directions. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="722">DEON</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>More sauce. </Text>
    </Paragraph>
    <Paragraph Number="77" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="56" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. roN'S CAR</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron takes a bite like a dear looking around for predators.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="723">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We living good right now y’all. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="724">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is the best food ever. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="725">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t get enough of the red sauce! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can never have too much. </Text>
    </Paragraph>
    <Paragraph Number="78" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="56" Title="">
        <SceneArcBeats/>
      </SceneProperties>
      <Text>ExT. rON’S CAR PARKED ON STREET - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>From the outside of Ron’s car we see them through the windows having a feast. Eating, licking fingers and laughing.</Text>
    </Paragraph>
    <Paragraph Number="79" Type="Scene Heading">
      <SceneProperties Length="7/8" Page="57" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="EDIBI EATS ADDICTS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. rON’S CAR</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="726">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I think I inhaled that.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke’s is licking inside the red sauce container. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="727">KeKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yup...Mmmm</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="728">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I swear I can eat two...more.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Outside the car’s windows, pressed up against them are faces of </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1097">5 EE ADDICTS</Text>
      <Text>. Saliva on their mouths, biting their lips, one is licking the window.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="729">Guy #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me have some.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="730">GUY #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Give it too us!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Told y’all to, keep ya eye’s open. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We was, where they come from?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They bang on the car windows and pull on the doors.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="731">EDIBI EATS ADDICTS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let us in! Open this door! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re everywhere!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>More join. They are really angry and aggressive. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>EDIBI EATS ADDICTS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You took it all! Give it back!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I got a idea. Open the sun roof. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hope you know what you’re doing.</Text>
    </Paragraph>
    <Paragraph Number="80" Type="Scene Heading">
      <SceneProperties Length="2 3/8" Page="57" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="EDIBI EATS ADDICTS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="LITTLE BOY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MOTHER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. RON'S CAR PARKED ON STREET - sAME</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon pop’s up through </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1099">the sunroof</Text>
      <Text> with a bag of Edibl Eats held high. They look at him like he’s a god.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="732">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Y’all want this!?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="733">Edibi eats addicts</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes... yea... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well here it is!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He throws the BAG high in the air, over the rear of the car. They run after it, pushing and shoving they rip into the bag.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lets go!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Doors open and they quietly get out and run. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="734">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Around the corner, up the street. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They turn the corner and see more </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1107">Edibl Eats Addicts</Text>
      <Text>. They all have stomach pain which effects their walking.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nobody panic, just do like we practiced and blend in. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re so many of them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just act and walk like them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="735">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I got a bad feeling about this. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They walk up the street blending in with them. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>See, we pulling it off.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A LITTLE BOY runs toward Ron and stops in front of him. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="736">Little Boy</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey mister, you smell good? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get away lil bro. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>LITTLE BOY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Your smell makes me feel happy. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Little Boy’s cute smile turns into a crazed look.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>LITTLE BOY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I want what you got!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1250">He jumps on Ron like a wild little monkey</Text>
      <Text> pulling on Ron’s jacket. The other Edibl Eats Addicts begin to notice. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get off me you crazy kid. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You blowing our cover. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>More Edibl Eats Addicts start walking towards them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If you ain’t the father, run! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They run as the Little Boy keeps pulling on Ron’s jacket. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Let me go! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron slings him off but his bags of Edibl Eats fall to the ground. He reaches for it but the boy’s MOTHER grabs it. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="737">Mother</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hands off my baby’s food! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn, child support!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s just up here! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They run up the street but are blocked by several EE Addicts. Deon throws a bag to the right and Keke throws one to the Left. The Addicts go after them opening up the street. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>keKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Can’t believe I’m throwing my good EE’s at them. Almost there!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1101">EE Addicts are fighting</Text>
      <Text> over the food.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hate this too but... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1103">Edibl Eats store front office</Text>
      <Text> is closed. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1105">A security gate is in front of the door</Text>
      <Text>. Keke </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1109">rings the bell</Text>
      <Text>. No answer.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn, now they all are coming.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You kept feeding them! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke rings the bell again and speaks in </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1111">the intercom</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mrs. Adams, its Keke, I need help, people are chasing us.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Edibl Eats Addicts are getting closer. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s me too Ms. Adams, let us in.</Text>
    </Paragraph>
    <Paragraph Number="81" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="60" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1113">security camera monitor</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke and Deon are on the screen. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1115">Keke looks into camera</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="738">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You said if I ever needed help to let you know. Well I need help now!</Text>
    </Paragraph>
    <Paragraph Number="82" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="60" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1117">edIBL EATS OFFICE BUILDING</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron pushes away Edibl Eats Addict #1 but Addict 2 grabs him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="739">DeoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Here, here, this is what you want!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Throws his last bag and Ron’s released as they fight over it.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="740">Ron</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Ugh, we need to run.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got that right, I’m all out! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Addict #3 swings at Deon who blocks and counters with a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1119">punch to the stomach causing him to throw up </Text>
      <Text>inside their face shield. Keke throws her last bag causing a feeding frenzy. </Text>
    </Paragraph>
    <Paragraph Number="83" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="60" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. television monitor</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke looks to camera.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="741">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They killed Pete!</Text>
    </Paragraph>
    <Paragraph Number="84" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="61" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EDIBI EATS ADDICT #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. eDIBL EATS OFFICE BUILDING</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The security gate opens just enough for them to duck underneath, then it closes back down. Addicts bang on gate.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="742">EDIBI EATS ADDICT #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Edibl Eats in there! Open up!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="743">Ron</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The door won’t open.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>POV Ron’s cell of Addict #2, still vomiting, bangs on the gate splashing it. The office door opens up and they run in.</Text>
    </Paragraph>
    <Paragraph Number="85" Type="Scene Heading">
      <SceneProperties Length="3 1/8" Page="61" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DR. REGINALD PALMER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPRESENTATIVE DICKENS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SENATOR ARMSTRONG">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. eDIBL EATS OFFICE BUILDING - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>They are in </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1252">an empty reception room</Text>
      <Text>. The picture of Terri Adams hangs on the wall.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="744">Deon</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn, not a bag left. I should of let them keep your ass.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="745">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It was that crazy kid! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="746">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Could of been your son for all I know... Is that gone be us soon?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not me! I’m getting mine! It’s got to be some in here somewhere. Not gonna be left with nothing! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon starts turning into an EE Addict, knocking stuff over.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m tear this place up looking! It’s because of y’all that I ain’t got shit! Especially you!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>He runs toward Ron but Keke </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1121">bitch slaps</Text>
      <Text> him across the room.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KekE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t you turn. Come back! I need you! You hear me, I need you! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon’s eyes focuses on Keke and he come back to himself. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You need me?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KekE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>TERRI enters the room. A </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1123">semi-automatic</Text>
      <Text> on her side.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="747">TERRI</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hi Keke, Deon, Ron. Sorry to hear about Pete.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>A fool shot him for his Edibl Eats!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Its horrible what’s happening. But please follow me.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>How you know my name?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know all my customers from this hood. Especially the one’s I’ve helped, like Deon and those I couldn’t like Keke’s brothers.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terri stands in front of a door. She </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1125">puts her hand on a pad and the door slides open</Text>
      <Text>. Inside are </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1128">several monitors in front of a command center with buttons, lights and switches</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like mission control. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The monitors show technical jargon, graphic’s over maps, the news, inside and outside showing Addicts banging on the gate. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s more of them coming! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>While Deon and Ron are looking at the monitors, Keke is looking at some firearms mounted on a wall.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You in trouble Mrs. Adams? What’s going on? Tell me the truth.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The truth is why I didn’t want to let you in here because the answers are coming. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke is closer to the firearms. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good, because I need some answers.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Start with who’s coming?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>THOMAS a latinx hard thug appears pointing </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1130">a gun</Text>
      <Text> at Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="748">THOMAS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She’ll answer your questions but first, step away from the guns. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now I know something ain’t right. </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thomas ass never been no damn good. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Good to see you too Keke.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I though you was in prison.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I would of been if weren't for... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>After all my brother’s crew did for you, this is how you repaid him.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Put the gun away Thomas.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Thomas does and sits down in front of the command center. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>roN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What is this, a thug reunion?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I guess it is. Thomas, Deon and Keke’s brother Link were rival street gang members before I got them to turn those selling on street block skills to doing boardroom business deals. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I bet he’s stealing from you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>She taught me to fish, so no need.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Whatever! Your Edibl Eats is killing people!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That crap they selling is not the Edibl Eats I created! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Then where’s the Edibl Eats you made? Here somewhere? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Actually me and my partner Reginald created.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, Mr. Palmer. He do this?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>No! The Edibl Eats we created was a good healthy meal. </Text>
    </Paragraph>
    <Paragraph Number="86" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="64" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. All the footages on the monitors - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The monitors shows pictures that relates to what is said. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The food being supplied to low income neighborhoods was not good quality. The meat was from the weakest animals and the produce was deficient in essential minerals. We, Reginald mainly, created a high nutrient Genetically Modified Designer Food, loaded with good nutraceutical additives. </Text>
    </Paragraph>
    <Paragraph Number="87" Type="Scene Heading">
      <SceneProperties Length="2 6/8" Page="64" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. eDIBL EATS CONTROL ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text AdornmentStyle="-1" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="">Nutrace</Text>
      <Text>... what?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nutraceuticals, health-giving additives that provides medicinal benefits. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I created this company to help my people not to hurt them. When the opportunity came to partner with Ingrowth to take our healthy food and job training programs to every low income neighborhood in the country, it seem like a good thing.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>One of those programs got me into the construction union. I tried to get Cal involved but...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>He got busted for robbery. I wish he would of listen to you. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>If it wasn’t for your program, I would of wound up in prison too. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You and Cal could of been roommates, I mean cellmates. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I tried to keep Link in the program too Keke. I regret to this day that I was unsuccessful.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>But why have people gone crazy?! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I knew something was wrong when they stop letting me get access to the lab’s R&amp;D department. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>R&amp;D?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Research and development.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Maybe you are a good student.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s where they were suppose to be improving the product and creating new items to serve customers. Instead they created something that’s doing this. And I’m being setup to take the fall.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Who setting you up?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I found out the Ingrowth Corporation also owns a company specializing in Bioweapons.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Biological weapon? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The monitor shows pictures that relates to what she says.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They reformulated Edibl Eats to make people kill each other. Hidden by what seems like gang wars. Edibl Eats sells are highest over the weekend at the same time shootings are up, averaging 200 people or more here in Chicago along. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They making gangs shoot each other?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not only gangs, domestic violence, armed robberies, child abuse...    </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So Ingrowth is doing this?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yes, targeting low income communities already living under the stress of poverty which has them in an unhealthy mental state.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Then this is the trigger that makes them snap.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Right! Based on the success of this experiment they plan to sell the formula to companies that do business with the military industrial complex. I know it sounds crazy but thats why this ain’t a safe place to be. There are people coming for me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Well news flash, out there ain’t the place you want to be either! So you’ve got some evidence? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Not yet, Reginald is on his way here with it. Then we’re going to get it on the news so people will know that they are being used as lab rats in an experiment gone bad! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Once it’s here I can also upload it to my influencers in social media. They will get the real word out. News networks are controlled...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t you start.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I saw a UFO once, filmed it and the news didn’t air my story...</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Okay...Lets just get you hooked up.</Text>
    </Paragraph>
    <Paragraph Number="88" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="67" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPRESENTATIVE DICKENS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SENATOR ARMSTRONG">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1254">senate courtroom</Text>
      <Text> hearing - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Senate hearings scene.</Text>
    </Paragraph>
    <Paragraph Number="89" Type="Scene Heading">
      <SceneProperties Length="1 6/8" Page="67" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="MARK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="REPRESENTATIVE DICKENS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="SENATOR ARMSTRONG">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. eDIBL EATS CONTROL ROOM - dAY</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hey Ms. Adams, checkout the news! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="749">SENATOR ARMSTRONG</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Mr. Wilson, we have asked you several times... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="750">MARK</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And as I have stated several times, that information is classified under the Proprietary Product Information Rights Act.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SeNATOR ARMSTRONG </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is there a reason these violent incidents are occurring the most in African American and Latino urban communities where the sales of Edibl Eats are also the highest? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We feel it’s because in those communities, where our stores were forced to close, the residents are feeling the loss of those jobs and are angry as a result of it. Because jobs are what’s most needed in those areas.    </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="751">REPRESENTATIVE DICKENS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is there any reason when Edibl Eats started selling their new red sauce the sales spiked?  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now we getting somewhere. Reginald said the sauce’s formula triggers the reaction. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Our research showed that our customers enjoy putting sauces on their meal. We just create something to help them have a more enjoyable experience. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>At that moment Mark’s LAWYER whispers in his ear.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s come to my attention that our internal security team has discovered the chemist that’s behind this. His name is Dr. Reginald Palmer. We have evidence he tampered with the formula.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’ve got to get him out of there. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>SENATOR ARMSTRONG</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is he in custody? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Unfortunately when they tried to apprehend him, he fatally shot himself. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They murdered him! </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>REPRESENTATIVE DICKENS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Was he the only one responsible for this?  </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mark’s Lawyer whispers in his ear.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>MARK</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They think he had an accomplice. We are working with law enforcement and will have an update soon. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>An alarm is heard. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Movement outside the East perimeter.</Text>
    </Paragraph>
    <Paragraph Number="90" Type="Scene Heading">
      <SceneProperties Length="1/8" Page="69" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. van with 8 private soldiers - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A black van driving down an alley carrying the Soldiers.   </Text>
    </Paragraph>
    <Paragraph Number="91" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="69" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. eDIBL EATS CONTROL ROOM - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m getting a message being downloaded from Mr. Palmer’s coded </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>e-cloud server. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What does it say? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>tHOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Pulling it up now. </Text>
    </Paragraph>
    <Paragraph Number="92" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="69" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DR. REGINALD PALMER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1256">office of Reginald</Text>
      <Text> - dAY</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A warm but intense REGINALD PALMER is talking to camera.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="752">DR. REGINALD PALMER</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Terri, I need to let you know it was me who dialed up the formula. I found out their plan was for this violent reaction to occur more slowly, over a longer period of time. Our people would of just looked like crazy, violent thugs terrorizing their communities. I made it stronger so that its effects will happen quicker. That way we can expose their plan. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The door behind him is being forced open.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DR. REGINALD PALMER</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>All the evidence needed is attached to this message. You’ve got to get this out. They know about you so please be careful. Sorry this ends like this. I love you!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Reginald looks down at the keyboard quickly typing. Gun shots are heard as the video turns to static.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Reggie!... Damn... You wanted answers. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They better be ready to answer for this shit too.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Me and all the people in the hood are being played!? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>THOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The good news is I got the evidence. Time to get it out.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Just need time to upload it to my key Influencer’s including Brandy.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The sound of </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1132">a gun being locked and loaded</Text>
      <Text> is heard. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1134">Keke has a semiautomatic tactical rifle.</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’ll have the time you need. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>thoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Still remember how to use that?</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon has</Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1136"> a semiautomatic handgun</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Like riding a bike. Swore to never pickup one of these again.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Terri gives everybody bulletproof vests.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lets go over our escape plan too. We do plan on escaping, right? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Keep uploading. We’ve got a few toy’s here that might help us out.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Thomas waves his hand over a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1139">LED pad on console</Text>
      <Text> as the monitor show 8 PRIVATE SOLDIERS in black battle fatigues behind the building. Ms. Adam’s cell rings. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Henry! You’ll rot in hell for that!</Text>
    </Paragraph>
    <Paragraph Number="93" Type="Scene Heading">
      <SceneProperties Length="3 7/8" Page="71" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="HENRY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="WORDS ON SCREEN">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. room with large monitors</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Henry is in front of </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1142">several large monitors</Text>
      <Text>. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1144">4 PEOPLE in lab coats</Text>
      <Text> are watching them. Scene cuts between Terri and Henry.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="753">HENRY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m here with a deal to keep hell from coming to you. I wanted to see if I can get you back on the team. Open the door so we can talk.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="754">TERRI</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Is this the same talk Reginald got? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We didn’t want that to happen. But he altered the formula and exposed us. But it can be different for you and very financially beneficial.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You know where you put them benefits right? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Monitor shows Private Soldier #1 putting a </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1258">clay substance</Text>
      <Text> on the security gate.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="755">ThoMAs</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re setting up explosives charges. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You’re not getting away with this. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s always so funny to hear when somebody says that.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="756">Ron</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Somethings messing with the upload.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They’re blocking our signal. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>And why is that?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because they have been getting away with it for centuries. From living conditions... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Images of project housing appear on their monitors.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... Their education...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Images of inferior and closed schools appear on the monitors.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... Medical care...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Picture of black men being given medicine by a white doctor. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>... Their water... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Images of the water in Flint Michigan.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>...Since the beginning they have been getting away with it...</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Image of black men on a chain gang and in modern prisons.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Down to a science how they can screw one community and not others.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Map of Chicago with the South and Westside highlighted. As the words come on the screen they change colors. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="757">Words on Screen</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Most Food Deserts. Higher cancer, asthma, diabetes rates. Most Deaths by Preventable Illnesses. Least Business Investment. Least Infrastructure Investment..</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got yo peeps killing themselves... </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Images of gang violence.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Fact is, they’ve been doing a damn good job of getting away with it. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Mrs. Adams looks at Thomas who holds up three fingers.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m gonna do everything in my power to stop you and those behind this!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You should be proud of this. We’re using the results of this experiment to help win wars in other countries before they ever begin. By making them fight and kill each other. So our troops never have to set a foot on foreign ground again. This is saving lives. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You are insane!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>HENRY</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’re shutting you down!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="758">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You the one gonna be shut down! </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1146">An explosion is heard and the outside door has been destroyed</Text>
      <Text>. Mrs. Adams hangs up.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAs</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>It’s about to turn up in here. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The upload?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Thomas</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>They did shut down our upload but I got Ron working through a back door connection... I’d hope. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I hope there’s a back door to get out of here!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Monitor shows the Private Soldiers entering the building.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Now!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>As they move down the hallway the lights go out. The Private Soldiers turn on their </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1148">Night Vision glasse</Text>
      <Text>s as the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1151">red lasers on their guns beam down the hall</Text>
      <Text>. Thomas </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1260">moves his hand putting a target image over Private Soldier #1</Text>
      <Text>. The hallway is blasted with white lights. As they are blinded a muffled shot is heard and Private Soldier #1 falls to the floor.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Try not to kill anybody.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Think they got the same memo? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1156">The Private Soldiers shoot in all directions</Text>
      <Text>. The </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1153">target’s over Soldier #2</Text>
      <Text>, a shot is heard and he hits the floor. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Who said I wouldn’t amount to nothing playing video games? </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Where you get these cool weapons?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Made a few friends with toys.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Heavy gunfire from the Private Soldiers as they grab the wounded and retreat.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I know whats coming next. Take cover behind these </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1263">armored desk</Text>
      <Text>. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>thoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hoping these would never be used. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Everyone takes cover a Private Soldier aim </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1159">a rocket-launcher and fires</Text>
      <Text>. The door explodes but the </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1162">armored desk</Text>
      <Text> have protected them. Special Soldiers advance down the hall. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This for Pete!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Both sides exchange fire. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Uploads done! The evidence is going viral.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>So sorry you’re caught up in this. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The gunfire goes back and forth. The Private Soldiers heavy gunfire pins them down as they move closer to the entrance. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1164">Mrs. Adams is hit</Text>
      <Text> and falls. Gun shots are heard outside. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="759">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s happening? </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Monitor shows Edibl Eats Addicts shooting at the Private Soldiers. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>THOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We’re getting some help from the people in the hood!</Text>
    </Paragraph>
    <Paragraph Number="94" Type="Scene Heading">
      <SceneProperties Length="5/8" Page="75" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EDIBI EATS ADDICT #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="EDIBI EATS ADDICT #2">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="GUY NEIGHBOR">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="POOK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. eDIBL EATS STORE FRONT BUILDING - night</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Private Soldiers are pin down as Ray, Pook, Guy Neighbor and Edibl Eats Addicts are attacking them with </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1166">bottles, rocks and guns</Text>
      <Text>.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="760">EDIBI EATS ADDICT #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This ours, get your own!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="761">RAY</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Get the fuck out our hood!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>A </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="" TagNumber="1265">Molotov cocktail explodes</Text>
      <Text> near the black van. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="762">EDIBI EATS ADDICT #2</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s all you got coming!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="763">Pook</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We got guns too motherfucker!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Pook shoots several rounds at them.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="764">Guy nEIGHBOR</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Damn right!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Private Soldiers retreat towards their van.</Text>
    </Paragraph>
    <Paragraph Number="95" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="75" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>Int. edibl Eats Control room</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="765">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Never though I’d be glad to see those guys.</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Keke and Deon check on Ms. Adams. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="766">TERRI</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I’m okay.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="767">KeKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Lucky, vest. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="768">ThoMAS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Homeland Security headed this way.</Text>
    </Paragraph>
    <Paragraph Number="96" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="75" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. edIBL EATS STORE FRONT BUILDING - nIGHt</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>The Private Soldiers drive off in their van.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="769">TERRI</Text>
      <Text> (O.S.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You guys better leave. </Text>
    </Paragraph>
    <Paragraph Number="97" Type="Scene Heading">
      <SceneProperties Length="1 4/8" Page="76" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="TERRI">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="THOMAS">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>InT. edIBL EATS CONTROL ROOM</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon and Keke are wiping there prints off the weapons. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="770">KEKE</Text>
      <Text> </Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea we almost ready!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="771">DeoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Don’t have to tell me twice!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="772">TERRI</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Thank you for standing by me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Deon</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Glad to return the favor. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Try and stay out of trouble. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>You do the same. Give em the 4 wheel.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="773">ThoMAS</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Follow me. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Glad to see you’ve done something with your life Thomas. Now I know anything’s possible. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>ThoMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>With God, all things. Deon, I remember when we had to let go of the bad blood we had. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>We made a decision to live and let live. Something else I didn’t think was possible after we ended so many of our homies lives.  </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KEKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Swore I’d never stop banging until the ones who killed my brother were dead. I feel like thats not important now. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DeoN</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Because we’ve been played. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="774">Ron</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Got us thinking we can’t do no better.   </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>THOMAS</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Hope its not to late to prove them wrong. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>keKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>What’s gonna happen to the people out there?</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>TERRI</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The effects will slowly wear off now that the supply of Edibl Eats has stop but it will probably get worst before it gets better. Let’s hope when they know the truth they’ll want to change. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>DEON</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Say no to being lab rats! I know I’m done with it... Forever! </Text>
    </Paragraph>
    <Paragraph Number="98" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="77" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. </Text>
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="1168">jeep driving</Text>
      <Text> thru traffic - nIGHT</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron drives around the cars left in the middle of the street.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Again the Edibl Eats Company is found guilty of enhancing their product to make people eat it... </Text>
    </Paragraph>
    <Paragraph Number="99" Type="Scene Heading">
      <SceneProperties Length="6/8" Page="77" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="POOK">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RADIO ANNOUNCER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>INT. rON’S CAR DRIVING THRU TRAFFIC - same</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER (v.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>This is based on damaging evidence that was found on social media... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="777">KEKE</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Nice job Ron!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>RADIO ANNOUNCER (V.O.)</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>The owners of Edibl Eats are not available for comment at this time and their parent company the Ingrowth Corporation has already gone on record that they knew nothing about this... </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>KeKE</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Yea, right!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron turns off the radio and continues to drive slowly. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="778">RoN</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Looks like there’s a Edibl Eats party in front of our building. </Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron stops the car and they look at the madness. People running around, screaming and showing withdraw symptoms. </Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="779">DEON</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Wonder how we’re going to get in.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text>Ron</Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>Check this!</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Ron drives on the sidewalk, across a vacant lot and down an alley to the back of their apartment building. </Text>
    </Paragraph>
    <Paragraph Number="100" Type="Scene Heading">
      <SceneProperties Length="2/8" Page="78" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="EDIBI EATS ADDICT #1">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RAY">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
        </SceneArcBeats>
      </SceneProperties>
      <Text>EXT. deon’s apartment building - nIGHt</Text>
    </Paragraph>
    <Paragraph Type="Action">
      <Text>Deon, Keke and Ron sneak into the front door. Ray see’s them go inside the building.</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="780">Ray</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>I bet he’s got some!</Text>
    </Paragraph>
    <Paragraph Type="Character">
      <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Courier Final Draft" RevisionID="0" Size="12" Style="AllCaps" TagNumber="781">EDIBI EATS ADDICT #1</Text>
      <Text></Text>
    </Paragraph>
    <Paragraph Type="Dialogue">
      <Text>That’s my girl and she got lots! </Text>
    </Paragraph>
    <Paragraph Number="101" Type="Scene Heading">
      <SceneProperties Length="3/8" Page="78" Title="">
        <SceneArcBeats>
          <CharacterArcBeat Name="DEON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="DR. CARTER">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="KEKE, DEON &amp; RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="PETE">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
          </CharacterArcBeat>
          <CharacterArcBeat Name="RON">
            <Paragraph Alignment="Left" FirstIndent="0.00" Leading="Regular" LeftIndent="0.00" RightIndent="1.39" SpaceBefore="0" Spacing="1" StartsNewPage="No">
              <Text AdornmentStyle="0" Background="#FFFFFFFFFFFF" Color="#000000000000" Font="Arial" RevisionID="0" Size="12" Style=""></Text>
            </Paragraph>
